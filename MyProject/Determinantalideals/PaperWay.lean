/-- Local StatementB failure contradiction for one Case 1 induction step.

Unlike the disabled global `StatementBFailure → small` theorem, this statement
carries exactly the induction hypotheses available in the paper proof before
proving statement (b) at the current chain index, and concludes `False`
directly under the non-smallness assumption `hnot`. -/
lemma closePairThm21_case1_statementB_failure_false_of_prev
    (ord : MonomialOrder (Fin m × Fin n))
    (hdiag : IsDiagonalTermOrder ord)
    (A B : MinorIndex m n t)
    (hC : Close A B)
    (hrowLt :
      rowExt B (uClose A B) < rowExt A (uClose A B))
    (L : ClosePairStrictBlock.RowLaplaceChoice A B hC)
    (σ : Equiv.Perm (Fin (ClosePairStrictBlock.width A B)))
    (hc :
      (closePairThm21_case1_rowTerm
        (m := m) (n := n) (t := t) (k := k) A B hC L σ).c ≠ 0)
    (hnot :
      ¬ ord.toSyn
          (closePairThm21_case1_rowTermExp
            (m := m) (n := n) (t := t) (k := k) A B hC L σ)
        <
        ord.toSyn
          (headLcm ord
            (genericMinor (k := k) A)
            (genericMinor (k := k) B)))
    (U : Case1UVChain A B hC)
    (i : Fin U.q)
    (F : StatementBFailure A B hC L U)
    (hFi : F.i = i)
    (hprevA :
      ∀ j : Fin U.q, j.1 < i.1 → StatementA A B hC L U j)
    (hprevB :
      ∀ j : Fin U.q, j.1 < i.1 → StatementB A B hC L U j)
    (hprevC :
      ∀ j : Fin U.q, j.1 < i.1 → StatementC A B hC L σ U j)
    (habove : StatementBAbove A B hC L U i F.j) :
    False := by
  classical
  have hprevA_atF :
      ∀ j : Fin U.q, j.1 < F.i.1 → StatementA A B hC L U j := by
    intro j hj
    exact hprevA j (by simpa [hFi] using hj)
  have hprevB_atF :
      ∀ j : Fin U.q, j.1 < F.i.1 → StatementB A B hC L U j := by
    intro j hj
    exact hprevB j (by simpa [hFi] using hj)
  have hprevC_atF :
      ∀ j : Fin U.q, j.1 < F.i.1 → StatementC A B hC L σ U j := by
    intro j hj
    exact hprevC j (by simpa [hFi] using hj)
  let idx : Fin t := F.idx
  have hidx_s : sClose A B ≤ idx.1 := by
    simpa [idx] using F.idx_s
  have hidx_u : idx.1 < uClose A B := by
    simpa [idx] using F.idx_u
  have hminor_diag_zero :
      diagExp L.minorIndex
        (A.row idx, A.col idx) = 0 := by
    simpa [idx] using
      closePairThm21_case1_statementB_failure_minor_diag_eq_zero
        (m := m) (n := n) (t := t) (k := k)
        A B hC L σ hc U F
  have hterm_at_failure_eq_cofactor :
      closePairThm21_case1_rowTermExp
          (m := m) (n := n) (t := t) (k := k) A B hC L σ
          (A.row idx, A.col idx) =
        MonomialCoefficientMatrix.permExp L.cofactorRow L.cofactorCol σ
          (A.row idx, A.col idx) := by
    simpa [idx] using
      closePairThm21_case1_statementB_failure_rowTermExp_eq_cofactor
        (m := m) (n := n) (t := t) (k := k)
        A B hC L σ hc U F
  have hnot_zero_and_pos :
      MonomialCoefficientMatrix.permExp L.cofactorRow L.cofactorCol σ
          (A.row idx, A.col idx) = 0 →
        1 ≤
          closePairThm21_case1_rowTermExp
            (m := m) (n := n) (t := t) (k := k) A B hC L σ
            (A.row idx, A.col idx) →
        False := by
    intro hcof hpos
    have heq :
        L.minorRows idx = ClosePairStrictBlock.aColumnPos A B hC idx :=
      closePairThm21_case1_statementB_at_of_cofactor_zero_of_exp_pos
        (m := m) (n := n) (t := t) (k := k)
        A B hC L σ hc idx hidx_s hidx_u hcof hpos
    exact F.hne_idx (by
      simpa [idx] using heq)
  have hgap_or_crossing :
      closePairThm21_case1_rowTermExp
          (m := m) (n := n) (t := t) (k := k) A B hC L σ
          (A.row idx, A.col idx) = 0 ∨
        ∃ p r : Fin (ClosePairStrictBlock.width A B),
          r < p ∧
            L.cofactorRows (σ r) =
              ClosePairStrictBlock.bMiddlePos A B hC p ∧
            L.cofactorRow (σ r) = A.row idx ∧
            L.cofactorCol r = A.col idx ∧
            U.v F.i.castSucc ≤ sClose A B + p.1 + 1 ∧
            sClose A B + r.1 + 1 < U.v F.i.castSucc := by
    simpa [idx] using
      closePairThm21_case1_statementB_failure_gap_or_crossing_hit
        (m := m) (n := n) (t := t) (k := k)
        A B hC hrowLt L σ hc U F
  have hA_diag_one :
      diagExp A (A.row idx, A.col idx) = 1 := by
    rw [diagExp_apply]
    exact if_pos ⟨idx, rfl, rfl⟩
  have hsup_at_failure :
      (diagExp A ⊔ diagExp B) (A.row idx, A.col idx) = 1 := by
    have hle_one : (diagExp A ⊔ diagExp B) (A.row idx, A.col idx) ≤ 1 := by
      change max (diagExp A (A.row idx, A.col idx))
          (diagExp B (A.row idx, A.col idx)) ≤ 1
      rw [hA_diag_one]
      simp only [Nat.max_le, le_refl, true_and]
      exact diagExp_apply_le_one B (A.row idx, A.col idx)
    have hge_one : 1 ≤ (diagExp A ⊔ diagExp B) (A.row idx, A.col idx) := by
      change 1 ≤ max (diagExp A (A.row idx, A.col idx))
          (diagExp B (A.row idx, A.col idx))
      rw [hA_diag_one]
      simp
    exact le_antisymm hle_one hge_one
  rcases hgap_or_crossing with hgap | hcross
  · have hpos :
        1 ≤
          closePairThm21_case1_rowTermExp
            (m := m) (n := n) (t := t) (k := k) A B hC L σ
            (A.row F.idx, A.col F.idx) :=
      closePairThm21_case1_statementB_failure_coord_pos_of_not_lt_prev
        (m := m) (n := n) (t := t) (k := k)
        ord hdiag A B hC hrowLt L σ hc hnot U i F hFi
        hprevA hprevB hprevC habove
    have hpos_idx :
        1 ≤
          closePairThm21_case1_rowTermExp
            (m := m) (n := n) (t := t) (k := k) A B hC L σ
            (A.row idx, A.col idx) := by
      simpa [idx] using hpos
    rw [hgap] at hpos_idx
    omega
  · rcases hcross with ⟨p, r, hrp, hp, hrow, hcol, hv_le_p, hr_lt_v⟩
    exact
      closePairThm21_case1_statementB_crossing_false_of_prev
        (m := m) (n := n) (t := t) (k := k)
        ord hdiag A B hC hrowLt L σ hc hnot U i F hFi p r hrp hp hrow hcol
        hv_le_p hr_lt_v
        hprevA hprevB hprevC

