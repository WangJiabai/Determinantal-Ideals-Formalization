/-- Convert a pointwise permutation-matrix description on the `B`-middle
square into equality with the corresponding `permExp`.

This isolates the finite-support/Finsupp bookkeeping from the paper
combinatorics that identifies the actual permutation. -/
lemma bMiddlePartExp_eq_permExp_of_apply
    (A B : MinorIndex m n t)
    (hC : Close A B)
    (L : ClosePairStrictBlock.RowLaplaceChoice A B hC)
    (σ : Equiv.Perm (Fin (ClosePairStrictBlock.width A B)))
    (τ : Equiv.Perm (Fin (ClosePairStrictBlock.width A B)))
    (happly :
      ∀ r s : Fin (ClosePairStrictBlock.width A B),
        closePairThm21_case1_BmiddlePartExp
            (m := m) (n := n) (t := t) (k := k) A B hC L σ
            ((ClosePairStrictBlock.bMiddleMinorIndex A B hC).row r,
             (ClosePairStrictBlock.bMiddleMinorIndex A B hC).col s)
          =
        if τ r = s then 1 else 0) :
    closePairThm21_case1_BmiddlePartExp
        (m := m) (n := n) (t := t) (k := k) A B hC L σ =
      permExp (ClosePairStrictBlock.bMiddleMinorIndex A B hC) τ := by
  classical
  let K : MinorIndex m n (ClosePairStrictBlock.width A B) :=
    ClosePairStrictBlock.bMiddleMinorIndex A B hC
  ext x
  rcases x with ⟨xm, xn⟩
  by_cases hx :
      ∃ r s : Fin (ClosePairStrictBlock.width A B),
        K.row r = xm ∧ K.col s = xn
  · rcases hx with ⟨r, s, hr, hs⟩
    have hcoord :
        (xm, xn) = (K.row r, K.col s) := by
      exact Prod.ext hr.symm hs.symm
    rw [hcoord]
    rw [show K = ClosePairStrictBlock.bMiddleMinorIndex A B hC from rfl]
    rw [happly r s]
    rw [permExp_apply]
    by_cases hτ : τ r = s
    · have hex :
          ∃ a : Fin (ClosePairStrictBlock.width A B),
            (ClosePairStrictBlock.bMiddleMinorIndex A B hC).row a =
              (ClosePairStrictBlock.bMiddleMinorIndex A B hC).row r ∧
            (ClosePairStrictBlock.bMiddleMinorIndex A B hC).col (τ a) =
              (ClosePairStrictBlock.bMiddleMinorIndex A B hC).col s := by
        refine ⟨r, rfl, ?_⟩
        rw [hτ]
      rw [if_pos hτ, if_pos hex]
    · have hnex :
          ¬ ∃ a : Fin (ClosePairStrictBlock.width A B),
            (ClosePairStrictBlock.bMiddleMinorIndex A B hC).row a =
              (ClosePairStrictBlock.bMiddleMinorIndex A B hC).row r ∧
            (ClosePairStrictBlock.bMiddleMinorIndex A B hC).col (τ a) =
              (ClosePairStrictBlock.bMiddleMinorIndex A B hC).col s := by
        intro hex
        rcases hex with ⟨a, hrow, hcol⟩
        have ha : a = r :=
          (ClosePairStrictBlock.bMiddleMinorIndex A B hC).row.injective hrow
        subst a
        have hτs : τ r = s :=
          (ClosePairStrictBlock.bMiddleMinorIndex A B hC).col.injective hcol
        exact hτ hτs
      rw [if_neg hτ, if_neg hnex]
  · have hleft_zero :
        closePairThm21_case1_BmiddlePartExp
            (m := m) (n := n) (t := t) (k := k) A B hC L σ
            (xm, xn) = 0 := by
      simp only [closePairThm21_case1_BmiddlePartExp,
        Finsupp.coe_finset_sum, Finset.sum_apply]
      refine Finset.sum_eq_zero ?_
      intro r _
      refine Finset.sum_eq_zero ?_
      intro s _
      have hpair :
          ((ClosePairStrictBlock.bMiddleMinorIndex A B hC).row r,
            (ClosePairStrictBlock.bMiddleMinorIndex A B hC).col s) ≠
            (xm, xn) := by
        intro hbad
        apply hx
        refine ⟨r, s, ?_, ?_⟩
        · simpa using congrArg Prod.fst hbad
        · simpa using congrArg Prod.snd hbad
      have hpair_eval :
          (xm, xn) ≠
            ((ClosePairStrictBlock.bMiddleMinorIndex A B hC).row r,
              (ClosePairStrictBlock.bMiddleMinorIndex A B hC).col s) :=
        fun hbad => hpair hbad.symm
      rw [Finsupp.single_eq_of_ne hpair_eval]
    have hright_zero :
        permExp (ClosePairStrictBlock.bMiddleMinorIndex A B hC) τ
          (xm, xn) = 0 := by
      rw [permExp_apply]
      have hnex :
          ¬ ∃ a : Fin (ClosePairStrictBlock.width A B),
            (ClosePairStrictBlock.bMiddleMinorIndex A B hC).row a = xm ∧
            (ClosePairStrictBlock.bMiddleMinorIndex A B hC).col (τ a) = xn := by
        intro hex
        rcases hex with ⟨a, hrow, hcol⟩
        apply hx
        exact ⟨a, τ a, hrow, hcol⟩
      rw [if_neg hnex]
    rw [hleft_zero, hright_zero]

