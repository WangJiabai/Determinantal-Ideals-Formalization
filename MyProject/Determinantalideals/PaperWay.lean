noncomputable def closePairThm21_equalCaseTerms
    (_ord : MonomialOrder (Fin m × Fin n))
    (A B : MinorIndex m n t)
    (hC : Close A B)
    (_hrowEq :
      rowExt B (uClose A B) = rowExt A (uClose A B)) :
    Finset (ClosePairThm21Term m n t k) := by
  classical
  let keys :=
    ClosePairStrictBlock.StrictLaplaceRawIndex.keyFinset
      (m := m) (n := n) (t := t) (k := k) A B hC
  let termOf :
      ClosePairStrictBlock.StrictLaplaceRawIndex.TermKey m n t →
        ClosePairThm21Term m n t k :=
    closePairThm21_equalCollectedTerm
      (m := m) (n := n) (t := t) (k := k) A B hC
  exact
    (keys.filter fun q => (termOf q).c ≠ 0).image termOf


lemma closePairThm21_equalCase_linear_identity
    (ord : MonomialOrder (Fin m × Fin n))
    (hdiag : IsDiagonalTermOrder ord)
    (A B : MinorIndex m n t)
    (hC : Close A B)
    (hrowEq :
      rowExt B (uClose A B) = rowExt A (uClose A B)) :
    ord.sPolynomial (genericMinor (k := k) A) (genericMinor (k := k) B) =
      ∑ T ∈ closePairThm21_equalCaseTerms
          (m := m) (n := n) (t := t) (k := k)
          ord A B hC hrowEq,
        T.poly := by
  classical
  let keys :=
    ClosePairStrictBlock.StrictLaplaceRawIndex.keyFinset
      (m := m) (n := n) (t := t) (k := k) A B hC
  let termOf :
      ClosePairStrictBlock.StrictLaplaceRawIndex.TermKey m n t →
        ClosePairThm21Term m n t k :=
    closePairThm21_equalCollectedTerm
      (m := m) (n := n) (t := t) (k := k) A B hC
  let p :
      ClosePairStrictBlock.StrictLaplaceRawIndex.TermKey m n t → Prop :=
    fun q => (termOf q).c ≠ 0
  have hsp_raw :
      ord.sPolynomial (genericMinor (k := k) A) (genericMinor (k := k) B) =
        ClosePairStrictBlock.StrictLaplaceRawIndex.rawPolySum
          (m := m) (n := n) (t := t) (k := k) A B hC :=
    closePairThm21_equal_sPolynomial_eq_rawPolySum
      (m := m) (n := n) (t := t) (k := k)
      ord hdiag A B hC
  have hcollectAll :
      (∑ q ∈ keys, (termOf q).poly) =
        ClosePairStrictBlock.StrictLaplaceRawIndex.rawPolySum
          (m := m) (n := n) (t := t) (k := k) A B hC := by
    simpa [termOf, keys] using
      closePairThm21_equal_sum_collectedTerm_poly_eq_rawPolySum
        (m := m) (n := n) (t := t) (k := k) A B hC
  have hfilter :
      (∑ q ∈ keys.filter p, (termOf q).poly) =
        ∑ q ∈ keys, (termOf q).poly := by
    refine Finset.sum_subset ?hsub ?hzero
    · intro q hq
      exact (Finset.mem_filter.mp hq).1
    · intro q hqkeys hqnot
      have hpnot : ¬ p q := by
        intro hp
        exact hqnot (Finset.mem_filter.mpr ⟨hqkeys, hp⟩)
      have hc0 : (termOf q).c = 0 := not_not.mp hpnot
      simp [termOf, ClosePairThm21Term.poly,
        ClosePairThm21Term.coeffPoly, hc0]
  have hinj :
      Function.Injective termOf := by
    exact
      closePairThm21_equalCollectedTerm_injective
        (m := m) (n := n) (t := t) (k := k) A B hC
  have hsum_image :
      (∑ T ∈ closePairThm21_equalCaseTerms
          (m := m) (n := n) (t := t) (k := k)
          ord A B hC hrowEq,
        T.poly)
      =
      ∑ q ∈ keys.filter p, (termOf q).poly := by
      unfold closePairThm21_equalCaseTerms
      dsimp [keys, termOf, p]
      rw [Finset.sum_image]
      intro x _hx y _hy hxy
      exact hinj hxy
  calc
    ord.sPolynomial (genericMinor (k := k) A) (genericMinor (k := k) B)
        =
      ClosePairStrictBlock.StrictLaplaceRawIndex.rawPolySum
        (m := m) (n := n) (t := t) (k := k) A B hC := hsp_raw
    _ =
      ∑ q ∈ keys, (termOf q).poly := hcollectAll.symm
    _ =
      ∑ q ∈ keys.filter p, (termOf q).poly := hfilter.symm
    _ =
      ∑ T ∈ closePairThm21_equalCaseTerms
          (m := m) (n := n) (t := t) (k := k)
          ord A B hC hrowEq,
        T.poly := hsum_image.symm


lemma closePairThm21_equalCase_terms_small
    (ord : MonomialOrder (Fin m × Fin n))
    (hdiag : IsDiagonalTermOrder ord)
    (A B : MinorIndex m n t)
    (hC : Close A B)
    (hrowEq :
      rowExt B (uClose A B) = rowExt A (uClose A B)) :
    ∀ T ∈ closePairThm21_equalCaseTerms
          (m := m) (n := n) (t := t) (k := k)
          ord A B hC hrowEq,
      ∀ a : k, a ≠ 0 →
        ord.toSyn
          (ord.degree
            (MvPolynomial.monomial T.d a * genericMinor (k := k) T.K)) <
        ord.toSyn
          (headLcm ord
            (genericMinor (k := k) A)
            (genericMinor (k := k) B)) := by
  classical
  intro T hT a ha
  let keys :=
    ClosePairStrictBlock.StrictLaplaceRawIndex.keyFinset
      (m := m) (n := n) (t := t) (k := k) A B hC
  let termOf :
      ClosePairStrictBlock.StrictLaplaceRawIndex.TermKey m n t →
        ClosePairThm21Term m n t k :=
    closePairThm21_equalCollectedTerm
      (m := m) (n := n) (t := t) (k := k) A B hC
  let p :
      ClosePairStrictBlock.StrictLaplaceRawIndex.TermKey m n t → Prop :=
    fun q => (termOf q).c ≠ 0
  have hmem :
      T ∈ (keys.filter p).image termOf := by
    simpa [closePairThm21_equalCaseTerms, keys, termOf, p] using hT
  rcases Finset.mem_image.mp hmem with ⟨q, hq, rfl⟩
  have hpq : p q := (Finset.mem_filter.mp hq).2
  have hcq :
      (closePairThm21_equalCollectedTerm
        (m := m) (n := n) (t := t) (k := k) A B hC q).c ≠ 0 := by
    simpa [p, termOf] using hpq
  rcases
    closePairThm21_equal_exists_raw_nonzero_of_collectedCoeff_ne_zero
      (m := m) (n := n) (t := t) (k := k)
      A B hC q hcq with
    ⟨i, hkey, hci⟩
  have hK :
      (ClosePairStrictBlock.StrictLaplaceRawIndex.term
        (m := m) (n := n) (t := t) (k := k)
        (A := A) (B := B) (hC := hC) i).K = q.1 :=
    congrArg Prod.fst hkey
  have hd :
      (ClosePairStrictBlock.StrictLaplaceRawIndex.term
        (m := m) (n := n) (t := t) (k := k)
        (A := A) (B := B) (hC := hC) i).d = q.2 :=
    congrArg Prod.snd hkey
  have hraw :=
    closePairThm21_equal_rawTerm_small
      (m := m) (n := n) (t := t) (k := k)
      ord hdiag A B hC hrowEq i hci a ha
  simpa [termOf, closePairThm21_equalCollectedTerm, hK, hd] using hraw

/-- Equality case of paper Theorem 2.1, at the raw term-sum level.

Here Lemma 1.4(iii) collapses the middle block to one position.  The missing
proof is the paper's final displayed formula obtained by expanding `M` along
the corresponding column and row, followed by the direct exponent inspection. -/
lemma closePairThm21_equal_terms
    (ord : MonomialOrder (Fin m × Fin n))
    (hdiag : IsDiagonalTermOrder ord)
    (A B : MinorIndex m n t)
    (hC : Close A B)
    (hrowEq :
      rowExt B (uClose A B) = rowExt A (uClose A B)) :
    ∃ S : Finset (ClosePairThm21Term m n t k),
      ord.sPolynomial (genericMinor (k := k) A) (genericMinor (k := k) B) =
        ∑ T ∈ S, T.poly ∧
      ∀ T ∈ S, ∀ a : k, a ≠ 0 →
        ord.toSyn
          (ord.degree
            (MvPolynomial.monomial T.d a * genericMinor (k := k) T.K)) <
        ord.toSyn
          (headLcm ord
            (genericMinor (k := k) A)
            (genericMinor (k := k) B)) := by
   classical
  refine ⟨
    closePairThm21_equalCaseTerms
      (m := m) (n := n) (t := t) (k := k)
      ord A B hC hrowEq,
    ?_,
    ?_
  ⟩
  · exact closePairThm21_equalCase_linear_identity
      (m := m) (n := n) (t := t) (k := k)
      ord hdiag A B hC hrowEq
  · exact closePairThm21_equalCase_terms_small
      (m := m) (n := n) (t := t) (k := k)
      ord hdiag A B hC hrowEq

/-- Equality case of paper Theorem 2.1, packaged as the local close-pair data
used by the good-chain assembly. -/
noncomputable def closePairThm21Data_of_uClose_row_eq
    (ord : MonomialOrder (Fin m × Fin n))
    (hdiag : IsDiagonalTermOrder ord)
    (A B : MinorIndex m n t)
    (hC : Close A B)
    (hrowEq :
      rowExt B (uClose A B) = rowExt A (uClose A B)) :
    ClosePairThm21Data (m := m) (n := n) (t := t) (k := k) ord A B := by
  exact
    closePairThm21DataOfTerms
      (m := m) (n := n) (t := t) (k := k)
      ord A B
      (closePairThm21_equal_terms
        (m := m) (n := n) (t := t) (k := k)
        ord hdiag A B hC hrowEq)

namespace ClosePairThm21Term

omit [Nontrivial k] in
noncomputable def neg (T : ClosePairThm21Term m n t k) :
    ClosePairThm21Term m n t k :=
  { K := T.K
    d := T.d
    c := -T.c }

omit [Nontrivial k] in
@[simp] lemma neg_K (T : ClosePairThm21Term m n t k) :
    T.neg.K = T.K := rfl

omit [Nontrivial k] in
@[simp] lemma neg_d (T : ClosePairThm21Term m n t k) :
    T.neg.d = T.d := rfl

omit [Nontrivial k] in
@[simp] lemma neg_poly (T : ClosePairThm21Term m n t k) :
    T.neg.poly = -T.poly := by
  have hmono :
      MvPolynomial.monomial T.d (-T.c) =
        -(MvPolynomial.monomial T.d T.c : MvPolynomial (Fin m × Fin n) k) := by
    ext e
    by_cases h : e = T.d
    · subst e
      simp
    · simp [MvPolynomial.coeff_monomial]
  simp [neg, poly, coeffPoly, hmono]

omit [Nontrivial k] in
lemma neg_injective :
    Function.Injective (neg (m := m) (n := n) (t := t) (k := k)) := by
  intro T U h
  cases T
  cases U
  simp only [neg, mk.injEq, neg_inj] at h ⊢
  exact h

end ClosePairThm21Term

omit [Nontrivial k] in
lemma sPolynomial_swap
    (ord : MonomialOrder (Fin m × Fin n))
    (f g : MvPolynomial (Fin m × Fin n) k) :
    ord.sPolynomial f g = -ord.sPolynomial g f := by
  rw [MonomialOrder.sPolynomial_def, MonomialOrder.sPolynomial_def]
  simp [sup_comm, sub_eq_add_neg]

omit [Nontrivial k] in
lemma headLcm_swap
    (ord : MonomialOrder (Fin m × Fin n))
    (f g : MvPolynomial (Fin m × Fin n) k) :
    headLcm ord f g = headLcm ord g f := by
  simp [headLcm, sup_comm]

/-- Symmetry of the close-pair Theorem 2.1 data.  This implements the paper's
"by symmetry" step: a representation for `S(B,A)` gives one for `S(A,B)` by
negating all displayed monomial coefficients. -/
noncomputable def closePairThm21Data_swap
    (ord : MonomialOrder (Fin m × Fin n))
    (A B : MinorIndex m n t)
    (D : ClosePairThm21Data (m := m) (n := n) (t := t) (k := k) ord B A) :
    ClosePairThm21Data (m := m) (n := n) (t := t) (k := k) ord A B := by
  classical
  let negTerm := ClosePairThm21Term.neg (m := m) (n := n) (t := t) (k := k)
  refine
    { terms := D.terms.image negTerm
      linear_identity := ?_
      term_small := ?_ }
  · rw [sPolynomial_swap]
    rw [D.linear_identity]
    rw [Finset.sum_image]
    · rw [← Finset.sum_neg_distrib]
      apply Finset.sum_congr rfl
      intro T hT
      simpa [negTerm] using (ClosePairThm21Term.neg_poly T).symm
    · intro x hx y hy hxy
      exact ClosePairThm21Term.neg_injective hxy
  · intro T hT a ha
    rcases Finset.mem_image.mp hT with ⟨U, hU, rfl⟩
    simpa [negTerm, headLcm_swap ord
        (genericMinor (k := k) A) (genericMinor (k := k) B)] using
      D.term_small U hU a ha

/-- Paper Theorem 2.1 for close pairs, reduced to the two case skeletons above.

If the strict inequality has the opposite orientation, we apply the strict case
to the swapped close pair and then use `S(A,B) = -S(B,A)`. -/
noncomputable def closePairThm21Data_of_close
    (ord : MonomialOrder (Fin m × Fin n))
    (hdiag : IsDiagonalTermOrder ord)
    (A B : MinorIndex m n t)
    (hC : Close A B) :
    ClosePairThm21Data (m := m) (n := n) (t := t) (k := k) ord A B := by
  classical
  by_cases hrowLt :
      rowExt B (uClose A B) < rowExt A (uClose A B)
  · exact
      closePairThm21Data_of_uClose_row_lt
        (m := m) (n := n) (t := t) (k := k)
        ord hdiag A B hC hrowLt
  · by_cases hrowEq :
        rowExt B (uClose A B) = rowExt A (uClose A B)
    · exact
        closePairThm21Data_of_uClose_row_eq
          (m := m) (n := n) (t := t) (k := k)
          ord hdiag A B hC hrowEq
    · have hrowGt :
          rowExt A (uClose A B) < rowExt B (uClose A B) := by
        have hle :
            rowExt A (uClose A B) ≤ rowExt B (uClose A B) :=
          le_of_not_gt hrowLt
        have hne :
            rowExt A (uClose A B) ≠ rowExt B (uClose A B) := by
          intro h
          exact hrowEq h.symm
        exact lt_of_le_of_ne hle hne
      have huEq : uClose A B = uClose B A := close_uClose_eq_symm A B hC
      have hswapLt :
          rowExt A (uClose B A) < rowExt B (uClose B A) := by
        simpa [← huEq] using hrowGt
      exact
        closePairThm21Data_swap
          (m := m) (n := n) (t := t) (k := k)
          ord A B
          (closePairThm21Data_of_uClose_row_lt
            (m := m) (n := n) (t := t) (k := k)
            ord hdiag B A hC.symm hswapLt)

/-- The main "paper route" assembly theorem:
from Prop. 1.5 + the close-pair analysis in §2.1, obtain a good chain
between any two minors. -/
theorem minor_hasGoodChain_of_isDiagonalTermOrder
    (ord : MonomialOrder (Fin m × Fin n))
    (hdiag : IsDiagonalTermOrder ord)
    (I J : MinorIndex m n t) :
    HasGoodChain
      ord
      (minorSet (m := m) (n := n) (k := k) t)
      (genericMinor (k := k) I)
      (genericMinor (k := k) J) := by
  exact
    minor_hasGoodChain_of_closePairThm21Data
      (m := m) (n := n) (t := t) (k := k)
      ord hdiag
      (fun A B hC =>
        closePairThm21Data_of_close
          (m := m) (n := n) (t := t) (k := k)
          ord hdiag A B hC)
      I J

theorem minorSet_isGroebnerBasis_of_isDiagonalTermOrder
    [NoZeroDivisors k]
    (ord : MonomialOrder (Fin m × Fin n))
    (hdiag : IsDiagonalTermOrder ord) :
    ord.IsGroebnerBasis
      (minorSet (m := m) (n := n) (k := k) t)
      (detIdeal m n t k) := by
  apply
    minorSet_isGroebnerBasis_of_diagonal_order_and_indexHasGoodChains ord hdiag
  intro I J
  exact minor_hasGoodChain_of_isDiagonalTermOrder ord hdiag I J

end paper2_1

