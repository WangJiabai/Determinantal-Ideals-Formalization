/-- Case 3 preliminary diagonal-order input:
a non-identity C-block permutation term is strictly smaller than the C-block
diagonal term. -/
lemma closePairThm21_case3_cTail_d_lt_middleDiag
    (ord : MonomialOrder (Fin m × Fin n))
    (hdiag : IsDiagonalTermOrder ord)
    (A B : MinorIndex m n t)
    (hC : Close A B)
    (σ : Equiv.Perm (Fin (ClosePairStrictBlock.width A B)))
