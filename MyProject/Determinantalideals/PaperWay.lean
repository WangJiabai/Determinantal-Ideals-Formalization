lemma rowFin_aRepeatedMiddlePos
    (A B : MinorIndex m n t)
    (hC : Close A B)
    (i : Fin (width A B)) :
    rowFin A B hC (aRepeatedMiddlePos A B hC i) =
      A.row ⟨sClose A B + i.1, by
