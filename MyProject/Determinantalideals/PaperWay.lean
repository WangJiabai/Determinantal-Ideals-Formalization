            simpa [x] using congrArg Prod.snd hcoord
          have hBcol_eq_Aq : B.col midS = A.col q :=
            hKcol.symm.trans hcol_eq
          have hmid_lt_q : midS < q := by
            apply Fin.mk_lt_mk.mpr
            have hsw : s.1 < uClose A B - sClose A B := by
              simp [ClosePairStrictBlock.width]
            change sClose A B + s.1 < q.1
            omega
          have hAq_eq_Bq : A.col q = B.col q := by
            have hpEq :
                pairExt A (q.1 + 1) = pairExt B (q.1 + 1) := by
              exact pairExt_eq_of_mu_eq_right_gt_u
                A B hC.ne hC.mu_eq_right (by omega) (by omega)
            have hqₜ : q.1 + 1 ≤ t := by omega
            rw [EndpointSelection.pairExt_endpoint (I := A) (by omega) hqₜ,
              EndpointSelection.pairExt_endpoint (I := B) (by omega) hqₜ] at hpEq
            have hcolNat := congrArg Prod.snd hpEq
            apply Fin.ext
            simp at hcolNat
            omega
          have hBcol_lt_Aq : B.col midS < A.col q := by
            calc
              B.col midS < B.col q := B.col.strictMono hmid_lt_q
              _ = A.col q := hAq_eq_Bq.symm
          exact (ne_of_lt hBcol_lt_Aq) hBcol_eq_Aq
        simpa [x] using
          closePairThm21_case1_BmiddleCofactorPartExp_apply_of_not_mem_square
            (m := m) (n := n) (t := t) A B hC L σ hnot_square
      have hA_zero : diagExp A x = 0 := by
        dsimp [x]
        rw [diagExp_apply]
        refine if_neg ?_
        rintro ⟨a, hrowa, hcola⟩
        have haF : a = F.idx := A.row.injective hrowa
        have haq : a = q := A.col.injective hcola
        exact (ne_of_lt hF_lt_q) (haF.symm.trans haq)
      have hxcommon :=
        congrArg (fun f : (Fin m × Fin n) →₀ ℕ => f x) hcommon
      change
        closePairThm21_case1_rowTermExp
            (m := m) (n := n) (t := t) (k := k) A B hC L σ x -
          closePairThm21_case1_BmiddleCofactorPartExp
            (m := m) (n := n) (t := t) A B hC L σ x =
        diagExp A x at hxcommon
      rw [hlocal_zero, hA_zero] at hxcommon
      dsimp [x] at hxcommon
      omega
    let TailLt : Prop :=
      ord.toSyn
          (closePairThm21_case1_rowTermExp
            (m := m) (n := n) (t := t) (k := k) A B hC L σ)
        <
        ord.toSyn
          (headLcm ord
            (genericMinor (k := k) A)
            (genericMinor (k := k) B))
    have htail_residual_cof_close_fail_lt
        (hcofCloseFail : L.cofactorRow (σ p) ≠ A.row q) : TailLt := by
      /-
      Cofactor closing edge fails.  This is a cofactor-side chain-extension
      residual, not a direct `B`-middle local permutation branch.
      -/
      sorry
    have htail_residual_col_endpoint_fail_lt
        (hcolFail : ¬ B.col midp < A.col e) : TailLt := by
      /-
      Endpoint column order fails.  This should start the column-side
      displacement chain.
      -/
      sorry
    have htail_residual_adjacent_bmiddle_overlap_lt
        (hadjBM :
          ∃ r : Fin (support.length - 1),
            BMiddleCofactorOverlap
              (support.get ⟨r.1, by omega⟩)
              (support.get ⟨r.1 + 1, by omega⟩)) : TailLt := by
      /-
      Adjacent minor-cycle edge is also hit by a `B`-middle cofactor entry.
      This is a direct candidate for the `B`-middle local permutation outlet.
      -/
      sorry
    have htail_residual_bdiag_middle_cycle_overlap_lt
        (hBDiag :
          ∃ r : Fin (support.length - 1),
            BDiagMiddleCycleOverlap r) : TailLt := by
      /-
      A middle cycle coordinate is already a `B` diagonal coordinate.  This is
      another `B`-middle local permutation residual.
      -/
      sorry
    have htail_residual_cofdiag_overlap_lt
        (hCofDiag :
          ∃ r : Fin support.length,
            CofDiagMiddleOverlap (support.get r)) : TailLt := by
      /-
      A support diagonal coordinate is hit by the cofactor monomial.  This
      should also feed the `B`-middle local permutation outlet when it is in
      the previous controlled range.
      -/
      sorry
    have htail_residual_cofq_overlap_lt
        (hCofQ : CofQDiagOverlap) : TailLt := by
      /-
      The `q`-diagonal has a cofactor hit.  This is a cofactor-side residual
      endpoint.
      -/
      sorry
    have htail_residual_closing_minor_overlap_lt
        (hClosing : ClosingMinorOverlap) : TailLt := by
      /-
      The closing cofactor edge is also hit by a later minor diagonal slot.
      This is a tail/minor chain-extension residual.
      -/
      sorry
    have htail_residual_missing_A_diag_lt
        (hMissingA : MissingADiagOutsideLocal) : TailLt := by
      /-
      Outside the local support, an `A` diagonal coordinate is missing from the
      selected minor diagonal.  This is a minor-side residual.
      -/
      sorry
    have htail_residual_missing_min_witness_lt
        (hMissingMin : MissingMinWitnessOutsideLocal) : TailLt := by
      /-
      A selected-minor witness outside the local support is non-fixed.  This is
      the witness-coordinate version of the missing `A` diagonal residual.
      -/
      sorry
    have htail_residual_bmiddle_multiplicity_overlap_lt
        (hMult : BMiddleMultiplicityOverlap) : TailLt := by
      rcases hMult with ⟨r, s, hcof_pos, hmin_pos⟩
      let K : MinorIndex m n (ClosePairStrictBlock.width A B) :=
        ClosePairStrictBlock.bMiddleMinorIndex A B hC
      rcases
        (MonomialCoefficientMatrix.permExp_pos_iff_exists
          L.cofactorRow L.cofactorCol σ
          (K.row r) (K.col s)).1
          (by simpa [K] using hcof_pos)
        with ⟨w, hwrow, hwcol⟩
      have hw_eq_s : w = s := by
        have hcol_ws : L.cofactorCol w = L.cofactorCol s := by
          calc
            L.cofactorCol w = K.col s := hwcol
            _ = L.cofactorCol s := by
              simp [K, ClosePairStrictBlock.RowLaplaceChoice.cofactorCol]
        have hcol_middle :
            ClosePairStrictBlock.colFin A B hC
                (ClosePairStrictBlock.bMiddlePos A B hC w) =
              ClosePairStrictBlock.colFin A B hC
                (ClosePairStrictBlock.bMiddlePos A B hC s) := by
          simpa [ClosePairStrictBlock.RowLaplaceChoice.cofactorCol]
            using hcol_ws
        exact
          (ClosePairStrictBlock.colFin_bMiddlePos_strictMono A B hC).injective
            hcol_middle
      rcases
        (diagExp_pos_iff_exists L.minorIndex (K.row r, K.col s)).1
          (by simpa [K] using hmin_pos)
        with ⟨a, harow, hacol⟩
      have hminor_col : A.col a = K.col s := by
        simpa [ClosePairStrictBlock.RowLaplaceChoice.minorIndex_col] using hacol
      have hminor_row : L.minorIndex.row a = K.row r := harow
      /-
      We have extracted the genuine crossing data:
        * cofactor column witness `w` is the displayed B-middle column `s`;
        * selected-minor diagonal slot `a` has row `K.row r` and column
          `K.col s`.
      The next step should classify `a` relative to the local support / outside
      support residuals, instead of routing through the cofactor-only common
      splice.
      -/
      sorry
    have htail_residual_missing_B_middle_part_diag_lt
        (hMissingB : MissingBMiddlePartDiagOutsideLocal) : TailLt := by
      /-
      Missing `B`-middle diagonal for the displayed part should be handled by
      proving the clean shape hypotheses (or by one of the already meaningful
      residuals such as cofactor nonfixed or multiplicity overlap), not by
      adding syntactic shape-failure residuals.
      -/
      sorry
    have htail_residual_missing_B_middle_cof_diag_lt
        (hMissingB : MissingBMiddleCofDiagOutsideLocal) : TailLt := by
      /-
      The cofactor alone misses a middle `B` diagonal coordinate.  This no
      longer implies the actual `B`-middle permutation is nonidentity, because
      the selected minor part may contribute the same coordinate.  It is kept
      as a separate overlap/chain residual.
      -/
      sorry
    have htail_residual_missing_B_nonmiddle_diag_lt
        (hMissingB : MissingBNonMiddleDiagOutsideLocal) : TailLt := by
      /-
      A missing `B` diagonal outside the close middle interval is not governed
      by the `B`-middle permutation.  This belongs to the external
      chain-extension residuals.
      -/
      sorry
    have htail_residual_cofactor_nonfixed_lt
        (hCofNonfixed : CofactorNonfixedOutsideLocal) : TailLt := by
      /-
      A cofactor column outside the local endpoint is not matched to its
      diagonal `B` row.  This is another `B`-middle local permutation residual.
      -/
      sorry
    have htail_residual_cofactor_overlap_fixed_min_lt
        (hCofOverlapFixedMin : CofactorOverlapFixedMin) : TailLt := by
      /-
      A clean `A` diagonal coordinate has an additional cofactor hit.  This is
      a local-overlap residual.
      -/
      sorry
    have htail_residual_minor_overlap_fixed_cof_lt
        (hMinorOverlapFixedCof : MinorOverlapFixedCof) : TailLt := by
      /-
      A clean `B` cofactor diagonal coordinate has an additional selected-minor
      hit.  This is the dual local-overlap residual.
      -/
      sorry
    have htail_residual_lt (hres : HasResidual) : TailLt := by
      rcases hres with hcofCloseFail | hres
      · exact htail_residual_cof_close_fail_lt hcofCloseFail
      rcases hres with hcolFail | hres
      · exact htail_residual_col_endpoint_fail_lt hcolFail
      rcases hres with hadjBM | hres
      · exact htail_residual_adjacent_bmiddle_overlap_lt hadjBM
      rcases hres with hBDiag | hres
      · exact htail_residual_bdiag_middle_cycle_overlap_lt hBDiag
      rcases hres with hCofDiag | hres
      · exact htail_residual_cofdiag_overlap_lt hCofDiag
      rcases hres with hCofQ | hres
      · exact htail_residual_cofq_overlap_lt hCofQ
      rcases hres with hClosing | hres
      · exact htail_residual_closing_minor_overlap_lt hClosing
      rcases hres with hMissingA | hres
      · exact htail_residual_missing_A_diag_lt hMissingA
      rcases hres with hMissingMin | hres
      · exact htail_residual_missing_min_witness_lt hMissingMin
      rcases hres with hBmiddleMult | hres
      · exact htail_residual_bmiddle_multiplicity_overlap_lt hBmiddleMult
      rcases hres with hMissingBMiddlePart | hres
      · exact htail_residual_missing_B_middle_part_diag_lt hMissingBMiddlePart
      rcases hres with hMissingBMiddleCof | hres
      · exact htail_residual_missing_B_middle_cof_diag_lt hMissingBMiddleCof
      rcases hres with hMissingBNonMiddle | hres
      · exact htail_residual_missing_B_nonmiddle_diag_lt hMissingBNonMiddle
      rcases hres with hCofNonfixed | hres
      · exact htail_residual_cofactor_nonfixed_lt hCofNonfixed
      rcases hres with hCofOverlapFixedMin | hMinorOverlapFixedCof
      · exact htail_residual_cofactor_overlap_fixed_min_lt hCofOverlapFixedMin
      · exact htail_residual_minor_overlap_fixed_cof_lt hMinorOverlapFixedCof
    have htail_simple_closed_cycle_lt (hno : NoResidual) :
        ord.toSyn
            (closePairThm21_case1_rowTermExp
              (m := m) (n := n) (t := t) (k := k) A B hC L σ)
          <
          ord.toSyn
            (headLcm ord
              (genericMinor (k := k) A)
              (genericMinor (k := k) B)) := by
      /-
      Clean closed-cycle branch.  From `hno` one recovers:
      * the cofactor closing edge,
      * the column endpoint order,
      * no adjacent B-middle cofactor overlap,
      * no B-diagonal cycle overlap,
      * no cofactor diagonal support overlap,
      * no q-diagonal cofactor overlap,
      * no closing-minor overlap.

      The completed local support construction and zero facts should live in
      the extracted simple-closed-cycle lemma.  Its remaining hard core is the
      outside-local residual equality.
      -/
      have hcof_close :
          L.cofactorRow (σ p) = A.row q := by
        by_contra hbad
        exact hno (Or.inl hbad)
      have hBcol_lt_Ae :
          B.col midp < A.col e := by
        by_contra hbad
        exact hno (Or.inr (Or.inl hbad))
      have hno_adjacent_overlap :
          ¬ ∃ r : Fin (support.length - 1),
            BMiddleCofactorOverlap
              (support.get ⟨r.1, by omega⟩)
              (support.get ⟨r.1 + 1, by omega⟩) := by
        intro h
        exact hno (Or.inr (Or.inr (Or.inl h)))
      have hno_BDiagOverlap :
          ¬ ∃ r : Fin (support.length - 1),
            BDiagMiddleCycleOverlap r := by
        intro h
        exact hno (Or.inr (Or.inr (Or.inr (Or.inl h))))
      have hno_CofDiagOverlap :
          ¬ ∃ r : Fin support.length,
            CofDiagMiddleOverlap (support.get r) := by
        intro h
        exact hno (Or.inr (Or.inr (Or.inr (Or.inr (Or.inl h)))))
      have hno_CofQDiagOverlap : ¬ CofQDiagOverlap := by
        intro h
        exact hno (Or.inr (Or.inr (Or.inr (Or.inr (Or.inr (Or.inl h))))))
      have hno_ClosingMinorOverlap : ¬ ClosingMinorOverlap := by
        intro h
        exact hno (Or.inr (Or.inr (Or.inr (Or.inr (Or.inr (Or.inr (Or.inl h)))))))
      have hno_MissingADiagOutsideLocal : ¬ MissingADiagOutsideLocal := by
        intro h
        exact hno (hHas_MissingADiagOutsideLocal h)
      have hcof_col_p :
          L.cofactorCol p = B.col midp := by
        have hmidp_eq :
            midp =
              ⟨sClose A B + p.1, by
                have hpw : p.1 < uClose A B - sClose A B := p.2
                have hu : uClose A B ≤ t :=
                  le_trans (uClose_le_pClose A B hC.ne) (pClose_le A B)
                omega⟩ := by
          apply Fin.ext
          exact hmidp
        simpa [ClosePairStrictBlock.RowLaplaceChoice.cofactorCol, hmidp_eq] using
          ClosePairStrictBlock.colFin_bMiddlePos A B hC p
      have hcof_close_pos :
          1 ≤
            MonomialCoefficientMatrix.permExp L.cofactorRow L.cofactorCol σ
              (A.row q, B.col midp) := by
        exact
          (MonomialCoefficientMatrix.permExp_pos_iff_exists
            L.cofactorRow L.cofactorCol σ
            (A.row q) (B.col midp)).2
            ⟨p, hcof_close, hcof_col_p⟩
      have hclosing_pos :
          1 ≤
            closePairThm21_case1_rowTermExp
              (m := m) (n := n) (t := t) (k := k) A B hC L σ
              (A.row q, B.col midp) := by
        rw [closePairThm21_case1_rowTermExp_eq]
        have h :
            1 ≤
              MonomialCoefficientMatrix.permExp L.cofactorRow L.cofactorCol σ
                  (A.row q, B.col midp) +
            diagExp L.minorIndex (A.row q, B.col midp) := by
          omega
        simpa [Pi.add_apply] using h
      have hendpoint_pos :
          1 ≤
            closePairThm21_case1_rowTermExp
              (m := m) (n := n) (t := t) (k := k) A B hC L σ
              (B.row midp, A.col e) := by
        rw [closePairThm21_case1_rowTermExp_eq]
        have hdiag_one :
            diagExp L.minorIndex (B.row midp, A.col e) = 1 := by
          rw [diagExp_apply]
          refine if_pos ?_
          refine ⟨e, he_row_B, ?_⟩
          simp [ClosePairStrictBlock.RowLaplaceChoice.minorIndex_col]
        have h :
            1 ≤
              MonomialCoefficientMatrix.permExp L.cofactorRow L.cofactorCol σ
                  (B.row midp, A.col e) +
                diagExp L.minorIndex (B.row midp, A.col e) := by
          rw [hdiag_one]
          omega
        simpa [Pi.add_apply] using h
      let EdgePos : Fin t → Fin t → Prop :=
        fun x y =>
          1 ≤
            closePairThm21_case1_rowTermExp
              (m := m) (n := n) (t := t) (k := k) A B hC L σ
              (A.row x, A.col y)
      have hedge_of_shift :
          ∀ {x y : Fin t},
            L.minorIndex.row y = A.row x →
              EdgePos x y := by
        intro x y hrow
        dsimp [EdgePos]
        rw [closePairThm21_case1_rowTermExp_eq]
        have hdiag_one :
            diagExp L.minorIndex (A.row x, A.col y) = 1 := by
          rw [diagExp_apply]
          refine if_pos ?_
          refine ⟨y, hrow, ?_⟩
          simp [ClosePairStrictBlock.RowLaplaceChoice.minorIndex_col]
        have h :
            1 ≤
              MonomialCoefficientMatrix.permExp L.cofactorRow L.cofactorCol σ
                  (A.row x, A.col y) +
                diagExp L.minorIndex (A.row x, A.col y) := by
          rw [hdiag_one]
          omega
        simpa [Pi.add_apply] using h
      have hsupport_edge_pos :
          List.IsChain EdgePos support :=
        hsupport_row_shift.imp (fun x y hxy => hedge_of_shift hxy)
      let localRowsList : List (Fin m) :=
        B.row midp :: support.map A.row
      let localColsList : List (Fin n) :=
        B.col midp :: support.map A.col
      have hmap_row_chain :
          ∀ l : List (Fin t),
            List.IsChain (fun x y : Fin t => x < y) l →
              List.IsChain (fun x y : Fin m => x < y) (l.map A.row) := by
        intro l hl
        induction l with
        | nil =>
            simp
        | cons a rest ih =>
            cases rest with
            | nil =>
                exact List.isChain_singleton (A.row a)
            | cons b bs =>
                have hsplit :
                    a < b ∧ List.IsChain (fun x y : Fin t => x < y) (b :: bs) := by
                  simpa using hl
                exact
                  List.IsChain.cons_cons
                    (A.row.strictMono hsplit.1)
                    (ih hsplit.2)
      have hmap_col_chain :
          ∀ l : List (Fin t),
            List.IsChain (fun x y : Fin t => x < y) l →
              List.IsChain (fun x y : Fin n => x < y) (l.map A.col) := by
        intro l hl
        induction l with
        | nil =>
            simp
        | cons a rest ih =>
            cases rest with
            | nil =>
                exact List.isChain_singleton (A.col a)
            | cons b bs =>
                have hsplit :
                    a < b ∧ List.IsChain (fun x y : Fin t => x < y) (b :: bs) := by
                  simpa using hl
                exact
                  List.IsChain.cons_cons
                    (A.col.strictMono hsplit.1)
                    (ih hsplit.2)
      have hsupport_cons : ∃ rest : List (Fin t), support = e :: rest := by
        cases hs : support with
        | nil =>
            rw [hs] at hsupport_head
            simp at hsupport_head
        | cons a rest =>
            rw [hs] at hsupport_head
            have ha : a = e := by
              simpa using hsupport_head
            subst a
            exact ⟨rest, rfl⟩
      have hlocalRows_chain :
          List.IsChain (fun x y : Fin m => x < y) localRowsList := by
        rcases hsupport_cons with ⟨rest, hsupport_eq⟩
        have hsupport_chain' :
            List.IsChain (fun x y : Fin t => x < y) (e :: rest) := by
          simpa [hsupport_eq] using hsupport_chain
        dsimp [localRowsList]
        rw [hsupport_eq]
        exact
          List.IsChain.cons_cons
            hendpoint_row_lt
            (hmap_row_chain (e :: rest) hsupport_chain')
      have hlocalCols_chain :
          List.IsChain (fun x y : Fin n => x < y) localColsList := by
        rcases hsupport_cons with ⟨rest, hsupport_eq⟩
        have hsupport_chain' :
            List.IsChain (fun x y : Fin t => x < y) (e :: rest) := by
          simpa [hsupport_eq] using hsupport_chain
        dsimp [localColsList]
        rw [hsupport_eq]
        exact
          List.IsChain.cons_cons
            hBcol_lt_Ae
            (hmap_col_chain (e :: rest) hsupport_chain')
      have hsupport_ge_head :
          ∀ x ∈ support, e ≤ x := by
        rcases hsupport_cons with ⟨rest, hsupport_eq⟩
        have hsupport_chain' :
            List.IsChain (fun x y : Fin t => x < y) (e :: rest) := by
          simpa [hsupport_eq] using hsupport_chain
        have hhead_le_all :
            ∀ (a : Fin t) (l : List (Fin t)),
              List.IsChain (fun x y : Fin t => x < y) (a :: l) →
                ∀ y ∈ l, a < y := by
          intro a l
          revert a
          induction l with
          | nil =>
              intro a _ y hy
              simp at hy
          | cons b bs ih =>
              intro a hchain y hy
              have hsplit :
                  a < b ∧ List.IsChain (fun x y : Fin t => x < y) (b :: bs) := by
                simpa using hchain
              simp only [List.mem_cons] at hy
              rcases hy with rfl | hybs
              · exact hsplit.1
              · exact lt_trans hsplit.1 (ih b hsplit.2 y hybs)
        intro x hx
        rw [hsupport_eq] at hx
        simp only [List.mem_cons] at hx
        rcases hx with rfl | hxrest
        · exact le_rfl
        · exact le_of_lt (hhead_le_all e rest hsupport_chain' x hxrest)
      have hBrow_not_mem :
          B.row midp ∉ support.map A.row := by
        intro hmem
        rcases List.mem_map.mp hmem with ⟨x, hxmem, hxrow⟩
        have hex : e ≤ x := hsupport_ge_head x hxmem
        have hAex : A.row e ≤ A.row x := by
          exact le_of_not_gt (by
            intro hlt
            exact (not_lt_of_ge hex) ((A.row.lt_iff_lt).mp hlt))
        have hlt : B.row midp < A.row x :=
          lt_of_lt_of_le hendpoint_row_lt hAex
        exact (ne_of_gt hlt) hxrow
      have hBcol_not_mem :
          B.col midp ∉ support.map A.col := by
        intro hmem
        rcases List.mem_map.mp hmem with ⟨x, hxmem, hxcol⟩
        have hex : e ≤ x := hsupport_ge_head x hxmem
        have hAex : A.col e ≤ A.col x := by
          exact le_of_not_gt (by
            intro hlt
            exact (not_lt_of_ge hex) ((A.col.lt_iff_lt).mp hlt))
        have hlt : B.col midp < A.col x :=
          lt_of_lt_of_le hBcol_lt_Ae hAex
        exact (ne_of_gt hlt) hxcol
      have hsupport_map_rows_nodup :
          (support.map A.row).Nodup :=
        hsupport_nodup.map (by
          intro x y hxy
          exact A.row.injective hxy)
      have hsupport_map_cols_nodup :
          (support.map A.col).Nodup :=
        hsupport_nodup.map (by
          intro x y hxy
          exact A.col.injective hxy)
      have hlocalRows_nodup : localRowsList.Nodup := by
        dsimp [localRowsList]
        exact List.nodup_cons.mpr ⟨hBrow_not_mem, hsupport_map_rows_nodup⟩
      have hlocalCols_nodup : localColsList.Nodup := by
        dsimp [localColsList]
        exact List.nodup_cons.mpr ⟨hBcol_not_mem, hsupport_map_cols_nodup⟩
      have hlocalRows_len :
          localRowsList.length = support.length + 1 := by
        simp [localRowsList]
      have hlocalCols_len :
          localColsList.length = support.length + 1 := by
        simp [localColsList]
      have hlocalLen_eq :
          localRowsList.length = localColsList.length := by
