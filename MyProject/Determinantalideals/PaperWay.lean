    (L : ClosePairStrictBlock.RowLaplaceChoice A B hC)
    (sigma : Equiv.Perm (Fin (ClosePairStrictBlock.width A B)))
    (_hc :
      (closePairThm21_case1_rowTerm
        (m := m) (n := n) (t := t) (k := k) A B hC L sigma).c ≠ 0)
    (U : Case1UVChain A B hC)
