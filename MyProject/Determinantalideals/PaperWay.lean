    (hlocal :
      ord.toSyn
          (closePairThm21_case1_BmiddleCofactorPartExp
            (m := m) (n := n) (t := t) A B hC L sigma)
        <
        ord.toSyn
          (diagExp (ClosePairStrictBlock.bMiddleMinorIndex A B hC)))
    (hcommon :
      closePairThm21_case1_rowTermExp
          (m := m) (n := n) (t := t) (k := k) A B hC L sigma -
        closePairThm21_case1_BmiddleCofactorPartExp
          (m := m) (n := n) (t := t) A B hC L sigma =
      diagExp A)
    (_hprevA :
      ∀ j : Fin U.q, j.1 < i.1 → StatementA A B hC L U j)
    (_hprevB :
      ∀ j : Fin U.q, j.1 < i.1 → StatementB A B hC L U j)
    (_hprevC :
      ∀ j : Fin U.q, j.1 < i.1 → StatementC A B hC L sigma U j) :
    ord.toSyn
        (closePairThm21_case1_rowTermExp
          (m := m) (n := n) (t := t) (k := k) A B hC L sigma)
      <
      ord.toSyn
        (headLcm ord
          (genericMinor (k := k) A)
          (genericMinor (k := k) B)) := by
  classical
  exact
    closePairThm21_case1_rowTermExp_lt_of_BmiddleCofactorPart_lt_of_common
      (m := m) (n := n) (t := t) (k := k)
      ord hdiag A B hC L sigma hlocal hcommon

