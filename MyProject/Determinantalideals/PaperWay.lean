lemma closePairThm21_equalCollectedTerm_poly_eq_sum_fiber
    (A B : MinorIndex m n t)
    (hC : Close A B)
    (q : ClosePairStrictBlock.StrictLaplaceRawIndex.TermKey m n t) :
    (closePairThm21_equalCollectedTerm
      (m := m) (n := n) (t := t) (k := k) A B hC q).poly =
      ∑ i ∈
        (closePairThm21_equalRawFiber
  (m := m) (n := n) (t := t) (k := k) A B hC q),
        (ClosePairStrictBlock.StrictLaplaceRawIndex.term
          (m := m) (n := n) (t := t) (k := k)
          (A := A) (B := B) (hC := hC) i).poly := by
  classical
  rw [closePairThm21_equalCollectedTerm,
    ClosePairThm21Term.poly, ClosePairThm21Term.coeffPoly,
    closePairThm21_equalCollectedCoeff]
  have hmono :
      MvPolynomial.monomial q.2
          (∑ i ∈
            (closePairThm21_equalRawFiber
  (m := m) (n := n) (t := t) (k := k) A B hC q),
            (ClosePairStrictBlock.StrictLaplaceRawIndex.term
              (m := m) (n := n) (t := t) (k := k)
              (A := A) (B := B) (hC := hC) i).c) =
        ∑ i ∈
          (closePairThm21_equalRawFiber
  (m := m) (n := n) (t := t) (k := k) A B hC q),
          MvPolynomial.monomial q.2
            ((ClosePairStrictBlock.StrictLaplaceRawIndex.term
              (m := m) (n := n) (t := t) (k := k)
              (A := A) (B := B) (hC := hC) i).c) := by
    simp
  rw [hmono, Finset.sum_mul]
  refine Finset.sum_congr rfl ?_
  intro i hi
  have hkey :
    ClosePairStrictBlock.StrictLaplaceRawIndex.rawKey
      (m := m) (n := n) (t := t) (k := k)
      (A := A) (B := B) (hC := hC) i = q :=
  (closePairThm21_mem_equalRawFiber_iff
    (m := m) (n := n) (t := t) (k := k) A B hC q i).mp hi
  let T : ClosePairThm21Term m n t k :=
    ClosePairStrictBlock.StrictLaplaceRawIndex.term
      (m := m) (n := n) (t := t) (k := k)
      (A := A) (B := B) (hC := hC) i
  have hK : T.K = q.1 := congrArg Prod.fst hkey
  have hd : T.d = q.2 := congrArg Prod.snd hkey
  simp [T, ClosePairThm21Term.poly, ClosePairThm21Term.coeffPoly, hK, hd]

omit [Nontrivial k] in
lemma closePairThm21_equal_sum_collectedTerm_poly_eq_rawPolySum
    (A B : MinorIndex m n t)
    (hC : Close A B) :
    (∑ q ∈
        ClosePairStrictBlock.StrictLaplaceRawIndex.keyFinset
          (m := m) (n := n) (t := t) (k := k) A B hC,
      (closePairThm21_equalCollectedTerm
        (m := m) (n := n) (t := t) (k := k) A B hC q).poly) =
      ClosePairStrictBlock.StrictLaplaceRawIndex.rawPolySum
        (m := m) (n := n) (t := t) (k := k) A B hC := by
  classical
  let ι := ClosePairStrictBlock.StrictLaplaceRawIndex A B hC
  let keys :=
    ClosePairStrictBlock.StrictLaplaceRawIndex.keyFinset
      (m := m) (n := n) (t := t) (k := k) A B hC
  let g : ι → ClosePairStrictBlock.StrictLaplaceRawIndex.TermKey m n t :=
    ClosePairStrictBlock.StrictLaplaceRawIndex.rawKey
      (m := m) (n := n) (t := t) (k := k)
      (A := A) (B := B) (hC := hC)
  let f : ι → MvPolynomial (Fin m × Fin n) k :=
    fun i =>
      (ClosePairStrictBlock.StrictLaplaceRawIndex.term
        (m := m) (n := n) (t := t) (k := k)
        (A := A) (B := B) (hC := hC) i).poly
  have hfiber :
      (∑ q ∈ keys,
        (closePairThm21_equalCollectedTerm
          (m := m) (n := n) (t := t) (k := k) A B hC q).poly) =
        ∑ q ∈ keys,
          ∑ i ∈ ((Finset.univ : Finset ι).filter fun i => g i = q),
            f i := by
    refine Finset.sum_congr rfl ?_
    intro q hq
    rw [closePairThm21_equalCollectedTerm_poly_eq_sum_fiber
      (m := m) (n := n) (t := t) (k := k) A B hC q]
    refine Finset.sum_congr ?hset ?hterm
    · ext i
      constructor
      · intro hi
        exact Finset.mem_filter.mpr ⟨
          Finset.mem_univ i,
          (closePairThm21_mem_equalRawFiber_iff
            (m := m) (n := n) (t := t) (k := k) A B hC q i).mp hi
        ⟩
      · intro hi
        exact
          (closePairThm21_mem_equalRawFiber_iff
            (m := m) (n := n) (t := t) (k := k) A B hC q i).mpr
            ((Finset.mem_filter.mp hi).2)
    · intro i hi
      rfl
  have hmaps :
      ∀ i ∈ (Finset.univ : Finset ι), g i ∈ keys := by
    intro i _hi
    simp [keys, g, ClosePairStrictBlock.StrictLaplaceRawIndex.keyFinset]
  have hsum :=
    Finset.sum_fiberwise_of_maps_to
      (s := (Finset.univ : Finset ι))
      (t := keys)
      (g := g)
      (f := f)
      hmaps
  calc
    (∑ q ∈ keys,
      (closePairThm21_equalCollectedTerm
        (m := m) (n := n) (t := t) (k := k) A B hC q).poly)
        =
      ∑ q ∈ keys,
        ∑ i ∈ ((Finset.univ : Finset ι).filter fun i => g i = q),
          f i := hfiber
    _ =
      ClosePairStrictBlock.StrictLaplaceRawIndex.rawPolySum
        (m := m) (n := n) (t := t) (k := k) A B hC := by
      dsimp [ClosePairStrictBlock.StrictLaplaceRawIndex.rawPolySum, f, ι]
      simpa only [Finset.mem_univ, if_true] using hsum

