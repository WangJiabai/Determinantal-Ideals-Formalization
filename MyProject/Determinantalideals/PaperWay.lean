/-- Once StatementB is known on every `u`-chain interval, every middle
principal `A` position occurs among the selected minor rows.

This is the middle-interval part of the final extraction
`γ` contains all `α` rows.  The prefix and tail parts are handled by the
separate zero-block lemmas. -/
lemma closePairThm21_case1_middle_aColumnPos_mem_minorRows_of_all_statementB
    (A B : MinorIndex m n t)
    (hC : Close A B)
    (L : ClosePairStrictBlock.RowLaplaceChoice A B hC)
    (U : Case1UVChain A B hC)
    (hB : ∀ i : Fin U.q, StatementB A B hC L U i)
    (idx : Fin t)
    (hmid : sClose A B ≤ idx.1 ∧ idx.1 < uClose A B) :
    ∃ j : Fin t,
      L.minorRows j = ClosePairStrictBlock.aColumnPos A B hC idx := by
  classical
  let paper : ℕ := idx.1 + 1
  have hpaper :
      sClose A B + 1 ≤ paper ∧ paper ≤ uClose A B := by
    constructor <;> omega
  rcases
    closePairThm21_case1_exists_u_interval_of_middle
      (m := m) (n := n) (t := t) A B hC U hpaper.1 hpaper.2
    with ⟨i, hlo, hhi⟩
  have hidx :
      middlePaperIndexToFinOfClose A B hC paper hpaper = idx := by
    apply Fin.ext
    simp [paper, middlePaperIndexToFinOfClose]
  have hstmt :
      L.minorRows
          (middlePaperIndexToFinOfClose A B hC paper hpaper) =
        aColumnPosOfPaperMiddle A B hC paper hpaper :=
    hB i paper hlo hhi
  refine ⟨idx, ?_⟩
  simpa [hidx, aColumnPosOfPaperMiddle] using hstmt

