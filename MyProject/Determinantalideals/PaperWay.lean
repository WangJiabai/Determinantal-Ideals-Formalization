/-- After the Case 1 induction has proved StatementB on all chain intervals,
the row choice must be the principal one.  The extra `hprefix_tail` packages
the already-separate prefix and tail row-containment arguments; the middle
rows come from `hB` and the fact that `U.u` runs from `uClose + 1` down to
`sClose + 1`. -/
lemma closePairThm21_case1_rowPrincipalChoice_of_all_statementB
    (A B : MinorIndex m n t)
    (hC : Close A B)
    (L : ClosePairStrictBlock.RowLaplaceChoice A B hC)
    (U : Case1UVChain A B hC)
    (hB : ∀ i : Fin U.q, StatementB A B hC L U i)
    (hprefix_tail :
      ∀ i : Fin t,
        (i.1 < sClose A B ∨ uClose A B ≤ i.1) →
          ∃ j : Fin t,
            L.minorRows j = ClosePairStrictBlock.aColumnPos A B hC i) :
    L = ClosePairStrictBlock.rowPrincipalChoice A B hC := by
  classical
  have hmem :
      ∀ i : Fin t, ∃ j : Fin t,
        L.minorRows j = ClosePairStrictBlock.aColumnPos A B hC i := by
    intro i
    by_cases hpre : i.1 < sClose A B
    · exact hprefix_tail i (Or.inl hpre)
    · by_cases hmid : i.1 < uClose A B
      · let paper : ℕ := i.1 + 1
        have hp_lo : sClose A B + 1 ≤ paper := by
          dsimp [paper]
          omega
        have hp_hi : paper ≤ uClose A B := by
          dsimp [paper]
          omega
        rcases
          closePairThm21_case1_exists_u_interval_of_middle
            A B hC U hp_lo hp_hi with
          ⟨q, hqlo, hqhi⟩
        have hstmt :
            L.minorRows
                (middlePaperIndexToFinOfClose A B hC paper
                  (by exact ⟨hp_lo, hp_hi⟩)) =
              aColumnPosOfPaperMiddle A B hC paper
                (by exact ⟨hp_lo, hp_hi⟩) := by
          exact hB q paper hqlo hqhi
        refine ⟨i, ?_⟩
        simpa [paper, middlePaperIndexToFinOfClose, aColumnPosOfPaperMiddle]
          using hstmt
      · exact hprefix_tail i (Or.inr (Nat.le_of_not_gt hmid))
  have hminor :
      L.minorRows = fun i => ClosePairStrictBlock.aColumnPos A B hC i :=
    closePairThm21_case1_minorRows_eq_aColumnPos_of_mem A B hC L hmem
  have hcofactor :
      L.cofactorRows = fun i => ClosePairStrictBlock.bMiddlePos A B hC i :=
    closePairThm21_case1_cofactorRows_eq_bMiddlePos_of_minorRows_eq_aColumnPos_core
      A B hC L hminor
  apply ClosePairStrictBlock.RowLaplaceChoice.ext_data
  · apply Equiv.ext
    intro x
    cases x with
    | inl i =>
        calc
          L.shuffle (Sum.inl i) = L.minorRows i := (L.minorRows_eq_shuffle i).symm
          _ = ClosePairStrictBlock.aColumnPos A B hC i := congrFun hminor i
          _ = (ClosePairStrictBlock.rowPrincipalChoice A B hC).shuffle (Sum.inl i) := rfl
    | inr i =>
        calc
          L.shuffle (Sum.inr i) = L.cofactorRows i := (L.cofactorRows_eq_shuffle i).symm
          _ = ClosePairStrictBlock.bMiddlePos A B hC i := congrFun hcofactor i
          _ = (ClosePairStrictBlock.rowPrincipalChoice A B hC).shuffle (Sum.inr i) := rfl
  · exact hminor
  · exact hcofactor

/-- A finite decreasing chain from `top` to `bot`, used to encode the paper's
interlacing breakpoints. -/
structure DecreasingChain (bot top : ℕ) where
  q : ℕ
  val : Fin (q + 1) → ℕ
  zero_eq : val 0 = top
  last_eq : val ⟨q, Nat.lt_succ_self q⟩ = bot
  strict : ∀ {i j : Fin (q + 1)}, i < j → val j < val i
  bounds : ∀ i : Fin (q + 1), bot ≤ val i ∧ val i ≤ top


/-! ### Case 1 breakpoint-chain construction

This is the construction layer for the paper's `u_i / v_i` chain in Case 1.

Important: this is not the adjacent full chain `u = v = top - i`.
The adjacent full chain would require false pointwise inequalities such as
`rowExt A j ≤ rowExt B (j+1)` for every middle `j`.

Instead we choose genuine breakpoints, exactly as in the paper:
starting from `(u₀, v₀) = (uClose + 1, uClose + 1)`, alternately choose

* the next `u`-breakpoint as the first row index where
  `rowExt B (v_i - 1) < rowExt A r`;
* the next `v`-breakpoint as the first row index where
  `rowExt A (u_{i+1} - 1) ≤ rowExt B r`.

The minimality of these choices gives the interval inequalities in
`Case1UVChain`.
-/

namespace Case1Breakpoint

variable {m n t : ℕ}

/-- Bottom of the paper middle interval, in paper-style indexing. -/
noncomputable abbrev bot (A B : MinorIndex m n t) : ℕ :=
  sClose A B + 1

/-- Top sentinel of the paper middle interval, in paper-style indexing. -/
noncomputable abbrev top (A B : MinorIndex m n t) : ℕ :=
  uClose A B + 1

/-- Predicate for the next `u`-breakpoint after the current `v`.

`r` is acceptable if it lies in the middle interval and the row of `A` at
`r` lies strictly above the previous `B` row `v - 1`. -/
def NextUOk
    (A B : MinorIndex m n t)
    (v r : ℕ) : Prop :=
  bot A B ≤ r ∧
  r ≤ uClose A B ∧
  rowExt B (v - 1) < rowExt A r

/-- Predicate for the next `v`-breakpoint after the new `u`.

`r` is acceptable if it lies in the middle interval and the row of `B` at
`r` dominates the previous `A` row `u - 1`. -/
def NextVOk
    (A B : MinorIndex m n t)
    (u r : ℕ) : Prop :=
  bot A B ≤ r ∧
  r ≤ uClose A B ∧
  rowExt A (u - 1) ≤ rowExt B r

/-- The next `u`-breakpoint.  If the predicate is empty, we return `bot`;
the specs below are always used under a proof of nonemptiness. -/
noncomputable def nextU
    (A B : MinorIndex m n t)
    (v : ℕ) : ℕ :=by
  classical
  exact
    if h : ∃ r : ℕ, NextUOk A B v r then
      Nat.find h
    else
      bot A B

/-- The next `v`-breakpoint.  If the predicate is empty, we return `bot`;
the specs below are always used under a proof of nonemptiness. -/
noncomputable def nextV
    (A B : MinorIndex m n t)
    (u : ℕ) : ℕ :=by
  classical
  exact
    if h : ∃ r : ℕ, NextVOk A B u r then
      Nat.find h
    else
      bot A B

lemma nextU_spec_of_exists
    (A B : MinorIndex m n t)
    {v : ℕ}
    (h : ∃ r : ℕ, NextUOk A B v r) :
    NextUOk A B v (nextU A B v) := by
  classical
  unfold nextU
  rw [dif_pos h]
  exact Nat.find_spec h

lemma nextU_min_of_exists
    (A B : MinorIndex m n t)
    {v r : ℕ}
    (h : ∃ r : ℕ, NextUOk A B v r)
    (hr : NextUOk A B v r) :
    nextU A B v ≤ r := by
  classical
  unfold nextU
  rw [dif_pos h]
  exact Nat.find_le hr

lemma nextV_spec_of_exists
    (A B : MinorIndex m n t)
    {u : ℕ}
    (h : ∃ r : ℕ, NextVOk A B u r) :
    NextVOk A B u (nextV A B u) := by
  classical
  unfold nextV
  rw [dif_pos h]
  exact Nat.find_spec h

lemma nextV_min_of_exists
    (A B : MinorIndex m n t)
    {u r : ℕ}
    (h : ∃ r : ℕ, NextVOk A B u r)
    (hr : NextVOk A B u r) :
    nextV A B u ≤ r := by
  classical
  unfold nextV
  rw [dif_pos h]
  exact Nat.find_le hr

/-- One breakpoint step: from current `(u, v)` to `(u', v')`.

If the next `u`-breakpoint has already reached `bot`, we stop immediately at
`(bot, bot)`.  Otherwise we choose the next `v`-breakpoint. -/
noncomputable def step
    (A B : MinorIndex m n t)
    (p : ℕ × ℕ) : ℕ × ℕ :=
  let u' := nextU A B p.2
  if u' = bot A B then
    (bot A B, bot A B)
  else
    let v' := nextV A B u'
    if v' = bot A B then
      (bot A B, bot A B)
    else
      (u', v')

/-- Iterating the breakpoint step from `(top, top)`. -/
noncomputable def seq
    (A B : MinorIndex m n t) :
    ℕ → ℕ × ℕ
  | 0 => (top A B, top A B)
  | r + 1 => step A B (seq A B r)

noncomputable def uSeq
    (A B : MinorIndex m n t)
    (r : ℕ) : ℕ :=
  (seq A B r).1

noncomputable def vSeq
    (A B : MinorIndex m n t)
    (r : ℕ) : ℕ :=
  (seq A B r).2

def hitBot
    (A B : MinorIndex m n t)
    (r : ℕ) : Prop :=
  uSeq A B r = bot A B ∧
  vSeq A B r = bot A B

/-- The next-`u` predicate is initially nonempty.  Candidate: `uClose`. -/
lemma nextU_exists_initial
    (A B : MinorIndex m n t)
    (hC : Close A B)
    (hrowLt :
      rowExt B (uClose A B) < rowExt A (uClose A B)) :
    ∃ r : ℕ, NextUOk A B (top A B) r := by
  classical
  refine ⟨uClose A B, ?_⟩
  have hsu : sClose A B < uClose A B :=
    sClose_lt_uClose A B hC.ne
  constructor
  · unfold bot
    omega
  constructor
  · exact le_rfl
  · simpa [top] using hrowLt

/-- If `u` is the next `u`-breakpoint chosen minimally from current `v`, then
all rows in `[u, oldU)` lie above `rowExt B (v-1)`.

This is exactly the interval field
`row_A_interval_gt_B_pred` later used in `Case1UVChain`.
-/
lemma nextU_interval
    (A B : MinorIndex m n t)
    {v u _oldU j : ℕ}
    (hex : ∃ r : ℕ, NextUOk A B v r)
    (hu : u = nextU A B v)
    (hju : u ≤ j)
    (_hjuTop : j ≤ uClose A B) :
    rowExt B (v - 1) < rowExt A j := by
  classical
  have hspec : NextUOk A B v u := by
    simpa [hu] using nextU_spec_of_exists A B hex
  have hmono : Monotone (rowExt A) := rowExt_monotone A
  exact lt_of_lt_of_le hspec.2.2 (hmono hju)

/-- Minimality of `nextU`: if `u > bot`, then the previous `A` row does not
lie above `rowExt B (v-1)`.  Since the row order is linear, this gives the
lower inequality needed to find the next `v`. -/
lemma nextU_prev_le_of_gt_bot
    (A B : MinorIndex m n t)
    {v u : ℕ}
    (hex : ∃ r : ℕ, NextUOk A B v r)
    (hu : u = nextU A B v)
    (hbot : bot A B < u) :
    rowExt A (u - 1) ≤ rowExt B (v - 1) := by
  classical
  by_contra hnot
  have hlt : rowExt B (v - 1) < rowExt A (u - 1) :=
    Nat.lt_of_not_ge hnot
  have hspec : NextUOk A B v u := by
    simpa [hu] using nextU_spec_of_exists A B hex
  have hprev_ok : NextUOk A B v (u - 1) := by
    constructor
    · unfold bot at hbot ⊢
      omega
    constructor
    · have hu_le : u ≤ uClose A B := hspec.2.1
      omega
    · exact hlt
  have hmin :
      nextU A B v ≤ u - 1 :=
    nextU_min_of_exists A B hex hprev_ok
  have hmin' : u ≤ u - 1 := by
    simpa [hu] using hmin
  omega

/-- Once `u = nextU v` is strictly above `bot`, the next-`v` predicate is
nonempty.  Candidate: `v - 1`.

This is the second half of the paper's breakpoint step.
-/
lemma nextV_exists_after_nextU
    (A B : MinorIndex m n t)
    {v u : ℕ}
    (hexU : ∃ r : ℕ, NextUOk A B v r)
    (hu : u = nextU A B v)
    (hvbot : bot A B < v)
    (hubot : bot A B < u)
    (hvle : v ≤ top A B) :
    ∃ r : ℕ, NextVOk A B u r := by
  classical
  refine ⟨v - 1, ?_⟩
  have hprev :
      rowExt A (u - 1) ≤ rowExt B (v - 1) :=
    nextU_prev_le_of_gt_bot A B hexU hu hubot
  constructor
  · unfold bot at hvbot ⊢
    omega
  constructor
  · unfold top at hvle
    omega
  · exact hprev

/-- If `v' = nextV u`, then all rows in `[v', oldV)` dominate
`rowExt A (u-1)`.

This is exactly the interval field
`row_B_interval_ge_A_lower_pred`.
-/
lemma nextV_interval
    (A B : MinorIndex m n t)
    {u v' j : ℕ}
    (hex : ∃ r : ℕ, NextVOk A B u r)
    (hv : v' = nextV A B u)
    (hjv : v' ≤ j)
    (_hjuTop : j ≤ uClose A B) :
    rowExt A (u - 1) ≤ rowExt B j := by
  classical
  have hspec : NextVOk A B u v' := by
    simpa [hv] using nextV_spec_of_exists A B hex
  have hmono : Monotone (rowExt B) := rowExt_monotone B
  exact le_trans hspec.2.2 (hmono hjv)

/-- The chosen `v'` lies at or below the old `v - 1`, hence the sequence
strictly descends while above `bot`. -/
lemma nextV_lt_oldV
    (A B : MinorIndex m n t)
    {u v : ℕ}
    (hexV : ∃ r : ℕ, NextVOk A B u r)
    (hcand : NextVOk A B u (v - 1))
    (hvbot : bot A B < v) :
    nextV A B u < v := by
  classical
  have hle :
      nextV A B u ≤ v - 1 :=
    nextV_min_of_exists A B hexV hcand
  omega

/-- Minimality of `nextV`: if `v' > bot`, then the previous `B` row is still
strictly below `rowExt A (u-1)`.

This is the invariant needed to start the next `u`-selection. -/
lemma nextV_prev_lt_of_gt_bot
    (A B : MinorIndex m n t)
    {u v' : ℕ}
    (hex : ∃ r : ℕ, NextVOk A B u r)
    (hv : v' = nextV A B u)
    (hbot : bot A B < v') :
    rowExt B (v' - 1) < rowExt A (u - 1) := by
  classical
  by_contra hnot
  have hle : rowExt A (u - 1) ≤ rowExt B (v' - 1) :=
    Nat.le_of_not_gt hnot
  have hspec : NextVOk A B u v' := by
    simpa [hv] using nextV_spec_of_exists A B hex
  have hprev_ok : NextVOk A B u (v' - 1) := by
    constructor
    · unfold bot at hbot ⊢
      omega
    constructor
    · have hv'_le : v' ≤ uClose A B := hspec.2.1
      omega
    · exact hle
  have hmin :
      nextV A B u ≤ v' - 1 :=
    nextV_min_of_exists A B hex hprev_ok
  have hmin' : v' ≤ v' - 1 := by
    simpa [← hv] using hmin
  omega

/-- After choosing `v' = nextV u`, if `v'` is still above `bot`, then the next
`u`-predicate is nonempty.  Candidate: `u - 1`. -/
lemma nextU_exists_after_nextV
    (A B : MinorIndex m n t)
    {u v' : ℕ}
    (hexV : ∃ r : ℕ, NextVOk A B u r)
    (hv : v' = nextV A B u)
    (hubot : bot A B < u)
    (hvbot : bot A B < v')
    (hule : u ≤ top A B) :
    ∃ r : ℕ, NextUOk A B v' r := by
  classical
  refine ⟨u - 1, ?_⟩
  have hprev :
      rowExt B (v' - 1) < rowExt A (u - 1) :=
    nextV_prev_lt_of_gt_bot A B hexV hv hvbot
  constructor
  · unfold bot at hubot ⊢
    omega
  constructor
  · unfold top at hule
    omega
  · exact hprev

/-- State invariant for the breakpoint construction.

For an active state `(u,v)`, the key invariant is

`rowExt B (v - 1) < rowExt A (u - 1)`,

which guarantees that `u - 1` is a valid candidate for the next `u`-breakpoint.
The remaining fields are interval bounds. -/
def StateInv
    (A B : MinorIndex m n t)
    (p : ℕ × ℕ) : Prop :=
  bot A B ≤ p.1 ∧ p.1 ≤ top A B ∧
  bot A B ≤ p.2 ∧ p.2 ≤ top A B ∧
  (bot A B < p.1 → bot A B < p.2 →
    rowExt B (p.2 - 1) < rowExt A (p.1 - 1))

/-- The initial breakpoint state satisfies the invariant. -/
lemma stateInv_initial
    (A B : MinorIndex m n t)
    (hC : Close A B)
    (hrowLt :
      rowExt B (uClose A B) < rowExt A (uClose A B)) :
    StateInv A B (top A B, top A B) := by
  classical
  have hsu : sClose A B < uClose A B :=
    sClose_lt_uClose A B hC.ne
  constructor
  · unfold bot top
    omega
  constructor
  · unfold top
    omega
  constructor
  · unfold bot top
    omega
  constructor
  · unfold top
    omega
  · intro _hu _hv
    simpa [top] using hrowLt

/-- At an active invariant state, the next `u` predicate is nonempty.

Candidate: `p.1 - 1`. -/
lemma nextU_exists_of_stateInv
    (A B : MinorIndex m n t)
    {p : ℕ × ℕ}
    (hInv : StateInv A B p)
    (hu : bot A B < p.1)
    (hv : bot A B < p.2) :
    ∃ r : ℕ, NextUOk A B p.2 r := by
  classical
  refine ⟨p.1 - 1, ?_⟩
  constructor
  · unfold StateInv at hInv
    unfold bot at hu ⊢
    omega
  constructor
  · unfold StateInv at hInv
    unfold top at hInv
    omega
  · exact hInv.2.2.2.2 hu hv

/-- If an invariant state is active, then `nextU` strictly decreases the `u`
coordinate. -/
lemma nextU_lt_oldU_of_stateInv
    (A B : MinorIndex m n t)
    {p : ℕ × ℕ}
    (hInv : StateInv A B p)
    (hu : bot A B < p.1)
    (hv : bot A B < p.2) :
    nextU A B p.2 < p.1 := by
  classical
  have hcand : NextUOk A B p.2 (p.1 - 1) := by
    constructor
    · have hp1_bot : bot A B ≤ p.1 := hInv.1
      unfold bot at hp1_bot hu ⊢
      omega
    constructor
    · have hp1_top : p.1 ≤ top A B := hInv.2.1
      unfold top at hp1_top
      omega
    · exact hInv.2.2.2.2 hu hv
  have hex : ∃ r : ℕ, NextUOk A B p.2 r :=
    ⟨p.1 - 1, hcand⟩
  have hle :
      nextU A B p.2 ≤ p.1 - 1 :=
    nextU_min_of_exists A B hex hcand
  omega

/-- One active step preserves the state invariant and strictly decreases both
coordinates unless it stops at `(bot,bot)`.

This is the main local transition lemma for the finite-descent proof. -/
lemma step_preserves_or_hits
    (A B : MinorIndex m n t)
    {p : ℕ × ℕ}
    (hInv : StateInv A B p)
    (hu : bot A B < p.1)
    (hv : bot A B < p.2) :
    step A B p = (bot A B, bot A B) ∨
      (StateInv A B (step A B p) ∧
        bot A B < (step A B p).1 ∧
        bot A B < (step A B p).2 ∧
        (step A B p).1 < p.1 ∧
        (step A B p).2 < p.2) := by
  classical
  let u' : ℕ := nextU A B p.2
  have hexU : ∃ r : ℕ, NextUOk A B p.2 r :=
    nextU_exists_of_stateInv A B hInv hu hv
  have hUok : NextUOk A B p.2 u' := by
    simpa [u'] using nextU_spec_of_exists A B hexU
  have hu'_lt_old : u' < p.1 := by
    simpa [u'] using nextU_lt_oldU_of_stateInv A B hInv hu hv
  by_cases hUbot : u' = bot A B
  · left
    simp [step, u', hUbot]
  · have hUbot_lt : bot A B < u' := by
      have hle : bot A B ≤ u' := hUok.1
      exact lt_of_le_of_ne hle (by
        intro h
        exact hUbot h.symm)
    have hvle : p.2 ≤ top A B := hInv.2.2.2.1
    have hexV : ∃ r : ℕ, NextVOk A B u' r :=
      nextV_exists_after_nextU
        A B
        (v := p.2)
        (u := u')
        hexU
        (by rfl)
        hv
        hUbot_lt
        hvle
    let v' : ℕ := nextV A B u'
    have hVok : NextVOk A B u' v' := by
      simpa [v'] using nextV_spec_of_exists A B hexV
    have hcand : NextVOk A B u' (p.2 - 1) := by
      have hprev :
          rowExt A (u' - 1) ≤ rowExt B (p.2 - 1) :=
        nextU_prev_le_of_gt_bot
          A B
          (v := p.2)
          (u := u')
          hexU
          (by rfl)
          hUbot_lt
      constructor
      · unfold bot at hv ⊢
        omega
      constructor
      · unfold top at hvle
        omega
      · exact hprev
    have hv'_lt_old : v' < p.2 := by
      simpa [v'] using
        nextV_lt_oldV
          A B
          (u := u')
          (v := p.2)
          hexV
          hcand
          hv
    by_cases hVbot : v' = bot A B
    · left
      simp [step, u', hUbot, v', hVbot]
    · have hVbot_lt : bot A B < v' := by
        have hle : bot A B ≤ v' := hVok.1
        exact lt_of_le_of_ne hle (by
          intro h
          exact hVbot h.symm)
      have hstep : step A B p = (u', v') := by
        simp [step, u', hUbot, v', hVbot]
      right
      change
        StateInv A B (step A B p) ∧
          bot A B < (step A B p).1 ∧
          bot A B < (step A B p).2 ∧
          (step A B p).1 < p.1 ∧
          (step A B p).2 < p.2
      rw [hstep]
      change
        StateInv A B (u', v') ∧
          bot A B < u' ∧
          bot A B < v' ∧
          u' < p.1 ∧
          v' < p.2
      constructor
      · unfold StateInv
        constructor
        · exact hUok.1
        constructor
        · have hu'_le_uClose : u' ≤ uClose A B := hUok.2.1
          unfold top
          omega
        constructor
        · exact hVok.1
        constructor
        · have hv'_le_uClose : v' ≤ uClose A B := hVok.2.1
          unfold top
          omega
        · intro _huActive hvActive
          exact
            nextV_prev_lt_of_gt_bot
              A B
              (u := u')
              (v' := v')
              hexV
              (by rfl)
              hvActive
      constructor
      · exact hUbot_lt
      constructor
      · exact hVbot_lt
      constructor
      · exact hu'_lt_old
      · exact hv'_lt_old

/-- Before the first hit, the breakpoint sequence is active and decreases by
at least one at each step. -/
lemma seq_active_bound_before_hit
    (A B : MinorIndex m n t)
    (hC : Close A B)
    (hrowLt :
      rowExt B (uClose A B) < rowExt A (uClose A B)) :
    ∀ r : ℕ,
      (∀ s ≤ r, ¬ hitBot A B s) →
        StateInv A B (seq A B r) ∧
        bot A B < uSeq A B r ∧
        bot A B < vSeq A B r ∧
        uSeq A B r + r ≤ top A B ∧
        vSeq A B r + r ≤ top A B := by
  classical
  intro r
  induction r with
  | zero =>
      intro hno
      have hInv0 :
          StateInv A B (seq A B 0) := by
        simpa [seq] using stateInv_initial A B hC hrowLt
      have hsu : sClose A B < uClose A B :=
        sClose_lt_uClose A B hC.ne
      refine ⟨hInv0, ?_, ?_, ?_, ?_⟩
      · simp [uSeq, seq, bot, top]
        omega
      · simp [vSeq, seq, bot, top]
        omega
      · simp [uSeq, seq]
      · simp [vSeq, seq]
    | succ r ih =>
      intro hno
      have hno_r : ∀ s ≤ r, ¬ hitBot A B s := by
        intro s hs
        exact hno s (Nat.le_trans hs (Nat.le_succ r))
      rcases ih hno_r with
        ⟨hInv, huActive, hvActive, huBound, hvBound⟩
      have hstep :=
        step_preserves_or_hits
          (A := A) (B := B)
          (p := seq A B r)
          hInv huActive hvActive
      rcases hstep with hhit | hnext
      · exfalso
        have hhit_succ : hitBot A B (r + 1) := by
          unfold hitBot uSeq vSeq
          simp [seq, hhit]
        exact hno (r + 1) (by omega) hhit_succ
      · have hInvNext :
            StateInv A B (step A B (seq A B r)) :=
          hnext.1
        have huNextActive :
            bot A B < (step A B (seq A B r)).1 :=
          hnext.2.1
        have hvNextActive :
            bot A B < (step A B (seq A B r)).2 :=
          hnext.2.2.1
        have huDec :
            (step A B (seq A B r)).1 < (seq A B r).1 :=
          hnext.2.2.2.1
        have hvDec :
            (step A B (seq A B r)).2 < (seq A B r).2 :=
          hnext.2.2.2.2
        have huDec' : uSeq A B (r + 1) < uSeq A B r := by
          simpa [uSeq, seq] using huDec
        have hvDec' : vSeq A B (r + 1) < vSeq A B r := by
          simpa [vSeq, seq] using hvDec
        refine ⟨?_, ?_, ?_, ?_, ?_⟩
        · simpa [seq] using hInvNext
        · simpa [uSeq, seq] using huNextActive
        · simpa [vSeq, seq] using hvNextActive
        · omega
        · omega

/-- The breakpoint iteration hits `(bot,bot)` in finitely many steps. -/
lemma exists_hitBot_seq
    (A B : MinorIndex m n t)
    (hC : Close A B)
    (hrowLt :
      rowExt B (uClose A B) < rowExt A (uClose A B)) :
    ∃ q : ℕ, hitBot A B q ∧
      ∀ r < q, ¬ hitBot A B r := by
  classical
  have hex : ∃ q : ℕ, hitBot A B q := by
    by_contra hnone_exists
    have hnone : ∀ q : ℕ, ¬ hitBot A B q := by
      intro q hq
      exact hnone_exists ⟨q, hq⟩
    let R : ℕ := top A B - bot A B + 1
    have hbound :=
      seq_active_bound_before_hit
        A B hC hrowLt R
        (by
          intro s _hs
          exact hnone s)
    rcases hbound with
      ⟨_hInvR, huActiveR, _hvActiveR, huBoundR, _hvBoundR⟩
    have hsu : sClose A B < uClose A B :=
      sClose_lt_uClose A B hC.ne
    have hbotTop : bot A B ≤ top A B := by
      unfold bot top
      omega
    have hcontr :
        ¬ (bot A B < uSeq A B R ∧
          uSeq A B R + R ≤ top A B) := by
      unfold R
      unfold bot top
      omega
    exact hcontr ⟨huActiveR, huBoundR⟩
  let q : ℕ := Nat.find hex
  refine ⟨q, ?_, ?_⟩
  · exact Nat.find_spec hex
  · intro r hr hhit
    have hle : q ≤ r := by
      change Nat.find hex ≤ r
      exact Nat.find_le hhit
    omega

/-- The `u`-sequence extracted from the breakpoint iteration up to a given
hitting time. -/
noncomputable def prefixU
    (A B : MinorIndex m n t)
    (q : ℕ) :
    Fin (q + 1) → ℕ :=
  fun i => uSeq A B i.1

/-- The `v`-sequence extracted from the breakpoint iteration up to a given
hitting time. -/
noncomputable def prefixV
    (A B : MinorIndex m n t)
    (q : ℕ) :
    Fin (q + 1) → ℕ :=
  fun i => vSeq A B i.1

/-- A generic helper: if a natural-number sequence strictly decreases at every
adjacent step before `q`, then it strictly decreases across any two indices
`i < j ≤ q`. -/
lemma nat_lt_of_adjacent_decrease
    {q : ℕ} {f : ℕ → ℕ}
    (hadj : ∀ r : ℕ, r < q → f (r + 1) < f r)
    {i j : ℕ}
    (hij : i < j)
    (hj : j ≤ q) :
    f j < f i := by
  have hle : i + 1 ≤ j := Nat.succ_le_of_lt hij
  rcases Nat.exists_eq_add_of_le hle with ⟨d, rfl⟩
  revert hj
  induction d with
  | zero =>
      intro hj
      simpa [Nat.add_assoc] using hadj i (by omega)
  | succ d ih =>
      intro hj
      have hprev : f (i + 1 + d) < f i := ih (by omega) (by omega) (by omega)
      have hstep : f (i + 1 + (d + 1)) < f (i + 1 + d) := by
        have hr : i + 1 + d < q := by omega
        simpa [Nat.add_assoc, Nat.add_comm, Nat.add_left_comm] using
          hadj (i + 1 + d) hr
      exact lt_trans hstep hprev

/-- Basic data extracted from the first hitting prefix:
endpoints, strict decrease, and bounds.

This is pure bookkeeping from:
* `seq 0 = (top, top)`;
* `hitBot q`;
* minimality of `q`;
* `step_preserves_or_hits`;
* `seq_active_bound_before_hit`.

It contains no determinant-specific argument. -/
lemma breakpoint_prefix_basic_of_first_hit
    (A B : MinorIndex m n t)
    (hC : Close A B)
    (hrowLt :
      rowExt B (uClose A B) < rowExt A (uClose A B))
    (q : ℕ)
    (hhit : hitBot A B q)
    (hmin : ∀ r < q, ¬ hitBot A B r) :
    prefixU A B q 0 = top A B ∧
    prefixV A B q 0 = top A B ∧
    prefixU A B q ⟨q, Nat.lt_succ_self q⟩ = bot A B ∧
    prefixV A B q ⟨q, Nat.lt_succ_self q⟩ = bot A B ∧
    (∀ {i j : Fin (q + 1)}, i < j →
      prefixU A B q j < prefixU A B q i) ∧
    (∀ {i j : Fin (q + 1)}, i < j →
      prefixV A B q j < prefixV A B q i) ∧
    (∀ i : Fin (q + 1),
      bot A B ≤ prefixU A B q i ∧ prefixU A B q i ≤ top A B) ∧
    (∀ i : Fin (q + 1),
      bot A B ≤ prefixV A B q i ∧ prefixV A B q i ≤ top A B) := by
  classical
  have hbotTop : bot A B ≤ top A B := by
    have hsu : sClose A B < uClose A B :=
      sClose_lt_uClose A B hC.ne
    unfold bot top
    omega
  have hadjU :
      ∀ r : ℕ, r < q → uSeq A B (r + 1) < uSeq A B r := by
    intro r hr
    have hno_r : ∀ s ≤ r, ¬ hitBot A B s := by
      intro s hs
      exact hmin s (by omega)
    rcases
      seq_active_bound_before_hit
        A B hC hrowLt r hno_r with
      ⟨hInv, huActive, hvActive, _huBound, _hvBound⟩
    have hstep :=
      step_preserves_or_hits
        (A := A) (B := B)
        (p := seq A B r)
        hInv huActive hvActive
    rcases hstep with hhitStep | hnext
    · have hUbot : uSeq A B (r + 1) = bot A B := by
        unfold uSeq
        simp [seq, hhitStep]
      rw [hUbot]
      exact huActive
    · have huDec :
          (step A B (seq A B r)).1 < (seq A B r).1 :=
        hnext.2.2.2.1
      simpa [uSeq, seq] using huDec
  have hadjV :
      ∀ r : ℕ, r < q → vSeq A B (r + 1) < vSeq A B r := by
    intro r hr
    have hno_r : ∀ s ≤ r, ¬ hitBot A B s := by
      intro s hs
      exact hmin s (by omega)
    rcases
      seq_active_bound_before_hit
        A B hC hrowLt r hno_r with
      ⟨hInv, huActive, hvActive, _huBound, _hvBound⟩
    have hstep :=
      step_preserves_or_hits
        (A := A) (B := B)
        (p := seq A B r)
        hInv huActive hvActive
    rcases hstep with hhitStep | hnext
    · have hVbot : vSeq A B (r + 1) = bot A B := by
        unfold vSeq
        simp [seq, hhitStep]
      rw [hVbot]
      exact hvActive
    · have hvDec :
          (step A B (seq A B r)).2 < (seq A B r).2 :=
        hnext.2.2.2.2
      simpa [vSeq, seq] using hvDec
  have huStrict :
      ∀ {i j : Fin (q + 1)}, i < j →
        prefixU A B q j < prefixU A B q i := by
    intro i j hij
    have hijNat : i.1 < j.1 := Fin.lt_def.mp hij
    have hjle : j.1 ≤ q := by
      have hjlt : j.1 < q + 1 := j.2
      omega
    simpa [prefixU] using
      nat_lt_of_adjacent_decrease
        (q := q) (f := uSeq A B) hadjU hijNat hjle
  have hvStrict :
      ∀ {i j : Fin (q + 1)}, i < j →
        prefixV A B q j < prefixV A B q i := by
    intro i j hij
    have hijNat : i.1 < j.1 := Fin.lt_def.mp hij
    have hjle : j.1 ≤ q := by
      have hjlt : j.1 < q + 1 := j.2
      omega
    simpa [prefixV] using
      nat_lt_of_adjacent_decrease
        (q := q) (f := vSeq A B) hadjV hijNat hjle
  have huBounds :
      ∀ i : Fin (q + 1),
        bot A B ≤ prefixU A B q i ∧
          prefixU A B q i ≤ top A B := by
    intro i
    by_cases hiq : i.1 = q
    · have hU : prefixU A B q i = bot A B := by
        simpa [prefixU, hiq] using hhit.1
      rw [hU]
      exact ⟨le_rfl, hbotTop⟩
    · have hi_lt : i.1 < q := by
        have hi_le : i.1 ≤ q := by
          have hi_lt_succ : i.1 < q + 1 := i.2
          omega
        omega
      have hno_i : ∀ s ≤ i.1, ¬ hitBot A B s := by
        intro s hs
        exact hmin s (by omega)
      rcases
        seq_active_bound_before_hit
          A B hC hrowLt i.1 hno_i with
        ⟨hInv, _huActive, _hvActive, _huBound, _hvBound⟩
      exact ⟨hInv.1, hInv.2.1⟩
  have hvBounds :
      ∀ i : Fin (q + 1),
        bot A B ≤ prefixV A B q i ∧
          prefixV A B q i ≤ top A B := by
    intro i
    by_cases hiq : i.1 = q
    · have hV : prefixV A B q i = bot A B := by
        simpa [prefixV, hiq] using hhit.2
      rw [hV]
      exact ⟨le_rfl, hbotTop⟩
    · have hi_lt : i.1 < q := by
        have hi_le : i.1 ≤ q := by
          have hi_lt_succ : i.1 < q + 1 := i.2
          omega
        omega
      have hno_i : ∀ s ≤ i.1, ¬ hitBot A B s := by
        intro s hs
        exact hmin s (by omega)
      rcases
        seq_active_bound_before_hit
          A B hC hrowLt i.1 hno_i with
        ⟨hInv, _huActive, _hvActive, _huBound, _hvBound⟩
      exact ⟨hInv.2.2.1, hInv.2.2.2.1⟩
  exact
    ⟨by simp [prefixU, uSeq, seq],
     by simp [prefixV, vSeq, seq],
     by simpa [prefixU] using hhit.1,
     by simpa [prefixV] using hhit.2,
     huStrict,
     hvStrict,
     huBounds,
     hvBounds⟩

/-- Initial top-row inequality for the breakpoint chain:
`rowExt A (top - 1) ≤ rowExt B top`.

This is the `i = 0` case of `row_B_top_ge_A_top`. -/
lemma initial_rowTop_le
    (A B : MinorIndex m n t)
    (hC : Close A B) :
    rowExt A (top A B - 1) ≤ rowExt B (top A B) := by
  classical
  have hu_le_t : uClose A B ≤ t :=
    le_trans (uClose_le_pClose A B hC.ne) (pClose_le A B)
  have hsu : sClose A B < uClose A B :=
    sClose_lt_uClose A B hC.ne
  by_cases hlast : uClose A B < t
  · have hAstep :
        rowExt A (uClose A B) < rowExt A (uClose A B + 1) := by
      exact rowExt_step_lt A (by omega) hlast
    have htail :
        rowExt A (uClose A B + 1) =
          rowExt B (uClose A B + 1) := by
      have hp :
          pairExt A (uClose A B + 1) =
            pairExt B (uClose A B + 1) := by
        exact pairExt_eq_of_mu_eq_right_gt_u
          A B hC.ne hC.mu_eq_right (by omega) (by omega)
      exact congrArg Prod.fst hp
    have hlt :
        rowExt A (uClose A B) <
          rowExt B (uClose A B + 1) := by
      simpa [htail] using hAstep
    simpa [top] using le_of_lt hlt
  · have hu_eq_t : uClose A B = t := by omega
    have hu_pos : 0 < uClose A B := by omega
    have hA_le_m : rowExt A (uClose A B) ≤ m :=
      ClosePairStrictBlock.rowExt_le_m_of_pos_le A hu_pos hu_le_t
    have hB_sentinel :
        rowExt B (uClose A B + 1) = m + 1 := by
      unfold rowExt
      simp [hu_eq_t]
    rw [show top A B = uClose A B + 1 by rfl, hB_sentinel]
    exact le_trans hA_le_m (Nat.le_succ m)


/-- If `u` is still above `bot`, then `nextV u` is also above `bot`.

This rules out the bad mixed terminal state where `v` reaches `bot` but `u`
does not. -/
lemma nextV_gt_bot_of_u_gt_bot
    (A B : MinorIndex m n t)
    (_hC : Close A B)
    (hrowLt :
      rowExt B (uClose A B) < rowExt A (uClose A B))
    {u : ℕ}
    (hexV : ∃ r : ℕ, NextVOk A B u r)
    (hubot : bot A B < u)
    (hule : u ≤ top A B) :
    bot A B < nextV A B u := by
  classical
  have hVok : NextVOk A B u (nextV A B u) :=
    nextV_spec_of_exists A B hexV
  have hbot_le : bot A B ≤ nextV A B u := hVok.1
  by_contra hnot
  have hv_eq : nextV A B u = bot A B := by omega
  have hA_le_Bbot :
      rowExt A (u - 1) ≤ rowExt B (bot A B) := by
    simpa [hv_eq] using hVok.2.2
  have hu_pred_lo : sClose A B + 1 ≤ u - 1 := by
    unfold bot at hubot
    omega
  have hu_pred_hi : u - 1 ≤ uClose A B := by
    unfold top at hule
    omega
  have hrow_chain :
      rowExt B (u - 1) < rowExt A (u - 1) :=
    close_row_chain_of_uClose_row_lt
      A B hrowLt (u - 1) hu_pred_lo hu_pred_hi
  have hmonoB : Monotone (rowExt B) := rowExt_monotone B
  have hBbot_le :
      rowExt B (bot A B) ≤ rowExt B (u - 1) := by
    exact hmonoB hu_pred_lo
  have hstrict :
      rowExt B (bot A B) < rowExt A (u - 1) :=
    lt_of_le_of_lt hBbot_le hrow_chain
  exact (not_le_of_gt hstrict) hA_le_Bbot


/-- Row-top inequality for every non-final prefix state. -/
lemma prefix_rowTop_before_hit
    (A B : MinorIndex m n t)
    (hC : Close A B)
    (hrowLt :
      rowExt B (uClose A B) < rowExt A (uClose A B))
    (q : ℕ)
    (_hhit : hitBot A B q)
    (hmin : ∀ r < q, ¬ hitBot A B r) :
    ∀ r : ℕ, r < q →
      rowExt A (uSeq A B r - 1) ≤ rowExt B (vSeq A B r) := by
  classical
  intro r hr
  induction r with
  | zero =>
      simpa [uSeq, vSeq, seq] using initial_rowTop_le A B hC
  | succ r ih =>
      have hr_prev : r < q := by omega
      have hrowTop_prev :
          rowExt A (uSeq A B r - 1) ≤ rowExt B (vSeq A B r) :=
        ih hr_prev
      have hno_r : ∀ s ≤ r, ¬ hitBot A B s := by
        intro s hs
        exact hmin s (by omega)
      rcases
        seq_active_bound_before_hit A B hC hrowLt r hno_r with
        ⟨hInv, huActive, hvActive, _huBound, _hvBound⟩
      have hstep :=
        step_preserves_or_hits
          (A := A) (B := B)
          (p := seq A B r)
          hInv huActive hvActive
      rcases hstep with hhitStep | hnext
      · exfalso
        have hhit_succ : hitBot A B (r + 1) := by
          unfold hitBot uSeq vSeq
          simp [seq, hhitStep]
        exact hmin (r + 1) (by omega) hhit_succ
      · /-
        In the non-hit branch, the next state is produced by `nextV`, so
        its row-top inequality is exactly `NextVOk.2.2`.
        We unfold the step once instead of trying to extract this from
        `StateInv`.
        -/
        let p : ℕ × ℕ := seq A B r
        let u' : ℕ := nextU A B p.2
        have hp_eq : p = seq A B r := rfl
        have hexU : ∃ x : ℕ, NextUOk A B p.2 x := by
          subst p
          exact nextU_exists_of_stateInv A B hInv huActive hvActive
        have hUok : NextUOk A B p.2 u' := by
          simpa [u'] using nextU_spec_of_exists A B hexU
        have hUbot_lt : bot A B < u' := by
          by_contra hnot
          have hUbot : u' = bot A B := by
            have hle : bot A B ≤ u' := hUok.1
            omega
          have hstep_hit : step A B p = (bot A B, bot A B) := by
            simp [step, u', hUbot]
          have hhit_succ : hitBot A B (r + 1) := by
            unfold hitBot uSeq vSeq
            subst p
            simp [seq, hstep_hit]
          exact hmin (r + 1) (by omega) hhit_succ
        have hvle : p.2 ≤ top A B := by
          subst p
          exact hInv.2.2.2.1
        have hexV : ∃ x : ℕ, NextVOk A B u' x :=
          nextV_exists_after_nextU
            A B
            (v := p.2)
            (u := u')
            hexU
            (by rfl)
            (by
              subst p
              exact hvActive)
            hUbot_lt
            hvle
        have hVbot_lt : bot A B < nextV A B u' :=
          nextV_gt_bot_of_u_gt_bot
            A B hC hrowLt hexV hUbot_lt
            (by
              have hu'_le : u' ≤ uClose A B := hUok.2.1
              unfold top
              omega)
        have hstep_pair :
            step A B p = (u', nextV A B u') := by
          simp only [step, u']
          have hUnbot : ¬ u' = bot A B := by
            exact ne_of_gt hUbot_lt
          have hVnbot : ¬ nextV A B u' = bot A B := by
            exact ne_of_gt hVbot_lt
          simp_all only [imp_self, ↓reduceIte, p, u']
        have hVok : NextVOk A B u' (nextV A B u') :=
          nextV_spec_of_exists A B hexV
        have huseq :
            uSeq A B (r + 1) = u' := by
          unfold uSeq
          subst p
          simp [seq, hstep_pair]
        have hvseq :
            vSeq A B (r + 1) = nextV A B u' := by
          unfold vSeq
          subst p
          simp [seq, hstep_pair]
        rw [huseq, hvseq]
        exact hVok.2.2

/-- Row-field extraction from the first hitting prefix.

This packages exactly the three row inequalities required by `Case1UVChain`.
They come from the `nextU`/`nextV` minimality lemmas:
* `nextU_prev_le_of_gt_bot`;
* `nextU_interval`;
* `nextV_interval`.

The terminal step where the next state is `(bot,bot)` should be handled using
the same selector facts plus the definition of `step`. -/
lemma breakpoint_prefix_row_fields_of_first_hit
    (A B : MinorIndex m n t)
    (hC : Close A B)
    (hrowLt :
      rowExt B (uClose A B) < rowExt A (uClose A B))
    (q : ℕ)
    (hhit : hitBot A B q)
    (hmin : ∀ r < q, ¬ hitBot A B r) :
    (∀ i : Fin q,
      rowExt A (prefixU A B q i.castSucc - 1) ≤
        rowExt B (prefixV A B q i.castSucc)) ∧
    (∀ i : Fin q, ∀ j : ℕ,
      prefixU A B q i.succ ≤ j →
      j < prefixU A B q i.castSucc →
        rowExt B (prefixV A B q i.castSucc - 1) < rowExt A j) ∧
    (∀ i : Fin q, ∀ j : ℕ,
      prefixV A B q i.succ ≤ j →
      j < prefixV A B q i.castSucc →
        rowExt A (prefixU A B q i.succ - 1) ≤ rowExt B j) := by
  classical
  refine ⟨?rowTop, ?rowAint, ?rowBint⟩
  · intro i
    have hi : i.1 < q := i.2
    simpa [prefixU, prefixV] using
      prefix_rowTop_before_hit A B hC hrowLt q hhit hmin i.1 hi
  · intro i j hjlo hjhi
    let r : ℕ := i.1
    have hr : r < q := i.2
    have hno_r : ∀ s ≤ r, ¬ hitBot A B s := by
      intro s hs
      exact hmin s (by omega)
    rcases
      seq_active_bound_before_hit A B hC hrowLt r hno_r with
      ⟨hInv, huActive, hvActive, _huBound, _hvBound⟩
    let p : ℕ × ℕ := seq A B r
    let u' : ℕ := nextU A B p.2
    have hexU : ∃ x : ℕ, NextUOk A B p.2 x := by
      subst p
      exact nextU_exists_of_stateInv A B hInv huActive hvActive
    have hUok : NextUOk A B p.2 u' := by
      simpa [u'] using nextU_spec_of_exists A B hexU
    by_cases hUbot : u' = bot A B
    · have hstep_hit : step A B p = (bot A B, bot A B) := by
        simp [step, u', hUbot]
      have hi_succ_val : (i.succ : Fin (q + 1)).1 = r + 1 := by
        simp [r]
      have hu_succ_bot :
          prefixU A B q i.succ = bot A B := by
        unfold prefixU uSeq
        rw [hi_succ_val]
        simp [seq, p, hstep_hit]
      have hu_succ :
          prefixU A B q i.succ = u' := by
        rw [hu_succ_bot, hUbot]
      have hp2 :
          prefixV A B q i.castSucc = p.2 := by
        simp [prefixV, p, r]
        simp_all only [Fin.is_lt, Order.add_one_le_iff, u', p, r]
        obtain ⟨fst, snd⟩ := p
        obtain ⟨w, h⟩ := hexU
        rfl
      have hu_cur :
          prefixU A B q i.castSucc = p.1 := by
        simp [prefixU, p, r]
        simp_all only [Fin.is_lt, Order.add_one_le_iff, u', p, r]
        obtain ⟨fst, snd⟩ := p
        obtain ⟨w, h⟩ := hexU
        rfl
      have hjlo' : u' ≤ j := by
        simpa [hu_succ] using hjlo
      have hjhi' : j < p.1 := by
        simpa [hu_cur] using hjhi
      exact
        nextU_interval
          A B
          (v := p.2)
          (u := u')
          (_oldU := p.1)
          (j := j)
          hexU
          (by rfl)
          hjlo'
          (by
            have hbasic :=
              breakpoint_prefix_basic_of_first_hit
                A B hC hrowLt q hhit hmin
            rcases hbasic with
              ⟨_hu0, _hv0, _hulast, _hvlast,
                _huStrict, _hvStrict, huBounds, _hvBounds⟩
            have hjleTop : j < prefixU A B q i.castSucc := hjhi
            have htop := (huBounds i.castSucc).2
            unfold top at htop
            omega)
    · have hUbot_lt : bot A B < u' := by
        have hle : bot A B ≤ u' := hUok.1
        exact lt_of_le_of_ne hle (by intro h; exact hUbot h.symm)
      have hvle : p.2 ≤ top A B := by
        subst p
        exact hInv.2.2.2.1
      have hexV : ∃ x : ℕ, NextVOk A B u' x :=
        nextV_exists_after_nextU
          A B
          (v := p.2)
          (u := u')
          hexU
          (by rfl)
          (by
            subst p
            exact hvActive)
          hUbot_lt
          hvle
      have hVbot_lt : bot A B < nextV A B u' :=
        nextV_gt_bot_of_u_gt_bot
          A B hC hrowLt hexV hUbot_lt
          (by
            have hu'_le : u' ≤ uClose A B := hUok.2.1
            unfold top
            omega)
      have hstep_pair :
          step A B p = (u', nextV A B u') := by
        simp [step, u']
        have hUnbot : ¬ u' = bot A B := ne_of_gt hUbot_lt
        have hVnbot : ¬ nextV A B u' = bot A B := ne_of_gt hVbot_lt
        simp_all only [Fin.is_lt, not_false_eq_true, ↓reduceIte, r, p, u']
      have hu_succ :
          prefixU A B q i.succ = u' := by
        unfold prefixU uSeq
        simp [r, p, seq, hstep_pair]
      have hv_cur :
          prefixV A B q i.castSucc = p.2 := by
        simp [prefixV, p, r]
        simp_all only [Fin.is_lt, u', p, r]
        obtain ⟨fst, snd⟩ := p
        obtain ⟨w, h⟩ := hexU
        rfl
      have hu_cur :
          prefixU A B q i.castSucc = p.1 := by
        simp [prefixU, p, r]
        simp_all only [Fin.is_lt, u', p, r]
        obtain ⟨fst, snd⟩ := p
        obtain ⟨w, h⟩ := hexU
        rfl
      have hjlo' : u' ≤ j := by
        simpa [hu_succ] using hjlo
      have hjhi' : j < p.1 := by
        simpa [hu_cur] using hjhi
      simpa [hv_cur] using
        nextU_interval
          A B
          (v := p.2)
          (u := u')
          (_oldU := p.1)
          (j := j)
          hexU
          (by rfl)
          hjlo'
          (by
            have hbasic :=
              breakpoint_prefix_basic_of_first_hit
                A B hC hrowLt q hhit hmin
            rcases hbasic with
              ⟨_hu0, _hv0, _hulast, _hvlast,
                _huStrict, _hvStrict, huBounds, _hvBounds⟩
            have htop := (huBounds i.castSucc).2
            unfold top at htop
            omega)
  · intro i j hjlo hjhi
    let r : ℕ := i.1
    have hr : r < q := i.2
    have hno_r : ∀ s ≤ r, ¬ hitBot A B s := by
      intro s hs
      exact hmin s (by omega)
    rcases
      seq_active_bound_before_hit A B hC hrowLt r hno_r with
      ⟨hInv, huActive, hvActive, _huBound, _hvBound⟩
    let p : ℕ × ℕ := seq A B r
    let u' : ℕ := nextU A B p.2
    have hexU : ∃ x : ℕ, NextUOk A B p.2 x := by
      subst p
      exact nextU_exists_of_stateInv A B hInv huActive hvActive
    have hUok : NextUOk A B p.2 u' := by
      simpa [u'] using nextU_spec_of_exists A B hexU
    by_cases hUbot : u' = bot A B
    · have hUsucc :
          prefixU A B q i.succ = bot A B := by
        unfold prefixU uSeq
        simp [r, p, seq, step, u', hUbot]
      rw [hUsucc]
      have hsSpec : sPred A B (sClose A B) :=
        sClose_spec A B hC.ne
      have hA_s_lt_B_bot :
          rowExt A (bot A B - 1) < rowExt B (bot A B) := by
        simpa [bot] using hsSpec.2.1
      have hmonoB : Monotone (rowExt B) := rowExt_monotone B
      have hbot_le_j : bot A B ≤ j := by
        have hbasic :=
          breakpoint_prefix_basic_of_first_hit
            A B hC hrowLt q hhit hmin
        rcases hbasic with
          ⟨_hu0, _hv0, _hulast, _hvlast,
            _huStrict, _hvStrict, _huBounds, hvBounds⟩
        exact le_trans (hvBounds i.succ).1 hjlo
      exact le_trans (le_of_lt hA_s_lt_B_bot) (hmonoB hbot_le_j)
    · have hUbot_lt : bot A B < u' := by
        have hle : bot A B ≤ u' := hUok.1
        exact lt_of_le_of_ne hle (by intro h; exact hUbot h.symm)
      have hvle : p.2 ≤ top A B := by
        subst p
        exact hInv.2.2.2.1
      have hexV : ∃ x : ℕ, NextVOk A B u' x :=
        nextV_exists_after_nextU
          A B
          (v := p.2)
          (u := u')
          hexU
          (by rfl)
          (by
            subst p
            exact hvActive)
          hUbot_lt
          hvle
      let v' : ℕ := nextV A B u'
      have hVbot_lt : bot A B < v' :=
        nextV_gt_bot_of_u_gt_bot
          A B hC hrowLt hexV hUbot_lt
          (by
            have hu'_le : u' ≤ uClose A B := hUok.2.1
            unfold top
            omega)
      have hstep_pair :
          step A B p = (u', v') := by
        simp [step, u', v']
        have hUnbot : ¬ u' = bot A B := ne_of_gt hUbot_lt
        have hVnbot : ¬ v' = bot A B := ne_of_gt hVbot_lt
        simp_all only [Fin.is_lt, not_false_eq_true, ↓reduceIte, r, p, u', v']
      have hu_succ :
          prefixU A B q i.succ = u' := by
        unfold prefixU uSeq
        simp [r, p, seq, hstep_pair]
      have hv_succ :
          prefixV A B q i.succ = v' := by
        unfold prefixV vSeq
        simp [r, p, seq, hstep_pair]
      have hjlo' : v' ≤ j := by
        simpa [hv_succ] using hjlo
      simpa [hu_succ] using
        nextV_interval
          A B
          (u := u')
          (v' := v')
          (j := j)
          hexV
          (by rfl)
          hjlo'
          (by
            have hbasic :=
              breakpoint_prefix_basic_of_first_hit
                A B hC hrowLt q hhit hmin
            rcases hbasic with
              ⟨_hu0, _hv0, _hulast, _hvlast,
                _huStrict, _hvStrict, _huBounds, hvBounds⟩
            have htop := (hvBounds i.castSucc).2
            unfold top at htop
            omega)

/-- Column consequence of the Case 1 orientation.

If two middle positions satisfy
`rowExt A i ≤ rowExt B j`, then necessarily
`colExt A i < colExt B j`.

This is the reusable column bridge for the breakpoint-chain construction. -/
lemma close_case1_col_A_lt_B_of_row_le
    (A B : MinorIndex m n t)
    (hC : Close A B)
    (hrowLt :
      rowExt B (uClose A B) < rowExt A (uClose A B))
    {i j : ℕ}
    (hi₁ : sClose A B + 1 ≤ i)
    (hi₂ : i ≤ uClose A B)
    (hj₁ : sClose A B + 1 ≤ j)
    (hj₂ : j ≤ uClose A B)
    (hrow : rowExt A i ≤ rowExt B j) :
    colExt A i < colExt B j := by
  classical
  by_cases hij : i < j
  · have hi_lt_u : i < uClose A B := by
      omega
    have hchain :
        colExt A i < colExt A (i + 1) ∧
          colExt A (i + 1) ≤ colExt B i :=
      close_col_chain_of_uClose_row_lt A B hC hrowLt i hi₁ hi_lt_u
    have hmonoB : Monotone (colExt B) := colExt_monotone B
    have hBi_le_Bj : colExt B i ≤ colExt B j :=
      hmonoB (Nat.le_of_lt hij)
    exact lt_of_lt_of_le hchain.1 (le_trans hchain.2 hBi_le_Bj)
  · have hji : j ≤ i := by omega
    have hrowj :
        rowExt B j < rowExt A j :=
      close_row_chain_of_uClose_row_lt A B hrowLt j hj₁ hj₂
    have hmonoA : Monotone (rowExt A) := rowExt_monotone A
    have hAj_le_Ai : rowExt A j ≤ rowExt A i :=
      hmonoA hji
    have hstrict : rowExt B j < rowExt A i :=
      lt_of_lt_of_le hrowj hAj_le_Ai
    exact False.elim ((not_le_of_gt hstrict) hrow)


/-- Boundary version of `close_case1_col_A_lt_B_of_row_le`, allowing the
right-hand `B` index to be the top sentinel `uClose + 1`. -/
lemma close_case1_col_A_lt_B_of_row_le_top
    (A B : MinorIndex m n t)
    (hC : Close A B)
    (hrowLt :
      rowExt B (uClose A B) < rowExt A (uClose A B))
    {i j : ℕ}
    (hi₁ : sClose A B + 1 ≤ i)
    (hi₂ : i ≤ uClose A B)
    (hj₁ : sClose A B + 1 ≤ j)
    (hj₂ : j ≤ top A B)
    (hrow : rowExt A i ≤ rowExt B j) :
    colExt A i < colExt B j := by
  classical
  by_cases hjtop : j = top A B
  · have hsucc_le : i + 1 ≤ j := by
      unfold top at hjtop
      omega
    have hbase :
        colExt A i < colExt B (i + 1) := by
      by_cases hiu : i < uClose A B
      · have hchain :
            colExt A i < colExt A (i + 1) ∧
              colExt A (i + 1) ≤ colExt B i :=
          close_col_chain_of_uClose_row_lt A B hC hrowLt i hi₁ hiu
        have hmonoB : Monotone (colExt B) := colExt_monotone B
        have hBi_le_Bsucc : colExt B i ≤ colExt B (i + 1) :=
          hmonoB (by omega)
        exact lt_of_lt_of_le hchain.1 (le_trans hchain.2 hBi_le_Bsucc)
      · have hi_eq_u : i = uClose A B := by omega
        subst hi_eq_u
        by_cases hlast : uClose A B < t
        · have hAstep :
              colExt A (uClose A B) <
                colExt A (uClose A B + 1) := by
            exact colExt_step_lt A
              (by
                have hsu : sClose A B < uClose A B :=
                  sClose_lt_uClose A B hC.ne
                omega)
              hlast
          have htail :
              colExt A (uClose A B + 1) =
                colExt B (uClose A B + 1) := by
            have hp :
                pairExt A (uClose A B + 1) =
                  pairExt B (uClose A B + 1) := by
              exact pairExt_eq_of_mu_eq_right_gt_u
                A B hC.ne hC.mu_eq_right (by omega) (by omega)
            exact congrArg Prod.snd hp
          simpa [htail] using hAstep
        · have hu_le_t : uClose A B ≤ t :=
            le_trans (uClose_le_pClose A B hC.ne) (pClose_le A B)
          have hu_eq_t : uClose A B = t := by omega
          have hu_pos : 0 < uClose A B := by
            have hsu : sClose A B < uClose A B :=
              sClose_lt_uClose A B hC.ne
            omega
          have hA_le_n : colExt A (uClose A B) ≤ n :=
            ClosePairStrictBlock.colExt_le_n_of_pos_le A hu_pos hu_le_t
          have hB_sentinel :
              colExt B (uClose A B + 1) = n + 1 := by
            unfold colExt
            simp [hu_eq_t]
          rw [hB_sentinel]
          exact lt_of_le_of_lt hA_le_n (Nat.lt_succ_self n)
    have hmonoB : Monotone (colExt B) := colExt_monotone B
    exact lt_of_lt_of_le hbase (hmonoB hsucc_le)
  · have hj₂' : j ≤ uClose A B := by
      have hltTop : j < top A B :=
        lt_of_le_of_ne hj₂ hjtop
      unfold top at hltTop
      exact Nat.lt_succ_iff.mp hltTop
    exact close_case1_col_A_lt_B_of_row_le
      A B hC hrowLt hi₁ hi₂ hj₁ hj₂' hrow


/-- Boundary version for the lower `A` index `u - 1`.

If `u = bot`, this is exactly the defining column inequality at `sClose`.
Otherwise it reduces to `close_case1_col_A_lt_B_of_row_le_top`. -/
lemma close_case1_col_A_pred_lt_B_of_row_le
    (A B : MinorIndex m n t)
    (hC : Close A B)
    (hrowLt :
      rowExt B (uClose A B) < rowExt A (uClose A B))
    {u j : ℕ}
    (hu₁ : bot A B ≤ u)
    (hu₂ : u ≤ top A B)
    (hj₁ : bot A B ≤ j)
    (hj₂ : j ≤ uClose A B)
    (hrow : rowExt A (u - 1) ≤ rowExt B j) :
    colExt A (u - 1) < colExt B j := by
  classical
  by_cases hubot : u = bot A B
  · have hsSpec : sPred A B (sClose A B) :=
      sClose_spec A B hC.ne
    have hbase :
        colExt A (bot A B - 1) < colExt B (bot A B) := by
      simpa [bot] using hsSpec.2.2
    have hmonoB : Monotone (colExt B) := colExt_monotone B
    have hbot_le_j : bot A B ≤ j := hj₁
    simpa [hubot] using
      lt_of_lt_of_le hbase (hmonoB hbot_le_j)
  · have hi₁ : sClose A B + 1 ≤ u - 1 := by
      unfold bot at hu₁ hubot
      omega
    have hi₂ : u - 1 ≤ uClose A B := by
      unfold top at hu₂
      omega
    exact close_case1_col_A_lt_B_of_row_le
      A B hC hrowLt
      hi₁ hi₂
      (by simpa [bot] using hj₁)
      hj₂
      hrow

/-- Column-field extraction from the first hitting prefix.

Unlike the row fields, these do not follow from the `nextU`/`nextV` minimality
alone. They are the column part of Lemma 1.4(iv), transported over the
breakpoint intervals. -/
lemma breakpoint_prefix_col_fields_of_first_hit
    (A B : MinorIndex m n t)
    (hC : Close A B)
    (hrowLt :
      rowExt B (uClose A B) < rowExt A (uClose A B))
    (q : ℕ)
    (hhit : hitBot A B q)
    (hmin : ∀ r < q, ¬ hitBot A B r) :
    (∀ i : Fin q, ∀ j : ℕ,
      prefixU A B q i.succ ≤ j →
      j < prefixU A B q i.castSucc →
        colExt A j < colExt B (prefixV A B q i.castSucc)) ∧
    (∀ i : Fin q, ∀ j : ℕ,
      prefixV A B q i.succ ≤ j →
      j < prefixV A B q i.castSucc →
        colExt A (prefixU A B q i.succ - 1) < colExt B j) := by
  classical
  rcases
    breakpoint_prefix_basic_of_first_hit
      A B hC hrowLt q hhit hmin with
    ⟨_hu0, _hv0, _hulast, _hvlast,
      _huStrict, _hvStrict, huBounds, hvBounds⟩
  rcases
    breakpoint_prefix_row_fields_of_first_hit
      A B hC hrowLt q hhit hmin with
    ⟨hrowTop, _hrowAint, hrowBint⟩
  refine ⟨?hcolTop, ?hcolInt⟩
  · intro i j hjlo hjhi
    have hj_bot : bot A B ≤ j := by
      exact le_trans (huBounds i.succ).1 hjlo
    have hj_u : j ≤ uClose A B := by
      have hcurTop : prefixU A B q i.castSucc ≤ top A B :=
        (huBounds i.castSucc).2
      unfold top at hcurTop
      omega
    have hv_bot : bot A B ≤ prefixV A B q i.castSucc :=
      (hvBounds i.castSucc).1
    have hv_top : prefixV A B q i.castSucc ≤ top A B :=
      (hvBounds i.castSucc).2
    have hj_le_pred :
        j ≤ prefixU A B q i.castSucc - 1 := by
      omega
    have hrow_j_le_top :
        rowExt A j ≤ rowExt A (prefixU A B q i.castSucc - 1) := by
      have hmonoA : Monotone (rowExt A) := rowExt_monotone A
      exact hmonoA hj_le_pred
    have hrow :
        rowExt A j ≤ rowExt B (prefixV A B q i.castSucc) :=
      le_trans hrow_j_le_top (hrowTop i)
    exact
      close_case1_col_A_lt_B_of_row_le_top
        A B hC hrowLt
        (by simpa [bot] using hj_bot)
        hj_u
        (by simpa [bot] using hv_bot)
        hv_top
        hrow
  · intro i j hjlo hjhi
    have hu_bot : bot A B ≤ prefixU A B q i.succ :=
      (huBounds i.succ).1
    have hu_top : prefixU A B q i.succ ≤ top A B :=
      (huBounds i.succ).2
    have hj_bot : bot A B ≤ j := by
      exact le_trans (hvBounds i.succ).1 hjlo
    have hj_u : j ≤ uClose A B := by
      have hcurTop : prefixV A B q i.castSucc ≤ top A B :=
        (hvBounds i.castSucc).2
      unfold top at hcurTop
      omega
    have hrow :
        rowExt A (prefixU A B q i.succ - 1) ≤ rowExt B j :=
      hrowBint i j hjlo hjhi
    exact
      close_case1_col_A_pred_lt_B_of_row_le
        A B hC hrowLt
        hu_bot
        hu_top
        hj_bot
        hj_u
        hrow

/-- The finite-descent theorem for the breakpoint iteration.

This is the only genuinely order-theoretic missing piece: prove by induction
on `top - bot` that iterating `step` from `(top,top)` eventually reaches
`(bot,bot)`, and before the hitting time the fields required by
`Case1UVChain` are satisfied.

Do not replace this with the adjacent full chain.  This theorem is the
formal version of the paper's “let `u_i,v_i` be the unique integers satisfying
(2.1.6)” construction.
-/
theorem breakpoint_chain_exists
    (A B : MinorIndex m n t)
    (hC : Close A B)
    (hrowLt :
      rowExt B (uClose A B) < rowExt A (uClose A B)) :
    ∃ q : ℕ,
    ∃ u v : Fin (q + 1) → ℕ,
      u 0 = top A B ∧
      v 0 = top A B ∧
      u ⟨q, Nat.lt_succ_self q⟩ = bot A B ∧
      v ⟨q, Nat.lt_succ_self q⟩ = bot A B ∧
      (∀ {i j : Fin (q + 1)}, i < j → u j < u i) ∧
      (∀ {i j : Fin (q + 1)}, i < j → v j < v i) ∧
      (∀ i : Fin (q + 1), bot A B ≤ u i ∧ u i ≤ top A B) ∧
      (∀ i : Fin (q + 1), bot A B ≤ v i ∧ v i ≤ top A B) ∧
      (∀ i : Fin q,
        rowExt A (u i.castSucc - 1) ≤ rowExt B (v i.castSucc)) ∧
      (∀ i : Fin q, ∀ j : ℕ,
        u i.succ ≤ j → j < u i.castSucc →
          rowExt B (v i.castSucc - 1) < rowExt A j) ∧
      (∀ i : Fin q, ∀ j : ℕ,
        v i.succ ≤ j → j < v i.castSucc →
          rowExt A (u i.succ - 1) ≤ rowExt B j) ∧
      (∀ i : Fin q, ∀ j : ℕ,
        u i.succ ≤ j → j < u i.castSucc →
          colExt A j < colExt B (v i.castSucc)) ∧
      (∀ i : Fin q, ∀ j : ℕ,
        v i.succ ≤ j → j < v i.castSucc →
          colExt A (u i.succ - 1) < colExt B j) := by
  classical
  rcases exists_hitBot_seq A B hC hrowLt with
    ⟨q, hhit, hmin⟩
  refine ⟨q, prefixU A B q, prefixV A B q, ?_⟩
  rcases
    breakpoint_prefix_basic_of_first_hit
      A B hC hrowLt q hhit hmin with
    ⟨hu0, hv0, hulast, hvlast,
      huStrict, hvStrict, huBounds, hvBounds⟩
  rcases
    breakpoint_prefix_row_fields_of_first_hit
      A B hC hrowLt q hhit hmin with
    ⟨hrowTop, hrowAint, hrowBint⟩
  rcases
    breakpoint_prefix_col_fields_of_first_hit
      A B hC hrowLt q hhit hmin with
    ⟨hcolTop, hcolInt⟩
  exact
    ⟨hu0, hv0, hulast, hvlast,
      huStrict, hvStrict,
      huBounds, hvBounds,
      hrowTop, hrowAint, hrowBint,
      hcolTop, hcolInt⟩

end Case1Breakpoint

theorem closePairThm21_case1_exists_uv_chain
    (A B : MinorIndex m n t)
    (hC : Close A B)
    (hrowLt :
      rowExt B (uClose A B) < rowExt A (uClose A B)) :
    Nonempty (Case1UVChain A B hC) := by
  classical
  rcases Case1Breakpoint.breakpoint_chain_exists A B hC hrowLt with
    ⟨q, u, v,
      hu0, hv0, hulast, hvlast,
      huStrict, hvStrict, huBounds, hvBounds,
      hrowTop, hrowAint, hrowBint, hcolTop, hcolInt⟩
  exact ⟨
    { q := q
      u := u
      v := v
      u_zero := by simpa [Case1Breakpoint.top] using hu0
      v_zero := by simpa [Case1Breakpoint.top] using hv0
      u_last := by simpa [Case1Breakpoint.bot] using hulast
      v_last := by simpa [Case1Breakpoint.bot] using hvlast
      u_strict := by
        intro i j hij
        exact huStrict hij
      v_strict := by
        intro i j hij
        exact hvStrict hij
      u_bounds := by
        intro i
        simpa [Case1Breakpoint.bot, Case1Breakpoint.top] using huBounds i
      v_bounds := by
        intro i
        simpa [Case1Breakpoint.bot, Case1Breakpoint.top] using hvBounds i
      row_B_top_ge_A_top := hrowTop
      row_A_interval_gt_B_pred := hrowAint
      row_B_interval_ge_A_lower_pred := hrowBint
      col_B_top_gt_A_interval := hcolTop
      col_B_interval_gt_A_lower_pred := hcolInt }⟩

/-! ### Case 1 fixed-chain induction, paper route

In the paper, Case 1 does **not** first prove a global endpoint-divisibility
statement and then extract statements (a), (b), and (c).  Instead, under the
non-smallness assumption

  `¬ rowTermExp < headLcm`

one directly runs the `u_i / v_i` induction from (2.1.6), proving the three
statements:

* (a) the indicated `B` rows occur in the cofactor row set;
* (b) the indicated `A` diagonal rows occur in the selected minor;
* (c) the indicated `B` diagonal variables occur in the cofactor monomial.

The previous contrapositive lemmas

  `closePairThm21_case1_lt_of_missing_A_endpoint`
  `closePairThm21_case1_lt_of_missing_B_endpoint`

and the bridge

  `closePairThm21_case1_endpoint_sup_le_rowTermExp_of_chain_not_lt`

are intentionally removed from the main route, because they reorganize the
paper proof in the reverse direction.
-/

/-- The inductive Case 1 step along a fixed `u_i/v_i` chain.

This is the direct formal counterpart of the paper's Case 1 induction after
(2.1.6).  From the non-smallness assumption `hnot`, one proves statements
(a), (b), and (c) along the fixed chain `U`, and also extracts the final
consequence needed later: every principal `A` row position is selected by the
row minor.

This theorem is now the single hard bridge in the Case 1 route.  It should be
proved directly from `hnot`, `hdiag`, `hc`, and the inequalities stored in
`U : Case1UVChain A B hC`; it should **not** call an endpoint-divisibility
lemma first. -/
theorem closePairThm21_case1_uv_induction_step
    (ord : MonomialOrder (Fin m × Fin n))
    (hdiag : IsDiagonalTermOrder ord)
    (A B : MinorIndex m n t)
    (hC : Close A B)
    (hrowLt :
      rowExt B (uClose A B) < rowExt A (uClose A B))
    (L : ClosePairStrictBlock.RowLaplaceChoice A B hC)
    (σ : Equiv.Perm (Fin (ClosePairStrictBlock.width A B)))
    (hc :
      (closePairThm21_case1_rowTerm
        (m := m) (n := n) (t := t) (k := k) A B hC L σ).c ≠ 0)
    (hnot :
      ¬ ord.toSyn
          (closePairThm21_case1_rowTermExp
            (m := m) (n := n) (t := t) (k := k) A B hC L σ)
        <
        ord.toSyn
          (headLcm ord
            (genericMinor (k := k) A)
            (genericMinor (k := k) B)))
    (U : Case1UVChain A B hC) :
      (∀ i : Fin U.q, StatementA A B hC L U i) ∧
      (∀ i : Fin U.q, StatementB A B hC L U i) ∧
      (∀ i : Fin U.q, StatementC A B hC L σ U i) ∧
      (∀ i : Fin t, ∃ j : Fin t,
        L.minorRows j = ClosePairStrictBlock.aColumnPos A B hC i) := by
  classical

  /-
  This is the place where the paper's actual induction should be formalized.

  Paper correspondence:

  * `U.u`, `U.v` encode the sequences

      u₀, ..., u_q ; v₀, ..., v_q

    from (2.1.6).

  * `StatementA A B hC L U i` is paper statement (a):
      the rows α'_{v_i-1}, ..., α'_{v_{i+1}}
      occur in the cofactor row set γ*.

  * `StatementB A B hC L U i` is paper statement (b):
      the variables X_{α_j β_j} for
      u_{i+1} ≤ j < u_i
      occur in the selected minor `D(γ,β)`.

  * `StatementC A B hC L σ U i` is paper statement (c):
      the variables X_{α'_j β'_j} for
      v_{i+1} ≤ j < v_i
      occur in the cofactor monomial `φ`.

  The proof should be by induction over the chain index `i : Fin U.q`.
  The induction step uses:
    - the nonzero-term hypothesis `hc`, to rule out zero-block terms;
    - the diagonal-order hypothesis `hdiag`, to turn failure of (b)/(c) into
      strict smallness, contradicting `hnot`;
    - the row/column inequalities stored in `U`.
  -/

  rcases
    closePairThm21_case1_all_statements
      (m := m) (n := n) (t := t) (k := k)
      ord hdiag A B hC hrowLt L σ hc hnot U with
    ⟨hB, hCstmt, hA⟩


  have hall :
      ∀ i : Fin t, ∃ j : Fin t,
        L.minorRows j = ClosePairStrictBlock.aColumnPos A B hC i := by
    intro idx
    by_cases hpre : idx.1 < sClose A B
    · /-
      Prefix positions are forced into the selected minor by the same
      zero-block argument used earlier for prefix `A` rows.
      -/
      sorry
    · by_cases hmid_lt : idx.1 < uClose A B
      · exact
          closePairThm21_case1_middle_aColumnPos_mem_minorRows_of_all_statementB
            (m := m) (n := n) (t := t) A B hC L U hB idx
            ⟨le_of_not_gt hpre, hmid_lt⟩
      · /-
        Tail positions are forced into the selected minor by the tail
        zero-block argument.
        -/
        sorry

  exact ⟨hA, hB, hCstmt, hall⟩

/-- The paper-specific Case 1 `u_i/v_i` induction layer.

This theorem is intentionally the only unfinished bridge used by
`closePairThm21_case1_diagExp_A_le_rowTermExp_of_not_lt`: it constructs the
chain from (2.1.6), proves statements (a), (b), and (c) along the chain, and
extracts that all principal `A` positions are selected by the row minor. -/
theorem closePairThm21_case1_uv_induction
    (ord : MonomialOrder (Fin m × Fin n))
    (hdiag : IsDiagonalTermOrder ord)
    (A B : MinorIndex m n t)
    (hC : Close A B)
    (hrowLt :
      rowExt B (uClose A B) < rowExt A (uClose A B))
    (L : ClosePairStrictBlock.RowLaplaceChoice A B hC)
    (σ : Equiv.Perm (Fin (ClosePairStrictBlock.width A B)))
    (hc :
      (closePairThm21_case1_rowTerm
        (m := m) (n := n) (t := t) (k := k) A B hC L σ).c ≠ 0)
    (hnot :
      ¬ ord.toSyn
          (closePairThm21_case1_rowTermExp
            (m := m) (n := n) (t := t) (k := k) A B hC L σ)
        <
        ord.toSyn
          (headLcm ord
            (genericMinor (k := k) A)
            (genericMinor (k := k) B))) :
    ∃ U : Case1UVChain A B hC,
      (∀ i : Fin U.q, StatementA A B hC L U i) ∧
      (∀ i : Fin U.q, StatementB A B hC L U i) ∧
      (∀ i : Fin U.q, StatementC A B hC L σ U i) ∧
      (∀ i : Fin t, ∃ j : Fin t,
        L.minorRows j = ClosePairStrictBlock.aColumnPos A B hC i) := by
  classical
  rcases closePairThm21_case1_exists_uv_chain A B hC hrowLt with ⟨U⟩
  refine ⟨U, ?_⟩
  exact
    closePairThm21_case1_uv_induction_step
      (m := m) (n := n) (t := t) (k := k)
      ord hdiag A B hC hrowLt L σ hc hnot U

end case1_uv_induction

/-- Case 1 paper auxiliary lemma, specialized to the row term.

If the Case 1 displayed monomial is not smaller than the endpoint lcm, then
the diagonal monomial of `A` divides that displayed exponent. -/
lemma closePairThm21_case1_diagExp_A_le_rowTermExp_of_not_lt
    (ord : MonomialOrder (Fin m × Fin n))
    (hdiag : IsDiagonalTermOrder ord)
    (A B : MinorIndex m n t)
    (hC : Close A B)
    (hrowLt :
      rowExt B (uClose A B) < rowExt A (uClose A B))
    (L : ClosePairStrictBlock.RowLaplaceChoice A B hC)
    (σ : Equiv.Perm (Fin (ClosePairStrictBlock.width A B)))
    (hc :
      (closePairThm21_case1_rowTerm
        (m := m) (n := n) (t := t) (k := k) A B hC L σ).c ≠ 0)
    (hnot :
      ¬ ord.toSyn
          (closePairThm21_case1_rowTermExp
            (m := m) (n := n) (t := t) (k := k) A B hC L σ)
        <
        ord.toSyn
          (headLcm ord
            (genericMinor (k := k) A)
            (genericMinor (k := k) B))) :
    diagExp A ≤
      closePairThm21_case1_rowTermExp
        (m := m) (n := n) (t := t) (k := k) A B hC L σ := by
  classical
  have hAllApos :
      ∀ i : Fin t, ∃ j : Fin t,
        L.minorRows j = ClosePairStrictBlock.aColumnPos A B hC i := by
    rcases closePairThm21_case1_uv_induction
        (m := m) (n := n) (t := t) (k := k)
        ord hdiag A B hC hrowLt L σ hc hnot with
      ⟨_U, _hA, _hB, _hC, hAll⟩
    exact hAll
  /-
  Convert membership of all principal A positions into equality of selected
  rows with the principal A positions.
  -/
  have hminorRows :
      L.minorRows =
        fun i : Fin t => ClosePairStrictBlock.aColumnPos A B hC i :=
    closePairThm21_case1_minorRows_eq_aColumnPos_of_mem
      (m := m) (n := n) (t := t) A B hC L hAllApos
  /-
  Every diagonal variable of `A` occurs in the diagonal monomial of
  `L.minorIndex`.
  -/
  have hdiagMinor :
      ∀ i : Fin t,
        diagExp L.minorIndex (A.row i, A.col i) = 1 := by
    intro i
    rw [diagExp_apply]
    refine if_pos ?_
    refine ⟨i, ?_, ?_⟩
    · calc
        L.minorIndex.row i =
            ClosePairStrictBlock.rowFin A B hC (L.minorRows i) :=
          ClosePairStrictBlock.RowLaplaceChoice.minorIndex_row L i
        _ =
            ClosePairStrictBlock.rowFin A B hC
              (ClosePairStrictBlock.aColumnPos A B hC i) := by
          rw [congrFun hminorRows i]
        _ = A.row i := by
          exact ClosePairStrictBlock.rowFin_aColumnPos A B hC i
    · simp [ClosePairStrictBlock.RowLaplaceChoice.minorIndex_col]
  /-
  Therefore every diagonal variable of `A` occurs in the whole Case 1
  row-term exponent.
  -/
  have htermDiag :
      ∀ i : Fin t,
        1 ≤
          closePairThm21_case1_rowTermExp
            (m := m) (n := n) (t := t) (k := k) A B hC L σ
            (A.row i, A.col i) := by
    intro i
    rw [closePairThm21_case1_rowTermExp_eq]
    have hdiag := hdiagMinor i
    have h :
        1 ≤
          (MonomialCoefficientMatrix.permExp
              L.cofactorRow L.cofactorCol σ
              (A.row i, A.col i) +
            diagExp L.minorIndex (A.row i, A.col i)) := by
      rw [hdiag]
      omega
    simpa [Pi.add_apply] using h
  /-
  Final pointwise proof of `diagExp A ≤ rowTermExp`.
  -/
  intro x
  rw [diagExp_apply]
  by_cases hx :
      ∃ i : Fin t, A.row i = x.1 ∧ A.col i = x.2
  · rw [if_pos hx]
    rcases hx with ⟨i, hrowx, hcolx⟩
    have hxpair : x = (A.row i, A.col i) := by
      cases x
      simp only [Prod.mk.injEq] at hrowx hcolx ⊢
      exact ⟨hrowx.symm, hcolx.symm⟩
    simpa [hxpair] using htermDiag i
  · rw [if_neg hx]
    exact Nat.zero_le _

/-- If the Case 1 row term is not small, then the `i`-th diagonal variable of
`A` occurs in the displayed exponent. -/
lemma closePairThm21_case1_A_diag_coord_pos_of_not_lt
    (ord : MonomialOrder (Fin m × Fin n))
    (hdiag : IsDiagonalTermOrder ord)
    (A B : MinorIndex m n t)
    (hC : Close A B)
    (hrowLt :
      rowExt B (uClose A B) < rowExt A (uClose A B))
    (L : ClosePairStrictBlock.RowLaplaceChoice A B hC)
    (σ : Equiv.Perm (Fin (ClosePairStrictBlock.width A B)))
    (hc :
      (closePairThm21_case1_rowTerm
        (m := m) (n := n) (t := t) (k := k) A B hC L σ).c ≠ 0)
    (hnot :
      ¬ ord.toSyn
          (closePairThm21_case1_rowTermExp
            (m := m) (n := n) (t := t) (k := k) A B hC L σ)
        <
        ord.toSyn
          (headLcm ord
            (genericMinor (k := k) A)
            (genericMinor (k := k) B)))
    (i : Fin t) :
    1 ≤
      closePairThm21_case1_rowTermExp
        (m := m) (n := n) (t := t) (k := k) A B hC L σ
        (A.row i, A.col i) := by
  classical
  have hle :
      diagExp A ≤
        closePairThm21_case1_rowTermExp
          (m := m) (n := n) (t := t) (k := k) A B hC L σ :=
    closePairThm21_case1_diagExp_A_le_rowTermExp_of_not_lt
      (m := m) (n := n) (t := t) (k := k)
      ord hdiag A B hC hrowLt L σ hc hnot
  have hA :
      diagExp A (A.row i, A.col i) = 1 := by
    rw [diagExp_apply]
    exact if_pos ⟨i, rfl, rfl⟩
  simpa [hA] using hle (A.row i, A.col i)

/-- Prefix version: from the Case 1 core auxiliary statement, the prefix
principal `A` position is selected by the row minor. -/
lemma closePairThm21_case1_A_prefix_pos_mem_minorRows_of_not_lt
    (ord : MonomialOrder (Fin m × Fin n))
    (hdiag : IsDiagonalTermOrder ord)
    (A B : MinorIndex m n t)
    (hC : Close A B)
    (hrowLt :
      rowExt B (uClose A B) < rowExt A (uClose A B))
    (L : ClosePairStrictBlock.RowLaplaceChoice A B hC)
    (σ : Equiv.Perm (Fin (ClosePairStrictBlock.width A B)))
    (hc :
      (closePairThm21_case1_rowTerm
        (m := m) (n := n) (t := t) (k := k) A B hC L σ).c ≠ 0)
    (hnot :
      ¬ ord.toSyn
          (closePairThm21_case1_rowTermExp
            (m := m) (n := n) (t := t) (k := k) A B hC L σ)
        <
        ord.toSyn
          (headLcm ord
            (genericMinor (k := k) A)
            (genericMinor (k := k) B)))
    (i : Fin t)
    (hi : i.1 < sClose A B) :
    ∃ j : Fin t, L.minorRows j = ClosePairStrictBlock.aColumnPos A B hC i := by
  classical
  have hcof :
      MonomialCoefficientMatrix.permExp
          L.cofactorRow L.cofactorCol σ (A.row i, A.col i) = 0 :=
