/-- Since `minorRows` and `cofactorRows` form the two sides of the row-choice
shuffle, and no cofactor row can be a repeated `A`-middle position, every
repeated `A`-middle position must occur among the minor rows. -/
lemma closePairThm21_case1_exists_minorRows_eq_aRepeatedMiddlePos
    (A B : MinorIndex m n t)
    (hC : Close A B)
    (L : ClosePairStrictBlock.RowLaplaceChoice A B hC)
    (σ : Equiv.Perm (Fin (ClosePairStrictBlock.width A B)))
    (hc :
      (closePairThm21_case1_rowTerm
        (m := m) (n := n) (t := t) (k := k) A B hC L σ).c ≠ 0)
    (r : Fin (ClosePairStrictBlock.width A B)) :
    ∃ i : Fin t,
      L.minorRows i = ClosePairStrictBlock.aRepeatedMiddlePos A B hC r := by
  classical
  let q : Fin (ClosePairStrictBlock.size A B) :=
    ClosePairStrictBlock.aRepeatedMiddlePos A B hC r
  let y : Fin t ⊕ Fin (ClosePairStrictBlock.width A B) :=
    L.shuffle.symm q
  have hy : L.shuffle y = q := by
    simp [y]
  cases hcase : y with
  | inl i =>
      refine ⟨i, ?_⟩
      rw [L.minorRows_eq_shuffle i]
      simpa [q, hcase] using hy
  | inr j =>
      exfalso
      have hcof :
          L.cofactorRows j = ClosePairStrictBlock.aRepeatedMiddlePos A B hC r := by
        rw [L.cofactorRows_eq_shuffle j]
        simpa [q, hcase] using hy
      exact
        closePairThm21_case1_cofactorRows_ne_aRepeatedMiddlePos
          (m := m) (n := n) (t := t) (k := k)
          A B hC L σ hc j r hcof

