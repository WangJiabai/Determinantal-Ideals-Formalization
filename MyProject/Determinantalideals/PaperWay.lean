lemma ClosePairStrictBlock.eq_aColumnPos_of_rowFin_eq_A_tail
    (A B : MinorIndex m n t)
    (hC : Close A B)
    (_hrowLt :
      rowExt B (uClose A B) < rowExt A (uClose A B))
    (i : Fin t)
    (hi : uClose A B ≤ i.1)
