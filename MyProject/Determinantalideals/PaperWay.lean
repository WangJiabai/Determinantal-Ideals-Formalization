/-- The middle `B` block as a genuine minor index. -/
noncomputable def bMiddleMinorIndex
    (A B : MinorIndex m n t)
    (hC : Close A B) :
    MinorIndex m n (width A B) :=
  { row := strictMonoToOrderEmbedding
      (fun i : Fin (width A B) => rowFin A B hC (bMiddlePos A B hC i))
      (rowFin_bMiddlePos_strictMono A B hC)
    col := strictMonoToOrderEmbedding
      (fun i : Fin (width A B) => colFin A B hC (bMiddlePos A B hC i))
      (colFin_bMiddlePos_strictMono A B hC) }

/-- The repeated middle `A` block as a genuine minor index. -/
noncomputable def aRepeatedMiddleMinorIndex
    (A B : MinorIndex m n t)
    (hC : Close A B) :
    MinorIndex m n (width A B) :=
  { row := strictMonoToOrderEmbedding
      (fun i : Fin (width A B) =>
        rowFin A B hC (aRepeatedMiddlePos A B hC i))
      (rowFin_aRepeatedMiddlePos_strictMono A B hC)
    col := strictMonoToOrderEmbedding
      (fun i : Fin (width A B) =>
        colFin A B hC (aRepeatedMiddlePos A B hC i))
      (colFin_aRepeatedMiddlePos_strictMono A B hC) }

@[simp] lemma bMiddleMinorIndex_row
    (A B : MinorIndex m n t)
    (hC : Close A B)
    (i : Fin (width A B)) :
    (bMiddleMinorIndex A B hC).row i =
      rowFin A B hC (bMiddlePos A B hC i) := rfl

@[simp] lemma bMiddleMinorIndex_col
    (A B : MinorIndex m n t)
    (hC : Close A B)
    (i : Fin (width A B)) :
    (bMiddleMinorIndex A B hC).col i =
      colFin A B hC (bMiddlePos A B hC i) := rfl

lemma bMiddleMinorIndex_coord_of_middle
    (A B : MinorIndex m n t)
    (hC : Close A B)
    (b : Fin t)
    (hb_s : sClose A B ≤ b.1)
    (hb_u : b.1 < uClose A B) :
    ∃ rb : Fin (width A B),
      (bMiddleMinorIndex A B hC).row rb = B.row b ∧
      (bMiddleMinorIndex A B hC).col rb = B.col b := by
  classical
  let rb : Fin (width A B) :=
    ⟨b.1 - sClose A B, by
      simp [width]
      omega⟩
  have hb_eq :
      (⟨sClose A B + rb.1, by
        have hu : uClose A B ≤ t :=
          le_trans (uClose_le_pClose A B hC.ne) (pClose_le A B)
        simp [rb]
        omega⟩ : Fin t) = b := by
    apply Fin.ext
    simp [rb]
    omega
  refine ⟨rb, ?_, ?_⟩
  · rw [bMiddleMinorIndex_row, rowFin_bMiddlePos]
    rw [hb_eq]
  · rw [bMiddleMinorIndex_col, colFin_bMiddlePos]
    rw [hb_eq]

@[simp] lemma aRepeatedMiddleMinorIndex_row
    (A B : MinorIndex m n t)
    (hC : Close A B)
    (i : Fin (width A B)) :
    (aRepeatedMiddleMinorIndex A B hC).row i =
      rowFin A B hC (aRepeatedMiddlePos A B hC i) := rfl

@[simp] lemma aRepeatedMiddleMinorIndex_col
    (A B : MinorIndex m n t)
    (hC : Close A B)
    (i : Fin (width A B)) :
    (aRepeatedMiddleMinorIndex A B hC).col i =
      colFin A B hC (aRepeatedMiddlePos A B hC i) := rfl

lemma bBlock_permExp_eq_middle_permExp_symm
    (A B : MinorIndex m n t)
    (hC : Close A B)
    (σ : Equiv.Perm (Fin (width A B))) :
    MonomialCoefficientMatrix.permExp
        (fun i : Fin (width A B) => rowFin A B hC (bMiddlePos A B hC i))
        (fun i : Fin (width A B) => colFin A B hC (bMiddlePos A B hC i))
        σ =
      permExp (bMiddleMinorIndex A B hC) σ.symm := by
  classical
  unfold MonomialCoefficientMatrix.permExp permExp
  let f : Fin (width A B) → (Fin m × Fin n) →₀ ℕ :=
    fun j =>
      Finsupp.single
        ((bMiddleMinorIndex A B hC).row j,
          (bMiddleMinorIndex A B hC).col (σ.symm j)) 1
  calc
    (∑ j : Fin (width A B),
      Finsupp.single
        (rowFin A B hC (bMiddlePos A B hC (σ j)),
          colFin A B hC (bMiddlePos A B hC j)) 1)
        =
      ∑ j : Fin (width A B), f (σ j) := by
        refine Finset.sum_congr rfl ?_
        intro j _hj
        simp [f]
    _ =
      ∑ j : Fin (width A B), f j := by
        exact
          Fintype.sum_equiv σ
            (fun j : Fin (width A B) => f (σ j))
            f
            (by intro j; rfl)

lemma cBlock_permExp_eq_middle_permExp_symm
    (A B : MinorIndex m n t)
    (hC : Close A B)
    (σ : Equiv.Perm (Fin (width A B))) :
    MonomialCoefficientMatrix.permExp
        (fun i : Fin (width A B) =>
          rowFin A B hC (aRepeatedMiddlePos A B hC i))
        (fun i : Fin (width A B) =>
          colFin A B hC (aRepeatedMiddlePos A B hC i))
        σ =
      permExp (aRepeatedMiddleMinorIndex A B hC) σ.symm := by
  classical
  unfold MonomialCoefficientMatrix.permExp permExp
  let f : Fin (width A B) → (Fin m × Fin n) →₀ ℕ :=
    fun j =>
      Finsupp.single
        ((aRepeatedMiddleMinorIndex A B hC).row j,
          (aRepeatedMiddleMinorIndex A B hC).col (σ.symm j)) 1
  calc
    (∑ j : Fin (width A B),
      Finsupp.single
        (rowFin A B hC (aRepeatedMiddlePos A B hC (σ j)),
          colFin A B hC (aRepeatedMiddlePos A B hC j)) 1)
        =
      ∑ j : Fin (width A B), f (σ j) := by
        refine Finset.sum_congr rfl ?_
        intro j _hj
        simp [f]
    _ =
      ∑ j : Fin (width A B), f j := by
        exact
          Fintype.sum_equiv σ
            (fun j : Fin (width A B) => f (σ j))
            f
            (by intro j; rfl)

lemma exists_bMiddlePos_of_B_diag_not_A
    (A B : MinorIndex m n t)
    (hC : Close A B)
    {a : Fin m} {b : Fin n}
    (hB : ∃ j : Fin t, B.row j = a ∧ B.col j = b)
    (hA : ¬ ∃ j : Fin t, A.row j = a ∧ A.col j = b) :
    ∃ i : Fin (width A B),
      rowFin A B hC (bMiddlePos A B hC i) = a ∧
        colFin A B hC (bMiddlePos A B hC i) = b := by
  rcases hB with ⟨j, hjrow, hjcol⟩
  by_cases hprefix : j.1 < sClose A B
  · have hpEq :
        pairExt A (j.1 + 1) = pairExt B (j.1 + 1) := by
      exact pairExt_eq_of_mu_eq_right_le_s
        A B hC.ne hC.mu_eq_right (by omega) (by omega)
    have hj₂ : j.1 + 1 ≤ t := by omega
    rw [EndpointSelection.pairExt_endpoint (I := A) (by omega) hj₂,
      EndpointSelection.pairExt_endpoint (I := B) (by omega) hj₂] at hpEq
    have hidx : (⟨j.1 + 1 - 1, by omega⟩ : Fin t) = j := by
      apply Fin.ext
      simp
    rw [hidx] at hpEq
    have hrow : A.row j = a := by
      apply Fin.ext
      have hval := congrArg Prod.fst hpEq
      omega
    have hcol : A.col j = b := by
      apply Fin.ext
      have hval := congrArg Prod.snd hpEq
      omega
    exact (hA ⟨j, hrow, hcol⟩).elim
  · by_cases hmid : j.1 < uClose A B
    · let i : Fin (width A B) := ⟨j.1 - sClose A B, by
        simp only [width]
        omega⟩
      refine ⟨i, ?_, ?_⟩
      · rw [rowFin_bMiddlePos A B hC i]
        have hidx :
            (⟨sClose A B + i.1, by
              have hi : i.1 < uClose A B - sClose A B := by
                simpa [i, width] using i.2
              have hu : uClose A B ≤ t :=
                le_trans (uClose_le_pClose A B hC.ne) (pClose_le A B)
              omega⟩ : Fin t) = j := by
          have hi_val : i.1 = j.1 - sClose A B := rfl
          apply Fin.ext
          change sClose A B + i.1 = j.1
          rw [hi_val]
          omega
        rw [hidx]
        exact hjrow
      · rw [colFin_bMiddlePos A B hC i]
        have hidx :
            (⟨sClose A B + i.1, by
              have hi : i.1 < uClose A B - sClose A B := by
                simpa [i, width] using i.2
              have hu : uClose A B ≤ t :=
                le_trans (uClose_le_pClose A B hC.ne) (pClose_le A B)
              omega⟩ : Fin t) = j := by
          have hi_val : i.1 = j.1 - sClose A B := rfl
          apply Fin.ext
          change sClose A B + i.1 = j.1
          rw [hi_val]
          omega
        rw [hidx]
        exact hjcol
    · have hpEq :
          pairExt A (j.1 + 1) = pairExt B (j.1 + 1) := by
        exact pairExt_eq_of_mu_eq_right_gt_u
          A B hC.ne hC.mu_eq_right (by omega) (by omega)
      have hj₂ : j.1 + 1 ≤ t := by omega
      rw [EndpointSelection.pairExt_endpoint (I := A) (by omega) hj₂,
        EndpointSelection.pairExt_endpoint (I := B) (by omega) hj₂] at hpEq
      have hidx : (⟨j.1 + 1 - 1, by omega⟩ : Fin t) = j := by
        apply Fin.ext
        simp
      rw [hidx] at hpEq
      have hrow : A.row j = a := by
        apply Fin.ext
        have hval := congrArg Prod.fst hpEq
        omega
      have hcol : A.col j = b := by
        apply Fin.ext
        have hval := congrArg Prod.snd hpEq
        omega
      exact (hA ⟨j, hrow, hcol⟩).elim

lemma bBlock_identity_permExp_apply
    (A B : MinorIndex m n t)
    (hC : Close A B)
    (a : Fin m)
    (b : Fin n) :
    MonomialCoefficientMatrix.permExp
        (fun i : Fin (width A B) => rowFin A B hC (bMiddlePos A B hC i))
        (fun i : Fin (width A B) => colFin A B hC (bMiddlePos A B hC i))
        (1 : Equiv.Perm (Fin (width A B))) (a, b) =
      if ∃ i : Fin (width A B),
          rowFin A B hC (bMiddlePos A B hC i) = a ∧
            colFin A B hC (bMiddlePos A B hC i) = b
      then 1 else 0 := by
  simpa using
    MonomialCoefficientMatrix.permExp_apply_of_row_injective
      (m := m) (n := n) (q := width A B)
      (row := fun i : Fin (width A B) =>
        rowFin A B hC (bMiddlePos A B hC i))
      (col := fun i : Fin (width A B) =>
        colFin A B hC (bMiddlePos A B hC i))
      (σ := (1 : Equiv.Perm (Fin (width A B))))
      (rowFin_bMiddlePos_injective A B hC) a b

lemma bBlock_identity_permExp_eq_lcmQuotient_A
    (A B : MinorIndex m n t)
    (hC : Close A B) :
    MonomialCoefficientMatrix.permExp
        (fun i : Fin (width A B) => rowFin A B hC (bMiddlePos A B hC i))
        (fun i : Fin (width A B) => colFin A B hC (bMiddlePos A B hC i))
        (1 : Equiv.Perm (Fin (width A B))) =
      (diagExp A ⊔ diagExp B) - diagExp A := by
  classical
  ext x
  rcases x with ⟨a, b⟩
  rw [bBlock_identity_permExp_apply A B hC a b]
  change
    (if ∃ i : Fin (width A B),
        rowFin A B hC (bMiddlePos A B hC i) = a ∧
          colFin A B hC (bMiddlePos A B hC i) = b then 1 else 0) =
      ((diagExp A (a, b) ⊔ diagExp B (a, b)) - diagExp A (a, b))
  rw [diagExp_apply A a b, diagExp_apply B a b]
  by_cases hmid :
      ∃ i : Fin (width A B),
        rowFin A B hC (bMiddlePos A B hC i) = a ∧
          colFin A B hC (bMiddlePos A B hC i) = b
  · rcases hmid with ⟨i, hirow, hicol⟩
    have hmidWitness :
        ∃ i : Fin (width A B),
          rowFin A B hC (bMiddlePos A B hC i) = a ∧
            colFin A B hC (bMiddlePos A B hC i) = b :=
      ⟨i, hirow, hicol⟩
    have hBdiag :
        ∃ j : Fin t, B.row j = a ∧ B.col j = b := by
      refine ⟨⟨sClose A B + i.1, by
        have hi : i.1 < uClose A B - sClose A B := by
          simp only [width] at i
          exact i.2
        have hu : uClose A B ≤ t :=
          le_trans (uClose_le_pClose A B hC.ne) (pClose_le A B)
        omega⟩, ?_, ?_⟩
      · simpa [rowFin_bMiddlePos A B hC i] using hirow
      · simpa [colFin_bMiddlePos A B hC i] using hicol
    have hAzero :
        diagExp A (a, b) = 0 := by
      have hz := diagExp_A_apply_B_middle_eq_zero A B hC i
      have hrowB := hirow
      have hcolB := hicol
      rw [rowFin_bMiddlePos A B hC i] at hrowB
      rw [colFin_bMiddlePos A B hC i] at hcolB
      simpa [hrowB, hcolB] using hz
    have hAdiag :
        ¬ ∃ j : Fin t, A.row j = a ∧ A.col j = b := by
      intro hA
      have hAone : diagExp A (a, b) = 1 := by
        rw [diagExp_apply]
        exact if_pos hA
      omega
    simp [hmidWitness, hBdiag, hAdiag]
  · by_cases hAdiag : ∃ j : Fin t, A.row j = a ∧ A.col j = b
    · by_cases hBdiag : ∃ j : Fin t, B.row j = a ∧ B.col j = b
      · simp [hmid, hAdiag, hBdiag]
      · simp [hmid, hAdiag, hBdiag]
    · by_cases hBdiag : ∃ j : Fin t, B.row j = a ∧ B.col j = b
      · have hmid' :=
          exists_bMiddlePos_of_B_diag_not_A A B hC hBdiag hAdiag
        exact (hmid hmid').elim
      · simp [hmid, hAdiag, hBdiag]

lemma cBlock_identity_permExp_apply
    (A B : MinorIndex m n t)
    (hC : Close A B)
    (a : Fin m)
    (b : Fin n) :
    MonomialCoefficientMatrix.permExp
        (fun i : Fin (width A B) =>
          rowFin A B hC (aRepeatedMiddlePos A B hC i))
        (fun i : Fin (width A B) =>
          colFin A B hC (aRepeatedMiddlePos A B hC i))
        (1 : Equiv.Perm (Fin (width A B))) (a, b) =
      if ∃ i : Fin (width A B),
          rowFin A B hC (aRepeatedMiddlePos A B hC i) = a ∧
            colFin A B hC (aRepeatedMiddlePos A B hC i) = b
      then 1 else 0 := by
  simpa using
    MonomialCoefficientMatrix.permExp_apply_of_row_injective
      (m := m) (n := n) (q := width A B)
      (row := fun i : Fin (width A B) =>
        rowFin A B hC (aRepeatedMiddlePos A B hC i))
      (col := fun i : Fin (width A B) =>
        colFin A B hC (aRepeatedMiddlePos A B hC i))
      (σ := (1 : Equiv.Perm (Fin (width A B))))
      (rowFin_aRepeatedMiddlePos_injective A B hC) a b

/-- Positions of the `A`-columns
`beta_1, ..., beta_s, beta_{s+1}, ..., beta_u, beta_{u+1}, ..., beta_t`
inside the strict block matrix.  Together with `bMiddlePos`, these columns
partition the columns of the block matrix for the row-side Laplace expansion
`(2.1.3)`. -/
noncomputable def aColumnPos
    (A B : MinorIndex m n t)
    (hC : Close A B)
    (i : Fin t) :
    Fin (size A B) := by
  classical
  by_cases hprefix : i.1 < sClose A B
  · exact ⟨i.1, by
      have hs_lt_t : sClose A B < t :=
        lt_of_lt_of_le (sClose_lt_pClose A B hC.ne) (pClose_le A B)
      unfold size
      omega⟩
  · by_cases hmid : i.1 < uClose A B
    · exact ⟨uClose A B + (i.1 - sClose A B), by
        have hu_le_t : uClose A B ≤ t :=
          le_trans (uClose_le_pClose A B hC.ne) (pClose_le A B)
        unfold size width
        omega⟩
    · exact ⟨i.1 + width A B, by
        unfold size
        omega⟩

lemma aColumnPos_of_prefix
    (A B : MinorIndex m n t)
    (hC : Close A B)
    {i : Fin t}
    (hi : i.1 < sClose A B) :
    (aColumnPos A B hC i).1 = i.1 := by
  simp [aColumnPos, hi]

lemma aColumnPos_of_middle
    (A B : MinorIndex m n t)
    (hC : Close A B)
    {i : Fin t}
    (hs : ¬ i.1 < sClose A B)
    (hi : i.1 < uClose A B) :
    (aColumnPos A B hC i).1 = uClose A B + (i.1 - sClose A B) := by
  simp [aColumnPos, hs, hi]

lemma aColumnPos_of_tail
    (A B : MinorIndex m n t)
    (hC : Close A B)
    {i : Fin t}
    (hs : ¬ i.1 < sClose A B)
    (hu : ¬ i.1 < uClose A B) :
    (aColumnPos A B hC i).1 = i.1 + width A B := by
  simp [aColumnPos, hs, hu]

lemma rowCoord_aColumnPos
    (A B : MinorIndex m n t)
    (hC : Close A B)
    (i : Fin t) :
    rowCoord A B (aColumnPos A B hC i).1 = rowExt A (i.1 + 1) := by
  classical
  by_cases hs : i.1 < sClose A B
  · have hpos : (aColumnPos A B hC i).1 < sClose A B := by
      rw [aColumnPos_of_prefix A B hC hs]
      exact hs
    rw [rowCoord_of_prefix A B hpos]
    rw [aColumnPos_of_prefix A B hC hs]
  · by_cases hu : i.1 < uClose A B
    · have hrep :
          aRepeatedMiddle A B (aColumnPos A B hC i).1 := by
        rw [aColumnPos_of_middle A B hC hs hu]
        unfold aRepeatedMiddle width
        omega
      rw [rowCoord_of_aRepeatedMiddle A B hC hrep]
      rw [aColumnPos_of_middle A B hC hs hu]
      have hcalc :
          sClose A B + 1 +
              (uClose A B + (i.1 - sClose A B) - uClose A B) =
            i.1 + 1 := by
        omega
      rw [hcalc]
    · have htail :
          tailBlock A B (aColumnPos A B hC i).1 := by
        rw [aColumnPos_of_tail A B hC hs hu]
        unfold tailBlock width
        omega
      rw [rowCoord_of_tail A B hC htail]
      rw [aColumnPos_of_tail A B hC hs hu]
      have hcalc : i.1 + width A B + 1 - width A B = i.1 + 1 := by
        unfold width
        omega
      rw [hcalc]

lemma colCoord_aColumnPos
    (A B : MinorIndex m n t)
    (hC : Close A B)
    (i : Fin t) :
    colCoord A B (aColumnPos A B hC i).1 = colExt A (i.1 + 1) := by
  classical
  by_cases hs : i.1 < sClose A B
  · have hpos : (aColumnPos A B hC i).1 < sClose A B := by
      rw [aColumnPos_of_prefix A B hC hs]
      exact hs
    rw [colCoord_of_prefix A B hpos]
    rw [aColumnPos_of_prefix A B hC hs]
  · by_cases hu : i.1 < uClose A B
    · have hrep :
          aRepeatedMiddle A B (aColumnPos A B hC i).1 := by
        rw [aColumnPos_of_middle A B hC hs hu]
        unfold aRepeatedMiddle width
        omega
      rw [colCoord_of_aRepeatedMiddle A B hC hrep]
      rw [aColumnPos_of_middle A B hC hs hu]
      have hcalc :
          sClose A B + 1 +
              (uClose A B + (i.1 - sClose A B) - uClose A B) =
            i.1 + 1 := by
        omega
      rw [hcalc]
    · have htail :
          tailBlock A B (aColumnPos A B hC i).1 := by
        rw [aColumnPos_of_tail A B hC hs hu]
        unfold tailBlock width
        omega
      rw [colCoord_of_tail A B hC htail]
      rw [aColumnPos_of_tail A B hC hs hu]
      have hcalc : i.1 + width A B + 1 - width A B = i.1 + 1 := by
        unfold width
        omega
      rw [hcalc]

lemma rowFin_aColumnPos
    (A B : MinorIndex m n t)
    (hC : Close A B)
    (i : Fin t) :
    rowFin A B hC (aColumnPos A B hC i) = A.row i := by
  apply Fin.ext
  change rowCoord A B (aColumnPos A B hC i).1 - 1 = (A.row i).1
  rw [rowCoord_aColumnPos A B hC i]
  have hbounds : 1 ≤ i.1 + 1 ∧ i.1 + 1 ≤ t := by
    omega
  rw [EndpointSelection.rowExt_endpoint (I := A) hbounds.1 hbounds.2]
  have hidx :
      (⟨i.1 + 1 - 1, by omega⟩ : Fin t) = i := by
    apply Fin.ext
    simp
  rw [hidx]
  omega

lemma colFin_aColumnPos
    (A B : MinorIndex m n t)
    (hC : Close A B)
    (i : Fin t) :
    colFin A B hC (aColumnPos A B hC i) = A.col i := by
  apply Fin.ext
  change colCoord A B (aColumnPos A B hC i).1 - 1 = (A.col i).1
  rw [colCoord_aColumnPos A B hC i]
  have hbounds : 1 ≤ i.1 + 1 ∧ i.1 + 1 ≤ t := by
    omega
  rw [EndpointSelection.colExt_endpoint (I := A) hbounds.1 hbounds.2]
  have hidx :
      (⟨i.1 + 1 - 1, by omega⟩ : Fin t) = i := by
    apply Fin.ext
    simp
  rw [hidx]
  omega

lemma not_bMiddle_aColumnPos
    (A B : MinorIndex m n t)
    (hC : Close A B)
    (i : Fin t) :
    ¬ bMiddle A B (aColumnPos A B hC i).1 := by
  classical
  intro hi
  by_cases hs : i.1 < sClose A B
  · rw [aColumnPos_of_prefix A B hC hs] at hi
    unfold bMiddle at hi
    omega
  · by_cases hu : i.1 < uClose A B
    · rw [aColumnPos_of_middle A B hC hs hu] at hi
      unfold bMiddle at hi
      omega
    · rw [aColumnPos_of_tail A B hC hs hu] at hi
      unfold bMiddle width at hi
      omega

lemma not_zeroBlock_aColumnPos
    (A B : MinorIndex m n t)
    (hC : Close A B)
    (i : Fin (size A B))
    (j : Fin t) :
    ¬ zeroBlock A B i.1 (aColumnPos A B hC j).1 := by
  intro hij
  exact not_bMiddle_aColumnPos A B hC j hij.2

/-- The row shuffle whose left block is the principal `A` rows and whose
right block is the complementary `B`-middle rows. -/
noncomputable def rowPrincipalShuffle
    (A B : MinorIndex m n t)
    (hC : Close A B) :
    Fin t ⊕ Fin (width A B) ≃ Fin (size A B) := by
  classical
  refine
    { toFun := fun x =>
        match x with
        | Sum.inl i => aColumnPos A B hC i
        | Sum.inr i => bMiddlePos A B hC i
      invFun := fun q =>
        if hprefix : q.1 < sClose A B then
          Sum.inl ⟨q.1, by
            have hs_lt_t : sClose A B < t :=
              lt_of_lt_of_le (sClose_lt_pClose A B hC.ne) (pClose_le A B)
            omega⟩
        else if hmid : q.1 < uClose A B then
          Sum.inr ⟨q.1 - sClose A B, by
            unfold width
            omega⟩
        else if hrep : q.1 < uClose A B + width A B then
          Sum.inl ⟨sClose A B + (q.1 - uClose A B), by
            have hu_le_t : uClose A B ≤ t :=
              le_trans (uClose_le_pClose A B hC.ne) (pClose_le A B)
            unfold width at hrep
            omega⟩
        else
          Sum.inl ⟨q.1 - width A B, by
            have hq : q.1 < size A B := q.2
            unfold size at hq
            omega⟩
      left_inv := by
        intro x
        cases x with
        | inl i =>
            by_cases hs : i.1 < sClose A B
            · simp [aColumnPos_of_prefix A B hC hs, hs]
            · by_cases hu : i.1 < uClose A B
              · have hnotPrefix :
                    ¬ uClose A B + (i.1 - sClose A B) < sClose A B := by
                    omega
                have hnotMid :
                    ¬ uClose A B + (i.1 - sClose A B) < uClose A B := by
                    omega
                have hrep :
                    uClose A B + (i.1 - sClose A B) <
                      uClose A B + width A B := by
                    unfold width
                    omega
                simp only [aColumnPos_of_middle A B hC hs hu, hnotPrefix, ↓reduceDIte, hnotMid,
                  hrep, add_tsub_cancel_left, Sum.inl.injEq]
                apply Fin.ext
                simp
                omega
              · have hnotPrefix : ¬ i.1 + width A B < sClose A B := by
                    unfold width
                    omega
                have hnotMid : ¬ i.1 + width A B < uClose A B := by
                    unfold width
                    omega
                have hnotRep :
                    ¬ i.1 + width A B < uClose A B + width A B := by
                    omega
                simp [aColumnPos_of_tail A B hC hs hu, hnotPrefix, hnotMid,
                  hnotRep]
        | inr i =>
            have hnotPrefix : ¬ sClose A B + i.1 < sClose A B := by
              omega
            have hmid : sClose A B + i.1 < uClose A B := by
              have hi : i.1 < uClose A B - sClose A B := by
                simp [width]
              omega
            simp [bMiddlePos, hnotPrefix, hmid]
      right_inv := by
        intro q
        rcases block_cases_of_lt_size A B q.2 with hprefix | hmid | hrep | htail
        · have hprefix' : q.1 < sClose A B := hprefix
          simp [hprefix', aColumnPos]
        · have hnotPrefix : ¬ q.1 < sClose A B := not_lt_of_ge hmid.1
          have hmid' : q.1 < uClose A B := hmid.2
          simp only [hnotPrefix, ↓reduceDIte, hmid']
          apply Fin.ext
          simp [bMiddlePos]
          omega
        · have hnotPrefix : ¬ q.1 < sClose A B := by
            have hsu : sClose A B ≤ uClose A B :=
              Nat.le_of_lt (sClose_lt_uClose A B hC.ne)
            exact not_lt_of_ge (le_trans hsu hrep.1)
          have hnotMid : ¬ q.1 < uClose A B := not_lt_of_ge hrep.1
          have hrep' : q.1 < uClose A B + width A B := hrep.2
          simp only [hnotPrefix, ↓reduceDIte, hnotMid, hrep']
          apply Fin.ext
          simp [aColumnPos]
          have hs1 :
              ¬ sClose A B + (q.1 - uClose A B) < sClose A B := by
            omega
          have hs2 :
              sClose A B + (q.1 - uClose A B) < uClose A B := by
            unfold width at hrep'
            omega
          simp [hs2]
          omega
        · have hnotPrefix : ¬ q.1 < sClose A B := by
            have hsu : sClose A B ≤ uClose A B :=
              Nat.le_of_lt (sClose_lt_uClose A B hC.ne)
            unfold tailBlock at htail
            omega
          have hnotMid : ¬ q.1 < uClose A B := by
            unfold tailBlock at htail
            omega
          have hnotRep : ¬ q.1 < uClose A B + width A B := by
            unfold tailBlock at htail
            omega
          simp only [hnotPrefix, ↓reduceDIte, hnotMid, hnotRep]
          apply Fin.ext
          simp [aColumnPos]
          have hs1 : ¬ q.1 - width A B < sClose A B := by
            have hsu : sClose A B ≤ uClose A B :=
              Nat.le_of_lt (sClose_lt_uClose A B hC.ne)
            unfold tailBlock width at htail
            omega
          have hs2 : ¬ q.1 - width A B < uClose A B := by
            unfold tailBlock width at htail
            omega
          simp [hs1, hs2]
          unfold tailBlock at htail
          omega }

/-- Positions of the `B`-rows
`alpha'_1, ..., alpha'_s, alpha'_{s+1}, ..., alpha'_u, alpha'_{u+1}, ..., alpha'_t`
inside the strict block matrix.  Together with `aRepeatedMiddlePos`, these rows
partition the rows of the block matrix for the column-side Laplace expansion
`(2.1.4)`. -/
noncomputable def bRowPos
    (A B : MinorIndex m n t)
    (hC : Close A B)
    (i : Fin t) :
    Fin (size A B) := by
  classical
  by_cases hprefix : i.1 < sClose A B
  · exact ⟨i.1, by
      have hs_lt_t : sClose A B < t :=
        lt_of_lt_of_le (sClose_lt_pClose A B hC.ne) (pClose_le A B)
      unfold size
      omega⟩
  · by_cases hmid : i.1 < uClose A B
    · exact ⟨i.1, by
        unfold size
        omega⟩
    · exact ⟨i.1 + width A B, by
        unfold size
        omega⟩

lemma bRowPos_of_prefix
    (A B : MinorIndex m n t)
    (hC : Close A B)
    {i : Fin t}
    (hi : i.1 < sClose A B) :
    (bRowPos A B hC i).1 = i.1 := by
  simp [bRowPos, hi]

lemma bRowPos_of_middle
    (A B : MinorIndex m n t)
    (hC : Close A B)
    {i : Fin t}
    (hs : ¬ i.1 < sClose A B)
    (hi : i.1 < uClose A B) :
    (bRowPos A B hC i).1 = i.1 := by
  simp [bRowPos, hs, hi]

lemma bRowPos_of_tail
    (A B : MinorIndex m n t)
    (hC : Close A B)
    {i : Fin t}
    (hs : ¬ i.1 < sClose A B)
    (hu : ¬ i.1 < uClose A B) :
    (bRowPos A B hC i).1 = i.1 + width A B := by
  simp [bRowPos, hs, hu]

lemma rowCoord_bRowPos
    (A B : MinorIndex m n t)
    (hC : Close A B)
    (i : Fin t) :
    rowCoord A B (bRowPos A B hC i).1 = rowExt B (i.1 + 1) := by
  classical
  by_cases hs : i.1 < sClose A B
  · have hpos : (bRowPos A B hC i).1 < sClose A B := by
      rw [bRowPos_of_prefix A B hC hs]
      exact hs
    rw [rowCoord_of_prefix A B hpos]
    rw [bRowPos_of_prefix A B hC hs]
    have hpEq :
        pairExt A (i.1 + 1) = pairExt B (i.1 + 1) := by
      exact pairExt_eq_of_mu_eq_right_le_s
        A B hC.ne hC.mu_eq_right (by omega) (by omega)
    have hrow := congrArg Prod.fst hpEq
    simpa using hrow
  · by_cases hu : i.1 < uClose A B
    · have hmid : bMiddle A B (bRowPos A B hC i).1 := by
        rw [bRowPos_of_middle A B hC hs hu]
        unfold bMiddle
        omega
      rw [rowCoord_of_bMiddle A B hmid]
      rw [bRowPos_of_middle A B hC hs hu]
    · have htail : tailBlock A B (bRowPos A B hC i).1 := by
        rw [bRowPos_of_tail A B hC hs hu]
        unfold tailBlock width
        omega
      rw [rowCoord_of_tail A B hC htail]
      rw [bRowPos_of_tail A B hC hs hu]
      have hcalc : i.1 + width A B + 1 - width A B = i.1 + 1 := by
        unfold width
        omega
      rw [hcalc]
      have hpEq :
          pairExt A (i.1 + 1) = pairExt B (i.1 + 1) := by
        exact pairExt_eq_of_mu_eq_right_gt_u
          A B hC.ne hC.mu_eq_right (by omega) (by omega)
      have hrow := congrArg Prod.fst hpEq
      simpa using hrow

lemma colCoord_bRowPos
    (A B : MinorIndex m n t)
    (hC : Close A B)
    (i : Fin t) :
    colCoord A B (bRowPos A B hC i).1 = colExt B (i.1 + 1) := by
  classical
  by_cases hs : i.1 < sClose A B
  · have hpos : (bRowPos A B hC i).1 < sClose A B := by
      rw [bRowPos_of_prefix A B hC hs]
      exact hs
    rw [colCoord_of_prefix A B hpos]
    rw [bRowPos_of_prefix A B hC hs]
    have hpEq :
        pairExt A (i.1 + 1) = pairExt B (i.1 + 1) := by
      exact pairExt_eq_of_mu_eq_right_le_s
        A B hC.ne hC.mu_eq_right (by omega) (by omega)
    have hcol := congrArg Prod.snd hpEq
    simpa using hcol
  · by_cases hu : i.1 < uClose A B
    · have hmid : bMiddle A B (bRowPos A B hC i).1 := by
        rw [bRowPos_of_middle A B hC hs hu]
        unfold bMiddle
        omega
      rw [colCoord_of_bMiddle A B hmid]
      rw [bRowPos_of_middle A B hC hs hu]
    · have htail : tailBlock A B (bRowPos A B hC i).1 := by
        rw [bRowPos_of_tail A B hC hs hu]
        unfold tailBlock width
        omega
      rw [colCoord_of_tail A B hC htail]
      rw [bRowPos_of_tail A B hC hs hu]
      have hcalc : i.1 + width A B + 1 - width A B = i.1 + 1 := by
        unfold width
        omega
      rw [hcalc]
      have hpEq :
          pairExt A (i.1 + 1) = pairExt B (i.1 + 1) := by
        exact pairExt_eq_of_mu_eq_right_gt_u
          A B hC.ne hC.mu_eq_right (by omega) (by omega)
      have hcol := congrArg Prod.snd hpEq
      simpa using hcol

lemma rowFin_bRowPos
    (A B : MinorIndex m n t)
    (hC : Close A B)
    (i : Fin t) :
    rowFin A B hC (bRowPos A B hC i) = B.row i := by
  apply Fin.ext
  change rowCoord A B (bRowPos A B hC i).1 - 1 = (B.row i).1
  rw [rowCoord_bRowPos A B hC i]
  have hbounds : 1 ≤ i.1 + 1 ∧ i.1 + 1 ≤ t := by
    omega
  rw [EndpointSelection.rowExt_endpoint (I := B) hbounds.1 hbounds.2]
  have hidx :
      (⟨i.1 + 1 - 1, by omega⟩ : Fin t) = i := by
    apply Fin.ext
    simp
  rw [hidx]
  omega

lemma colFin_bRowPos
    (A B : MinorIndex m n t)
    (hC : Close A B)
    (i : Fin t) :
    colFin A B hC (bRowPos A B hC i) = B.col i := by
  apply Fin.ext
  change colCoord A B (bRowPos A B hC i).1 - 1 = (B.col i).1
  rw [colCoord_bRowPos A B hC i]
  have hbounds : 1 ≤ i.1 + 1 ∧ i.1 + 1 ≤ t := by
    omega
  rw [EndpointSelection.colExt_endpoint (I := B) hbounds.1 hbounds.2]
  have hidx :
      (⟨i.1 + 1 - 1, by omega⟩ : Fin t) = i := by
    apply Fin.ext
    simp
  rw [hidx]
  omega

/-- Principal shuffle for the column-side Laplace expansion.  The selected
minor columns are the `B` row positions, and the complementary columns are the
repeated `A` middle positions. -/
noncomputable def colPrincipalShuffle
    (A B : MinorIndex m n t)
    (hC : Close A B) :
    Fin t ⊕ Fin (width A B) ≃ Fin (size A B) := by
  classical
  refine
    { toFun := fun x =>
        match x with
        | Sum.inl i => bRowPos A B hC i
        | Sum.inr i => aRepeatedMiddlePos A B hC i
      invFun := fun q =>
        if hprefix : q.1 < sClose A B then
          Sum.inl ⟨q.1, by
            have hs_lt_t : sClose A B < t :=
              lt_of_lt_of_le (sClose_lt_pClose A B hC.ne) (pClose_le A B)
            omega⟩
        else if hmid : q.1 < uClose A B then
          Sum.inl ⟨q.1, by
            have hu_le_t : uClose A B ≤ t :=
              le_trans (uClose_le_pClose A B hC.ne) (pClose_le A B)
            omega⟩
        else if hrep : q.1 < uClose A B + width A B then
          Sum.inr ⟨q.1 - uClose A B, by
            have hge : uClose A B ≤ q.1 := not_lt.mp hmid
            omega⟩
        else
          Sum.inl ⟨q.1 - width A B, by
            have hq : q.1 < size A B := q.2
            unfold size at hq
            omega⟩
      left_inv := by
        intro x
        cases x with
        | inl i =>
            by_cases hs : i.1 < sClose A B
            · simp [bRowPos_of_prefix A B hC hs, hs]
            · by_cases hu : i.1 < uClose A B
              · simp [bRowPos_of_middle A B hC hs hu, hs, hu]
              · have hnotPrefix : ¬ i.1 + width A B < sClose A B := by
                    unfold width
                    omega
                have hnotMid : ¬ i.1 + width A B < uClose A B := by
                    unfold width
                    omega
                have hnotRep :
                    ¬ i.1 + width A B < uClose A B + width A B := by
                    omega
                simp [bRowPos_of_tail A B hC hs hu, hnotPrefix, hnotMid,
                  hnotRep]
        | inr i =>
            have hnotPrefix : ¬ uClose A B + i.1 < sClose A B := by
              have hsu : sClose A B ≤ uClose A B :=
                Nat.le_of_lt (sClose_lt_uClose A B hC.ne)
              omega
            have hnotMid : ¬ uClose A B + i.1 < uClose A B := by
              omega
            have hrep : uClose A B + i.1 < uClose A B + width A B := by
              have hi : i.1 < uClose A B - sClose A B := by
                simp [width]
              unfold width
              omega
            simp [aRepeatedMiddlePos, hnotPrefix, hnotMid, hrep]
      right_inv := by
        intro q
        rcases block_cases_of_lt_size A B q.2 with hprefix | hmid | hrep | htail
        · have hprefix' : q.1 < sClose A B := hprefix
          simp [hprefix', bRowPos]
        · have hnotPrefix : ¬ q.1 < sClose A B := not_lt_of_ge hmid.1
          have hmid' : q.1 < uClose A B := hmid.2
          simp only [hnotPrefix, ↓reduceDIte, hmid']
          simp [bRowPos, hnotPrefix, hmid']
        · have hnotPrefix : ¬ q.1 < sClose A B := by
            have hsu : sClose A B ≤ uClose A B :=
              Nat.le_of_lt (sClose_lt_uClose A B hC.ne)
            exact not_lt_of_ge (le_trans hsu hrep.1)
          have hnotMid : ¬ q.1 < uClose A B := not_lt_of_ge hrep.1
          have hrep' : q.1 < uClose A B + width A B := hrep.2
          simp only [hnotPrefix, ↓reduceDIte, hnotMid, hrep']
          apply Fin.ext
          simp [aRepeatedMiddlePos]
          omega
        · have hnotPrefix : ¬ q.1 < sClose A B := by
            have hsu : sClose A B ≤ uClose A B :=
              Nat.le_of_lt (sClose_lt_uClose A B hC.ne)
            unfold tailBlock at htail
            omega
          have hnotMid : ¬ q.1 < uClose A B := by
            unfold tailBlock at htail
            omega
          have hnotRep : ¬ q.1 < uClose A B + width A B := by
            unfold tailBlock at htail
            omega
          simp only [hnotPrefix, ↓reduceDIte, hnotMid, hnotRep]
          apply Fin.ext
          simp [bRowPos]
          have hs1 : ¬ q.1 - width A B < sClose A B := by
            have hsu : sClose A B ≤ uClose A B :=
              Nat.le_of_lt (sClose_lt_uClose A B hC.ne)
            unfold tailBlock width at htail
            omega
          have hs2 : ¬ q.1 - width A B < uClose A B := by
            unfold tailBlock width at htail
            omega
          simp [hs1, hs2]
          unfold tailBlock at htail
          omega }

/-- One row-side Laplace choice `γ` in `(2.1.3)`, together with the complementary
rows used by the cofactor `Rγ*`.

The `minorRowsStrict` field is precisely the nonzero-minor condition for the
minor `D(γ,β)`.  The complement/partition facts needed to identify this with
Mathlib's general Laplace expansion will be added in the next layer. -/
structure RowLaplaceChoice
    (A B : MinorIndex m n t)
    (hC : Close A B) where
  shuffle : Fin t ⊕ Fin (width A B) ≃ Fin (size A B)
  minorRows : Fin t → Fin (size A B)
  cofactorRows : Fin (width A B) → Fin (size A B)
  minorRows_eq_shuffle : ∀ i : Fin t, minorRows i = shuffle (Sum.inl i)
  cofactorRows_eq_shuffle :
    ∀ i : Fin (width A B), cofactorRows i = shuffle (Sum.inr i)
  minorRowsStrict : StrictMono fun i : Fin t => rowFin A B hC (minorRows i)
  cofactorRowsStrict : StrictMono cofactorRows

noncomputable instance rowLaplaceChoiceFintype
    (A B : MinorIndex m n t)
    (hC : Close A B) :
    Fintype (RowLaplaceChoice A B hC) := by
  classical
  let Shuffle : Type := Fin t ⊕ Fin (width A B) ≃ Fin (size A B)
  let α : Type :=
    {p :
      (Shuffle ×
        ((Fin t → Fin (size A B)) ×
        (Fin (width A B) → Fin (size A B)))) //
      (∀ i : Fin t, (Prod.fst (Prod.snd p)) i = (Prod.fst p) (Sum.inl i)) ∧
      (∀ i : Fin (width A B),
        (Prod.snd (Prod.snd p)) i = (Prod.fst p) (Sum.inr i)) ∧
      StrictMono (fun i : Fin t => rowFin A B hC ((Prod.fst (Prod.snd p)) i)) ∧
      StrictMono (Prod.snd (Prod.snd p))}
  let e : RowLaplaceChoice A B hC ≃ α :=
  {
    toFun L :=
      ⟨(L.shuffle, (L.minorRows, L.cofactorRows)),
        L.minorRows_eq_shuffle, L.cofactorRows_eq_shuffle, L.minorRowsStrict,
        L.cofactorRowsStrict⟩
    invFun p :=
      { shuffle := Prod.fst p.1
        minorRows := Prod.fst (Prod.snd p.1)
        cofactorRows := Prod.snd (Prod.snd p.1)
        minorRows_eq_shuffle := p.2.1
        cofactorRows_eq_shuffle := p.2.2.1
        minorRowsStrict := p.2.2.2.1
        cofactorRowsStrict := p.2.2.2.2 }
    left_inv L := by
      cases L
      rfl
    right_inv p := by
      cases p
      rfl
  }
  exact Fintype.ofEquiv α e.symm

namespace RowLaplaceChoice

variable {A B : MinorIndex m n t}
variable {hC : Close A B}

lemma ext_data
    {L M : RowLaplaceChoice A B hC}
    (hshuffle : L.shuffle = M.shuffle)
    (hminorRows : L.minorRows = M.minorRows)
    (hcofactorRows : L.cofactorRows = M.cofactorRows) :
    L = M := by
  cases L
  cases M
  cases hshuffle
  cases hminorRows
  cases hcofactorRows
  rfl

/-- The minor `D(γ,β)` attached to a row-side Laplace choice. -/
noncomputable def minorIndex
    (L : RowLaplaceChoice A B hC) :
    MinorIndex m n t :=
  { row := strictMonoToOrderEmbedding
      (fun i : Fin t => rowFin A B hC (L.minorRows i))
      L.minorRowsStrict
    col := A.col }

@[simp] lemma minorIndex_col
    (L : RowLaplaceChoice A B hC) (i : Fin t) :
    L.minorIndex.col i = A.col i := rfl

@[simp] lemma minorIndex_row
    (L : RowLaplaceChoice A B hC) (i : Fin t) :
    L.minorIndex.row i = rowFin A B hC (L.minorRows i) := rfl

/-- Row variables of the cofactor `Rγ*`. -/
noncomputable def cofactorRow
    (L : RowLaplaceChoice A B hC) :
    Fin (width A B) → Fin m :=
  fun i => rowFin A B hC (L.cofactorRows i)

/-- Column variables of the cofactor `Rγ*`, namely the `B`-middle columns. -/
noncomputable def cofactorCol
    (_L : RowLaplaceChoice A B hC) :
    Fin (width A B) → Fin n :=
  fun i => colFin A B hC (bMiddlePos A B hC i)

/-- Zero predicate inherited from the strict block matrix for `Rγ*`. -/
noncomputable def cofactorZero
    (L : RowLaplaceChoice A B hC) :
    Fin (width A B) → Fin (width A B) → Prop :=
  fun i j => zeroBlock A B (L.cofactorRows i).1 (bMiddlePos A B hC j).1

/-- The coefficient matrix `Rγ*`. -/
noncomputable def cofactorMatrix
    (L : RowLaplaceChoice A B hC) :
    Matrix (Fin (width A B)) (Fin (width A B))
      (MvPolynomial (Fin m × Fin n) k) :=
  MonomialCoefficientMatrix.matrix
    (m := m) (n := n) (q := width A B) (k := k)
    L.cofactorRow L.cofactorCol L.cofactorZero

/-- One monomial term from `det(Rγ*) D(γ,β)`, with an external Laplace sign. -/
noncomputable def term
    (L : RowLaplaceChoice A B hC)
    (a : k)
    (σ : Equiv.Perm (Fin (width A B))) :
    ClosePairThm21Term m n t k :=
  MonomialCoefficientMatrix.closePairTerm
    (m := m) (n := n) (t := t) (q := width A B) (k := k)
    L.cofactorRow L.cofactorCol L.cofactorZero L.minorIndex a σ

omit [Nontrivial k] in
lemma scaled_det_mul_minor_eq_sum_terms
    (L : RowLaplaceChoice A B hC)
    (a : k) :
    MvPolynomial.C a *
        (Matrix.det L.cofactorMatrix *
          genericMinor (k := k) L.minorIndex) =
      ∑ σ : Equiv.Perm (Fin (width A B)), (L.term (k := k) a σ).poly := by
  exact
    MonomialCoefficientMatrix.scaled_det_mul_minor_eq_sum_closePairTerm
      (m := m) (n := n) (t := t) (q := width A B) (k := k)
      L.cofactorRow L.cofactorCol L.cofactorZero L.minorIndex a

end RowLaplaceChoice

/-- One column-side Laplace choice `δ` in `(2.1.4)`, together with the
complementary columns used by the cofactor `Cδ*`. -/
structure ColLaplaceChoice
    (A B : MinorIndex m n t)
    (hC : Close A B) where
  shuffle : Fin t ⊕ Fin (width A B) ≃ Fin (size A B)
  minorCols : Fin t → Fin (size A B)
  cofactorCols : Fin (width A B) → Fin (size A B)
  minorCols_eq_shuffle : ∀ i : Fin t, minorCols i = shuffle (Sum.inl i)
  cofactorCols_eq_shuffle :
    ∀ i : Fin (width A B), cofactorCols i = shuffle (Sum.inr i)
  minorColsStrict : StrictMono fun i : Fin t => colFin A B hC (minorCols i)
  cofactorColsStrict : StrictMono cofactorCols

noncomputable instance colLaplaceChoiceFintype
    (A B : MinorIndex m n t)
    (hC : Close A B) :
    Fintype (ColLaplaceChoice A B hC) := by
  classical
  let Shuffle : Type := Fin t ⊕ Fin (width A B) ≃ Fin (size A B)
  let α : Type :=
    {p :
      (Shuffle ×
        ((Fin t → Fin (size A B)) ×
        (Fin (width A B) → Fin (size A B)))) //
      (∀ i : Fin t, (Prod.fst (Prod.snd p)) i = (Prod.fst p) (Sum.inl i)) ∧
      (∀ i : Fin (width A B),
        (Prod.snd (Prod.snd p)) i = (Prod.fst p) (Sum.inr i)) ∧
      StrictMono (fun i : Fin t => colFin A B hC ((Prod.fst (Prod.snd p)) i)) ∧
      StrictMono (Prod.snd (Prod.snd p))}
  let e : ColLaplaceChoice A B hC ≃ α :=
  {
    toFun L :=
      ⟨(L.shuffle, (L.minorCols, L.cofactorCols)),
        L.minorCols_eq_shuffle, L.cofactorCols_eq_shuffle, L.minorColsStrict,
        L.cofactorColsStrict⟩
    invFun p :=
      { shuffle := Prod.fst p.1
        minorCols := Prod.fst (Prod.snd p.1)
        cofactorCols := Prod.snd (Prod.snd p.1)
        minorCols_eq_shuffle := p.2.1
        cofactorCols_eq_shuffle := p.2.2.1
        minorColsStrict := p.2.2.2.1
        cofactorColsStrict := p.2.2.2.2 }
    left_inv L := by
      cases L
      rfl
    right_inv p := by
      cases p
      rfl
  }
  exact Fintype.ofEquiv α e.symm

namespace ColLaplaceChoice

variable {A B : MinorIndex m n t}
variable {hC : Close A B}

lemma ext_data
    {L M : ColLaplaceChoice A B hC}
    (hshuffle : L.shuffle = M.shuffle)
    (hminorCols : L.minorCols = M.minorCols)
    (hcofactorCols : L.cofactorCols = M.cofactorCols) :
    L = M := by
  cases L
  cases M
  cases hshuffle
  cases hminorCols
  cases hcofactorCols
  rfl

/-- The minor `D(α',δ)` attached to a column-side Laplace choice. -/
noncomputable def minorIndex
    (L : ColLaplaceChoice A B hC) :
    MinorIndex m n t :=
  { row := B.row
    col := strictMonoToOrderEmbedding
      (fun i : Fin t => colFin A B hC (L.minorCols i))
      L.minorColsStrict }

@[simp] lemma minorIndex_row
    (L : ColLaplaceChoice A B hC) (i : Fin t) :
    L.minorIndex.row i = B.row i := rfl

@[simp] lemma minorIndex_col
    (L : ColLaplaceChoice A B hC) (i : Fin t) :
    L.minorIndex.col i = colFin A B hC (L.minorCols i) := rfl

/-- Row variables of the cofactor `Cδ*`, namely the repeated `A`-middle rows. -/
noncomputable def cofactorRow
    (_L : ColLaplaceChoice A B hC) :
    Fin (width A B) → Fin m :=
  fun i => rowFin A B hC (aRepeatedMiddlePos A B hC i)

/-- Column variables of the cofactor `Cδ*`. -/
noncomputable def cofactorCol
    (L : ColLaplaceChoice A B hC) :
    Fin (width A B) → Fin n :=
  fun i => colFin A B hC (L.cofactorCols i)

/-- Zero predicate inherited from the strict block matrix for `Cδ*`. -/
noncomputable def cofactorZero
    (L : ColLaplaceChoice A B hC) :
    Fin (width A B) → Fin (width A B) → Prop :=
  fun i j => zeroBlock A B (aRepeatedMiddlePos A B hC i).1 (L.cofactorCols j).1

/-- The coefficient matrix `Cδ*`. -/
noncomputable def cofactorMatrix
    (L : ColLaplaceChoice A B hC) :
    Matrix (Fin (width A B)) (Fin (width A B))
      (MvPolynomial (Fin m × Fin n) k) :=
  MonomialCoefficientMatrix.matrix
    (m := m) (n := n) (q := width A B) (k := k)
    L.cofactorRow L.cofactorCol L.cofactorZero

/-- One monomial term from `det(Cδ*) D(α',δ)`, with an external Laplace sign. -/
noncomputable def term
    (L : ColLaplaceChoice A B hC)
    (a : k)
    (σ : Equiv.Perm (Fin (width A B))) :
    ClosePairThm21Term m n t k :=
  MonomialCoefficientMatrix.closePairTerm
    (m := m) (n := n) (t := t) (q := width A B) (k := k)
    L.cofactorRow L.cofactorCol L.cofactorZero L.minorIndex a σ

omit [Nontrivial k] in
lemma scaled_det_mul_minor_eq_sum_terms
    (L : ColLaplaceChoice A B hC)
    (a : k) :
    MvPolynomial.C a *
        (Matrix.det L.cofactorMatrix *
          genericMinor (k := k) L.minorIndex) =
      ∑ σ : Equiv.Perm (Fin (width A B)), (L.term (k := k) a σ).poly := by
  exact
    MonomialCoefficientMatrix.scaled_det_mul_minor_eq_sum_closePairTerm
      (m := m) (n := n) (t := t) (q := width A B) (k := k)
      L.cofactorRow L.cofactorCol L.cofactorZero L.minorIndex a

end ColLaplaceChoice

/-- The cofactor block `B` from the strict-case matrix, expanded as a monomial
coefficient multiplying `D(α,β)`.  The permutation `1` is the diagonal term
`ΔB`; non-identity permutations are the monomials in `det B - ΔB`. -/
noncomputable def bBlockTerm
    (A B : MinorIndex m n t)
    (hC : Close A B)
    (a : k)
    (σ : Equiv.Perm (Fin (width A B))) :
    ClosePairThm21Term m n t k :=
  MonomialCoefficientMatrix.closePairTerm
    (m := m) (n := n) (t := t) (q := width A B) (k := k)
    (fun i => rowFin A B hC (bMiddlePos A B hC i))
    (fun i => colFin A B hC (bMiddlePos A B hC i))
    (fun _ _ => False)
    A a σ

/-- The cofactor block `C` from the strict-case matrix, expanded as a monomial
coefficient multiplying `D(α',β')`.  The permutation `1` is the diagonal term
`ΔC`; non-identity permutations are the monomials in `det C - ΔC`. -/
noncomputable def cBlockTerm
    (A B : MinorIndex m n t)
    (hC : Close A B)
    (a : k)
    (σ : Equiv.Perm (Fin (width A B))) :
    ClosePairThm21Term m n t k :=
  MonomialCoefficientMatrix.closePairTerm
    (m := m) (n := n) (t := t) (q := width A B) (k := k)
    (fun i => rowFin A B hC (aRepeatedMiddlePos A B hC i))
    (fun i => colFin A B hC (aRepeatedMiddlePos A B hC i))
    (fun _ _ => False)
    B a σ

/-- The standard ordered coproduct identification
`Fin t ⊕ Fin (width A B) ≃ Fin (size A B)`. -/
noncomputable def sumFinToSize
    (A B : MinorIndex m n t) :
    Fin t ⊕ Fin (width A B) ≃ Fin (size A B) :=
  finSumFinEquiv

/-- The sign of a Laplace shuffle, cast to the coefficient ring. -/
noncomputable def laplaceShuffleSign
    {α : Type*} [Fintype α] [DecidableEq α]
    (e : Equiv.Perm α) : k :=
  (((Equiv.Perm.sign e : ℤˣ) : ℤ) : k)

/-- The Laplace sign `σ_γ` in (2.1.3).  It is the product of the varying
row/cofactor shuffle and the fixed column/cofactor shuffle. -/
noncomputable def rowLaplaceSign
    (A B : MinorIndex m n t)
    (hC : Close A B)
    (L : RowLaplaceChoice A B hC) : k :=
  laplaceShuffleSign (k := k) (L.shuffle.trans (sumFinToSize A B).symm) *
    laplaceShuffleSign (k := k)
      ((rowPrincipalShuffle A B hC).trans (sumFinToSize A B).symm)

/-- The full Leibniz permutation obtained from a row-side Laplace choice,
a permutation in the selected minor, and a permutation in the cofactor.  It
maps the fixed `A`-columns through the minor rows and the fixed `B`-middle
columns through the cofactor rows. -/
noncomputable def rowLaplacePerm
    (A B : MinorIndex m n t)
    (hC : Close A B)
    (L : RowLaplaceChoice A B hC)
    (τ : Equiv.Perm (Fin t))
    (σ : Equiv.Perm (Fin (width A B))) :
    Equiv.Perm (Fin (size A B)) :=
  (rowPrincipalShuffle A B hC).symm.trans
    ((Equiv.Perm.sumCongr τ σ).trans L.shuffle)

@[simp] lemma rowLaplacePerm_aColumnPos
    (A B : MinorIndex m n t)
    (hC : Close A B)
    (L : RowLaplaceChoice A B hC)
    (τ : Equiv.Perm (Fin t))
    (σ : Equiv.Perm (Fin (width A B)))
    (j : Fin t) :
    rowLaplacePerm A B hC L τ σ (aColumnPos A B hC j) =
      L.minorRows (τ j) := by
  have hleft :
      (rowPrincipalShuffle A B hC).symm (aColumnPos A B hC j) =
        Sum.inl j := by
    simpa [rowPrincipalShuffle] using
      (rowPrincipalShuffle A B hC).left_inv (Sum.inl j)
  simp [rowLaplacePerm, hleft, L.minorRows_eq_shuffle]

@[simp] lemma rowLaplacePerm_bMiddlePos
    (A B : MinorIndex m n t)
    (hC : Close A B)
    (L : RowLaplaceChoice A B hC)
    (τ : Equiv.Perm (Fin t))
    (σ : Equiv.Perm (Fin (width A B)))
    (j : Fin (width A B)) :
    rowLaplacePerm A B hC L τ σ (bMiddlePos A B hC j) =
      L.cofactorRows (σ j) := by
  have hright :
      (rowPrincipalShuffle A B hC).symm (bMiddlePos A B hC j) =
        Sum.inr j := by
    simpa [rowPrincipalShuffle] using
      (rowPrincipalShuffle A B hC).left_inv (Sum.inr j)
  simp [rowLaplacePerm, hright, L.cofactorRows_eq_shuffle]

/-- The product of matrix entries for the full Leibniz permutation attached
to a row-side Laplace datum splits into the minor part and the cofactor part. -/
lemma rowLaplacePerm_product_split
    {R : Type*} [CommMonoid R]
    (A B : MinorIndex m n t)
    (hC : Close A B)
    (L : RowLaplaceChoice A B hC)
    (τ : Equiv.Perm (Fin t))
    (σ : Equiv.Perm (Fin (width A B)))
    (M : Matrix (Fin (size A B)) (Fin (size A B)) R) :
    (∏ j : Fin (size A B),
        M (rowLaplacePerm A B hC L τ σ j) j) =
      (∏ j : Fin t,
        M (L.minorRows (τ j)) (aColumnPos A B hC j)) *
      (∏ j : Fin (width A B),
        M (L.cofactorRows (σ j)) (bMiddlePos A B hC j)) := by
  classical
  rw [← Equiv.prod_comp (rowPrincipalShuffle A B hC)
    (fun j : Fin (size A B) =>
      M (rowLaplacePerm A B hC L τ σ j) j)]
  rw [Fintype.prod_sum_type]
  simp [rowPrincipalShuffle]

omit [Nontrivial k] in
lemma rowLaplacePerm_sign
    (A B : MinorIndex m n t)
    (hC : Close A B)
    (L : RowLaplaceChoice A B hC)
    (τ : Equiv.Perm (Fin t))
    (σ : Equiv.Perm (Fin (width A B))) :
    laplaceShuffleSign (k := k) (rowLaplacePerm A B hC L τ σ) =
      rowLaplaceSign (m := m) (n := n) (t := t) (k := k) A B hC L *
        (laplaceShuffleSign (k := k) τ *
          laplaceShuffleSign (k := k) σ) := by
  classical
  let S := sumFinToSize A B
  let C := rowPrincipalShuffle A B hC
  let lrel : Equiv.Perm (Fin t ⊕ Fin (width A B)) := L.shuffle.trans S.symm
  let crel : Equiv.Perm (Fin t ⊕ Fin (width A B)) := C.trans S.symm
  have hconj :
      (S.trans (rowLaplacePerm A B hC L τ σ)).trans S.symm =
        crel.symm.trans ((Equiv.Perm.sumCongr τ σ).trans lrel) := by
    ext x
    simp [rowLaplacePerm, S, C, lrel, crel]
  have hsign :
      Equiv.Perm.sign (rowLaplacePerm A B hC L τ σ) =
      Equiv.Perm.sign
          (crel.symm.trans ((Equiv.Perm.sumCongr τ σ).trans lrel)) := by
    rw [← hconj]
    exact (Equiv.Perm.sign_trans_trans_symm
      (rowLaplacePerm A B hC L τ σ) S).symm
  unfold laplaceShuffleSign rowLaplaceSign
  rw [hsign]
  simp [laplaceShuffleSign, S, C, lrel, crel,
    Equiv.Perm.sign_trans, Equiv.Perm.sign_sumCongr,
    mul_assoc, mul_comm, mul_left_comm]

/-- The full Leibniz permutation obtained from a column-side Laplace choice,
a permutation in the selected minor, and a permutation in the cofactor.  It
maps the chosen minor columns to the fixed `B` rows and the chosen cofactor
columns to the repeated `A` middle rows. -/
noncomputable def colLaplacePerm
    (A B : MinorIndex m n t)
    (hC : Close A B)
    (L : ColLaplaceChoice A B hC)
    (τ : Equiv.Perm (Fin t))
    (σ : Equiv.Perm (Fin (width A B))) :
    Equiv.Perm (Fin (size A B)) :=
  L.shuffle.symm.trans
    ((Equiv.Perm.sumCongr τ σ).trans (colPrincipalShuffle A B hC))

@[simp] lemma colLaplacePerm_minorCols
    (A B : MinorIndex m n t)
    (hC : Close A B)
    (L : ColLaplaceChoice A B hC)
    (τ : Equiv.Perm (Fin t))
    (σ : Equiv.Perm (Fin (width A B)))
    (j : Fin t) :
    colLaplacePerm A B hC L τ σ (L.minorCols j) =
      bRowPos A B hC (τ j) := by
  have hleft :
      L.shuffle.symm (L.minorCols j) = Sum.inl j := by
    rw [L.minorCols_eq_shuffle]
    exact L.shuffle.left_inv (Sum.inl j)
  simp [colLaplacePerm, hleft, colPrincipalShuffle]

@[simp] lemma colLaplacePerm_cofactorCols
    (A B : MinorIndex m n t)
    (hC : Close A B)
    (L : ColLaplaceChoice A B hC)
    (τ : Equiv.Perm (Fin t))
    (σ : Equiv.Perm (Fin (width A B)))
    (j : Fin (width A B)) :
    colLaplacePerm A B hC L τ σ (L.cofactorCols j) =
      aRepeatedMiddlePos A B hC (σ j) := by
  have hright :
      L.shuffle.symm (L.cofactorCols j) = Sum.inr j := by
    rw [L.cofactorCols_eq_shuffle]
    exact L.shuffle.left_inv (Sum.inr j)
  simp [colLaplacePerm, hright, colPrincipalShuffle]

lemma colLaplacePerm_product_split
    {R : Type*} [CommMonoid R]
    (A B : MinorIndex m n t)
    (hC : Close A B)
    (L : ColLaplaceChoice A B hC)
    (τ : Equiv.Perm (Fin t))
    (σ : Equiv.Perm (Fin (width A B)))
    (M : Matrix (Fin (size A B)) (Fin (size A B)) R) :
    (∏ j : Fin (size A B),
        M (colLaplacePerm A B hC L τ σ j) j) =
      (∏ j : Fin t,
        M (bRowPos A B hC (τ j)) (L.minorCols j)) *
      (∏ j : Fin (width A B),
        M (aRepeatedMiddlePos A B hC (σ j)) (L.cofactorCols j)) := by
  classical
  rw [← Equiv.prod_comp L.shuffle
    (fun j : Fin (size A B) =>
      M (colLaplacePerm A B hC L τ σ j) j)]
  rw [Fintype.prod_sum_type]
  simp [colLaplacePerm, colPrincipalShuffle, L.minorCols_eq_shuffle,
    L.cofactorCols_eq_shuffle]

/-- The Laplace sign `ρ_δ` in (2.1.4), coming from the column/cofactor shuffle. -/
noncomputable def colLaplaceSign
    (A B : MinorIndex m n t)
    (hC : Close A B)
    (L : ColLaplaceChoice A B hC) : k :=
  laplaceShuffleSign (k := k) (L.shuffle.trans (sumFinToSize A B).symm) *
    laplaceShuffleSign (k := k)
      ((colPrincipalShuffle A B hC).trans (sumFinToSize A B).symm)

omit [Nontrivial k] in
lemma colLaplacePerm_sign
    (A B : MinorIndex m n t)
    (hC : Close A B)
    (L : ColLaplaceChoice A B hC)
    (τ : Equiv.Perm (Fin t))
    (σ : Equiv.Perm (Fin (width A B))) :
    laplaceShuffleSign (k := k) (colLaplacePerm A B hC L τ σ) =
      colLaplaceSign (m := m) (n := n) (t := t) (k := k) A B hC L *
        (laplaceShuffleSign (k := k) τ *
          laplaceShuffleSign (k := k) σ) := by
  classical
  let S := sumFinToSize A B
  let C := colPrincipalShuffle A B hC
  let lrel : Equiv.Perm (Fin t ⊕ Fin (width A B)) := L.shuffle.trans S.symm
  let crel : Equiv.Perm (Fin t ⊕ Fin (width A B)) := C.trans S.symm
  have hconj :
      (S.trans (colLaplacePerm A B hC L τ σ)).trans S.symm =
        lrel.symm.trans ((Equiv.Perm.sumCongr τ σ).trans crel) := by
    ext x
    simp [colLaplacePerm, S, C, lrel, crel]
  have hsign :
      Equiv.Perm.sign (colLaplacePerm A B hC L τ σ) =
      Equiv.Perm.sign
          (lrel.symm.trans ((Equiv.Perm.sumCongr τ σ).trans crel)) := by
    rw [← hconj]
    exact (Equiv.Perm.sign_trans_trans_symm
      (colLaplacePerm A B hC L τ σ) S).symm
  unfold laplaceShuffleSign colLaplaceSign
  rw [hsign]
  simp [laplaceShuffleSign, S, C, lrel, crel,
    Equiv.Perm.sign_trans, Equiv.Perm.sign_sumCongr,
    mul_assoc, mul_comm, mul_left_comm]

/-- The principal row-side Laplace choice, corresponding to the minor `D(A)`
and the cofactor block `B`.

This is the formal version of the paper's principal term
`B = R_{α*}`. -/
noncomputable def rowPrincipalChoice
    (A B : MinorIndex m n t)
    (hC : Close A B) :
    RowLaplaceChoice A B hC := by
  classical
  refine
    { shuffle := rowPrincipalShuffle A B hC
      minorRows := fun i => aColumnPos A B hC i
      cofactorRows := fun i => bMiddlePos A B hC i
      minorRows_eq_shuffle := ?_
      cofactorRows_eq_shuffle := ?_
      minorRowsStrict := ?_
      cofactorRowsStrict := ?_ }
  · intro i
    rfl
  · intro i
    rfl
  · intro i j hij
    simpa [rowFin_aColumnPos]
      using A.row.strictMono hij
  · intro i j hij
    simp [bMiddlePos]
    omega

/-- The principal column-side Laplace choice, corresponding to the minor
`D(B)` and the cofactor block `C`. -/
noncomputable def colPrincipalChoice
    (A B : MinorIndex m n t)
    (hC : Close A B) :
    ColLaplaceChoice A B hC := by
  classical
  refine
    { shuffle := colPrincipalShuffle A B hC
      minorCols := fun i => bRowPos A B hC i
      cofactorCols := fun i => aRepeatedMiddlePos A B hC i
      minorCols_eq_shuffle := ?_
      cofactorCols_eq_shuffle := ?_
      minorColsStrict := ?_
      cofactorColsStrict := ?_ }
  · intro i
    rfl
  · intro i
    rfl
  · intro i j hij
    simpa [colFin_bRowPos]
      using B.col.strictMono hij
  · intro i j hij
    simp [aRepeatedMiddlePos]
    omega

/-- The four raw finite families of monomial summands in the strict-case
formula (2.1.5): column-expansion terms, row-expansion terms, the tail of
`det C`, and the tail of `det B`. -/
abbrev StrictLaplaceRawIndex
  (A B : MinorIndex m n t)
  (hC : Close A B) : Type :=
  (Σ L : ColLaplaceChoice A B hC,
      {_σ : Equiv.Perm (Fin (width A B)) //
        L ≠ colPrincipalChoice A B hC}) ⊕
  (Σ L : RowLaplaceChoice A B hC,
      {_σ : Equiv.Perm (Fin (width A B)) //
        L ≠ rowPrincipalChoice A B hC}) ⊕
  {σ : Equiv.Perm (Fin (width A B)) // σ ≠ 1} ⊕
  {σ : Equiv.Perm (Fin (width A B)) // σ ≠ 1}

namespace StrictLaplaceRawIndex

/-- Interpret one raw strict-case Laplace index as a displayed
`ClosePairThm21Term`.  The signs follow formula (2.1.5):
column terms have positive sign, row terms have negative sign, `det C - ΔC`
has positive sign, and `det B - ΔB` has negative sign. -/
noncomputable def term
    {A B : MinorIndex m n t}
    {hC : Close A B}
    (i : StrictLaplaceRawIndex A B hC) :
    ClosePairThm21Term m n t k :=
  match i with
  | Sum.inl ⟨L, σ⟩ =>
      L.term (k := k) (colLaplaceSign (m := m) (n := n) (t := t) (k := k) A B hC L) σ
  | Sum.inr (Sum.inl ⟨L, σ⟩) =>
      L.term (k := k) (-(rowLaplaceSign (m := m) (n := n) (t := t) (k := k) A B hC L)) σ
  | Sum.inr (Sum.inr (Sum.inl σ)) =>
      cBlockTerm (m := m) (n := n) (t := t) (k := k) A B hC 1 σ
  | Sum.inr (Sum.inr (Sum.inr σ)) =>
      bBlockTerm (m := m) (n := n) (t := t) (k := k) A B hC (-1) σ

/-- The column-expansion part of the raw strict-case family. -/
noncomputable def colPartSum
    (A B : MinorIndex m n t)
    (hC : Close A B) :
    MvPolynomial (Fin m × Fin n) k := by
  classical
  exact
    ∑ i :
        Σ L : ColLaplaceChoice A B hC,
          {_σ : Equiv.Perm (Fin (width A B)) //
            L ≠ colPrincipalChoice A B hC},
      (i.1.term (k := k)
        (colLaplaceSign (m := m) (n := n) (t := t) (k := k) A B hC i.1)
        i.2).poly

/-- The row-expansion part of the raw strict-case family, with the sign used in
formula `(2.1.5)`. -/
noncomputable def rowPartSum
    (A B : MinorIndex m n t)
    (hC : Close A B) :
    MvPolynomial (Fin m × Fin n) k := by
  classical
  exact
    ∑ i :
        Σ L : RowLaplaceChoice A B hC,
          {_σ : Equiv.Perm (Fin (width A B)) //
            L ≠ rowPrincipalChoice A B hC},
      (i.1.term (k := k)
        (-(rowLaplaceSign (m := m) (n := n) (t := t) (k := k) A B hC i.1))
        i.2).poly

/-- The non-diagonal tail of the `C` cofactor block in formula `(2.1.5)`. -/
noncomputable def cTailPartSum
    (A B : MinorIndex m n t)
    (hC : Close A B) :
    MvPolynomial (Fin m × Fin n) k := by
  classical
  exact
    ∑ σ : {σ : Equiv.Perm (Fin (width A B)) // σ ≠ 1},
      (cBlockTerm (m := m) (n := n) (t := t) (k := k) A B hC 1 σ).poly

/-- The non-diagonal tail of the `B` cofactor block in formula `(2.1.5)`, with
the minus sign already included in the displayed terms. -/
noncomputable def bTailPartSum
    (A B : MinorIndex m n t)
    (hC : Close A B) :
    MvPolynomial (Fin m × Fin n) k := by
  classical
  exact
    ∑ σ : {σ : Equiv.Perm (Fin (width A B)) // σ ≠ 1},
      (bBlockTerm (m := m) (n := n) (t := t) (k := k) A B hC (-1) σ).poly

/-- The raw indexed polynomial sum before collecting duplicate displayed
`ClosePairThm21Term`s. -/
noncomputable def rawPolySum
    (A B : MinorIndex m n t)
    (hC : Close A B) :
    MvPolynomial (Fin m × Fin n) k := by
  classical
  exact
    ∑ i : StrictLaplaceRawIndex A B hC,
      (term (m := m) (n := n) (t := t) (k := k)
        (A := A) (B := B) (hC := hC) i).poly

/-- The key by which raw Laplace terms are collected: the minor and exponent
part.  Coefficients with the same key are summed. -/
abbrev TermKey (m n t : ℕ) :=
  MinorIndex m n t × ((Fin m × Fin n) →₀ ℕ)

/-- The `(K,d)` key of one raw Laplace term. -/
noncomputable def rawKey
    {A B : MinorIndex m n t}
    {hC : Close A B}
    (i : StrictLaplaceRawIndex A B hC) :
    TermKey m n t :=
  let T :=
    term (m := m) (n := n) (t := t) (k := k)
      (A := A) (B := B) (hC := hC) i
  (T.K, T.d)

/-- The finite set of keys appearing in the raw Laplace family. -/
noncomputable def keyFinset
    (A B : MinorIndex m n t)
    (hC : Close A B) :
    Finset (TermKey m n t) := by
  classical
  exact
    Finset.univ.image
      (rawKey (m := m) (n := n) (t := t) (k := k)
        (A := A) (B := B) (hC := hC))

/-- The finite index type of collected raw Laplace terms. -/
abbrev CollectedIndex
    (A B : MinorIndex m n t)
    (hC : Close A B) : Type :=
  {q : TermKey m n t // q ∈ keyFinset (m := m) (n := n) (t := t) (k := k) A B hC}

noncomputable instance collectedIndexFintype
    (A B : MinorIndex m n t)
    (hC : Close A B) :
    Fintype (CollectedIndex (m := m) (n := n) (t := t) (k := k) A B hC) := by
  classical
  exact Finset.Subtype.fintype
    (keyFinset (m := m) (n := n) (t := t) (k := k) A B hC)

/-- The collected key attached to one raw index. -/
noncomputable def rawKeyIndex
    {A B : MinorIndex m n t}
    {hC : Close A B}
    (i : StrictLaplaceRawIndex A B hC) :
    CollectedIndex (m := m) (n := n) (t := t) (k := k) A B hC := by
  classical
  exact
    ⟨rawKey (m := m) (n := n) (t := t) (k := k)
        (A := A) (B := B) (hC := hC) i,
      by
        simp [keyFinset]⟩

/-- The sum of all coefficients of raw terms having a fixed collected key. -/
noncomputable def collectedCoeff
    {A B : MinorIndex m n t}
    {hC : Close A B}
    (q : CollectedIndex (m := m) (n := n) (t := t) (k := k) A B hC) : k := by
  classical
  exact
    ∑ i ∈ (Finset.univ.filter fun i : StrictLaplaceRawIndex A B hC =>
        rawKeyIndex (m := m) (n := n) (t := t) (k := k)
          (A := A) (B := B) (hC := hC) i = q),
      (term (m := m) (n := n) (t := t) (k := k)
        (A := A) (B := B) (hC := hC) i).c

/-- The displayed term obtained by collecting all raw Laplace terms with the
same `(K,d)` key. -/
noncomputable def collectedTerm
    {A B : MinorIndex m n t}
    {hC : Close A B}
    (q : CollectedIndex (m := m) (n := n) (t := t) (k := k) A B hC) :
    ClosePairThm21Term m n t k :=
  { K := q.1.1
    d := q.1.2
    c := collectedCoeff (m := m) (n := n) (t := t) (k := k)
      (A := A) (B := B) (hC := hC) q }

/-- The polynomial sum of the raw fiber represented by one collected key. -/
noncomputable def collectedFiberPolySum
    {A B : MinorIndex m n t}
    {hC : Close A B}
    (q : CollectedIndex (m := m) (n := n) (t := t) (k := k) A B hC) :
    MvPolynomial (Fin m × Fin n) k := by
  classical
  exact
    ∑ i ∈ (Finset.univ.filter fun i : StrictLaplaceRawIndex A B hC =>
        rawKeyIndex (m := m) (n := n) (t := t) (k := k)
          (A := A) (B := B) (hC := hC) i = q),
      (term (m := m) (n := n) (t := t) (k := k)
        (A := A) (B := B) (hC := hC) i).poly

omit [Nontrivial k] in
lemma collectedTerm_injective
    (A B : MinorIndex m n t)
    (hC : Close A B) :
    Function.Injective
      (collectedTerm (m := m) (n := n) (t := t) (k := k)
        (A := A) (B := B) (hC := hC)) := by
  intro q r hqr
  apply Subtype.ext
  cases q with
  | mk q hq =>
    cases r with
    | mk r hr =>
      simp only [collectedTerm, ClosePairThm21Term.mk.injEq] at hqr
      exact Prod.ext hqr.1 hqr.2.1

omit [Nontrivial k] in
lemma collectedTerm_poly_eq_sum_fiber
    {A B : MinorIndex m n t}
    {hC : Close A B}
    (q : CollectedIndex (m := m) (n := n) (t := t) (k := k) A B hC) :
    (collectedTerm (m := m) (n := n) (t := t) (k := k)
        (A := A) (B := B) (hC := hC) q).poly =
      collectedFiberPolySum (m := m) (n := n) (t := t) (k := k)
        (A := A) (B := B) (hC := hC) q := by
  classical
  rw [collectedTerm, ClosePairThm21Term.poly, ClosePairThm21Term.coeffPoly,
    collectedCoeff, collectedFiberPolySum]
  have hmono :
      MvPolynomial.monomial q.1.2
          (∑ i ∈ (Finset.univ.filter fun i : StrictLaplaceRawIndex A B hC =>
              rawKeyIndex (m := m) (n := n) (t := t) (k := k)
                (A := A) (B := B) (hC := hC) i = q),
            (term (m := m) (n := n) (t := t) (k := k)
              (A := A) (B := B) (hC := hC) i).c) =
        ∑ i ∈ (Finset.univ.filter fun i : StrictLaplaceRawIndex A B hC =>
            rawKeyIndex (m := m) (n := n) (t := t) (k := k)
              (A := A) (B := B) (hC := hC) i = q),
          MvPolynomial.monomial q.1.2
            ((term (m := m) (n := n) (t := t) (k := k)
              (A := A) (B := B) (hC := hC) i).c) := by
    simp
  rw [hmono, Finset.sum_mul]
  refine Finset.sum_congr rfl ?_
  intro i _hi
  have hkey :
      rawKey (m := m) (n := n) (t := t) (k := k)
        (A := A) (B := B) (hC := hC) i = q.1 := by
    have hmem := (Finset.mem_filter.mp _hi).2
    simpa [rawKeyIndex] using congrArg Subtype.val hmem
  let T : ClosePairThm21Term m n t k :=
    term (m := m) (n := n) (t := t) (k := k)
      (A := A) (B := B) (hC := hC) i
  have hK : T.K = q.1.1 := congrArg Prod.fst hkey
  have hd : T.d = q.1.2 := congrArg Prod.snd hkey
  simp [T, ClosePairThm21Term.poly, ClosePairThm21Term.coeffPoly, hK, hd]


omit [Nontrivial k] in
lemma sum_collectedFiberPolySum_eq_rawPolySum
    {A B : MinorIndex m n t}
    {hC : Close A B} :
    (∑ q : CollectedIndex (m := m) (n := n) (t := t) (k := k) A B hC,
      collectedFiberPolySum (m := m) (n := n) (t := t) (k := k)
        (A := A) (B := B) (hC := hC) q) =
      rawPolySum (m := m) (n := n) (t := t) (k := k) A B hC := by
  classical
  let ι := StrictLaplaceRawIndex A B hC
  let κ :=
    CollectedIndex (m := m) (n := n) (t := t) (k := k) A B hC
  let g : ι → κ :=
    rawKeyIndex (m := m) (n := n) (t := t) (k := k)
      (A := A) (B := B) (hC := hC)
  let f : ι → MvPolynomial (Fin m × Fin n) k :=
    fun i =>
      (term (m := m) (n := n) (t := t) (k := k)
        (A := A) (B := B) (hC := hC) i).poly
  calc
    (∑ q : κ,
      collectedFiberPolySum (m := m) (n := n) (t := t) (k := k)
        (A := A) (B := B) (hC := hC) q)
        =
      ∑ q : κ,
        ∑ i ∈ ((Finset.univ : Finset ι).filter fun i => g i = q),
          f i := by
        refine Finset.sum_congr rfl ?_
        intro q _hq
        unfold collectedFiberPolySum
        dsimp [g, f, ι, κ]
    _ =
      rawPolySum (m := m) (n := n) (t := t) (k := k) A B hC := by
        have hmaps :
            ∀ i ∈ (Finset.univ : Finset ι),
              g i ∈ (Finset.univ : Finset κ) := by
          intro i _hi
          exact Finset.mem_univ (g i)
        have hsum :=
          Finset.sum_fiberwise_of_maps_to
            (s := (Finset.univ : Finset ι))
            (t := (Finset.univ : Finset κ))
            (g := g)
            (f := f)
            hmaps
        dsimp [rawPolySum, f, ι, κ]
        simpa only [Finset.mem_univ, if_true] using hsum

omit [Nontrivial k] in
lemma sum_collectedTerm_poly_eq_rawPolySum
    {A B : MinorIndex m n t}
    {hC : Close A B} :
    (∑ q : CollectedIndex (m := m) (n := n) (t := t) (k := k) A B hC,
      (collectedTerm (m := m) (n := n) (t := t) (k := k)
        (A := A) (B := B) (hC := hC) q).poly) =
      rawPolySum (m := m) (n := n) (t := t) (k := k) A B hC := by
  classical
  rw [show
      (∑ q : CollectedIndex (m := m) (n := n) (t := t) (k := k) A B hC,
        (collectedTerm (m := m) (n := n) (t := t) (k := k)
          (A := A) (B := B) (hC := hC) q).poly) =
        ∑ q : CollectedIndex (m := m) (n := n) (t := t) (k := k) A B hC,
          collectedFiberPolySum (m := m) (n := n) (t := t) (k := k)
            (A := A) (B := B) (hC := hC) q by
    refine Finset.sum_congr rfl ?_
    intro q _hq
    exact collectedTerm_poly_eq_sum_fiber
      (m := m) (n := n) (t := t) (k := k)
      (A := A) (B := B) (hC := hC) q]
  exact
    sum_collectedFiberPolySum_eq_rawPolySum
      (m := m) (n := n) (t := t) (k := k) (A := A) (B := B) (hC := hC)

omit [Nontrivial k] in
lemma exists_raw_of_collectedIndex
    {A B : MinorIndex m n t}
    {hC : Close A B}
    (q : CollectedIndex (m := m) (n := n) (t := t) (k := k) A B hC) :
