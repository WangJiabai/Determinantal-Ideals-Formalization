/-- Raw-term smallness in the equality case.

This is the genuine remaining mathematical content of the equality case.
After `hrowEq`, the middle block has width `1`, so the two tail families are
empty and the row/column nonprincipal Laplace terms are exactly the displayed
terms in the paper's equality-case formula.  The proof is the paper's
“direct inspection” of exponents.

Do not try to prove this from the strict-case smallness lemmas: those require
`rowExt B (uClose A B) < rowExt A (uClose A B)`, while here we are in the
equality case. -/
lemma closePairThm21_equal_rawTerm_small
    (ord : MonomialOrder (Fin m × Fin n))
    (hdiag : IsDiagonalTermOrder ord)
    (A B : MinorIndex m n t)
    (hC : Close A B)
    (hrowEq :
      rowExt B (uClose A B) = rowExt A (uClose A B))
    (i : ClosePairStrictBlock.StrictLaplaceRawIndex A B hC)
    (hc :
      (ClosePairStrictBlock.StrictLaplaceRawIndex.term
        (m := m) (n := n) (t := t) (k := k)
        (A := A) (B := B) (hC := hC) i).c ≠ 0) :
    ∀ a : k, a ≠ 0 →
      ord.toSyn
        (ord.degree
          (MvPolynomial.monomial
            (ClosePairStrictBlock.StrictLaplaceRawIndex.term
              (m := m) (n := n) (t := t) (k := k)
              (A := A) (B := B) (hC := hC) i).d
            a *
            genericMinor (k := k)
              (ClosePairStrictBlock.StrictLaplaceRawIndex.term
                (m := m) (n := n) (t := t) (k := k)
                (A := A) (B := B) (hC := hC) i).K))
      <
      ord.toSyn
        (headLcm ord
          (genericMinor (k := k) A)
          (genericMinor (k := k) B)) := by
  classical
  intro a ha
  have hwidth :
      ClosePairStrictBlock.width A B = 1 :=
    width_eq_one_of_uClose_row_eq A B hC hrowEq
  cases i with
  | inl col =>
      -- Column-expansion term: `φ D(α', δ)`, with `L ≠ colPrincipalChoice`.
      rcases col with ⟨L, σ⟩
      simpa [ClosePairStrictBlock.StrictLaplaceRawIndex.term,
        closePairThm21_case2_colTerm] using
        closePairThm21_equal_colTerm_small
          (m := m) (n := n) (t := t) (k := k)
          ord hdiag A B hC hrowEq L σ.1 σ.2
          (by
            simpa [ClosePairStrictBlock.StrictLaplaceRawIndex.term,
              closePairThm21_case2_colTerm] using hc)
          a ha
  | inr rest =>
      cases rest with
      | inl row =>
          -- Row-expansion term: `φ D(γ, β)`, with `L ≠ rowPrincipalChoice`.
          rcases row with ⟨L, σ⟩
          simpa [ClosePairStrictBlock.StrictLaplaceRawIndex.term,
            closePairThm21_case1_rowTerm] using
            closePairThm21_equal_rowTerm_small
              (m := m) (n := n) (t := t) (k := k)
              ord hdiag A B hC hrowEq L σ.1 σ.2
              (by
                simpa [ClosePairStrictBlock.StrictLaplaceRawIndex.term,
                  closePairThm21_case1_rowTerm] using hc)
              a ha
      | inr rest' =>
          cases rest' with
          | inl σ =>
              -- `det C - ΔC` tail.  Impossible when `width = 1`.
              haveI :
                  Subsingleton
                    (Equiv.Perm (Fin (ClosePairStrictBlock.width A B))) := by
                rw [hwidth]
                infer_instance
              exact False.elim (σ.2 (Subsingleton.elim σ.1 1))
          | inr σ =>
              -- `det B - ΔB` tail.  Impossible when `width = 1`.
              haveI :
                  Subsingleton
                    (Equiv.Perm (Fin (ClosePairStrictBlock.width A B))) := by
                rw [hwidth]
                infer_instance
              exact False.elim (σ.2 (Subsingleton.elim σ.1 1))

/-- The raw terms whose key is `q`.

This helper packages the `filter` together with an explicit classical
`DecidablePred`, avoiding synthesis failures for predicates of the form
`rawKey i = q`. -/
noncomputable def closePairThm21_equalRawFiber
    (A B : MinorIndex m n t)
    (hC : Close A B)
    (q : ClosePairStrictBlock.StrictLaplaceRawIndex.TermKey m n t) :
    Finset (ClosePairStrictBlock.StrictLaplaceRawIndex A B hC) := by
  classical
  let p :
      ClosePairStrictBlock.StrictLaplaceRawIndex A B hC → Prop :=
    fun i =>
      ClosePairStrictBlock.StrictLaplaceRawIndex.rawKey
        (m := m) (n := n) (t := t) (k := k)
        (A := A) (B := B) (hC := hC) i = q
  letI : DecidablePred p := fun i => Classical.propDecidable (p i)
  exact (Finset.univ.filter p)

