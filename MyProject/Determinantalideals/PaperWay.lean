            exact congrArg Fin.val hfin
        · have hrpos : 0 < r.1 := Nat.pos_of_ne_zero hr0
          let rPrev : Fin (support.length - 1) :=
            ⟨r.1 - 1, by omega⟩
          have hr_eq :
              r = ⟨rPrev.1 + 1, by omega⟩ := by
            apply Fin.ext
            dsimp [rPrev]
            omega
          let idx : Fin N := ⟨rPrev.1 + 1, by dsimp [N]; omega⟩
          have hrow_shift :
              L.minorIndex.row
                  (support.get ⟨rPrev.1 + 1, by omega⟩) =
                A.row (support.get ⟨rPrev.1, by omega⟩) := by
            simpa [rPrev] using
              List.IsChain.getElem hsupport_row_shift rPrev.1 (by omega)
          have hτ_idx :
              τ idx = ⟨r.1 + 1, by dsimp [N]; omega⟩ := by
            dsimp [τ, idx]
            apply Fin.ext
            rw [Fin.val_add]
            have hlt : (rPrev.1 + 1 + 1) < N := by
              dsimp [N, rPrev]
              omega
            have hmod :
                (rPrev.1 + 1 + 1) % N = rPrev.1 + 1 + 1 :=
              Nat.mod_eq_of_lt hlt
            simp [hmod, rPrev]
            omega
          have hget_eq :
              support.get r =
                support.get ⟨rPrev.1 + 1, by omega⟩ := by
            exact congrArg support.get hr_eq
          refine ⟨idx, ?_⟩
          ext
          · have hfin :
                L.minorIndex.row a = Klocal.row idx := by
              calc
                L.minorIndex.row a =
                    L.minorIndex.row (support.get r) := by rw [hr]
                _ =
                    L.minorIndex.row
                      (support.get ⟨rPrev.1 + 1, by omega⟩) := by
                      rw [hget_eq]
                _ = A.row (support.get ⟨rPrev.1, by omega⟩) :=
                      hrow_shift
                _ = Klocal.row idx := by
                      dsimp [idx]
                      exact (hK_row_succ ⟨rPrev.1, by omega⟩).symm
            exact congrArg Fin.val hfin
          · have hfin :
                L.minorIndex.col a = Klocal.col (τ idx) := by
              calc
                L.minorIndex.col a = A.col a := by
                  simp [ClosePairStrictBlock.RowLaplaceChoice.minorIndex_col]
                _ = A.col (support.get r) := by rw [hr]
                _ = Klocal.col ⟨r.1 + 1, by dsimp [N]; omega⟩ := by
                      exact (hK_col_succ r).symm
                _ = Klocal.col (τ idx) := by rw [hτ_idx]
            exact congrArg Fin.val hfin
      have hmin_witness_fixed_or_residual :
          ∀ a : Fin t,
            ¬ IsLocalCycleCoord
                (L.minorIndex.row a, L.minorIndex.col a) →
            ¬ IsLocalDiagCoord
                (L.minorIndex.row a, L.minorIndex.col a) →
              (L.minorIndex.row a = A.row a) ∨ HasResidual := by
        intro a ha_not_cycle ha_not_diag
        by_cases hfixed : L.minorIndex.row a = A.row a
        · exact Or.inl hfixed
        · right
          exact
            hHas_MissingMinWitnessOutsideLocal
              ⟨a,
                hminor_coord_not_inSupport_of_not_local_cycle
                  a hfixed ha_not_cycle,
                hfixed⟩
      have hcof_zero_of_fixed_min_noResidual :
          ∀ a : Fin t,
            ¬ IsLocalCycleCoord (A.row a, A.col a) →
            ¬ IsLocalDiagCoord (A.row a, A.col a) →
            L.minorIndex.row a = A.row a →
            NoResidual →
              cofExp (A.row a, A.col a) = 0 := by
        intro a hnotCycle hnotDiag hfixed hno'
        by_cases hzero : cofExp (A.row a, A.col a) = 0
        · exact hzero
        · exact False.elim
            (hno'
              (hHas_CofactorOverlapFixedMin
                ⟨a,
                  hA_diag_not_inSupport_of_not_local_diag a hnotDiag,
                  hfixed,
                  by simpa [cofExp] using hzero⟩))
      have hcof_witness_fixed_or_residual :
          ∀ s : Fin (ClosePairStrictBlock.width A B),
            ¬ IsLocalCycleCoord
                (L.cofactorRow (σ s), L.cofactorCol s) →
            ¬ IsLocalDiagCoord
                (L.cofactorRow (σ s), L.cofactorCol s) →
              (∃ midS : Fin t,
                midS.1 = sClose A B + s.1 ∧
                L.cofactorRow (σ s) = B.row midS ∧
                L.cofactorCol s = B.col midS) ∨
              HasResidual := by
        intro s hs_not_cycle hs_not_diag
        let midS : Fin t :=
          ⟨sClose A B + s.1, by
            have hsw : s.1 < uClose A B - sClose A B := s.2
            have hu : uClose A B ≤ t :=
              le_trans (uClose_le_pClose A B hC.ne) (pClose_le A B)
            omega⟩
        have hcof_col_s :
            L.cofactorCol s = B.col midS := by
          simpa [ClosePairStrictBlock.RowLaplaceChoice.cofactorCol, midS] using
            ClosePairStrictBlock.colFin_bMiddlePos A B hC s
        by_cases hfixed : L.cofactorRow (σ s) = B.row midS
        · left
          exact ⟨midS, rfl, hfixed, hcof_col_s⟩
        · right
          by_cases hsp : s = p
          · by_cases hclose : L.cofactorRow (σ p) = A.row q
            · exfalso
              apply hs_not_cycle
              have hmidS_eq : midS = midp := by
                apply Fin.ext
                rw [hmidp]
                dsimp [midS]
                rw [hsp]
              have hcoord :
                  (L.cofactorRow (σ s), L.cofactorCol s) =
                    (A.row q, B.col midp) := by
                ext
                · rw [hsp]
                  exact congrArg Fin.val hclose
                · rw [hcof_col_s, hmidS_eq]
              simpa [hcoord] using hclosing_cycle_coord
            · exact Or.inl hclose
          · exact
              hHas_CofactorNonfixedOutsideLocal
                ⟨s, midS, hsp, rfl, hfixed⟩
      have hmin_zero_of_fixed_cof_noResidual :
          ∀ s : Fin (ClosePairStrictBlock.width A B),
          ∀ midS : Fin t,
            ¬ IsLocalCycleCoord (B.row midS, B.col midS) →
            ¬ IsLocalDiagCoord (B.row midS, B.col midS) →
            midS.1 = sClose A B + s.1 →
            L.cofactorRow (σ s) = B.row midS →
            NoResidual →
              minExp (B.row midS, B.col midS) = 0 := by
        intro s midS hnotCycle hnotDiag hmidS hrow_fixed hno'
        by_cases hzero : minExp (B.row midS, B.col midS) = 0
        · exact hzero
        · exact False.elim
            (hno'
              (hHas_MinorOverlapFixedCof
                ⟨s, midS,
                  (by
                    intro hmid
                    apply hnotDiag
                    rw [hmid]
                    refine ⟨⟨0, hN_pos⟩, ?_⟩
                    ext
                    · exact congrArg Fin.val hK_row_zero.symm
                    · exact congrArg Fin.val hK_col_zero.symm),
                  hmidS, hrow_fixed, by simpa [minExp] using hzero⟩))
      have houtside_row_le_head :
          ∀ x,
            ¬ IsLocalCycleCoord x →
            ¬ IsLocalDiagCoord x →
              rowExp x ≤ headExp x := by
        intro x hxCycle hxDiag
        by_cases hxrow : rowExp x = 0
        · rw [hxrow]
          exact Nat.zero_le _
        rcases hrow_source x hxrow with hcof | hmin
        · /-
          Cofactor source outside the local cycle.  In the clean branch this
          must be an endpoint `B` diagonal coordinate; otherwise it is one of
          the residual cases packed in `HasResidual`.
          -/
          rcases hcof_source_witness x hcof with ⟨s, hsrow, hscol⟩
          have hx_coord :
              x = (L.cofactorRow (σ s), L.cofactorCol s) :=
            Prod.ext hsrow.symm hscol.symm
          have hclass :=
            hcof_witness_fixed_or_residual s
              (by
                intro hcy
                exact hxCycle (by simpa [hx_coord] using hcy))
              (by
                intro hdi
                exact hxDiag (by simpa [hx_coord] using hdi))
          rcases hclass with hfixed | hres
          · rcases hfixed with ⟨midS, hmidS, hrow_fixed, hcol_fixed⟩
            have hx_eq_Bdiag : x = (B.row midS, B.col midS) := by
              rw [hx_coord]
              exact Prod.ext hrow_fixed hcol_fixed
            have hcof_one : cofExp x = 1 := by
              rw [hx_coord]
              dsimp [cofExp]
              have hcofCol_inj : Function.Injective L.cofactorCol :=
                (ClosePairStrictBlock.colFin_bMiddlePos_strictMono A B hC).injective
              rw [MonomialCoefficientMatrix.permExp_apply_of_col_injective
                L.cofactorRow L.cofactorCol σ hcofCol_inj]
              exact if_pos ⟨s, rfl, rfl⟩
            have hmin_zero : minExp x = 0 := by
              rw [hx_eq_Bdiag]
              exact
                hmin_zero_of_fixed_cof_noResidual s midS
                  (by
                    intro h
                    exact hxCycle (by simpa [hx_eq_Bdiag] using h))
                  (by
                    intro h
                    exact hxDiag (by simpa [hx_eq_Bdiag] using h))
                  hmidS hrow_fixed hno
            have hrow_one : rowExp x = 1 := by
              rw [hrowExp_eq_cof_add_min]
              change cofExp x + minExp x = 1
              rw [hcof_one, hmin_zero]
            have hhead_one : headExp x = 1 := by
              rw [hx_eq_Bdiag]
              dsimp [headExp]
              rw [headLcm_genericMinor_eq_sup_diagExp (k := k) ord hdiag A B]
              change
                max
                    (diagExp A (B.row midS, B.col midS))
                    (diagExp B (B.row midS, B.col midS)) =
                  1
              have hB_one :
                  diagExp B (B.row midS, B.col midS) = 1 := by
                rw [diagExp_apply]
                exact if_pos ⟨midS, rfl, rfl⟩
              have hA_le :
                  diagExp A (B.row midS, B.col midS) ≤ 1 :=
                diagExp_apply_le_one A (B.row midS, B.col midS)
              rw [hB_one]
              omega
            rw [hrow_one, hhead_one]
          · exact False.elim (hno hres)
        · /-
          Selected-minor source outside the local cycle/diagonal.  The next
          step is to extract the minor diagonal witness and show that any
          non-endpoint-lcm coordinate is already a `ClosingMinorOverlap` or
          another residual covered by `HasResidual`.
          -/
          rcases hmin_source_witness x hmin with ⟨a, harow, hacol⟩
          have hx_coord :
              x = (L.minorIndex.row a, L.minorIndex.col a) :=
            Prod.ext harow.symm hacol.symm
          have hclass :=
            hmin_witness_fixed_or_residual a
              (by
                intro hcy
                exact hxCycle (by simpa [hx_coord] using hcy))
              (by
                intro hdi
                exact hxDiag (by simpa [hx_coord] using hdi))
          rcases hclass with hfixed | hres
          · have hx_eq_A_diag : x = (A.row a, A.col a) := by
              rw [hx_coord]
              ext
              · simpa using congrArg Fin.val hfixed
              · simp [ClosePairStrictBlock.RowLaplaceChoice.minorIndex_col]
            have hmin_one : minExp x = 1 := by
              rw [hx_coord]
              dsimp [minExp]
              rw [diagExp_apply]
              exact if_pos ⟨a, rfl, rfl⟩
            have hcof_zero : cofExp x = 0 := by
              rw [hx_eq_A_diag]
              exact
                hcof_zero_of_fixed_min_noResidual a
                  (by
                    intro h
                    exact hxCycle (by simpa [hx_eq_A_diag] using h))
                  (by
                    intro h
                    exact hxDiag (by simpa [hx_eq_A_diag] using h))
                  hfixed hno
            have hrow_one : rowExp x = 1 := by
              rw [hrowExp_eq_cof_add_min]
              change cofExp x + minExp x = 1
              rw [hcof_zero, hmin_one]
            have hhead_one : headExp x = 1 := by
              rw [hx_eq_A_diag]
              dsimp [headExp]
              rw [headLcm_genericMinor_eq_sup_diagExp (k := k) ord hdiag A B]
              change
                max
                    (diagExp A (A.row a, A.col a))
                    (diagExp B (A.row a, A.col a)) =
                  1
              have hA_one :
                  diagExp A (A.row a, A.col a) = 1 := by
                rw [diagExp_apply]
                exact if_pos ⟨a, rfl, rfl⟩
              have hB_le :
                  diagExp B (A.row a, A.col a) ≤ 1 :=
                diagExp_apply_le_one B (A.row a, A.col a)
              rw [hA_one]
              omega
            rw [hrow_one, hhead_one]
          · exact False.elim (hno hres)
      have hhead_le_one :
          ∀ x, headExp x ≤ 1 := by
        intro x
        dsimp [headExp]
        rw [headLcm_genericMinor_eq_sup_diagExp (k := k) ord hdiag A B]
        change max (diagExp A x) (diagExp B x) ≤ 1
        have hA : diagExp A x ≤ 1 :=
          diagExp_apply_le_one A x
        have hB : diagExp B x ≤ 1 :=
          diagExp_apply_le_one B x
        omega
      have hA_diag_covered_or_residual :
          ∀ a : Fin t,
            ¬ IsLocalCycleCoord (A.row a, A.col a) →
            ¬ IsLocalDiagCoord (A.row a, A.col a) →
              minExp (A.row a, A.col a) = 1 ∨ HasResidual := by
        intro a hnotCycle hnotDiag
        by_cases hfixed : L.minorIndex.row a = A.row a
        · left
          dsimp [minExp]
          rw [diagExp_apply]
          refine if_pos ?_
          refine ⟨a, hfixed, ?_⟩
          simp [ClosePairStrictBlock.RowLaplaceChoice.minorIndex_col]
        · right
          exact
            hHas_MissingADiagOutsideLocal
              ⟨a,
                hA_diag_not_inSupport_of_not_local_diag a hnotDiag,
                hfixed⟩
      have hB_diag_covered_or_residual :
          ∀ b : Fin t,
            ¬ IsLocalCycleCoord (B.row b, B.col b) →
            ¬ IsLocalDiagCoord (B.row b, B.col b) →
              1 ≤ rowExp (B.row b, B.col b) ∨ HasResidual := by
        intro b hnotCycle hnotDiag
        by_cases hrow_pos : 1 ≤ rowExp (B.row b, B.col b)
        · exact Or.inl hrow_pos
        · have hb_ne_midp : b ≠ midp := by
            intro hb
            apply hnotDiag
            rw [hb]
            refine ⟨⟨0, hN_pos⟩, ?_⟩
            ext
            · exact congrArg Fin.val hK_row_zero.symm
            · exact congrArg Fin.val hK_col_zero.symm
          have hrow_zero :
              rowExp (B.row b, B.col b) = 0 := by
            omega
          have hcof_ne_one :
              cofExp (B.row b, B.col b) ≠ 1 := by
            intro hcof_one
            have hrow_pos' : 1 ≤ rowExp (B.row b, B.col b) := by
              rw [hrowExp_eq_cof_add_min]
              change
                1 ≤ cofExp (B.row b, B.col b) +
                  minExp (B.row b, B.col b)
              rw [hcof_one]
              omega
            exact hrow_pos hrow_pos'
          by_cases hbmid : sClose A B ≤ b.1 ∧ b.1 < uClose A B
          · exact Or.inr
              (hHas_MissingBMiddleCofDiagOutsideLocal
                ⟨b, hb_ne_midp, hbmid.1, hbmid.2,
                  by simpa [cofExp] using hcof_ne_one⟩)
          · exact Or.inr
              (hHas_MissingBNonMiddleDiagOutsideLocal
                ⟨b, hb_ne_midp, hbmid,
                  by simpa [rowExp] using (by
                    intro hbad
                    exact hrow_pos (by rw [hbad]))⟩)
      have houtside_head_le_row :
          ∀ x,
            ¬ IsLocalCycleCoord x →
            ¬ IsLocalDiagCoord x →
              headExp x ≤ rowExp x := by
        intro x hxCycle hxDiag
        by_cases hxhead : headExp x = 0
        · rw [hxhead]
          exact Nat.zero_le _
        rcases hhead_source x hxhead with hA | hB
        · rw [diagExp_apply] at hA
          have hhit :
              ∃ a : Fin t, A.row a = x.1 ∧ A.col a = x.2
              := by
            by_contra hnot
            rw [if_neg hnot] at hA
            exact (hA rfl).elim
          rcases hhit with ⟨a, hrowa, hcola⟩
          have hx_eq : x = (A.row a, A.col a) := by
            exact Prod.ext hrowa.symm hcola.symm
          rcases
            hA_diag_covered_or_residual a
              (by
                intro h
                exact hxCycle (by simpa [hx_eq] using h))
              (by
                intro h
                exact hxDiag (by simpa [hx_eq] using h))
            with hmin_one | hres
          · have hrow_pos : 1 ≤ rowExp x := by
              rw [hrowExp_eq_cof_add_min]
              rw [hx_eq]
              change
                1 ≤ cofExp (A.row a, A.col a) +
                  minExp (A.row a, A.col a)
              rw [hmin_one]
              omega
            exact le_trans (hhead_le_one x) hrow_pos
          · exact False.elim (hno hres)
        · rw [diagExp_apply] at hB
          have hhit :
              ∃ b : Fin t, B.row b = x.1 ∧ B.col b = x.2
              := by
            by_contra hnot
            rw [if_neg hnot] at hB
            exact (hB rfl).elim
          rcases hhit with ⟨b, hrowb, hcolb⟩
          have hx_eq : x = (B.row b, B.col b) := by
            exact Prod.ext hrowb.symm hcolb.symm
          rcases
            hB_diag_covered_or_residual b
              (by
                intro h
                exact hxCycle (by simpa [hx_eq] using h))
              (by
                intro h
                exact hxDiag (by simpa [hx_eq] using h))
            with hrow_pos | hres
          · exact le_trans (hhead_le_one x) (by simpa [hx_eq] using hrow_pos)
          · exact False.elim (hno hres)
      have houtside_eq :
          ∀ x,
            ¬ IsLocalCycleCoord x →
            ¬ IsLocalDiagCoord x →
              rowExp x = headExp x := by
        intro x hxCycle hxDiag
        exact le_antisymm
          (houtside_row_le_head x hxCycle hxDiag)
          (houtside_head_le_row x hxCycle hxDiag)
      have hcommon_eq : commonRow = commonHead :=
        hcommon_eq_of_outside houtside_eq
      have hlocal_cycle_lt' :
          ord.toSyn cycleExp < ord.toSyn localDiag := by
        simpa [cycleExp, localDiag] using hlocal_cycle_lt
      have hlocal_plus :
          ord.toSyn (cycleExp + commonRow) <
            ord.toSyn (localDiag + commonRow) :=
        toSyn_add_lt_add_right (ord := ord) (c := commonRow) hlocal_cycle_lt'
      have hsmall : ord.toSyn rowExp < ord.toSyn headExp := by
        rw [hrow_decomp, hhead_decomp]
        rw [← hcommon_eq]
        exact hlocal_plus
      simpa [rowExp, headExp] using hsmall
    by_cases hres : HasResidual
    · exact htail_residual_lt hres
    · exact htail_simple_closed_cycle_lt hres

/-
/-- Gap branch of the local StatementB induction step.

Assuming the failed `A` diagonal coordinate is absent from the whole displayed
row term, the already-proved upper part of the current `u`-interval and the
previous chain statements force the displayed monomial below the endpoint
lcm. -/
lemma closePairThm21_case1_statementB_gap_branch_lt_of_above_prev
    (ord : MonomialOrder (Fin m × Fin n))
    (hdiag : IsDiagonalTermOrder ord)
    (A B : MinorIndex m n t)
    (hC : Close A B)
    (hrowLt :
      rowExt B (uClose A B) < rowExt A (uClose A B))
    (L : ClosePairStrictBlock.RowLaplaceChoice A B hC)
    (σ : Equiv.Perm (Fin (ClosePairStrictBlock.width A B)))
    (hc :
      (closePairThm21_case1_rowTerm
        (m := m) (n := n) (t := t) (k := k) A B hC L σ).c ≠ 0)
    (_hnot :
      ¬ ord.toSyn
          (closePairThm21_case1_rowTermExp
            (m := m) (n := n) (t := t) (k := k) A B hC L σ)
        <
        ord.toSyn
          (headLcm ord
            (genericMinor (k := k) A)
            (genericMinor (k := k) B)))
    (U : Case1UVChain A B hC)
    (i : Fin U.q)
    (F : StatementBFailure A B hC L U)
    (hFi : F.i = i)
    (hzero :
      closePairThm21_case1_rowTermExp
        (m := m) (n := n) (t := t) (k := k) A B hC L σ
        (A.row F.idx, A.col F.idx) = 0)
    (habove : StatementBAbove A B hC L U i F.j)
    (hprevA :
      ∀ j : Fin U.q, j.1 < i.1 → StatementA A B hC L U j)
    (hprevB :
      ∀ j : Fin U.q, j.1 < i.1 → StatementB A B hC L U j)
    (hprevC :
      ∀ j : Fin U.q, j.1 < i.1 → StatementC A B hC L σ U j) :
    ord.toSyn
        (closePairThm21_case1_rowTermExp
          (m := m) (n := n) (t := t) (k := k) A B hC L σ)
      <
      ord.toSyn
        (headLcm ord
          (genericMinor (k := k) A)
          (genericMinor (k := k) B)) := by
  classical
  have hoff :
      ∃ q : Fin t,
        (q < F.idx ∨ uClose A B ≤ q.1) ∧
          q ≠ F.idx ∧
          L.minorIndex.row q = A.row F.idx :=
    closePairThm21_case1_gap_A_row_occurs_below_or_tail
      (m := m) (n := n) (t := t) (k := k)
      A B hC L σ hc U i F hFi habove hprevB
  rcases hoff with ⟨q, hcase, hqne, hqrow⟩
  rcases hcase with hbelow | htail
  · exact
      closePairThm21_case1_gap_minor_displacement_lt_of_below
        (m := m) (n := n) (t := t) (k := k)
        ord hdiag A B hC hrowLt L σ hc U i F hFi
        hzero habove hprevA hprevB hprevC q hbelow hqrow
  · exact
      closePairThm21_case1_gap_minor_displacement_lt_of_tail
        (m := m) (n := n) (t := t) (k := k)
        ord hdiag A B hC hrowLt L σ hc U i F hFi
        hzero habove hprevA hprevB hprevC q htail hqne hqrow

/-- In the local Case 1 StatementB step, non-smallness forces the failed
`A` diagonal variable to occur in the displayed row-term exponent.

This is the exact local fact needed to close the gap branch; it is deliberately
weaker than the global statement `diagExp A ≤ rowTermExp`. -/
lemma closePairThm21_case1_statementB_failure_coord_pos_of_not_lt_prev
    (ord : MonomialOrder (Fin m × Fin n))
    (hdiag : IsDiagonalTermOrder ord)
    (A B : MinorIndex m n t)
    (hC : Close A B)
    (hrowLt :
      rowExt B (uClose A B) < rowExt A (uClose A B))
    (L : ClosePairStrictBlock.RowLaplaceChoice A B hC)
    (σ : Equiv.Perm (Fin (ClosePairStrictBlock.width A B)))
    (hc :
      (closePairThm21_case1_rowTerm
        (m := m) (n := n) (t := t) (k := k) A B hC L σ).c ≠ 0)
    (hnot :
      ¬ ord.toSyn
          (closePairThm21_case1_rowTermExp
            (m := m) (n := n) (t := t) (k := k) A B hC L σ)
        <
        ord.toSyn
          (headLcm ord
            (genericMinor (k := k) A)
            (genericMinor (k := k) B)))
    (U : Case1UVChain A B hC)
    (i : Fin U.q)
    (F : StatementBFailure A B hC L U)
    (hFi : F.i = i)
    (hprevA :
