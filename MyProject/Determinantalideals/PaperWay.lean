/-- If a raw column choice is not sortable, its selected minor determinant
vanishes. -/
lemma rawColLaplace_minorDet_eq_zero_of_not_sortable
    (A B : MinorIndex m n t)
    (hC : Close A B)
    (R : RawColLaplaceChoice A B hC)
    (hbad : ¬ R.Sortable) :
    Matrix.det
      (Matrix.submatrix
        (ClosePairStrictBlock.matrix
          (m := m) (n := n) (t := t) (k := k) A B)
        (ClosePairStrictBlock.bRowPos A B hC)
        R.minorCols) = 0 := by
  classical
  rw [RawColLaplaceChoice.Sortable] at hbad
  rcases Function.not_injective_iff.mp hbad with ⟨i, j, hcol, hij⟩
  apply Matrix.det_zero_of_column_eq hij
  intro r
  change
    ClosePairStrictBlock.matrix
        (m := m) (n := n) (t := t) (k := k) A B
        (ClosePairStrictBlock.bRowPos A B hC r) (R.minorCols i) =
      ClosePairStrictBlock.matrix
        (m := m) (n := n) (t := t) (k := k) A B
        (ClosePairStrictBlock.bRowPos A B hC r) (R.minorCols j)
  have hnotLeft : ¬ ClosePairStrictBlock.zeroBlock A B
      (ClosePairStrictBlock.bRowPos A B hC r).1 (R.minorCols i).1 := by
    intro hzero
    rcases hzero with ⟨ha, _hb⟩
    have hnot : ¬ ClosePairStrictBlock.aRepeatedMiddle A B
        (ClosePairStrictBlock.bRowPos A B hC r).1 := by
      by_cases hs : r.1 < sClose A B
      · rw [ClosePairStrictBlock.bRowPos_of_prefix A B hC hs]
        have hsu : sClose A B < uClose A B :=
          sClose_lt_uClose A B hC.ne
        unfold ClosePairStrictBlock.aRepeatedMiddle
        omega
      · by_cases hu : r.1 < uClose A B
        · rw [ClosePairStrictBlock.bRowPos_of_middle A B hC hs hu]
          unfold ClosePairStrictBlock.aRepeatedMiddle
          omega
        · rw [ClosePairStrictBlock.bRowPos_of_tail A B hC hs hu]
          unfold ClosePairStrictBlock.aRepeatedMiddle ClosePairStrictBlock.width
          omega
    exact hnot ha
  have hnotRight : ¬ ClosePairStrictBlock.zeroBlock A B
      (ClosePairStrictBlock.bRowPos A B hC r).1 (R.minorCols j).1 := by
    intro hzero
    rcases hzero with ⟨ha, _hb⟩
    have hnot : ¬ ClosePairStrictBlock.aRepeatedMiddle A B
        (ClosePairStrictBlock.bRowPos A B hC r).1 := by
      by_cases hs : r.1 < sClose A B
      · rw [ClosePairStrictBlock.bRowPos_of_prefix A B hC hs]
        have hsu : sClose A B < uClose A B :=
          sClose_lt_uClose A B hC.ne
        unfold ClosePairStrictBlock.aRepeatedMiddle
        omega
      · by_cases hu : r.1 < uClose A B
        · rw [ClosePairStrictBlock.bRowPos_of_middle A B hC hs hu]
          unfold ClosePairStrictBlock.aRepeatedMiddle
          omega
        · rw [ClosePairStrictBlock.bRowPos_of_tail A B hC hs hu]
          unfold ClosePairStrictBlock.aRepeatedMiddle ClosePairStrictBlock.width
          omega
    exact hnot ha
  rw [ClosePairStrictBlock.matrix_entry_of_not_zeroBlock_as_X'
    (m := m) (n := n) (t := t) (k := k) A B hC hnotLeft]
  rw [ClosePairStrictBlock.matrix_entry_of_not_zeroBlock_as_X'
    (m := m) (n := n) (t := t) (k := k) A B hC hnotRight]
  simp [hcol]

omit [Nontrivial k] in
/-- If a raw column choice is not sortable, its raw summand vanishes. -/
lemma rawColLaplaceSummand_eq_zero_of_not_sortable
    (A B : MinorIndex m n t)
    (hC : Close A B)
    (R : RawColLaplaceChoice A B hC)
    (hbad : ¬ R.Sortable) :
    rawColLaplaceSummand
        (m := m) (n := n) (t := t) (k := k) A B hC R = 0 := by
  classical
  rw [rawColLaplaceSummand]
  rw [rawColLaplace_minorDet_eq_zero_of_not_sortable
    (m := m) (n := n) (t := t) (k := k) A B hC R hbad]
  simp

/-- Normalize a sortable raw column choice to a paper-style `ColLaplaceChoice`.

Only selected minor columns are sorted by actual `colFin`; cofactor columns
remain in matrix-position order. -/
noncomputable def colChoiceOfSortableRaw
    (A B : MinorIndex m n t)
    (hC : Close A B)
    (R : RawColLaplaceChoice A B hC)
    (hR : R.Sortable) :
    ClosePairStrictBlock.ColLaplaceChoice A B hC := by
  classical
  let minorColFin : Fin t → Fin n :=
    fun i => ClosePairStrictBlock.colFin A B hC (R.minorCols i)
  let minorSort : Equiv.Perm (Fin t) :=
    Tuple.sort minorColFin
  let shuffle :
      Fin t ⊕ Fin (ClosePairStrictBlock.width A B) ≃
        Fin (ClosePairStrictBlock.size A B) :=
    (Equiv.sumCongr minorSort
      (Equiv.refl (Fin (ClosePairStrictBlock.width A B)))).trans R.shuffle
  refine
    { shuffle := shuffle
      minorCols := fun i => R.minorCols (minorSort i)
      cofactorCols := R.cofactorCols
      minorCols_eq_shuffle := ?_
      cofactorCols_eq_shuffle := ?_
      minorColsStrict := ?_
      cofactorColsStrict := ?_ }
  · intro i
    rfl
  · intro i
    rfl
  · intro i j hij
    have hmono :
        StrictMono (fun i : Fin t => (minorColFin (minorSort i)).1) :=
      strictMono_val_comp_tuple_sort_of_injective minorColFin hR
    exact hmono hij
  · intro i j hij
    exact R.cofactorColsPosStrict hij

@[simp] lemma colChoiceOfSortableRaw_minorCols
    (A B : MinorIndex m n t)
    (hC : Close A B)
    (R : RawColLaplaceChoice A B hC)
    (hR : R.Sortable)
    (i : Fin t) :
    (colChoiceOfSortableRaw (m := m) (n := n) (t := t) A B hC R hR).minorCols i =
      R.minorCols
        (Tuple.sort
          (fun i => ClosePairStrictBlock.colFin A B hC (R.minorCols i)) i) := by
  simp [colChoiceOfSortableRaw]

@[simp] lemma colChoiceOfSortableRaw_cofactorCols
    (A B : MinorIndex m n t)
    (hC : Close A B)
    (R : RawColLaplaceChoice A B hC)
    (hR : R.Sortable)
    (i : Fin (ClosePairStrictBlock.width A B)) :
    (colChoiceOfSortableRaw (m := m) (n := n) (t := t) A B hC R hR).cofactorCols i =
      R.cofactorCols i := by
  simp [colChoiceOfSortableRaw]

@[simp] lemma colChoiceOfSortableRaw_shuffle
    (A B : MinorIndex m n t)
    (hC : Close A B)
    (R : RawColLaplaceChoice A B hC)
    (hR : R.Sortable) :
    (colChoiceOfSortableRaw (m := m) (n := n) (t := t) A B hC R hR).shuffle =
      (Equiv.sumCongr
        (Tuple.sort
          (fun i => ClosePairStrictBlock.colFin A B hC (R.minorCols i)))
        (Equiv.refl (Fin (ClosePairStrictBlock.width A B)))).trans R.shuffle := by
  simp [colChoiceOfSortableRaw]

lemma colLaplacePerm_colChoiceOfSortableRaw
    (A B : MinorIndex m n t)
    (hC : Close A B)
    (R : RawColLaplaceChoice A B hC)
    (hR : R.Sortable)
    (τ : Equiv.Perm (Fin t))
    (σ : Equiv.Perm (Fin (ClosePairStrictBlock.width A B))) :
    ClosePairStrictBlock.colLaplacePerm A B hC
        (colChoiceOfSortableRaw
          (m := m) (n := n) (t := t) A B hC R hR)
        τ σ =
      rawColLaplacePerm A B hC R
        ((Tuple.sort
            (fun i => ClosePairStrictBlock.colFin A B hC (R.minorCols i))).symm.trans τ)
        σ := by
  ext x
  simp [ClosePairStrictBlock.colLaplacePerm, rawColLaplacePerm, colChoiceOfSortableRaw,
    RawColLaplaceChoice.minorCols]

/-- Forget a `ColLaplaceChoice` back to a position-sorted raw column choice.

The minor columns of a `ColLaplaceChoice` are sorted by actual column
variables, so we sort them back by matrix position.  Cofactor columns are
already position-sorted and are kept unchanged. -/
noncomputable def rawChoiceOfColChoice
    (A B : MinorIndex m n t)
    (hC : Close A B)
    (L : ClosePairStrictBlock.ColLaplaceChoice A B hC) :
    RawColLaplaceChoice A B hC := by
  classical
  let minorPosSort : Equiv.Perm (Fin t) :=
    Tuple.sort L.minorCols
  let shuffle :
      Fin t ⊕ Fin (ClosePairStrictBlock.width A B) ≃
        Fin (ClosePairStrictBlock.size A B) :=
    (Equiv.sumCongr minorPosSort
      (Equiv.refl (Fin (ClosePairStrictBlock.width A B)))).trans L.shuffle
  refine
    { shuffle := shuffle
      minorColsPosStrict := ?_
      cofactorColsPosStrict := ?_ }
  · have hminorInj : Function.Injective L.minorCols := by
      intro i j hij
      have h :
          L.shuffle (Sum.inl i) = L.shuffle (Sum.inl j) := by
        simpa [ClosePairStrictBlock.ColLaplaceChoice.minorCols_eq_shuffle] using hij
      exact Sum.inl_injective (L.shuffle.injective h)
    simpa [shuffle, minorPosSort, ClosePairStrictBlock.ColLaplaceChoice.minorCols_eq_shuffle]
      using strictMono_val_comp_tuple_sort_of_injective L.minorCols hminorInj
  · intro i j hij
    simpa [shuffle, L.cofactorCols_eq_shuffle] using
      L.cofactorColsStrict hij

lemma rawChoiceOfColChoice_sortable
    (A B : MinorIndex m n t)
    (hC : Close A B)
    (L : ClosePairStrictBlock.ColLaplaceChoice A B hC) :
    (rawChoiceOfColChoice (m := m) (n := n) (t := t) A B hC L).Sortable := by
  classical
  rw [RawColLaplaceChoice.Sortable]
  intro i j hij
  apply (Tuple.sort L.minorCols).injective
  apply L.minorColsStrict.injective
  change
      ClosePairStrictBlock.colFin A B hC
          ((rawChoiceOfColChoice (m := m) (n := n) (t := t) A B hC L).shuffle
            (Sum.inl i)) =
        ClosePairStrictBlock.colFin A B hC
          ((rawChoiceOfColChoice (m := m) (n := n) (t := t) A B hC L).shuffle
            (Sum.inl j)) at hij
  simp only [rawChoiceOfColChoice, Equiv.trans_apply, Equiv.sumCongr_apply, Equiv.coe_refl,
    Sum.map_inl] at hij
  rw [← L.minorCols_eq_shuffle ((Tuple.sort L.minorCols) i),
    ← L.minorCols_eq_shuffle ((Tuple.sort L.minorCols) j)] at hij
  exact hij

omit [Nontrivial k] in
/-- The normalized column choice has the same Laplace summand as the original
sortable raw column choice. -/
lemma rawColLaplaceSummand_eq_strictColLaplaceSummand_of_sortable
    (A B : MinorIndex m n t)
    (hC : Close A B)
    (R : RawColLaplaceChoice A B hC)
    (hR : R.Sortable) :
    rawColLaplaceSummand
        (m := m) (n := n) (t := t) (k := k) A B hC R =
      strictColLaplaceSummand
        (m := m) (n := n) (t := t) (k := k) A B hC
        (colChoiceOfSortableRaw
          (m := m) (n := n) (t := t) A B hC R hR) := by
  classical
  let L : ClosePairStrictBlock.ColLaplaceChoice A B hC :=
    colChoiceOfSortableRaw (m := m) (n := n) (t := t) A B hC R hR
  let s : Equiv.Perm (Fin t) :=
    Tuple.sort
      (fun i => ClosePairStrictBlock.colFin A B hC (R.minorCols i))
  let detTerm : Equiv.Perm (Fin (ClosePairStrictBlock.size A B)) →
      MvPolynomial (Fin m × Fin n) k :=
    fun ρ =>
      ClosePairStrictBlock.laplaceShuffleSign
          (k := MvPolynomial (Fin m × Fin n) k) ρ *
        ∏ j : Fin (ClosePairStrictBlock.size A B),
          ClosePairStrictBlock.matrix
            (m := m) (n := n) (t := t) (k := k) A B (ρ j) j
  rw [rawColLaplaceSummand_eq_sum_rawColLaplacePerm_terms
    (m := m) (n := n) (t := t) (k := k) A B hC R]
  rw [strictColLaplaceSummand_eq_sum_colLaplacePerm_terms
    (m := m) (n := n) (t := t) (k := k) A B hC L]
  change
    (∑ p : Equiv.Perm (Fin t) ×
        Equiv.Perm (Fin (ClosePairStrictBlock.width A B)),
      detTerm (rawColLaplacePerm A B hC R p.1 p.2)) =
    ∑ p : Equiv.Perm (Fin t) ×
        Equiv.Perm (Fin (ClosePairStrictBlock.width A B)),
      detTerm (ClosePairStrictBlock.colLaplacePerm A B hC L p.1 p.2)
  let e :
      (Equiv.Perm (Fin t) ×
        Equiv.Perm (Fin (ClosePairStrictBlock.width A B))) ≃
      (Equiv.Perm (Fin t) ×
        Equiv.Perm (Fin (ClosePairStrictBlock.width A B))) :=
    { toFun := fun p => (s.trans p.1, p.2)
      invFun := fun p => (s.symm.trans p.1, p.2)
      left_inv := by
        intro p
        cases p with
        | mk τ σ =>
            apply Prod.ext
            · ext i
              simp [s]
            · rfl
      right_inv := by
        intro p
        cases p with
        | mk τ σ =>
            apply Prod.ext
            · ext i
              simp [s]
            · rfl }
  calc
    (∑ p : Equiv.Perm (Fin t) ×
        Equiv.Perm (Fin (ClosePairStrictBlock.width A B)),
      detTerm (rawColLaplacePerm A B hC R p.1 p.2))
        =
      ∑ p : Equiv.Perm (Fin t) ×
          Equiv.Perm (Fin (ClosePairStrictBlock.width A B)),
        detTerm (ClosePairStrictBlock.colLaplacePerm A B hC L
          (s.trans p.1) p.2) := by
        refine Finset.sum_congr rfl ?_
        intro p _hp
        have hτ : s.symm.trans (s.trans p.1) = p.1 := by
          ext i
          simp [s]
        have hperm :
            ClosePairStrictBlock.colLaplacePerm A B hC L
                (s.trans p.1) p.2 =
              rawColLaplacePerm A B hC R p.1 p.2 := by
          rw [show L =
              colChoiceOfSortableRaw
                (m := m) (n := n) (t := t) A B hC R hR from rfl]
          rw [colLaplacePerm_colChoiceOfSortableRaw
            (m := m) (n := n) (t := t) A B hC R hR
            (s.trans p.1) p.2]
          simpa [s] using congrArg
            (fun τ' => rawColLaplacePerm A B hC R τ' p.2) hτ
        rw [hperm]
    _ =
      ∑ p : Equiv.Perm (Fin t) ×
          Equiv.Perm (Fin (ClosePairStrictBlock.width A B)),
        detTerm (ClosePairStrictBlock.colLaplacePerm A B hC L p.1 p.2) := by
        exact Fintype.sum_equiv e
          (fun p =>
            detTerm (ClosePairStrictBlock.colLaplacePerm A B hC L
              (s.trans p.1) p.2))
          (fun p =>
            detTerm (ClosePairStrictBlock.colLaplacePerm A B hC L p.1 p.2))
          (by intro p; rfl)

/-- Sortable raw column choices are equivalent to `ColLaplaceChoice`. -/
noncomputable def sortableRawColChoiceEquivColChoice
    (A B : MinorIndex m n t)
    (hC : Close A B) :
    {R : RawColLaplaceChoice A B hC // R.Sortable} ≃
      ClosePairStrictBlock.ColLaplaceChoice A B hC := by
  classical
  refine
    { toFun := fun R =>
        colChoiceOfSortableRaw
          (m := m) (n := n) (t := t) A B hC R.1 R.2
      invFun := fun L =>
        ⟨rawChoiceOfColChoice
            (m := m) (n := n) (t := t) A B hC L,
          rawChoiceOfColChoice_sortable
            (m := m) (n := n) (t := t) A B hC L⟩
      left_inv := ?_
      right_inv := ?_ }
  · intro R
    cases R with
    | mk R hR =>
      let minorColFin : Fin t → Fin n :=
        fun i => ClosePairStrictBlock.colFin A B hC (R.minorCols i)
      let minorSort : Equiv.Perm (Fin t) := Tuple.sort minorColFin
      have hposSort :
          Tuple.sort
              (colChoiceOfSortableRaw
                (m := m) (n := n) (t := t) A B hC R hR).minorCols =
            minorSort.symm := by
        apply tuple_sort_eq_of_strictMono_val_comp
        intro i j hij
        change
          (R.minorCols (minorSort (minorSort.symm i))).1 <
            (R.minorCols (minorSort (minorSort.symm j))).1
        simpa using R.minorColsPosStrict hij
      apply Subtype.ext
      apply RawColLaplaceChoice.ext_shuffle
      simp only [rawChoiceOfColChoice]
      rw [hposSort]
      rw [colChoiceOfSortableRaw_shuffle
        (m := m) (n := n) (t := t) A B hC R hR]
      ext x
      cases x with
      | inl i =>
          simp only [Equiv.trans_apply, Equiv.sumCongr_apply, Equiv.coe_refl,
            Sum.map_inl]
          have hs :
              (Tuple.sort
                (fun i => ClosePairStrictBlock.colFin A B hC (R.minorCols i)))
                  (minorSort.symm i) = i := by
            change minorSort (minorSort.symm i) = i
            simp
          rw [hs]
      | inr i =>
          simp
  · intro L
    let R : RawColLaplaceChoice A B hC :=
      rawChoiceOfColChoice (m := m) (n := n) (t := t) A B hC L
    let hR : R.Sortable :=
      rawChoiceOfColChoice_sortable
        (m := m) (n := n) (t := t) A B hC L
    let minorPosSort : Equiv.Perm (Fin t) := Tuple.sort L.minorCols
    have hcolSort :
        Tuple.sort
            (fun i : Fin t =>
              ClosePairStrictBlock.colFin A B hC (R.minorCols i)) =
          minorPosSort.symm := by
      apply tuple_sort_eq_of_strictMono_val_comp
      intro i j hij
      have hi : R.minorCols (minorPosSort.symm i) = L.minorCols i := by
        simpa [R, rawChoiceOfColChoice, RawColLaplaceChoice.minorCols,
          minorPosSort] using (L.minorCols_eq_shuffle i).symm
      have hj : R.minorCols (minorPosSort.symm j) = L.minorCols j := by
        simpa [R, rawChoiceOfColChoice, RawColLaplaceChoice.minorCols,
          minorPosSort] using (L.minorCols_eq_shuffle j).symm
      simpa [hi, hj] using L.minorColsStrict hij
    apply ClosePairStrictBlock.ColLaplaceChoice.ext_data
    · change
        (colChoiceOfSortableRaw
          (m := m) (n := n) (t := t) A B hC R hR).shuffle = L.shuffle
      rw [colChoiceOfSortableRaw_shuffle
        (m := m) (n := n) (t := t) A B hC R hR]
      rw [hcolSort]
      ext x
      cases x with
      | inl i =>
          simp [R, rawChoiceOfColChoice, minorPosSort]
      | inr i =>
          simp [R, rawChoiceOfColChoice]
    · funext i
      change
        (colChoiceOfSortableRaw
          (m := m) (n := n) (t := t) A B hC R hR).minorCols i =
          L.minorCols i
      rw [colChoiceOfSortableRaw_minorCols
        (m := m) (n := n) (t := t) A B hC R hR i]
      rw [hcolSort]
      simpa [R, rawChoiceOfColChoice, RawColLaplaceChoice.minorCols,
        minorPosSort] using (L.minorCols_eq_shuffle i).symm
    · funext i
      change
        (colChoiceOfSortableRaw
          (m := m) (n := n) (t := t) A B hC R hR).cofactorCols i =
          L.cofactorCols i
      rw [colChoiceOfSortableRaw_cofactorCols
        (m := m) (n := n) (t := t) A B hC R hR i]
      simpa [R, rawChoiceOfColChoice, RawColLaplaceChoice.cofactorCols]
        using (L.cofactorCols_eq_shuffle i).symm

omit [Nontrivial k] in
/-- The raw Laplace sum over sortable choices is the column-choice Laplace
sum. -/
lemma sortable_raw_col_laplace_sum_eq_col_choice_sum
    (A B : MinorIndex m n t)
    (hC : Close A B) :
    (∑ R : {R : RawColLaplaceChoice A B hC // R.Sortable},
      rawColLaplaceSummand
        (m := m) (n := n) (t := t) (k := k) A B hC R.1) =
