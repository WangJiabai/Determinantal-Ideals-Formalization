/-- Early core form of the cofactor-complement argument used by the Case 1
paper induction section. -/
lemma closePairThm21_case1_cofactorRows_eq_bMiddlePos_of_minorRows_eq_aColumnPos_core
    (A B : MinorIndex m n t)
    (hC : Close A B)
    (L : ClosePairStrictBlock.RowLaplaceChoice A B hC)
    (hminor :
      L.minorRows = fun i => ClosePairStrictBlock.aColumnPos A B hC i) :
    L.cofactorRows = fun i => ClosePairStrictBlock.bMiddlePos A B hC i := by
  classical
  let s : Finset (Fin (ClosePairStrictBlock.size A B)) := Finset.univ.image
    (fun j : Fin (ClosePairStrictBlock.width A B) =>
      ClosePairStrictBlock.bMiddlePos A B hC j)
  have hbInj :
      Function.Injective
        (fun j : Fin (ClosePairStrictBlock.width A B) =>
          ClosePairStrictBlock.bMiddlePos A B hC j) := by
    intro i j hij
    apply Fin.ext
    have hval := congrArg Fin.val hij
    simpa [ClosePairStrictBlock.bMiddlePos] using hval
  have hcard : s.card = ClosePairStrictBlock.width A B := by
    unfold s
    rw [Finset.card_image_of_injective]
    · simp
    · exact hbInj
  have hbStrict :
      StrictMono
        (fun j : Fin (ClosePairStrictBlock.width A B) =>
          ClosePairStrictBlock.bMiddlePos A B hC j) := by
    intro i j hij
    change
      (ClosePairStrictBlock.bMiddlePos A B hC i).1 <
        (ClosePairStrictBlock.bMiddlePos A B hC j).1
    simp [ClosePairStrictBlock.bMiddlePos]
    have hij' : i.1 < j.1 := by
      simpa using hij
    omega
  have hB :
      (fun j : Fin (ClosePairStrictBlock.width A B) =>
        ClosePairStrictBlock.bMiddlePos A B hC j) =
        s.orderEmbOfFin hcard := by
    exact Finset.orderEmbOfFin_unique hcard (by intro j; simp [s]) hbStrict
  have hL_mem :
      ∀ j : Fin (ClosePairStrictBlock.width A B), L.cofactorRows j ∈ s := by
    intro j
    let q : Fin (ClosePairStrictBlock.size A B) := L.cofactorRows j
    let y : Fin t ⊕ Fin (ClosePairStrictBlock.width A B) :=
      (ClosePairStrictBlock.rowPrincipalShuffle A B hC).symm q
    have hy :
        ClosePairStrictBlock.rowPrincipalShuffle A B hC y = q := by
      dsimp [y]
      simp
    cases hcase : y with
    | inl i =>
        have hyq :
            ClosePairStrictBlock.aColumnPos A B hC i = q := by
          calc
            ClosePairStrictBlock.aColumnPos A B hC i =
                ClosePairStrictBlock.rowPrincipalShuffle A B hC (Sum.inl i) := rfl
            _ = ClosePairStrictBlock.rowPrincipalShuffle A B hC y := by rw [hcase]
            _ = q := hy
        have hleft : L.shuffle (Sum.inl i) = q := by
          calc
            L.shuffle (Sum.inl i) = L.minorRows i := (L.minorRows_eq_shuffle i).symm
            _ = ClosePairStrictBlock.aColumnPos A B hC i := congrFun hminor i
            _ = q := hyq
        have hright : L.shuffle (Sum.inr j) = q := by
          simpa [q] using (L.cofactorRows_eq_shuffle j).symm
        have hbad : Sum.inl i = Sum.inr j :=
          L.shuffle.injective (hleft.trans hright.symm)
        cases hbad
    | inr r =>
        have hyq :
            ClosePairStrictBlock.bMiddlePos A B hC r = q := by
          calc
            ClosePairStrictBlock.bMiddlePos A B hC r =
                ClosePairStrictBlock.rowPrincipalShuffle A B hC (Sum.inr r) := rfl
            _ = ClosePairStrictBlock.rowPrincipalShuffle A B hC y := by rw [hcase]
            _ = q := hy
        exact Finset.mem_image.mpr ⟨r, by simp, hyq⟩
  have hL :
      (fun j : Fin (ClosePairStrictBlock.width A B) => L.cofactorRows j) =
        s.orderEmbOfFin hcard := by
    exact Finset.orderEmbOfFin_unique hcard hL_mem L.cofactorRowsStrict
  exact hL.trans hB.symm

