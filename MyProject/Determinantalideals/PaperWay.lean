lemma rawColLaplacePerm_sign
    (A B : MinorIndex m n t)
    (hC : Close A B)
    (R : RawColLaplaceChoice A B hC)
    (τ : Equiv.Perm (Fin t))
    (σ : Equiv.Perm (Fin (ClosePairStrictBlock.width A B))) :
    ClosePairStrictBlock.laplaceShuffleSign
        (k := k) (rawColLaplacePerm A B hC R τ σ) =
      rawColLaplaceSign (m := m) (n := n) (t := t) (k := k) A B hC R *
        (ClosePairStrictBlock.laplaceShuffleSign (k := k) τ *
          ClosePairStrictBlock.laplaceShuffleSign (k := k) σ) := by
  classical
  let S := ClosePairStrictBlock.sumFinToSize A B
  let C := ClosePairStrictBlock.colPrincipalShuffle A B hC
  let rrel : Equiv.Perm
      (Fin t ⊕ Fin (ClosePairStrictBlock.width A B)) :=
    R.shuffle.trans S.symm
  let crel : Equiv.Perm
      (Fin t ⊕ Fin (ClosePairStrictBlock.width A B)) :=
    C.trans S.symm
  have hconj :
      (S.trans (rawColLaplacePerm A B hC R τ σ)).trans S.symm =
        rrel.symm.trans ((Equiv.Perm.sumCongr τ σ).trans crel) := by
    ext x
    simp [rawColLaplacePerm, S, C, rrel, crel]
  have hsign :
      Equiv.Perm.sign (rawColLaplacePerm A B hC R τ σ) =
      Equiv.Perm.sign
          (rrel.symm.trans ((Equiv.Perm.sumCongr τ σ).trans crel)) := by
    rw [← hconj]
    exact (Equiv.Perm.sign_trans_trans_symm
      (rawColLaplacePerm A B hC R τ σ) S).symm
  unfold ClosePairStrictBlock.laplaceShuffleSign rawColLaplaceSign
  rw [hsign]
  simp [ClosePairStrictBlock.laplaceShuffleSign, S, C, rrel, crel,
    Equiv.Perm.sign_trans, Equiv.Perm.sign_sumCongr,
    mul_assoc, mul_comm, mul_left_comm]

