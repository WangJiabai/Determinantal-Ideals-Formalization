lemma diagExp_A_apply_B_middle_eq_zero
    (A B : MinorIndex m n t)
    (hC : Close A B)
    (i : Fin (width A B)) :
    diagExp A
      (B.row ⟨sClose A B + i.1, by
        have hi : i.1 < uClose A B - sClose A B := by
          simp only [width] at i
          exact i.2
        have hu : uClose A B ≤ t :=
          le_trans (uClose_le_pClose A B hC.ne) (pClose_le A B)
        omega⟩,
       B.col ⟨sClose A B + i.1, by
        have hi : i.1 < uClose A B - sClose A B := by
          simp only [width] at i
          exact i.2
        have hu : uClose A B ≤ t :=
          le_trans (uClose_le_pClose A B hC.ne) (pClose_le A B)
        omega⟩) = 0 := by
  classical
  rw [diagExp_apply]
  apply if_neg
  rintro ⟨j, hrow, hcol⟩
  have hiMem := bMiddlePos_paper_mem_closeMiddle A B hC i
  have hj₂ : j.1 + 1 ≤ t := by omega
  have hneq :=
    closeMiddle_pairExt_B_ne_A A B hC (j := j.1 + 1) hiMem (by omega) hj₂
  apply hneq
  have hpaper₂ : sClose A B + i.1 + 1 ≤ t := by
    have hi : i.1 < uClose A B - sClose A B := by
      simp only [width] at i
      exact i.2
    have hu : uClose A B ≤ t :=
      le_trans (uClose_le_pClose A B hC.ne) (pClose_le A B)
    omega
  rw [EndpointSelection.pairExt_endpoint (I := B) (by omega) hpaper₂]
  rw [EndpointSelection.pairExt_endpoint (I := A) (by omega) hj₂]
  have hidxB :
      (⟨sClose A B + i.1 + 1 - 1, by omega⟩ : Fin t) =
        ⟨sClose A B + i.1, by
          have hi : i.1 < uClose A B - sClose A B := by
            simp only [width] at i
            exact i.2
          have hu : uClose A B ≤ t :=
            le_trans (uClose_le_pClose A B hC.ne) (pClose_le A B)
          omega⟩ := by
    apply Fin.ext
    simp
  have hidxA : (⟨j.1 + 1 - 1, by omega⟩ : Fin t) = j := by
    apply Fin.ext
    simp
  rw [hidxB, hidxA]
  exact Prod.ext (by simp [hrow]) (by simp [hcol])

lemma diagExp_B_apply_A_middle_eq_zero
    (A B : MinorIndex m n t)
    (hC : Close A B)
    (i : Fin (width A B)) :
    diagExp B
      (A.row ⟨sClose A B + i.1, by
