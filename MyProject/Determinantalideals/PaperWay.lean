  have hsup :
      (diagExp (ClosePairStrictBlock.bMiddleMinorIndex A B hC) +
            diagExp A) x =
          (diagExp A ⊔ diagExp B) x := by
    exact congrArg
      (fun f : (Fin m × Fin n) →₀ ℕ => f x)
      (bMiddleMinorIndex_diagExp_add_A_eq_sup
        (m := m) (n := n) (t := t) A B hC)
  change
    diagExp (ClosePairStrictBlock.bMiddleMinorIndex A B hC) x ≤
      (diagExp A ⊔ diagExp B) x
  simp only [Finsupp.coe_add, Pi.add_apply, Finsupp.sup_apply] at hsup
  change
    diagExp (ClosePairStrictBlock.bMiddleMinorIndex A B hC) x ≤
      max (diagExp A x) (diagExp B x)
  rw [← hsup]
  exact Nat.le_add_right _ _

