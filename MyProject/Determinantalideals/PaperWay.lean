lemma toSyn_add_lt_add_right
    (ord : MonomialOrder (Fin m × Fin n))
    {a b c : (Fin m × Fin n) →₀ ℕ}
    (h : ord.toSyn a < ord.toSyn b) :
    ord.toSyn (a + c) < ord.toSyn (b + c) := by
  simpa [map_add] using add_lt_add_right h (ord.toSyn c)

lemma toSyn_add_lt_add_left
    (ord : MonomialOrder (Fin m × Fin n))
    {a b c : (Fin m × Fin n) →₀ ℕ}
    (h : ord.toSyn a < ord.toSyn b) :
    ord.toSyn (c + a) < ord.toSyn (c + b) := by
  simpa [add_comm] using toSyn_add_lt_add_right (ord := ord) (c := c) h

/-- Splice a strict local comparison back into a global exponent when both
sides have the same explicitly identified common factor. -/
lemma toSyn_lt_of_local_lt_with_common
    (ord : MonomialOrder (Fin m × Fin n))
    {loc diag common rowExp headExp : (Fin m × Fin n) →₀ ℕ}
    (hlocal : ord.toSyn loc < ord.toSyn diag)
    (hrow : rowExp = loc + common)
    (hhead : headExp = diag + common) :
    ord.toSyn rowExp < ord.toSyn headExp := by
  rw [hrow, hhead]
  exact toSyn_add_lt_add_right (ord := ord) (c := common) hlocal

