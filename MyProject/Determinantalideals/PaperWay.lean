/-- If all principal `A` block positions occur among the selected row-choice
minor rows, then the selected minor rows are exactly the principal positions. -/
lemma closePairThm21_case1_minorRows_eq_aColumnPos_of_mem
    (A B : MinorIndex m n t)
    (hC : Close A B)
    (L : ClosePairStrictBlock.RowLaplaceChoice A B hC)
    (hmem : ∀ i : Fin t, ∃ j : Fin t,
      L.minorRows j = ClosePairStrictBlock.aColumnPos A B hC i) :
    L.minorRows = fun i => ClosePairStrictBlock.aColumnPos A B hC i := by
  classical
  let s : Finset (Fin m) := Finset.univ.image
    (fun j : Fin t =>
      ClosePairStrictBlock.rowFin A B hC (L.minorRows j))
