            (m := m) (n := n) (t := t) (k := k) A B hC 1 σ.1).poly := by
        rw [Fintype.sum_eq_add_sum_subtype_ne
          (fun σ : Equiv.Perm (Fin (ClosePairStrictBlock.width A B)) =>
            (ClosePairStrictBlock.bBlockTerm
              (m := m) (n := n) (t := t) (k := k) A B hC 1 σ).poly)
          (1 : Equiv.Perm (Fin (ClosePairStrictBlock.width A B)))]
