/-- The principal row-side cofactor matrix is exactly the `B` block. -/
lemma rowPrincipalChoice_cofactorMatrix_eq_bBlockMatrix
    (A B : MinorIndex m n t)
    (hC : Close A B) :
    (rowPrincipalChoice (m := m) (n := n) (t := t) A B hC).cofactorMatrix =
      strictBBlockMatrix (m := m) (n := n) (t := t) (k := k) A B hC := by
  classical
  ext i j
  have hzero :
      ¬ ClosePairStrictBlock.zeroBlock A B
        (ClosePairStrictBlock.bMiddlePos A B hC i).1
        (ClosePairStrictBlock.bMiddlePos A B hC j).1 := by
    intro hzero
    rcases hzero with ⟨ha, _hbcol⟩
    have hbrow := ClosePairStrictBlock.bMiddlePos_mem A B hC i
    unfold ClosePairStrictBlock.aRepeatedMiddle at ha
    unfold ClosePairStrictBlock.bMiddle at hbrow
    omega
  simp [rowPrincipalChoice, ClosePairStrictBlock.rowPrincipalChoice, strictBBlockMatrix,
    ClosePairStrictBlock.RowLaplaceChoice.cofactorMatrix,
    ClosePairStrictBlock.RowLaplaceChoice.cofactorRow,
    ClosePairStrictBlock.RowLaplaceChoice.cofactorCol,
    ClosePairStrictBlock.RowLaplaceChoice.cofactorZero,
    MonomialCoefficientMatrix.matrix, hzero]

