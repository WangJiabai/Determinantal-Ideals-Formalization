/-- The raw Laplace sum over sortable choices is the row-choice Laplace sum. -/
lemma sortable_raw_row_laplace_sum_eq_row_choice_sum
    (A B : MinorIndex m n t)
    (hC : Close A B) :
    (∑ R : {R : RawRowLaplaceChoice A B hC // R.Sortable},
      rawRowLaplaceSummand
        (m := m) (n := n) (t := t) (k := k) A B hC R.1) =
      ∑ L : ClosePairStrictBlock.RowLaplaceChoice A B hC,
        strictRowLaplaceSummand
          (m := m) (n := n) (t := t) (k := k) A B hC L := by
  classical
  let e := sortableRawRowChoiceEquivRowChoice
    (m := m) (n := n) (t := t) A B hC
  have hsum :
      (∑ R : {R : RawRowLaplaceChoice A B hC // R.Sortable},
        strictRowLaplaceSummand
          (m := m) (n := n) (t := t) (k := k) A B hC (e R)) =
        ∑ L : ClosePairStrictBlock.RowLaplaceChoice A B hC,
          strictRowLaplaceSummand
            (m := m) (n := n) (t := t) (k := k) A B hC L :=
    Fintype.sum_equiv e
      (fun R =>
        strictRowLaplaceSummand
          (m := m) (n := n) (t := t) (k := k) A B hC (e R))
      (fun L =>
        strictRowLaplaceSummand
          (m := m) (n := n) (t := t) (k := k) A B hC L)
      (by intro R; rfl)
  calc
    (∑ R : {R : RawRowLaplaceChoice A B hC // R.Sortable},
      rawRowLaplaceSummand
        (m := m) (n := n) (t := t) (k := k) A B hC R.1)
        =
      ∑ R : {R : RawRowLaplaceChoice A B hC // R.Sortable},
        strictRowLaplaceSummand
          (m := m) (n := n) (t := t) (k := k) A B hC (e R) := by
        refine Finset.sum_congr rfl ?_
        intro R _hR
        exact rawRowLaplaceSummand_eq_strictRowLaplaceSummand_of_sortable
          (m := m) (n := n) (t := t) (k := k) A B hC R.1 R.2
    _ =
      ∑ L : ClosePairStrictBlock.RowLaplaceChoice A B hC,
        strictRowLaplaceSummand
          (m := m) (n := n) (t := t) (k := k) A B hC L := hsum

