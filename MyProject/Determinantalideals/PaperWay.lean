  generalize
      Equiv.Perm.sign
        ((ClosePairStrictBlock.rowPrincipalShuffle A B hC).trans
          (ClosePairStrictBlock.sumFinToSize A B).symm) = ε
  rcases Int.units_eq_one_or ε with hε | hε <;> simp [hε]

