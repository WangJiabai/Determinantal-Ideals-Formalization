/-- If the range of the row order embedding of a row-choice minor contains all
rows of `A`, then the row-choice minor has the same rows as `A`.

This is a finite sorted-list/range argument for order embeddings `Fin t ↪o Fin m`. -/
lemma rowChoice_minorIndex_row_eq_A_row_of_A_rows_mem
    (A B : MinorIndex m n t)
    (hC : Close A B)
    (L : ClosePairStrictBlock.RowLaplaceChoice A B hC)
    (hmem : ∀ i : Fin t, ∃ j : Fin t, L.minorIndex.row j = A.row i) :
    L.minorIndex.row = A.row := by
  classical
  let s : Finset (Fin m) := Finset.univ.image (fun j : Fin t => L.minorIndex.row j)
  have hcard : s.card = t := by
    unfold s
    rw [Finset.card_image_of_injective]
    · simp
    · intro i j hij
      exact (L.minorIndex.row).injective hij
  have hL :
      (fun j : Fin t => L.minorIndex.row j) = s.orderEmbOfFin hcard := by
    exact Finset.orderEmbOfFin_unique hcard (by intro j; simp [s]) L.minorIndex.row.strictMono
  have hA_mem : ∀ i : Fin t, A.row i ∈ s := by
    intro i
    rcases hmem i with ⟨j, hj⟩
    exact Finset.mem_image.mpr ⟨j, by simp, hj⟩
  have hA :
      (fun i : Fin t => A.row i) = s.orderEmbOfFin hcard := by
    exact Finset.orderEmbOfFin_unique hcard hA_mem A.row.strictMono
  apply DFunLike.ext
  intro i
  exact congrFun (hL.trans hA.symm) i


