lemma strictCDiagPart_eq_lcmQuotient_mul_B
    (A B : MinorIndex m n t)
    (hC : Close A B)
    (_hrowLt :
      rowExt B (uClose A B) < rowExt A (uClose A B)) :
    strictCDiagPart (m := m) (n := n) (t := t) (k := k) A B hC =
      MvPolynomial.monomial
        ((diagExp A ⊔ diagExp B) - diagExp B) (1 : k) *
          genericMinor (k := k) B := by
  classical
  rw [strictCDiagPart, ClosePairStrictBlock.cBlockTerm]
  rw [MonomialCoefficientMatrix.closePairTerm_poly
    (m := m) (n := n) (t := t) (q := ClosePairStrictBlock.width A B) (k := k)
    (row := fun i : Fin (ClosePairStrictBlock.width A B) =>
      ClosePairStrictBlock.rowFin A B hC
        (ClosePairStrictBlock.aRepeatedMiddlePos A B hC i))
    (col := fun i : Fin (ClosePairStrictBlock.width A B) =>
      ClosePairStrictBlock.colFin A B hC
        (ClosePairStrictBlock.aRepeatedMiddlePos A B hC i))
    (zero := fun _ _ => False)
    (K := B)
    (a := 1)
    (σ := (1 : Equiv.Perm (Fin (ClosePairStrictBlock.width A B))))]
  rw [MonomialCoefficientMatrix.permTerm]
  rw [cBlock_identity_permExp_eq_lcmQuotient_B
    (m := m) (n := n) (t := t) A B hC]
  simp [MonomialCoefficientMatrix.permCoeffWithZero, permCoeff]

lemma closePair_sPolynomial_eq_lcm_quotient_terms
    (ord : MonomialOrder (Fin m × Fin n))
    (hdiag : IsDiagonalTermOrder ord)
    (A B : MinorIndex m n t) :
    ord.sPolynomial (genericMinor (k := k) A) (genericMinor (k := k) B) =
      MvPolynomial.monomial
        ((diagExp A ⊔ diagExp B) - diagExp A) (1 : k) *
          genericMinor (k := k) A
      -
      MvPolynomial.monomial
        ((diagExp A ⊔ diagExp B) - diagExp B) (1 : k) *
          genericMinor (k := k) B := by
  classical
  have hL :
      headLcm ord (genericMinor (k := k) A) (genericMinor (k := k) B) =
        diagExp A ⊔ diagExp B :=
    headLcm_genericMinor_eq_sup_diagExp
      (m := m) (n := n) (t := t) (k := k) ord hdiag A B
  simpa [hL] using
    closePair_sPolynomial_eq_scaled_minors
      (m := m) (n := n) (t := t) (k := k) ord hdiag A B

/-- Close-pair `S`-polynomial in the strict orientation.

This is the formal version of the paper's sentence:

`S is, by definition, equal to Δ_B D_(α,β) - Δ_C D_(α',β')`.

It should be proved by unfolding `ord.sPolynomial`, using the diagonal-head
lemma for minors, the close-pair lcm computation, and the identification of
the two quotient monomials with the diagonal `B` and `C` block terms. -/
lemma closePair_sPolynomial_eq_strict_diag_parts
    (ord : MonomialOrder (Fin m × Fin n))
    (hdiag : IsDiagonalTermOrder ord)
    (A B : MinorIndex m n t)
    (hC : Close A B)
    (hrowLt :
      rowExt B (uClose A B) < rowExt A (uClose A B)) :
    ord.sPolynomial (genericMinor (k := k) A) (genericMinor (k := k) B) =
      strictBDiagPart (m := m) (n := n) (t := t) (k := k) A B hC -
      strictCDiagPart (m := m) (n := n) (t := t) (k := k) A B hC := by
  classical
  rw [closePair_sPolynomial_eq_lcm_quotient_terms
    (m := m) (n := n) (t := t) (k := k) ord hdiag A B]
  rw [strictBDiagPart_eq_lcmQuotient_mul_A
    (m := m) (n := n) (t := t) (k := k) A B hC hrowLt]
  rw [strictCDiagPart_eq_lcmQuotient_mul_B
    (m := m) (n := n) (t := t) (k := k) A B hC hrowLt]
  /-
  Real proof target.

  Expected ingredients:
  * `hdiag` gives
      ord.degree (genericMinor A) = diagExp A
      ord.degree (genericMinor B) = diagExp B
    and leading coefficient `1`;
  * close-pair/lcm API gives
      headLcm ord (genericMinor A) (genericMinor B)
        = diagExp A ⊔ diagExp B;
  * strict orientation identifies
      (diagExp A ⊔ diagExp B) - diagExp A
    with the exponent of the diagonal B-block,
    and
      (diagExp A ⊔ diagExp B) - diagExp B
    with the exponent of the diagonal C-block.
  -/






/-! ### Row-side Laplace expansion for the strict case -/

/-- The coefficient block `B` in the row-side Laplace principal term. -/
noncomputable def strictBBlockMatrix
    (A B : MinorIndex m n t)
    (hC : Close A B) :
    Matrix (Fin (ClosePairStrictBlock.width A B))
      (Fin (ClosePairStrictBlock.width A B))
      (MvPolynomial (Fin m × Fin n) k) :=
  MonomialCoefficientMatrix.matrix
    (m := m) (n := n) (q := ClosePairStrictBlock.width A B) (k := k)
    (fun i =>
      ClosePairStrictBlock.rowFin A B hC
        (ClosePairStrictBlock.bMiddlePos A B hC i))
    (fun i =>
      ClosePairStrictBlock.colFin A B hC
        (ClosePairStrictBlock.bMiddlePos A B hC i))
    (fun _ _ => False)

/-- One row-side Laplace summand before expanding the cofactor determinant. -/
noncomputable def strictRowLaplaceSummand
    (A B : MinorIndex m n t)
    (hC : Close A B)
    (L : ClosePairStrictBlock.RowLaplaceChoice A B hC) :
    MvPolynomial (Fin m × Fin n) k :=
  MvPolynomial.C
      (ClosePairStrictBlock.rowLaplaceSign
        (m := m) (n := n) (t := t) (k := k) A B hC L) *
    (Matrix.det L.cofactorMatrix *
      genericMinor (k := k) L.minorIndex)

/-- Sum of the non-principal row-side Laplace summands, before expanding
their cofactor determinants. -/
noncomputable def strictRowNonprincipalLaplaceSum
    (A B : MinorIndex m n t)
    (hC : Close A B) :
    MvPolynomial (Fin m × Fin n) k := by
  classical
  exact
    ∑ L : {L : ClosePairStrictBlock.RowLaplaceChoice A B hC //
        L ≠ ClosePairStrictBlock.rowPrincipalChoice A B hC},
      strictRowLaplaceSummand
        (m := m) (n := n) (t := t) (k := k) A B hC L.1

/-- Top-level alias for the principal row-side Laplace choice. -/
noncomputable abbrev rowPrincipalChoice
    (A B : MinorIndex m n t)
    (hC : Close A B) :
    ClosePairStrictBlock.RowLaplaceChoice A B hC :=
  ClosePairStrictBlock.rowPrincipalChoice A B hC

/-- The coefficient block `C` in the column-side Laplace principal term. -/
noncomputable def strictCBlockMatrix
    (A B : MinorIndex m n t)
    (hC : Close A B) :
    Matrix (Fin (ClosePairStrictBlock.width A B))
      (Fin (ClosePairStrictBlock.width A B))
      (MvPolynomial (Fin m × Fin n) k) :=
  MonomialCoefficientMatrix.matrix
    (m := m) (n := n) (q := ClosePairStrictBlock.width A B) (k := k)
    (fun i =>
      ClosePairStrictBlock.rowFin A B hC
        (ClosePairStrictBlock.aRepeatedMiddlePos A B hC i))
    (fun i =>
      ClosePairStrictBlock.colFin A B hC
        (ClosePairStrictBlock.aRepeatedMiddlePos A B hC i))
    (fun _ _ => False)

/-- One column-side Laplace summand before expanding the cofactor determinant. -/
noncomputable def strictColLaplaceSummand
    (A B : MinorIndex m n t)
    (hC : Close A B)
    (L : ClosePairStrictBlock.ColLaplaceChoice A B hC) :
    MvPolynomial (Fin m × Fin n) k :=
  MvPolynomial.C
      (ClosePairStrictBlock.colLaplaceSign
        (m := m) (n := n) (t := t) (k := k) A B hC L) *
    (Matrix.det L.cofactorMatrix *
      genericMinor (k := k) L.minorIndex)

/-- Sum of the non-principal column-side Laplace summands, before expanding
their cofactor determinants. -/
noncomputable def strictColNonprincipalLaplaceSum
    (A B : MinorIndex m n t)
    (hC : Close A B) :
    MvPolynomial (Fin m × Fin n) k := by
  classical
  exact
    ∑ L : {L : ClosePairStrictBlock.ColLaplaceChoice A B hC //
        L ≠ ClosePairStrictBlock.colPrincipalChoice A B hC},
      strictColLaplaceSummand
        (m := m) (n := n) (t := t) (k := k) A B hC L.1

/-- Top-level alias for the principal column-side Laplace choice. -/
noncomputable abbrev colPrincipalChoice
    (A B : MinorIndex m n t)
    (hC : Close A B) :
    ClosePairStrictBlock.ColLaplaceChoice A B hC :=
  ClosePairStrictBlock.colPrincipalChoice A B hC

/-- The principal row-side choice has minor index `A`. -/
lemma rowPrincipalChoice_minorIndex
    (A B : MinorIndex m n t)
    (hC : Close A B) :
    (rowPrincipalChoice (m := m) (n := n) (t := t) A B hC).minorIndex = A := by
  classical
  cases A with
  | mk row col =>
      apply congrArg
        (fun r : Fin t ↪o Fin m => ({ row := r, col := col } : MinorIndex m n t))
      apply DFunLike.ext
      intro i
      simp [rowPrincipalChoice, ClosePairStrictBlock.rowPrincipalChoice,
        strictMonoToOrderEmbedding,
        ClosePairStrictBlock.rowFin_aColumnPos]

/-- The principal column-side choice has minor index `B`. -/
lemma colPrincipalChoice_minorIndex
    (A B : MinorIndex m n t)
    (hC : Close A B) :
    (colPrincipalChoice (m := m) (n := n) (t := t) A B hC).minorIndex = B := by
  classical
  cases B with
  | mk row col =>
      apply congrArg
        (fun c : Fin t ↪o Fin n => ({ row := row, col := c } : MinorIndex m n t))
      apply DFunLike.ext
      intro i
      simp [colPrincipalChoice, ClosePairStrictBlock.colPrincipalChoice,
        strictMonoToOrderEmbedding,
        ClosePairStrictBlock.colFin_bRowPos]

