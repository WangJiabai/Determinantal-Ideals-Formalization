    simpa [hj, ClosePairStrictBlock.rowFin_aColumnPos] using congrFun hrow j
  have hji : j = i := A.row.injective hrowji.symm
  simpa [hji] using hj

section case1_uv_induction

variable {m n t : ℕ}
variable {k : Type*} [CommRing k] [Nontrivial k]

/-- Convert a paper-style middle index `j ∈ [s+1,u]` to the corresponding
zero-based `Fin t` index. -/
noncomputable def middlePaperIndexToFinOfClose
    (A B : MinorIndex m n t)
    (hC : Close A B)
    (j : ℕ)
    (hj : sClose A B + 1 ≤ j ∧ j ≤ uClose A B) :
    Fin t :=
  ⟨j - 1, by
    have hu : uClose A B ≤ t :=
      le_trans (uClose_le_pClose A B hC.ne) (pClose_le A B)
    omega⟩

/-- Convert a paper-style middle index `j ∈ [s+1,u]` to the local width index
used by the strict middle blocks. -/
noncomputable def middlePaperIndexToWidthFinOfClose
    (A B : MinorIndex m n t)
    (hC : Close A B)
    (j : ℕ)
    (hj : sClose A B + 1 ≤ j ∧ j ≤ uClose A B) :
    Fin (ClosePairStrictBlock.width A B) :=
  ⟨j - (sClose A B + 1), by
    have hsu : sClose A B < uClose A B :=
      sClose_lt_uClose A B hC.ne
    unfold ClosePairStrictBlock.width
    omega⟩

/-- The principal `A` row position in the strict block corresponding to a
paper-style middle index. -/
noncomputable def aColumnPosOfPaperMiddle
    (A B : MinorIndex m n t)
    (hC : Close A B)
    (j : ℕ)
    (hj : sClose A B + 1 ≤ j ∧ j ≤ uClose A B) :
    Fin (ClosePairStrictBlock.size A B) :=
  ClosePairStrictBlock.aColumnPos A B hC
    (middlePaperIndexToFinOfClose A B hC j hj)

/-- The `B`-middle position in the strict block corresponding to a paper-style
middle index. -/
noncomputable def bMiddlePosOfPaperMiddle
    (A B : MinorIndex m n t)
    (hC : Close A B)
    (j : ℕ)
    (hj : sClose A B + 1 ≤ j ∧ j ≤ uClose A B) :
    Fin (ClosePairStrictBlock.size A B) :=
  ClosePairStrictBlock.bMiddlePos A B hC
    (middlePaperIndexToWidthFinOfClose A B hC j hj)

/-- The formal `u_i/v_i` chain used in Case 1 of the paper.

The fields record the real order data from (2.1.6): both chains decrease from
`u+1` to `s+1`, stay in the close middle interval, and each step carries the
row and column inequalities used in the induction. -/
structure Case1UVChain
    (A B : MinorIndex m n t)
    (hC : Close A B) where
  q : ℕ
  u : Fin (q + 1) → ℕ
  v : Fin (q + 1) → ℕ
  u_zero : u 0 = uClose A B + 1
  v_zero : v 0 = uClose A B + 1
  u_last : u ⟨q, Nat.lt_succ_self q⟩ = sClose A B + 1
  v_last : v ⟨q, Nat.lt_succ_self q⟩ = sClose A B + 1
  u_strict : ∀ {i j : Fin (q + 1)}, i < j → u j < u i
  v_strict : ∀ {i j : Fin (q + 1)}, i < j → v j < v i
  u_bounds : ∀ i : Fin (q + 1),
    sClose A B + 1 ≤ u i ∧ u i ≤ uClose A B + 1
  v_bounds : ∀ i : Fin (q + 1),
    sClose A B + 1 ≤ v i ∧ v i ≤ uClose A B + 1
  row_B_top_ge_A_top :
    ∀ i : Fin q,
      rowExt A (u i.castSucc - 1) ≤ rowExt B (v i.castSucc)
  row_A_interval_gt_B_pred :
    ∀ i : Fin q, ∀ j : ℕ,
      u i.succ ≤ j → j < u i.castSucc →
        rowExt B (v i.castSucc - 1) < rowExt A j
  row_B_interval_ge_A_lower_pred :
    ∀ i : Fin q, ∀ j : ℕ,
      v i.succ ≤ j → j < v i.castSucc →
        rowExt A (u i.succ - 1) ≤ rowExt B j
  col_B_top_gt_A_interval :
    ∀ i : Fin q, ∀ j : ℕ,
      u i.succ ≤ j → j < u i.castSucc →
        colExt A j < colExt B (v i.castSucc)
  col_B_interval_gt_A_lower_pred :
    ∀ i : Fin q, ∀ j : ℕ,
      v i.succ ≤ j → j < v i.castSucc →
        colExt A (u i.succ - 1) < colExt B j

/-- Paper Case 1 statement (a): the indicated `B` rows lie in the cofactor
row set `γ*`. -/
def StatementA
    (A B : MinorIndex m n t)
    (hC : Close A B)
    (L : ClosePairStrictBlock.RowLaplaceChoice A B hC)
    (U : Case1UVChain A B hC)
    (i : Fin U.q) : Prop :=
  ∀ (j : ℕ) (hjlo : U.v i.succ ≤ j) (hjhi : j < U.v i.castSucc),
    ∃ r : Fin (ClosePairStrictBlock.width A B),
      L.cofactorRows r =
        bMiddlePosOfPaperMiddle A B hC j
          (by
            have hs : sClose A B + 1 ≤ j :=
              le_trans (U.v_bounds i.succ).1 hjlo
            have hu : j ≤ uClose A B := by
              have htop := (U.v_bounds i.castSucc).2
              omega
            exact ⟨hs, hu⟩)

/-- Paper Case 1 statement (b), in the indexed form needed later: the selected
minor row at each paper middle index is exactly the corresponding principal
`A` position. -/
def StatementB
    (A B : MinorIndex m n t)
    (hC : Close A B)
    (L : ClosePairStrictBlock.RowLaplaceChoice A B hC)
    (U : Case1UVChain A B hC)
    (i : Fin U.q) : Prop :=
  ∀ (j : ℕ) (hjlo : U.u i.succ ≤ j) (hjhi : j < U.u i.castSucc),
    L.minorRows
        (middlePaperIndexToFinOfClose A B hC j
          (by
            have hs : sClose A B + 1 ≤ j :=
              le_trans (U.u_bounds i.succ).1 hjlo
            have hu : j ≤ uClose A B := by
              have htop := (U.u_bounds i.castSucc).2
              omega
            exact ⟨hs, hu⟩)) =
      aColumnPosOfPaperMiddle A B hC j
        (by
          have hs : sClose A B + 1 ≤ j :=
            le_trans (U.u_bounds i.succ).1 hjlo
          have hu : j ≤ uClose A B := by
            have htop := (U.u_bounds i.castSucc).2
            omega
          exact ⟨hs, hu⟩)

/-- StatementB at a single paper index in the current `u`-interval. -/
def StatementBAt
    (A B : MinorIndex m n t)
    (hC : Close A B)
    (L : ClosePairStrictBlock.RowLaplaceChoice A B hC)
    (U : Case1UVChain A B hC)
    (i : Fin U.q)
    (j : ℕ)
    (hjlo : U.u i.succ ≤ j)
    (hjhi : j < U.u i.castSucc) : Prop :=
  L.minorRows
      (middlePaperIndexToFinOfClose A B hC j
        (by
          have hs : sClose A B + 1 ≤ j := by
            have hU := (U.u_bounds i.succ).1
            omega
          have hu : j ≤ uClose A B := by
            have hU := (U.u_bounds i.castSucc).2
            omega
          exact ⟨hs, hu⟩)) =
    aColumnPosOfPaperMiddle A B hC j
      (by
        have hs : sClose A B + 1 ≤ j := by
          have hU := (U.u_bounds i.succ).1
          omega
        have hu : j ≤ uClose A B := by
          have hU := (U.u_bounds i.castSucc).2
          omega
        exact ⟨hs, hu⟩)

/-- StatementB has already been proved above the paper index `j0` inside the
current `u`-interval. -/
def StatementBAbove
    (A B : MinorIndex m n t)
    (hC : Close A B)
    (L : ClosePairStrictBlock.RowLaplaceChoice A B hC)
    (U : Case1UVChain A B hC)
    (i : Fin U.q)
    (j0 : ℕ) : Prop :=
  ∀ j : ℕ,
    j0 < j →
    ∀ (hjhi : j < U.u i.castSucc) (hjlo : U.u i.succ ≤ j),
      StatementBAt A B hC L U i j hjlo hjhi

/-- A suffix of the current `u`-interval has StatementB proved.  Taking
`N = U.u i.succ` recovers the full current StatementB interval. -/
def StatementBSuffix
    (A B : MinorIndex m n t)
    (hC : Close A B)
    (L : ClosePairStrictBlock.RowLaplaceChoice A B hC)
    (U : Case1UVChain A B hC)
    (i : Fin U.q)
    (N : ℕ) : Prop :=
  ∀ j : ℕ,
    N ≤ j →
    ∀ (hjhi : j < U.u i.castSucc) (hjlo : U.u i.succ ≤ j),
      StatementBAt A B hC L U i j hjlo hjhi

