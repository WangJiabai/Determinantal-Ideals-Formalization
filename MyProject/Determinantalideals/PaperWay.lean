/-- The decreasing `u`-chain covers every paper middle index.

This is the finite interval fact used after the Case 1 induction: since
`u₀ = uClose + 1` and `u_q = sClose + 1`, every middle paper index
`j ∈ [sClose + 1, uClose]` lies in one of the half-open intervals
`[u_{i+1}, u_i)`. -/
lemma closePairThm21_case1_exists_u_interval_of_middle
    (A B : MinorIndex m n t)
    (hC : Close A B)
    (U : Case1UVChain A B hC)
    {j : ℕ}
    (hjlo : sClose A B + 1 ≤ j)
    (hjhi : j ≤ uClose A B) :
    ∃ i : Fin U.q, U.u i.succ ≤ j ∧ j < U.u i.castSucc := by
  classical
  let P : ℕ → Prop :=
    fun N => ∃ hN : N ≤ U.q, U.u ⟨N, Nat.lt_succ_of_le hN⟩ ≤ j
  have hex : ∃ N : ℕ, P N := by
    refine ⟨U.q, ?_⟩
    refine ⟨le_rfl, ?_⟩
    simpa [P, U.u_last] using hjlo
  let N : ℕ := Nat.find hex
  have hNspec : P N := by
    simpa [N] using Nat.find_spec hex
  rcases hNspec with ⟨hNle, hNu⟩
  have hNpos : 0 < N := by
    by_contra hnot
    have hN0 : N = 0 := Nat.eq_zero_of_not_pos hnot
    have hfin :
        (⟨N, Nat.lt_succ_of_le hNle⟩ : Fin (U.q + 1)) =
          (0 : Fin (U.q + 1)) := by
      apply Fin.ext
      simp [hN0]
    have hle0 : U.u (0 : Fin (U.q + 1)) ≤ j := by
      simpa [hfin] using hNu
    have huj : uClose A B + 1 ≤ j := by
      simpa [U.u_zero] using hle0
    omega
  have hpred_lt_q : N - 1 < U.q := by
    omega
  let i : Fin U.q := ⟨N - 1, hpred_lt_q⟩
  refine ⟨i, ?_, ?_⟩
  · have hsucc :
        i.succ = (⟨N, Nat.lt_succ_of_le hNle⟩ : Fin (U.q + 1)) := by
      apply Fin.ext
      simp [i]
      omega
    simpa [hsucc] using hNu
  · have hpred_lt_N : N - 1 < N := by
      omega
    have hnotPpred : ¬ P (N - 1) := by
      simpa [N] using (Nat.find_min hex hpred_lt_N)
    have hnot_le : ¬ U.u i.castSucc ≤ j := by
      intro hle
      apply hnotPpred
      refine ⟨?_, ?_⟩
      · omega
      · simpa [P, i] using hle
    exact Nat.lt_of_not_ge hnot_le

