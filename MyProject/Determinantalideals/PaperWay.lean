/-- A prefix `A` row occurs only at its principal `aColumnPos` position in the
strict block. -/
lemma ClosePairStrictBlock.eq_aColumnPos_of_rowFin_eq_A_prefix
    (A B : MinorIndex m n t)
    (hC : Close A B)
    (i : Fin t)
    (hi : i.1 < sClose A B)
    (q : Fin (ClosePairStrictBlock.size A B))
    (hrow : ClosePairStrictBlock.rowFin A B hC q = A.row i) :
    q = ClosePairStrictBlock.aColumnPos A B hC i := by
  classical
  rcases ClosePairStrictBlock.block_cases_of_lt_size A B q.2 with hpre | hmid | hrep | htail
  · have hq_lt_s : q.1 < sClose A B := by
      simpa [ClosePairStrictBlock.prefixBlock] using hpre
    have hidx :
        (⟨q.1, by
          have hslt : sClose A B < t :=
            lt_of_lt_of_le (sClose_lt_pClose A B hC.ne) (pClose_le A B)
          omega⟩ : Fin t) = i := by
      apply A.row.injective
      calc
        A.row
            ⟨q.1, by
              have hslt : sClose A B < t :=
                lt_of_lt_of_le (sClose_lt_pClose A B hC.ne) (pClose_le A B)
              omega⟩ =
            ClosePairStrictBlock.rowFin A B hC q := by
          apply Fin.ext
          change (A.row ⟨q.1, by
            have hslt : sClose A B < t :=
              lt_of_lt_of_le (sClose_lt_pClose A B hC.ne) (pClose_le A B)
            omega⟩).1 = rowCoord A B q.1 - 1
          rw [ClosePairStrictBlock.rowCoord_of_prefix A B hq_lt_s]
          rw [EndpointSelection.rowExt_endpoint (I := A) (by omega)
            (by
              have hslt : sClose A B < t :=
                lt_of_lt_of_le (sClose_lt_pClose A B hC.ne) (pClose_le A B)
              omega)]
          simp
        _ = A.row i := hrow
    apply Fin.ext
    rw [ClosePairStrictBlock.aColumnPos_of_prefix A B hC hi]
    have hval := congrArg Fin.val hidx
    simpa using hval
  · exfalso
    have hq_ge_s : sClose A B ≤ q.1 := hmid.1
    have hq_lt_u : q.1 < uClose A B := hmid.2
    have hq_lt_t : q.1 < t := by
      have hu : uClose A B ≤ t :=
        le_trans (uClose_le_pClose A B hC.ne) (pClose_le A B)
      omega
    have hqrow :
        ClosePairStrictBlock.rowFin A B hC q =
          B.row
            ⟨q.1, by
              exact hq_lt_t⟩ := by
      apply Fin.ext
      change rowCoord A B q.1 - 1 =
        (B.row ⟨q.1, by
          exact hq_lt_t⟩).1
      rw [ClosePairStrictBlock.rowCoord_of_bMiddle A B hmid]
      rw [EndpointSelection.rowExt_endpoint (I := B) (by omega)
        (by omega)]
      simp
    have hAiBi : A.row i = B.row i := by
      have hpEq :
          pairExt A (i.1 + 1) = pairExt B (i.1 + 1) := by
        exact pairExt_eq_of_mu_eq_right_le_s A B hC.ne hC.mu_eq_right (by omega) (by omega)
      have hi₂ : i.1 + 1 ≤ t := by omega
      rw [EndpointSelection.pairExt_endpoint (I := A) (by omega) hi₂,
        EndpointSelection.pairExt_endpoint (I := B) (by omega) hi₂] at hpEq
      have hrowNat := congrArg Prod.fst hpEq
      apply Fin.ext
      simp at hrowNat
      omega
    have hlt :
        B.row i <
          B.row
            ⟨q.1, by
              exact hq_lt_t⟩ := by
      apply B.row.strictMono
      exact Fin.mk_lt_mk.mpr (by omega)
    have heq :
        B.row
            ⟨q.1, by
              exact hq_lt_t⟩ =
          B.row i := by
      exact hqrow.symm.trans (hrow.trans hAiBi)
    exact (ne_of_gt hlt) heq
  · exfalso
    have hrep_ge : uClose A B ≤ q.1 := hrep.1
    have hrep_lt : q.1 < uClose A B + ClosePairStrictBlock.width A B := hrep.2
    let r : Fin (ClosePairStrictBlock.width A B) :=
      ⟨q.1 - uClose A B, by
        have hrep_lt' : q.1 < uClose A B + (uClose A B - sClose A B) := by
          simpa [ClosePairStrictBlock.width] using hrep_lt
        unfold ClosePairStrictBlock.width
        omega⟩
    have hq_eq_rep :
        q = ClosePairStrictBlock.aRepeatedMiddlePos A B hC r := by
      apply Fin.ext
      simp [ClosePairStrictBlock.aRepeatedMiddlePos, r]
      omega
    have hqrow :
        ClosePairStrictBlock.rowFin A B hC q =
          A.row
            ⟨sClose A B + r.1, by
              have hu : uClose A B ≤ t :=
                le_trans (uClose_le_pClose A B hC.ne) (pClose_le A B)
              have hr : r.1 < uClose A B - sClose A B := by
                simpa [r, ClosePairStrictBlock.width] using r.2
              omega⟩ := by
      exact
        (congrArg (fun q' => ClosePairStrictBlock.rowFin A B hC q') hq_eq_rep).trans
          (by simpa [r] using ClosePairStrictBlock.rowFin_aRepeatedMiddlePos A B hC r)
    have hlt :
        i <
          (⟨sClose A B + r.1, by
            have hu : uClose A B ≤ t :=
              le_trans (uClose_le_pClose A B hC.ne) (pClose_le A B)
            have hr : r.1 < uClose A B - sClose A B := by
              simpa [r, ClosePairStrictBlock.width] using r.2
            omega⟩ : Fin t) := by
      exact Fin.mk_lt_mk.mpr (by
        have hsu : sClose A B < uClose A B := sClose_lt_uClose A B hC.ne
        omega)
