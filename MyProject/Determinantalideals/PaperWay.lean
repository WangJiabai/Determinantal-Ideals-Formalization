/-! ### Raw column-subset Laplace layer

This is the column-side analogue of the raw row layer above.  Raw choices are
ordered by their positions in the strict block matrix; sortable choices are
then normalized to `ColLaplaceChoice`, where only the selected minor columns
are sorted by actual column variables.
-/

/-- Raw column-subset choice for the column-side Laplace expansion.

The two column groups are ordered by their positions in the strict block
matrix.  This gives a canonical indexing for the direct Leibniz/Laplace
expansion before sorting by actual column variables. -/
structure RawColLaplaceChoice
    (A B : MinorIndex m n t)
    (hC : Close A B) where
  shuffle :
    Fin t ⊕ Fin (ClosePairStrictBlock.width A B) ≃
      Fin (ClosePairStrictBlock.size A B)
  minorColsPosStrict :
    StrictMono (fun i : Fin t => (shuffle (Sum.inl i)).1)
  cofactorColsPosStrict :
    StrictMono
      (fun i : Fin (ClosePairStrictBlock.width A B) =>
        (shuffle (Sum.inr i)).1)

namespace RawColLaplaceChoice

/-- The minor columns selected by a raw column-subset choice. -/
noncomputable def minorCols
    {A B : MinorIndex m n t}
    {hC : Close A B}
    (R : RawColLaplaceChoice A B hC) :
    Fin t → Fin (ClosePairStrictBlock.size A B) :=
  fun i => R.shuffle (Sum.inl i)

/-- The cofactor columns selected by a raw column-subset choice. -/
noncomputable def cofactorCols
    {A B : MinorIndex m n t}
    {hC : Close A B}
    (R : RawColLaplaceChoice A B hC) :
    Fin (ClosePairStrictBlock.width A B) →
      Fin (ClosePairStrictBlock.size A B) :=
  fun i => R.shuffle (Sum.inr i)

/-- Raw minor columns are position-injective. -/
lemma minorCols_injective
    {A B : MinorIndex m n t}
    {hC : Close A B}
    (R : RawColLaplaceChoice A B hC) :
    Function.Injective R.minorCols := by
  intro i j hij
  have hval :
      (R.shuffle (Sum.inl i)).1 = (R.shuffle (Sum.inl j)).1 := by
    simpa [minorCols] using congrArg Fin.val hij
  apply Fin.ext
  exact congrArg Fin.val (StrictMono.injective R.minorColsPosStrict hval)

/-- Raw cofactor columns are position-injective. -/
lemma cofactorCols_injective
    {A B : MinorIndex m n t}
    {hC : Close A B}
    (R : RawColLaplaceChoice A B hC) :
    Function.Injective R.cofactorCols := by
  intro i j hij
  have hval :
      (R.shuffle (Sum.inr i)).1 = (R.shuffle (Sum.inr j)).1 := by
    simpa [cofactorCols] using congrArg Fin.val hij
  apply Fin.ext
  exact congrArg Fin.val (StrictMono.injective R.cofactorColsPosStrict hval)

lemma ext_shuffle
    {A B : MinorIndex m n t}
    {hC : Close A B}
    {R S : RawColLaplaceChoice A B hC}
    (hshuffle : R.shuffle = S.shuffle) :
    R = S := by
  cases R
  cases S
  cases hshuffle
  rfl

end RawColLaplaceChoice

noncomputable instance rawColLaplaceChoiceFintype
    (A B : MinorIndex m n t)
    (hC : Close A B) :
    Fintype (RawColLaplaceChoice A B hC) := by
  classical
  let Shuffle : Type :=
    Fin t ⊕ Fin (ClosePairStrictBlock.width A B) ≃
      Fin (ClosePairStrictBlock.size A B)
  let α : Type :=
    {p : Shuffle //
      StrictMono (fun i : Fin t => (p (Sum.inl i)).1) ∧
      StrictMono
        (fun i : Fin (ClosePairStrictBlock.width A B) =>
          (p (Sum.inr i)).1)}
  let e : RawColLaplaceChoice A B hC ≃ α :=
  {
    toFun R :=
      ⟨R.shuffle, R.minorColsPosStrict, R.cofactorColsPosStrict⟩
    invFun p :=
      { shuffle := p.1
        minorColsPosStrict := p.2.1
        cofactorColsPosStrict := p.2.2 }
    left_inv R := by
      cases R
      rfl
    right_inv p := by
      cases p
      rfl
  }
  exact Fintype.ofEquiv α e.symm

/-- The raw column-side Laplace sign attached to a position-ordered column
subset. -/
noncomputable def rawColLaplaceSign
    (A B : MinorIndex m n t)
    (hC : Close A B)
    (R : RawColLaplaceChoice A B hC) : k :=
  ClosePairStrictBlock.laplaceShuffleSign
    (k := k)
    (R.shuffle.trans (ClosePairStrictBlock.sumFinToSize A B).symm) *
    ClosePairStrictBlock.laplaceShuffleSign
      (k := k)
      ((ClosePairStrictBlock.colPrincipalShuffle A B hC).trans
        (ClosePairStrictBlock.sumFinToSize A B).symm)

/-- One raw column-side Laplace summand, before normalizing the selected
columns into a `ColLaplaceChoice`. -/
noncomputable def rawColLaplaceSummand
    (A B : MinorIndex m n t)
    (hC : Close A B)
    (R : RawColLaplaceChoice A B hC) :
    MvPolynomial (Fin m × Fin n) k :=
  MvPolynomial.C
      (rawColLaplaceSign
        (m := m) (n := n) (t := t) (k := k) A B hC R) *
    (Matrix.det
        (Matrix.submatrix
          (ClosePairStrictBlock.matrix
            (m := m) (n := n) (t := t) (k := k) A B)
          (ClosePairStrictBlock.aRepeatedMiddlePos A B hC)
          R.cofactorCols) *
      Matrix.det
        (Matrix.submatrix
          (ClosePairStrictBlock.matrix
            (m := m) (n := n) (t := t) (k := k) A B)
          (ClosePairStrictBlock.bRowPos A B hC)
          R.minorCols))

/-- The full permutation attached to a raw column choice and the two internal
Leibniz permutations. -/
noncomputable def rawColLaplacePerm
    (A B : MinorIndex m n t)
    (hC : Close A B)
    (R : RawColLaplaceChoice A B hC)
    (τ : Equiv.Perm (Fin t))
    (σ : Equiv.Perm (Fin (ClosePairStrictBlock.width A B))) :
    Equiv.Perm (Fin (ClosePairStrictBlock.size A B)) :=
  R.shuffle.symm.trans
    ((Equiv.Perm.sumCongr τ σ).trans
      (ClosePairStrictBlock.colPrincipalShuffle A B hC))

@[simp] lemma rawColLaplacePerm_minorCols
    (A B : MinorIndex m n t)
    (hC : Close A B)
    (R : RawColLaplaceChoice A B hC)
    (τ : Equiv.Perm (Fin t))
    (σ : Equiv.Perm (Fin (ClosePairStrictBlock.width A B)))
    (j : Fin t) :
    rawColLaplacePerm A B hC R τ σ (R.minorCols j) =
      ClosePairStrictBlock.bRowPos A B hC (τ j) := by
  have hleft :
      R.shuffle.symm (R.minorCols j) = Sum.inl j := by
    rw [RawColLaplaceChoice.minorCols]
    exact R.shuffle.left_inv (Sum.inl j)
  simp [rawColLaplacePerm, hleft, ClosePairStrictBlock.colPrincipalShuffle]

@[simp] lemma rawColLaplacePerm_cofactorCols
    (A B : MinorIndex m n t)
    (hC : Close A B)
    (R : RawColLaplaceChoice A B hC)
    (τ : Equiv.Perm (Fin t))
    (σ : Equiv.Perm (Fin (ClosePairStrictBlock.width A B)))
    (j : Fin (ClosePairStrictBlock.width A B)) :
    rawColLaplacePerm A B hC R τ σ (R.cofactorCols j) =
      ClosePairStrictBlock.aRepeatedMiddlePos A B hC (σ j) := by
  have hright :
      R.shuffle.symm (R.cofactorCols j) = Sum.inr j := by
    rw [RawColLaplaceChoice.cofactorCols]
    exact R.shuffle.left_inv (Sum.inr j)
  simp [rawColLaplacePerm, hright, ClosePairStrictBlock.colPrincipalShuffle]

lemma rawColLaplacePerm_product_split
    {Rng : Type*} [CommMonoid Rng]
    (A B : MinorIndex m n t)
    (hC : Close A B)
    (R : RawColLaplaceChoice A B hC)
    (τ : Equiv.Perm (Fin t))
    (σ : Equiv.Perm (Fin (ClosePairStrictBlock.width A B)))
    (M : Matrix (Fin (ClosePairStrictBlock.size A B))
          (Fin (ClosePairStrictBlock.size A B)) Rng) :
    (∏ j : Fin (ClosePairStrictBlock.size A B),
        M (rawColLaplacePerm A B hC R τ σ j) j) =
      (∏ j : Fin t,
        M (ClosePairStrictBlock.bRowPos A B hC (τ j)) (R.minorCols j)) *
      (∏ j : Fin (ClosePairStrictBlock.width A B),
        M (ClosePairStrictBlock.aRepeatedMiddlePos A B hC (σ j))
          (R.cofactorCols j)) := by
  classical
  rw [← Equiv.prod_comp R.shuffle
    (fun j : Fin (ClosePairStrictBlock.size A B) =>
      M (rawColLaplacePerm A B hC R τ σ j) j)]
  rw [Fintype.prod_sum_type]
  simp [rawColLaplacePerm, ClosePairStrictBlock.colPrincipalShuffle,
    RawColLaplaceChoice.minorCols, RawColLaplaceChoice.cofactorCols]

