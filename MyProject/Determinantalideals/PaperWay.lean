/-- Raw column-subset Laplace expansion along the `B` rows. -/
lemma strict_col_laplace_expansion_raw_choices
    (A B : MinorIndex m n t)
    (hC : Close A B) :
    ClosePairStrictBlock.det
        (m := m) (n := n) (t := t) (k := k) A B =
      ∑ R : RawColLaplaceChoice A B hC,
        rawColLaplaceSummand
          (m := m) (n := n) (t := t) (k := k) A B hC R := by
  classical
  let detTerm : Equiv.Perm (Fin (ClosePairStrictBlock.size A B)) →
      MvPolynomial (Fin m × Fin n) k :=
    fun ρ =>
      ClosePairStrictBlock.laplaceShuffleSign
          (k := MvPolynomial (Fin m × Fin n) k) ρ *
        ∏ j : Fin (ClosePairStrictBlock.size A B),
          ClosePairStrictBlock.matrix
            (m := m) (n := n) (t := t) (k := k) A B (ρ j) j
  calc
    ClosePairStrictBlock.det
        (m := m) (n := n) (t := t) (k := k) A B =
      ∑ ρ : Equiv.Perm (Fin (ClosePairStrictBlock.size A B)), detTerm ρ := by
        rw [ClosePairStrictBlock.det, Matrix.det_apply']
        simp [detTerm, ClosePairStrictBlock.laplaceShuffleSign]
    _ =
      ∑ x :
          Σ R : RawColLaplaceChoice A B hC,
            Equiv.Perm (Fin t) ×
              Equiv.Perm (Fin (ClosePairStrictBlock.width A B)),
        detTerm (rawColLaplacePerm A B hC x.1 x.2.1 x.2.2) := by
        let e := rawColLaplaceIndexEquiv
          (m := m) (n := n) (t := t) A B hC
        have hsum :
            (∑ x :
                Σ R : RawColLaplaceChoice A B hC,
                  Equiv.Perm (Fin t) ×
                    Equiv.Perm (Fin (ClosePairStrictBlock.width A B)),
              detTerm (e x)) =
            ∑ ρ : Equiv.Perm (Fin (ClosePairStrictBlock.size A B)),
              detTerm ρ :=
          Fintype.sum_equiv e
            (fun x => detTerm (e x))
            detTerm
            (by intro x; rfl)
        simpa [e, rawColLaplaceIndexEquiv, rawColLaplacePerm] using hsum.symm
    _ =
      ∑ R : RawColLaplaceChoice A B hC,
        rawColLaplaceSummand
          (m := m) (n := n) (t := t) (k := k) A B hC R := by
        calc
          (∑ x :
              Σ R : RawColLaplaceChoice A B hC,
                Equiv.Perm (Fin t) ×
                  Equiv.Perm (Fin (ClosePairStrictBlock.width A B)),
            detTerm (rawColLaplacePerm A B hC x.1 x.2.1 x.2.2))
              =
            ∑ R : RawColLaplaceChoice A B hC,
              ∑ p : Equiv.Perm (Fin t) ×
                  Equiv.Perm (Fin (ClosePairStrictBlock.width A B)),
                detTerm (rawColLaplacePerm A B hC R p.1 p.2) := by
              exact
                Fintype.sum_sigma'
                  (fun R : RawColLaplaceChoice A B hC =>
                    fun p : Equiv.Perm (Fin t) ×
                        Equiv.Perm (Fin (ClosePairStrictBlock.width A B)) =>
                      detTerm (rawColLaplacePerm A B hC R p.1 p.2))
          _ =
            ∑ R : RawColLaplaceChoice A B hC,
              rawColLaplaceSummand
                (m := m) (n := n) (t := t) (k := k) A B hC R := by
              refine Finset.sum_congr rfl ?_
              intro R _hR
              exact
                (rawColLaplaceSummand_eq_sum_rawColLaplacePerm_terms
                  (m := m) (n := n) (t := t) (k := k) A B hC R).symm

/-! The remaining raw column facts are the normalization layer. -/

namespace RawColLaplaceChoice

/-- A raw column choice is sortable if the selected minor columns have
pairwise distinct actual column variables. -/
def Sortable
    {A B : MinorIndex m n t}
    {hC : Close A B}
    (R : RawColLaplaceChoice A B hC) : Prop :=
  Function.Injective
    (fun i : Fin t =>
      ClosePairStrictBlock.colFin A B hC (R.minorCols i))

end RawColLaplaceChoice

noncomputable instance sortableRawColLaplaceChoiceFintype
    (A B : MinorIndex m n t)
    (hC : Close A B) :
    Fintype {R : RawColLaplaceChoice A B hC // R.Sortable} := by
  classical
  infer_instance

noncomputable instance notSortableRawColLaplaceChoiceFintype
    (A B : MinorIndex m n t)
    (hC : Close A B) :
    Fintype {R : RawColLaplaceChoice A B hC // ¬ R.Sortable} := by
  classical
  infer_instance

