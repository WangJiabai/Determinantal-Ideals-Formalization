/-- The part of a Case 1 row-term exponent supported on the `B`-middle square.

This is the local block that should be compared with the diagonal exponent of
`bMiddleMinorIndex`.  It is defined by restricting the full displayed exponent
to coordinates of the form
`((bMiddleMinorIndex).row x, (bMiddleMinorIndex).col y)`. -/
noncomputable def closePairThm21_case1_BmiddlePartExp
    (A B : MinorIndex m n t)
    (hC : Close A B)
    (L : ClosePairStrictBlock.RowLaplaceChoice A B hC)
    (σ : Equiv.Perm (Fin (ClosePairStrictBlock.width A B))) :
    (Fin m × Fin n) →₀ ℕ :=
  ∑ x : Fin (ClosePairStrictBlock.width A B),
    ∑ y : Fin (ClosePairStrictBlock.width A B),
      Finsupp.single
        ((ClosePairStrictBlock.bMiddleMinorIndex A B hC).row x,
          (ClosePairStrictBlock.bMiddleMinorIndex A B hC).col y)
        (closePairThm21_case1_rowTermExp
          (m := m) (n := n) (t := t) (k := k) A B hC L σ
          ((ClosePairStrictBlock.bMiddleMinorIndex A B hC).row x,
