  have hnotPre_i : ¬ i.1 < sClose A B := by
    have hsu : sClose A B < uClose A B :=
      sClose_lt_uClose A B hC.ne
    exact not_lt_of_ge (le_trans (Nat.le_of_lt hsu) hi)
  have hnotMid_i : ¬ i.1 < uClose A B := by
    exact not_lt_of_ge hi
  rcases ClosePairStrictBlock.block_cases_of_lt_size A B q.2 with
      hpre | hmid | hrep | htail
  · /- prefix block: row is `A.row q`, but `q < s ≤ u ≤ i`. -/
    have hq_lt_s : q.1 < sClose A B := by
      simpa [ClosePairStrictBlock.prefixBlock] using hpre
    have hq_lt_t : q.1 < t := by
      have hslt : sClose A B < t :=
        lt_of_lt_of_le (sClose_lt_pClose A B hC.ne) (pClose_le A B)
      omega
    let qidx : Fin t := ⟨q.1, hq_lt_t⟩
    have hqrow :
        ClosePairStrictBlock.rowFin A B hC q = A.row qidx := by
      apply Fin.ext
      change rowCoord A B q.1 - 1 = (A.row qidx).1
      rw [ClosePairStrictBlock.rowCoord_of_prefix A B hq_lt_s]
      rw [EndpointSelection.rowExt_endpoint (I := A) (by omega) (by omega)]
      simp [qidx]
    have hlt : qidx < i := by
      exact Fin.mk_lt_mk.mpr (by
        have hsu : sClose A B < uClose A B :=
          sClose_lt_uClose A B hC.ne
        omega)
    have hltrow : A.row qidx < A.row i :=
      A.row.strictMono hlt
    have heq : A.row qidx = A.row i :=
      hqrow.symm.trans hrow
    exfalso
    exact (ne_of_lt hltrow) heq
  · /- B-middle block: row is `B.row q`; tail `A.row i = B.row i`,
       and `q < u ≤ i`, so strict monotonicity of `B.row` contradicts equality. -/
    have hq_ge_s : sClose A B ≤ q.1 := hmid.1
    have hq_lt_u : q.1 < uClose A B := hmid.2
    have hq_lt_t : q.1 < t := by
