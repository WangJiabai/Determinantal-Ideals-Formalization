lemma colLaplaceChoice_minorDet_eq_genericMinor
    (A B : MinorIndex m n t)
    (hC : Close A B)
    (L : ClosePairStrictBlock.ColLaplaceChoice A B hC) :
    Matrix.det
      (Matrix.submatrix
        (ClosePairStrictBlock.matrix
          (m := m) (n := n) (t := t) (k := k) A B)
        (ClosePairStrictBlock.bRowPos A B hC)
        L.minorCols) =
      genericMinor (k := k) L.minorIndex := by
  classical
  exact colLaplaceChoice_minorSubmatrix_det_eq_genericMinor
    (m := m) (n := n) (t := t) (k := k) A B hC L

