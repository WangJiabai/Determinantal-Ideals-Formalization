/-- Expanding one row-Laplace summand gives exactly the Leibniz terms whose
full permutation is `rowLaplacePerm L τ σ`. -/
lemma strictRowLaplaceSummand_eq_sum_rowLaplacePerm_terms
    (A B : MinorIndex m n t)
    (hC : Close A B)
    (L : ClosePairStrictBlock.RowLaplaceChoice A B hC) :
    strictRowLaplaceSummand
        (m := m) (n := n) (t := t) (k := k) A B hC L =
      ∑ p : Equiv.Perm (Fin t) ×
          Equiv.Perm (Fin (ClosePairStrictBlock.width A B)),
        ClosePairStrictBlock.laplaceShuffleSign
            (k := MvPolynomial (Fin m × Fin n) k)
            (ClosePairStrictBlock.rowLaplacePerm A B hC L p.1 p.2) *
          ∏ j : Fin (ClosePairStrictBlock.size A B),
            ClosePairStrictBlock.matrix
              (m := m) (n := n) (t := t) (k := k) A B
              (ClosePairStrictBlock.rowLaplacePerm A B hC L p.1 p.2 j) j := by
  classical
  rw [strictRowLaplaceSummand]
  rw [← rowLaplaceChoice_minorDet_eq_genericMinor
    (m := m) (n := n) (t := t) (k := k) A B hC L]
  rw [← rowLaplaceChoice_cofactorSubmatrix_eq_cofactorMatrix
    (m := m) (n := n) (t := t) (k := k) A B hC L]
  rw [Matrix.det_apply', Matrix.det_apply']
  simp_rw [Finset.sum_mul, Finset.mul_sum]
  rw [Finset.sum_comm]
  rw [← Fintype.sum_prod_type']
  refine Finset.sum_congr rfl ?_
  rintro ⟨τ, σ⟩ _hp
  have hprod :=
    ClosePairStrictBlock.rowLaplacePerm_product_split
      (m := m) (n := n) (t := t) A B hC L τ σ
      (ClosePairStrictBlock.matrix
        (m := m) (n := n) (t := t) (k := k) A B)
  have hsign :=
    ClosePairStrictBlock.rowLaplacePerm_sign
      (m := m) (n := n) (t := t)
      (k := MvPolynomial (Fin m × Fin n) k) A B hC L τ σ
  rw [hsign, hprod]
  simp [ClosePairStrictBlock.laplaceShuffleSign,
    ClosePairStrictBlock.rowLaplaceSign, MvPolynomial.C_mul]
  ring

