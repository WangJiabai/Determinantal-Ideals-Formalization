    rowFin A B hC (aRepeatedMiddlePos A B hC j) at hij
  rw [rowFin_aRepeatedMiddlePos A B hC i,
    rowFin_aRepeatedMiddlePos A B hC j] at hij
  have hidx := A.row.injective hij
  apply Fin.ext
  have hval := congrArg Fin.val hidx
  simpa using hval

lemma rowFin_bMiddlePos_strictMono
    (A B : MinorIndex m n t)
  (hC : Close A B) :
    StrictMono
      (fun i : Fin (width A B) => rowFin A B hC (bMiddlePos A B hC i)) := by
  intro i j hij
  change rowFin A B hC (bMiddlePos A B hC i) <
    rowFin A B hC (bMiddlePos A B hC j)
  rw [rowFin_bMiddlePos A B hC i, rowFin_bMiddlePos A B hC j]
