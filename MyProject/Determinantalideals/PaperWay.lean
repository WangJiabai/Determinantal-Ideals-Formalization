          (m := m) (n := n) (t := t) (k := k) A B hC := by
  classical
  /-
  Use `MonomialCoefficientMatrix.scaled_det_mul_minor_eq_sum_closePairTerm`
  with scalar `1`, then split the permutation sum into:
    * identity permutation -> `strictBDiagPart`;
    * non-identity permutations -> `- bTailPartSum`.

  The definition of `bTailPartSum` uses `bBlockTerm ... (-1) σ`.
  -/
