/-- A cofactor row whose actual row is a middle `B` row must be the
corresponding `B`-middle strict-block position.

The nonzero coefficient hypothesis is used only to rule out the repeated
`A`-middle zero block on the cofactor side. -/
lemma closePairThm21_case1_cofactorRows_eq_bMiddlePos_of_cofactorRow_eq_B_middle
    (A B : MinorIndex m n t)
    (hC : Close A B)
    (L : ClosePairStrictBlock.RowLaplaceChoice A B hC)
    (σ : Equiv.Perm (Fin (ClosePairStrictBlock.width A B)))
    (hc :
      (closePairThm21_case1_rowTerm
        (m := m) (n := n) (t := t) (k := k) A B hC L σ).c ≠ 0)
    (idx : Fin t)
    (hs : sClose A B ≤ idx.1)
    (hu : idx.1 < uClose A B)
    (w : Fin (ClosePairStrictBlock.width A B))
    (hrow :
      L.cofactorRow (σ w) = B.row idx) :
    L.cofactorRows (σ w) =
      ClosePairStrictBlock.bMiddlePos A B hC
        ⟨idx.1 - sClose A B, by
          simp [ClosePairStrictBlock.width]
          omega⟩ := by
  classical
  let q : Fin (ClosePairStrictBlock.size A B) := L.cofactorRows (σ w)
  let target : Fin (ClosePairStrictBlock.width A B) :=
    ⟨idx.1 - sClose A B, by
      simp [ClosePairStrictBlock.width]
      omega⟩
  have hqrow :
      ClosePairStrictBlock.rowFin A B hC q = B.row idx := by
    simpa [q, ClosePairStrictBlock.RowLaplaceChoice.cofactorRow] using hrow
  have hnotRep :
      ¬ ClosePairStrictBlock.aRepeatedMiddle A B q.1 := by
    simpa [q] using
      closePairThm21_case1_cofactorRows_not_aRepeatedMiddle_any
        (m := m) (n := n) (t := t) (k := k)
        A B hC L σ hc (σ w)
  rcases ClosePairStrictBlock.block_cases_of_lt_size A B q.2 with
      hpre | hmid | hrep | htail
  · exfalso
    have hq_lt_s : q.1 < sClose A B := by
      simpa [ClosePairStrictBlock.prefixBlock] using hpre
    have hq_lt_t : q.1 < t := by
      have hslt : sClose A B < t :=
        lt_of_lt_of_le (sClose_lt_pClose A B hC.ne) (pClose_le A B)
      omega
    let qidx : Fin t := ⟨q.1, hq_lt_t⟩
    have hqrowA :
        ClosePairStrictBlock.rowFin A B hC q = A.row qidx := by
      apply Fin.ext
      have hcoord :
          ClosePairStrictBlock.rowCoord A B q.1 =
            rowExt A (q.1 + 1) :=
        ClosePairStrictBlock.rowCoord_of_prefix A B hq_lt_s
      have hext :
          rowExt A (q.1 + 1) = (A.row qidx).1 + 1 := by
        rw [EndpointSelection.rowExt_endpoint (I := A)
          (Nat.succ_pos q.1) (Nat.succ_le_of_lt qidx.2)]
        simp [qidx]
      change ClosePairStrictBlock.rowCoord A B q.1 - 1 =
        (A.row qidx).1
      rw [hcoord, hext]
      simp
    have hABrow : A.row qidx = B.row qidx := by
      have hpEq :
          pairExt A (qidx.1 + 1) = pairExt B (qidx.1 + 1) := by
        exact pairExt_eq_of_mu_eq_right_le_s
          A B hC.ne hC.mu_eq_right (Nat.succ_pos qidx.1)
          (by
            dsimp [qidx]
            exact Nat.succ_le_of_lt hq_lt_s)
      have hq₂ : qidx.1 + 1 ≤ t := by omega
      rw [EndpointSelection.pairExt_endpoint (I := A) (by omega) hq₂,
        EndpointSelection.pairExt_endpoint (I := B) (by omega) hq₂] at hpEq
      have hrowNat := congrArg Prod.fst hpEq
      apply Fin.ext
      simp at hrowNat
      omega
    have hlt : qidx < idx := by
      exact Fin.mk_lt_mk.mpr (by omega)
    have hltrow : B.row qidx < B.row idx :=
      B.row.strictMono hlt
    have heq : B.row qidx = B.row idx :=
      hABrow.symm.trans (hqrowA.symm.trans hqrow)
    exact (ne_of_lt hltrow) heq
  · let p : Fin (ClosePairStrictBlock.width A B) :=
      ⟨q.1 - sClose A B, by
        have hge : sClose A B ≤ q.1 := hmid.1
        have hlt : q.1 < uClose A B := hmid.2
        simp [ClosePairStrictBlock.width]
        omega⟩
    have hq_eq :
        q = ClosePairStrictBlock.bMiddlePos A B hC p := by
      apply Fin.ext
      change q.1 = sClose A B + (q.1 - sClose A B)
      exact (Nat.add_sub_of_le hmid.1).symm
    have hprow :
        B.row
            (⟨sClose A B + p.1, by
              have hpw : p.1 < uClose A B - sClose A B := by
                simpa [p, ClosePairStrictBlock.width] using p.2
              have hut : uClose A B ≤ t :=
                le_trans (uClose_le_pClose A B hC.ne) (pClose_le A B)
              omega⟩ : Fin t) =
          B.row idx := by
      have hqrow' := hqrow
      rw [hq_eq, ClosePairStrictBlock.rowFin_bMiddlePos A B hC p] at hqrow'
      exact hqrow'
    have hidx_eq :
        (⟨sClose A B + p.1, by
          have hpw : p.1 < uClose A B - sClose A B := by
            simpa [p, ClosePairStrictBlock.width] using p.2
          have hut : uClose A B ≤ t :=
            le_trans (uClose_le_pClose A B hC.ne) (pClose_le A B)
          omega⟩ : Fin t) = idx :=
      B.row.injective hprow
    have hp_eq_target : p = target := by
      apply Fin.ext
      have hval := congrArg Fin.val hidx_eq
      simp [target, p] at hval ⊢
      omega
    simpa [q, target, hp_eq_target] using hq_eq
  · exfalso
    exact hnotRep hrep
  · exfalso
    have htail_ge :
        uClose A B + ClosePairStrictBlock.width A B ≤ q.1 := by
      simpa [ClosePairStrictBlock.tailBlock] using htail
    have hq_lt_size : q.1 < ClosePairStrictBlock.size A B := q.2
    let qidx : Fin t :=
      ⟨q.1 - ClosePairStrictBlock.width A B, by
        unfold ClosePairStrictBlock.size at hq_lt_size
        omega⟩
    have hqrowA :
        ClosePairStrictBlock.rowFin A B hC q = A.row qidx := by
      apply Fin.ext
      have hcoord :
          ClosePairStrictBlock.rowCoord A B q.1 =
            rowExt A (q.1 + 1 - ClosePairStrictBlock.width A B) :=
        ClosePairStrictBlock.rowCoord_of_tail A B hC htail
      have hpaper :
          q.1 + 1 - ClosePairStrictBlock.width A B =
            qidx.1 + 1 := by
        simp [qidx]
        omega
      have hext :
          rowExt A (q.1 + 1 - ClosePairStrictBlock.width A B) =
            (A.row qidx).1 + 1 := by
        rw [hpaper]
        rw [EndpointSelection.rowExt_endpoint (I := A)
          (Nat.succ_pos qidx.1)
          (Nat.succ_le_of_lt qidx.2)]
        simp [qidx]
      change ClosePairStrictBlock.rowCoord A B q.1 - 1 =
        (A.row qidx).1
      rw [hcoord, hext]
      simp
    have hABrow : A.row qidx = B.row qidx := by
      have hpEq :
          pairExt A (qidx.1 + 1) = pairExt B (qidx.1 + 1) := by
        exact pairExt_eq_of_mu_eq_right_gt_u
          A B hC.ne hC.mu_eq_right (by
            have hqidx_ge_u :
                uClose A B ≤ qidx.1 := by
              dsimp [qidx]
              exact Nat.le_sub_of_add_le htail_ge
            omega) (by omega)
      have hq₂ : qidx.1 + 1 ≤ t := by omega
      rw [EndpointSelection.pairExt_endpoint (I := A) (by omega) hq₂,
        EndpointSelection.pairExt_endpoint (I := B) (by omega) hq₂] at hpEq
      have hrowNat := congrArg Prod.fst hpEq
      apply Fin.ext
      simp at hrowNat
      omega
    have hlt : idx < qidx := by
      exact Fin.mk_lt_mk.mpr (by
        have hqidx_ge_u :
            uClose A B ≤ qidx.1 := by
          dsimp [qidx]
          exact Nat.le_sub_of_add_le htail_ge
        omega)
    have hltrow : B.row idx < B.row qidx :=
      B.row.strictMono hlt
    have heq : B.row qidx = B.row idx :=
      hABrow.symm.trans (hqrowA.symm.trans hqrow)
    exact (ne_of_gt hltrow) heq

