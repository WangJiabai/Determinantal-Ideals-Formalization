    Matrix.det
          (strictBBlockMatrix (m := m) (n := n) (t := t) (k := k) A B hC) *
        genericMinor (k := k) A
        =
      ∑ σ : Equiv.Perm (Fin (ClosePairStrictBlock.width A B)),
        (ClosePairStrictBlock.bBlockTerm
          (m := m) (n := n) (t := t) (k := k) A B hC 1 σ).poly := hdet
    _ =
      strictBDiagPart (m := m) (n := n) (t := t) (k := k) A B hC +
        ∑ σ : {σ : Equiv.Perm (Fin (ClosePairStrictBlock.width A B)) // σ ≠ 1},
