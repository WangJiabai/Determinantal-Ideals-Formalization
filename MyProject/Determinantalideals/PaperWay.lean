/-- One step of the paper Case 1 `u_i/v_i` induction.

At index `i`, the proof order follows the paper:

1. prove Statement (b) for the current `u`-interval;
2. prove Statement (c) for the current `v`-interval;
3. prove Statement (a) for the current `v`-interval.

The previous intervals are available through `hprevA`, `hprevB`, and
`hprevC`. -/
lemma closePairThm21_case1_chain_step
    (ord : MonomialOrder (Fin m × Fin n))
    (hdiag : IsDiagonalTermOrder ord)
    (A B : MinorIndex m n t)
    (hC : Close A B)
    (hrowLt :
      rowExt B (uClose A B) < rowExt A (uClose A B))
    (L : ClosePairStrictBlock.RowLaplaceChoice A B hC)
    (σ : Equiv.Perm (Fin (ClosePairStrictBlock.width A B)))
    (hc :
      (closePairThm21_case1_rowTerm
        (m := m) (n := n) (t := t) (k := k) A B hC L σ).c ≠ 0)
    (hnot :
      ¬ ord.toSyn
          (closePairThm21_case1_rowTermExp
            (m := m) (n := n) (t := t) (k := k) A B hC L σ)
        <
        ord.toSyn
          (headLcm ord
            (genericMinor (k := k) A)
            (genericMinor (k := k) B)))
    (U : Case1UVChain A B hC)
    (i : Fin U.q)
    (hprevA :
      ∀ j : Fin U.q, j.1 < i.1 → StatementA A B hC L U j)
    (hprevB :
      ∀ j : Fin U.q, j.1 < i.1 → StatementB A B hC L U j)
    (hprevC :
      ∀ j : Fin U.q, j.1 < i.1 → StatementC A B hC L σ U j) :
    StatementB A B hC L U i ∧
    StatementC A B hC L σ U i ∧
    StatementA A B hC L U i := by
  classical
  have hB_suffix : StatementBSuffix A B hC L U i (U.u i.succ) :=
    closePairThm21_case1_statementB_suffix_of_prev
        (m := m) (n := n) (t := t) (k := k)
        ord hdiag A B hC hrowLt L σ hc hnot U i
        hprevA hprevB hprevC
  have hB : StatementB A B hC L U i := by
    intro j hjlo hjhi
    simpa [StatementBAt] using hB_suffix j hjlo hjhi hjlo
  have hCstmt : StatementC A B hC L σ U i := by
    intro j hjlo hjhi
    by_contra hfail
    have hzero :
        MonomialCoefficientMatrix.permExp L.cofactorRow L.cofactorCol σ
          (B.row
              (middlePaperIndexToFinOfClose A B hC j
                (by
                  have hs : sClose A B + 1 ≤ j :=
                    le_trans (U.v_bounds i.succ).1 hjlo
                  have hu : j ≤ uClose A B := by
                    have htop := (U.v_bounds i.castSucc).2
