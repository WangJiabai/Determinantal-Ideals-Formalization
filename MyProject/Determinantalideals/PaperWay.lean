        (L.cofactorCols j) =
      L.cofactorMatrix i j
  by_cases hzero :
      ClosePairStrictBlock.zeroBlock A B
        (ClosePairStrictBlock.aRepeatedMiddlePos A B hC i).1
        (L.cofactorCols j).1
  · simp [ClosePairStrictBlock.matrix,
      ClosePairStrictBlock.ColLaplaceChoice.cofactorMatrix,
      ClosePairStrictBlock.ColLaplaceChoice.cofactorZero,
      MonomialCoefficientMatrix.matrix, hzero]
  · rw [ClosePairStrictBlock.matrix_entry_of_not_zeroBlock_as_X'
      (m := m) (n := n) (t := t) (k := k) A B hC hzero]
    simp [ClosePairStrictBlock.ColLaplaceChoice.cofactorMatrix,
      ClosePairStrictBlock.ColLaplaceChoice.cofactorRow,
      ClosePairStrictBlock.ColLaplaceChoice.cofactorCol,
      ClosePairStrictBlock.ColLaplaceChoice.cofactorZero,
      MonomialCoefficientMatrix.matrix, hzero]

