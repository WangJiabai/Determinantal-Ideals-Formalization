            (m := m) (n := n) (t := t) (k := k) A B hC)
        (colPart :=
          ClosePairStrictBlock.StrictLaplaceRawIndex.colPartSum
            (m := m) (n := n) (t := t) (k := k) A B hC)
        (bTailPart :=
          ClosePairStrictBlock.StrictLaplaceRawIndex.bTailPartSum
            (m := m) (n := n) (t := t) (k := k) A B hC)
        (cTailPart :=
          ClosePairStrictBlock.StrictLaplaceRawIndex.cTailPartSum
            (m := m) (n := n) (t := t) (k := k) A B hC)
        hsp hrow hcol
  calc
    ord.sPolynomial (genericMinor (k := k) A) (genericMinor (k := k) B)
        =
      ClosePairStrictBlock.StrictLaplaceRawIndex.colPartSum
        (m := m) (n := n) (t := t) (k := k) A B hC +
      ClosePairStrictBlock.StrictLaplaceRawIndex.rowPartSum
        (m := m) (n := n) (t := t) (k := k) A B hC +
      ClosePairStrictBlock.StrictLaplaceRawIndex.cTailPartSum
        (m := m) (n := n) (t := t) (k := k) A B hC +
      ClosePairStrictBlock.StrictLaplaceRawIndex.bTailPartSum
        (m := m) (n := n) (t := t) (k := k) A B hC := hfour
    _ =
      ClosePairStrictBlock.StrictLaplaceRawIndex.rawPolySum
        (m := m) (n := n) (t := t) (k := k) A B hC :=
      (strict_rawPolySum_eq_four_part_sums
        (m := m) (n := n) (t := t) (k := k) A B hC).symm




/-! ### Paper Theorem 2.1 skeleton for close pairs

The remaining work in the paper route is local to close pairs.  Following §2,
we split it into the two cases after orienting the pair so that the boundary
row from `B` is not above the boundary row from `A`.

* strict case: `α'_t < α_t` in the file's extended-index notation;
  this is the determinant expansion of the block matrix `M` along the columns
  `β'_{s+1}, ..., β'_t` and along the rows `α_{s+1}, ..., α_t`;
* equality case: Lemma 1.4(iii) gives `t = s+1`, and the paper uses the
  one-row/one-column expansion.
-/

omit [Nontrivial k] in
/-- Bridge from an indexed finite family of displayed Theorem 2.1 terms to the
`Finset ClosePairThm21Term` statement used by the close-pair API.  This is the
form naturally produced by Laplace expansion: the index carries the choice of
rows/columns and the cofactor permutation. -/
lemma closePairThm21_terms_of_indexed_family
    {ι : Type*} [Fintype ι]
    (ord : MonomialOrder (Fin m × Fin n))
    (A B : MinorIndex m n t)
    (T : ι → ClosePairThm21Term m n t k)
    (hinj : Function.Injective T)
    (hlin :
      ord.sPolynomial (genericMinor (k := k) A) (genericMinor (k := k) B) =
        ∑ i : ι, (T i).poly)
    (hsmall :
      ∀ i : ι, ∀ a : k, a ≠ 0 →
        ord.toSyn
          (ord.degree
            (MvPolynomial.monomial (T i).d a *
              genericMinor (k := k) (T i).K)) <
        ord.toSyn
          (headLcm ord
            (genericMinor (k := k) A)
            (genericMinor (k := k) B))) :
    ∃ S : Finset (ClosePairThm21Term m n t k),
      ord.sPolynomial (genericMinor (k := k) A) (genericMinor (k := k) B) =
        ∑ U ∈ S, U.poly ∧
      ∀ U ∈ S, ∀ a : k, a ≠ 0 →
        ord.toSyn
          (ord.degree
            (MvPolynomial.monomial U.d a * genericMinor (k := k) U.K)) <
        ord.toSyn
          (headLcm ord
            (genericMinor (k := k) A)
            (genericMinor (k := k) B)) := by
  classical
  refine ⟨Finset.univ.image T, ?_, ?_⟩
  · rw [Finset.sum_image]
    · simpa using hlin
    · intro x _hx y _hy hxy
      exact hinj hxy
  · intro U hU a ha
    rcases Finset.mem_image.mp hU with ⟨i, _hi, rfl⟩
    exact hsmall i a ha

/-- Exponent estimates for an indexed strict-case Laplace family imply the
`headLcm` smallness statement needed by the `ClosePairThm21Term` packaging
lemma.

This is the formal version of the last paragraph after `(*)` in the paper:
once every displayed summand is bounded by `diagExp A ⊔ diagExp B` and has a
strict coordinate gap, diagonality of the order turns this into strict
smallness below the endpoint lcm. -/
lemma closePairThm21_strict_indexed_small_of_exponent_data
    {ι : Type*}
    (ord : MonomialOrder (Fin m × Fin n))
    (hdiag : IsDiagonalTermOrder ord)
    (A B : MinorIndex m n t)
    (T : ι → ClosePairThm21Term m n t k)
    (hle :
      ∀ i : ι, (T i).d + diagExp (T i).K ≤ diagExp A ⊔ diagExp B)
    (hgap :
      ∀ i : ι,
        ∃ x : Fin m × Fin n,
          ((T i).d + diagExp (T i).K) x <
            (diagExp A ⊔ diagExp B) x) :
    ∀ i : ι, ∀ a : k, a ≠ 0 →
      ord.toSyn
        (ord.degree
          (MvPolynomial.monomial (T i).d a *
            genericMinor (k := k) (T i).K)) <
      ord.toSyn
        (headLcm ord
          (genericMinor (k := k) A)
          (genericMinor (k := k) B)) := by
  intro i a ha
  exact (T i).small_of_le_sup_and_gap
    (k := k) ord hdiag A B (hle i) (hgap i) a ha


lemma sum_ulift_down
    {α : Type v} {R : Type w} [Fintype α] [AddCommMonoid R]
    (F : α → R) :
    (∑ x : ULift.{u, v} α, F x.down) = ∑ x : α, F x := by
  classical
  exact
    Fintype.sum_equiv
      (Equiv.ulift : ULift.{u, v} α ≃ α)
      (fun x : ULift.{u, v} α => F x.down)
      F
      (by intro x; rfl)


/-! ### Strict case: four smallness cases after `(*)`

The four cases correspond to the four constructors of
`ClosePairStrictBlock.StrictLaplaceRawIndex.term`:

* Case 2 in the paper: column terms `φ D(α', δ)`, non-principal column choice;
* Case 1 in the paper: row terms `φ D(γ, β)`, non-principal row choice;
* Case 3 in the paper: non-diagonal terms in `det C - ΔC`;
* Case 4 in the paper: non-diagonal terms in `det B - ΔB`.

The low-level target for each case is the direct monomial-order estimate

  `ord.toSyn (T.d + diagExp T.K) < ord.toSyn (headLcm ord D_A D_B)`.

Then `ClosePairThm21Term.small_of_add_diagExp_lt` converts it to the final
degree estimate for
  `MvPolynomial.monomial T.d a * genericMinor T.K`.
-/

section strict_case_four_smallness

open scoped BigOperators

variable {m n t : ℕ}
variable {k : Type*} [CommRing k] [Nontrivial k]

lemma perm_symm_ne_one_of_ne_one
    {α : Type*}
    (σ : Equiv.Perm α)
    (hσ : σ ≠ 1) :
    σ.symm ≠ 1 := by
  intro hs
  apply hσ
  ext x
  have hx : σ.symm (σ x) = σ x := by
    simp [hs]
  simpa using hx.symm

/-- Case 2 displayed term: a column-Laplace term
`φ D(α', δ)`, with positive sign. -/
noncomputable def closePairThm21_case2_colTerm
    (A B : MinorIndex m n t)
    (hC : Close A B)
    (L : ClosePairStrictBlock.ColLaplaceChoice A B hC)
    (σ : Equiv.Perm (Fin (ClosePairStrictBlock.width A B))) :
    ClosePairThm21Term m n t k :=
  L.term (k := k)
    (ClosePairStrictBlock.colLaplaceSign
      (m := m) (n := n) (t := t) (k := k) A B hC L)
    σ

/-- Case 1 displayed term: a row-Laplace term
`φ D(γ, β)`, with the negative sign used in formula `(2.1.5)`. -/
noncomputable def closePairThm21_case1_rowTerm
    (A B : MinorIndex m n t)
    (hC : Close A B)
    (L : ClosePairStrictBlock.RowLaplaceChoice A B hC)
    (σ : Equiv.Perm (Fin (ClosePairStrictBlock.width A B))) :
    ClosePairThm21Term m n t k :=
  L.term (k := k)
    (-(ClosePairStrictBlock.rowLaplaceSign
      (m := m) (n := n) (t := t) (k := k) A B hC L))
    σ

/-- Case 3 displayed term: a non-diagonal term in `det C - ΔC`,
multiplying `D(B)`. -/
noncomputable def closePairThm21_case3_cTailTerm
    (A B : MinorIndex m n t)
    (hC : Close A B)
    (σ : Equiv.Perm (Fin (ClosePairStrictBlock.width A B))) :
    ClosePairThm21Term m n t k :=
  ClosePairStrictBlock.cBlockTerm
    (m := m) (n := n) (t := t) (k := k) A B hC 1 σ

/-- Case 4 displayed term: a non-diagonal term in `det B - ΔB`,
multiplying `D(A)`. -/
noncomputable def closePairThm21_case4_bTailTerm
    (A B : MinorIndex m n t)
    (hC : Close A B)
    (σ : Equiv.Perm (Fin (ClosePairStrictBlock.width A B))) :
    ClosePairThm21Term m n t k :=
  ClosePairStrictBlock.bBlockTerm
    (m := m) (n := n) (t := t) (k := k) A B hC (-1) σ

