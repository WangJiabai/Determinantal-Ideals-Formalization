    {q : ιAll //
      (ClosePairStrictBlock.StrictLaplaceRawIndex.collectedTerm
        (m := m) (n := n) (t := t) (k := k)
        (A := A) (B := B) (hC := hC) q).c ≠ 0}
  let ι : Type u := ULift.{u, 0} ι0
  let T : ι → ClosePairThm21Term m n t k :=
    fun q =>
      ClosePairStrictBlock.StrictLaplaceRawIndex.collectedTerm
        (m := m) (n := n) (t := t) (k := k)
        (A := A) (B := B) (hC := hC)
        q.down.1
  refine ⟨ι, inferInstance, T, ?_, ?_, ?_⟩
  · intro q r hqr
    apply ULift.ext
    apply Subtype.ext
    exact
      ClosePairStrictBlock.StrictLaplaceRawIndex.collectedTerm_injective
        (m := m) (n := n) (t := t) (k := k) A B hC hqr
  · /-
    REAL WORK 1:
    Prove the strict-case algebraic identity

      S(D_A,D_B) = rawPolySum A B hC.

    This is formula (2.1.5), after comparing the two Laplace expansions and
    expanding the four coefficient determinants into raw monomial terms.
    -/
    have hsp_raw :
        ord.sPolynomial (genericMinor (k := k) A) (genericMinor (k := k) B) =
          ClosePairStrictBlock.StrictLaplaceRawIndex.rawPolySum
            (m := m) (n := n) (t := t) (k := k) A B hC :=
            closePairThm21_strict_sPolynomial_eq_rawPolySum
        (m := m) (n := n) (t := t) (k := k)
        ord hdiag A B hC hrowLt
    have hcollectAll :
        (∑ q : ιAll,
          (ClosePairStrictBlock.StrictLaplaceRawIndex.collectedTerm
            (m := m) (n := n) (t := t) (k := k)
            (A := A) (B := B) (hC := hC) q).poly) =
          ClosePairStrictBlock.StrictLaplaceRawIndex.rawPolySum
            (m := m) (n := n) (t := t) (k := k) A B hC := by
      exact
        ClosePairStrictBlock.StrictLaplaceRawIndex.sum_collectedTerm_poly_eq_rawPolySum
          (m := m) (n := n) (t := t) (k := k)
          (A := A) (B := B) (hC := hC)
    have hcollect :
        (∑ q : ι0,
          (ClosePairStrictBlock.StrictLaplaceRawIndex.collectedTerm
            (m := m) (n := n) (t := t) (k := k)
            (A := A) (B := B) (hC := hC) q.1).poly) =
          ClosePairStrictBlock.StrictLaplaceRawIndex.rawPolySum
            (m := m) (n := n) (t := t) (k := k) A B hC := by
      let F : ιAll → MvPolynomial (Fin m × Fin n) k :=
        fun q =>
          (ClosePairStrictBlock.StrictLaplaceRawIndex.collectedTerm
            (m := m) (n := n) (t := t) (k := k)
            (A := A) (B := B) (hC := hC) q).poly
      let p : ιAll → Prop :=
        fun q =>
          (ClosePairStrictBlock.StrictLaplaceRawIndex.collectedTerm
            (m := m) (n := n) (t := t) (k := k)
            (A := A) (B := B) (hC := hC) q).c ≠ 0
      have hzero :
          (∑ q : {q : ιAll // ¬ p q}, F q.1) = 0 := by
        refine Finset.sum_eq_zero ?_
        intro q _hq
        have hc0 :
            (ClosePairStrictBlock.StrictLaplaceRawIndex.collectedTerm
              (m := m) (n := n) (t := t) (k := k)
              (A := A) (B := B) (hC := hC) q.1).c = 0 :=
          not_not.mp q.2
        simp [F, ClosePairThm21Term.poly, ClosePairThm21Term.coeffPoly, hc0]
      have hsplit :
          (∑ q : ιAll, F q) =
            (∑ q : {q : ιAll // p q}, F q.1) +
              ∑ q : {q : ιAll // ¬ p q}, F q.1 :=
        (Fintype.sum_subtype_add_sum_subtype (p := p) F).symm
      calc
        (∑ q : ι0,
          (ClosePairStrictBlock.StrictLaplaceRawIndex.collectedTerm
            (m := m) (n := n) (t := t) (k := k)
            (A := A) (B := B) (hC := hC) q.1).poly)
            =
          ∑ q : {q : ιAll // p q}, F q.1 := rfl
        _ = ∑ q : ιAll, F q := by
          rw [hsplit, hzero, add_zero]
        _ =
          ClosePairStrictBlock.StrictLaplaceRawIndex.rawPolySum
            (m := m) (n := n) (t := t) (k := k) A B hC := hcollectAll
    have hulift :
        (∑ q : ι, (T q).poly) =
          ∑ q : ι0,
            (ClosePairStrictBlock.StrictLaplaceRawIndex.collectedTerm
              (m := m) (n := n) (t := t) (k := k)
              (A := A) (B := B) (hC := hC) q.1).poly := by
      let F : ι0 → MvPolynomial (Fin m × Fin n) k :=
        fun q =>
          (ClosePairStrictBlock.StrictLaplaceRawIndex.collectedTerm
            (m := m) (n := n) (t := t) (k := k)
            (A := A) (B := B) (hC := hC) q.1).poly
      change
        (∑ q : ULift.{u, 0} ι0, F q.down) =
          ∑ q : ι0, F q
      exact sum_ulift_down  F
    calc
      ord.sPolynomial (genericMinor (k := k) A) (genericMinor (k := k) B)
          =
        ClosePairStrictBlock.StrictLaplaceRawIndex.rawPolySum
          (m := m) (n := n) (t := t) (k := k) A B hC := hsp_raw
      _ =
        ∑ q : ι0,
          (ClosePairStrictBlock.StrictLaplaceRawIndex.collectedTerm
            (m := m) (n := n) (t := t) (k := k)
            (A := A) (B := B) (hC := hC) q.1).poly := hcollect.symm
      _ =
        ∑ q : ι, (T q).poly := hulift.symm
  · intro q a ha
    /-
    REAL WORK 2:
    Raw four-case smallness.

    This is exactly the proof after `(*)` in the paper.  The outer collected
    term is reduced to one raw term with the same `(K,d)` key; since the
    smallness statement is uniform in the nonzero coefficient `a`, the raw
    smallness proof transfers to the collected term.
    -/
    have hraw :
        ∀ i : ClosePairStrictBlock.StrictLaplaceRawIndex A B hC,
          (ClosePairStrictBlock.StrictLaplaceRawIndex.term
            (m := m) (n := n) (t := t) (k := k)
            (A := A) (B := B) (hC := hC) i).c ≠ 0 →
          ∀ a : k, a ≠ 0 →
            ord.toSyn
              (ord.degree
                (MvPolynomial.monomial
                  (ClosePairStrictBlock.StrictLaplaceRawIndex.term
                    (m := m) (n := n) (t := t) (k := k)
                    (A := A) (B := B) (hC := hC) i).d
                  a *
                  genericMinor (k := k)
                    (ClosePairStrictBlock.StrictLaplaceRawIndex.term
                      (m := m) (n := n) (t := t) (k := k)
                      (A := A) (B := B) (hC := hC) i).K)) <
            ord.toSyn
              (headLcm ord
                (genericMinor (k := k) A)
                (genericMinor (k := k) B)) := by
      intro i hc a ha
      exact closePairThm21_strict_rawTerm_small
        (m := m) (n := n) (t := t) (k := k)
        ord hdiag A B hC hrowLt i hc a ha
    rcases
      closePairThm21_exists_raw_nonzero_of_collectedTerm_coeff_ne_zero
        (m := m) (n := n) (t := t) (k := k)
        A B hC q.down.1 q.down.2 with
      ⟨i, hi, hci⟩
    have hkey :=
      ClosePairStrictBlock.StrictLaplaceRawIndex.collectedTerm_key_eq_raw_of_rawKeyIndex_eq
        (m := m) (n := n) (t := t) (k := k)
        (A := A) (B := B) (hC := hC) hi
    dsimp [T]
    rw [hkey.2, hkey.1]
    exact hraw i hci a ha

/-- Strict case of paper Theorem 2.1, at the raw term-sum level.

This is the place where the paper constructs the block matrix `M`, compares
the two Laplace expansions `(2.1.3)` and `(2.1.4)`, expands the coefficient
determinants into monomials, and proves the four smallness subcases following
`(*)`. -/
lemma closePairThm21_strict_laplace_terms
    (ord : MonomialOrder (Fin m × Fin n))
    (hdiag : IsDiagonalTermOrder ord)
    (A B : MinorIndex m n t)
    (hC : Close A B)
    (hrowLt :
      rowExt B (uClose A B) < rowExt A (uClose A B)) :
    ∃ S : Finset (ClosePairThm21Term m n t k),
      ord.sPolynomial (genericMinor (k := k) A) (genericMinor (k := k) B) =
        ∑ T ∈ S, T.poly ∧
      ∀ T ∈ S, ∀ a : k, a ≠ 0 →
        ord.toSyn
          (ord.degree
            (MvPolynomial.monomial T.d a * genericMinor (k := k) T.K)) <
        ord.toSyn
          (headLcm ord
            (genericMinor (k := k) A)
            (genericMinor (k := k) B)) := by
  /-
  Paper proof obligation.

  Construct the block matrix `M` with row sequence
    α₁,...,α_s, α'_{s+1},...,α'_t, α_{s+1},...,α_t, α_{t+1},...,α_r
  and the analogous column sequence, with the south-west middle block set to
  zero.  Compare the two Laplace expansions of `det M`, expand all coefficient
  determinants into monomials, and collect the resulting displayed terms into
  `S`.

  The last field is exactly the four-case proof after `(*)` in the paper:
  terms of type
    1. φ D(γ, β), γ ≠ α,
    2. φ D(α', δ), δ ≠ β',
    3. φ D(α', β'), φ from det C - ΔC,
    4. φ D(α, β), φ from det B - ΔB
  all have head strictly below the endpoint lcm.
  -/
  classical
  rcases closePairThm21_strict_laplace_indexed_small_data
      (m := m) (n := n) (t := t) (k := k)
      ord hdiag A B hC hrowLt with
    ⟨ι, hι, T, hinj, hlin, hsmall⟩
  letI := hι
  exact
    closePairThm21_terms_of_indexed_family
      (m := m) (n := n) (t := t) (k := k)
      ord A B T hinj hlin hsmall

lemma closePairThm21_strict_terms
    (ord : MonomialOrder (Fin m × Fin n))
    (hdiag : IsDiagonalTermOrder ord)
    (A B : MinorIndex m n t)
    (hC : Close A B)
    (hrowLt :
      rowExt B (uClose A B) < rowExt A (uClose A B)) :
    ∃ S : Finset (ClosePairThm21Term m n t k),
      ord.sPolynomial (genericMinor (k := k) A) (genericMinor (k := k) B) =
        ∑ T ∈ S, T.poly ∧
      ∀ T ∈ S, ∀ a : k, a ≠ 0 →
        ord.toSyn
          (ord.degree
            (MvPolynomial.monomial T.d a * genericMinor (k := k) T.K)) <
        ord.toSyn
          (headLcm ord
            (genericMinor (k := k) A)
            (genericMinor (k := k) B)) := by
  classical
  exact closePairThm21_strict_laplace_terms
      (m := m) (n := n) (t := t) (k := k)
      ord hdiag A B hC hrowLt

noncomputable def closePairThm21DataOfTerms
    (ord : MonomialOrder (Fin m × Fin n))
    (A B : MinorIndex m n t)
    (hterms :
      ∃ S : Finset (ClosePairThm21Term m n t k),
        ord.sPolynomial (genericMinor (k := k) A) (genericMinor (k := k) B) =
          ∑ T ∈ S, T.poly ∧
        ∀ T ∈ S, ∀ a : k, a ≠ 0 →
          ord.toSyn
            (ord.degree
              (MvPolynomial.monomial T.d a * genericMinor (k := k) T.K)) <
          ord.toSyn
            (headLcm ord
              (genericMinor (k := k) A)
              (genericMinor (k := k) B))) :
    ClosePairThm21Data (m := m) (n := n) (t := t) (k := k) ord A B := by
  classical
  exact
    { terms := Classical.choose hterms
      linear_identity := (Classical.choose_spec hterms).1
      term_small := (Classical.choose_spec hterms).2 }

/-- Strict case of paper Theorem 2.1, packaged as the local close-pair data
used by the good-chain assembly. -/
noncomputable def closePairThm21Data_of_uClose_row_lt
    (ord : MonomialOrder (Fin m × Fin n))
    (hdiag : IsDiagonalTermOrder ord)
    (A B : MinorIndex m n t)
    (hC : Close A B)
    (hrowLt :
      rowExt B (uClose A B) < rowExt A (uClose A B)) :
    ClosePairThm21Data (m := m) (n := n) (t := t) (k := k) ord A B := by
  exact
    closePairThm21DataOfTerms
      (m := m) (n := n) (t := t) (k := k)
      ord A B
      (closePairThm21_strict_terms
        (m := m) (n := n) (t := t) (k := k)
