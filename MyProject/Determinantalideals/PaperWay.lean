/-- The `B`-middle diagonal exponent is contained in the endpoint lcm. -/
lemma closePairThm21_case1_bMiddle_diagExp_le_headLcm
    (ord : MonomialOrder (Fin m × Fin n))
    (hdiag : IsDiagonalTermOrder ord)
    (A B : MinorIndex m n t)
