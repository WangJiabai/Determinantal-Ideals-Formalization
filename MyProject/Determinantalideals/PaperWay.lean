    unfold s
    rw [Finset.card_image_of_injective]
    · simp
    · exact L.minorRowsStrict.injective
  have hL :
      (fun j : Fin t =>
        ClosePairStrictBlock.rowFin A B hC (L.minorRows j)) =
        s.orderEmbOfFin hcard := by
    exact Finset.orderEmbOfFin_unique hcard (by intro j; simp [s]) L.minorRowsStrict
  have hA_mem : ∀ i : Fin t, A.row i ∈ s := by
    intro i
    rcases hmem i with ⟨j, hj⟩
    exact Finset.mem_image.mpr
      ⟨j, by simp,
        by simp [hj, ClosePairStrictBlock.rowFin_aColumnPos]⟩
  have hA :
      (fun i : Fin t => A.row i) = s.orderEmbOfFin hcard := by
    exact Finset.orderEmbOfFin_unique hcard hA_mem A.row.strictMono
  have hrow :
      (fun j : Fin t =>
        ClosePairStrictBlock.rowFin A B hC (L.minorRows j)) =
