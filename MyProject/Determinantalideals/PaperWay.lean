      omega
    let F : StatementCFailure A B hC L σ U :=
      { i := i
        j := j
        hjlo := hjlo
        hjhi := hjhi
        hzero := hzero }
    exact
      closePairThm21_case1_statementC_failure_false_of_prev
        (m := m) (n := n) (t := t) (k := k)
        ord hdiag A B hC hrowLt L σ hc hnot U i hB F rfl
        hprevA hprevB hprevC
  have hA : StatementA A B hC L U i := by
    intro j hjlo hjhi
    by_contra hfail
    let F : StatementAFailure A B hC L U :=
      { i := i
        j := j
