/-- If a Case 1 exponent is known to be bounded by the endpoint lcm and it is
not strictly below the endpoint lcm, then it has no coordinate gap.  This is a
small order-theoretic bridge used to translate the paper's `ψ ≥ ΔAΔB...`
argument into coordinate statements. -/
lemma closePairThm21_case1_no_gap_of_le_sup_of_not_lt
    (ord : MonomialOrder (Fin m × Fin n))
    (hdiag : IsDiagonalTermOrder ord)
    (A B : MinorIndex m n t)
    (hC : Close A B)
    (L : ClosePairStrictBlock.RowLaplaceChoice A B hC)
    (σ : Equiv.Perm (Fin (ClosePairStrictBlock.width A B)))
    (hle :
      closePairThm21_case1_rowTermExp
          (m := m) (n := n) (t := t) (k := k) A B hC L σ ≤
        diagExp A ⊔ diagExp B)
    (hnot :
      ¬ ord.toSyn
          (closePairThm21_case1_rowTermExp
            (m := m) (n := n) (t := t) (k := k) A B hC L σ)
        <
        ord.toSyn
          (headLcm ord
            (genericMinor (k := k) A)
            (genericMinor (k := k) B))) :
    ∀ x : Fin m × Fin n,
      closePairThm21_case1_rowTermExp
          (m := m) (n := n) (t := t) (k := k) A B hC L σ x =
        (diagExp A ⊔ diagExp B) x := by
  classical
  intro x
  apply le_antisymm
  · exact hle x
  · by_contra hltNat
    have hxlt :
        closePairThm21_case1_rowTermExp
            (m := m) (n := n) (t := t) (k := k) A B hC L σ x <
          (diagExp A ⊔ diagExp B) x := by
      exact Nat.lt_of_not_ge hltNat
    have hlt :
        ord.toSyn
            (closePairThm21_case1_rowTermExp
              (m := m) (n := n) (t := t) (k := k) A B hC L σ)
          <
          ord.toSyn (diagExp A ⊔ diagExp B) :=
      toSyn_lt_of_le_of_apply_lt ord hle hxlt
    have hltHead :
        ord.toSyn
            (closePairThm21_case1_rowTermExp
              (m := m) (n := n) (t := t) (k := k) A B hC L σ)
          <
          ord.toSyn
            (headLcm ord
              (genericMinor (k := k) A)
              (genericMinor (k := k) B)) := by
      simpa [headLcm_genericMinor_eq_sup_diagExp (k := k) ord hdiag A B]
        using hlt
    exact hnot hltHead

/-- Coordinate form of the previous lemma at a diagonal variable of `A`. -/
lemma closePairThm21_case1_A_diag_coord_eq_one_of_le_sup_of_not_lt
    (ord : MonomialOrder (Fin m × Fin n))
    (hdiag : IsDiagonalTermOrder ord)
    (A B : MinorIndex m n t)
    (hC : Close A B)
    (L : ClosePairStrictBlock.RowLaplaceChoice A B hC)
    (σ : Equiv.Perm (Fin (ClosePairStrictBlock.width A B)))
    (hle :
      closePairThm21_case1_rowTermExp
          (m := m) (n := n) (t := t) (k := k) A B hC L σ ≤
        diagExp A ⊔ diagExp B)
    (hnot :
      ¬ ord.toSyn
          (closePairThm21_case1_rowTermExp
            (m := m) (n := n) (t := t) (k := k) A B hC L σ)
        <
        ord.toSyn
          (headLcm ord
            (genericMinor (k := k) A)
            (genericMinor (k := k) B)))
    (i : Fin t) :
    closePairThm21_case1_rowTermExp
        (m := m) (n := n) (t := t) (k := k) A B hC L σ
        (A.row i, A.col i) = 1 := by
  classical
  have hcoord :=
    closePairThm21_case1_no_gap_of_le_sup_of_not_lt
      (m := m) (n := n) (t := t) (k := k)
      ord hdiag A B hC L σ hle hnot (A.row i, A.col i)
  have hA : diagExp A (A.row i, A.col i) = 1 := by
    rw [diagExp_apply]
    exact if_pos ⟨i, rfl, rfl⟩
  have hsup : (diagExp A ⊔ diagExp B) (A.row i, A.col i) = 1 := by
    have hle_one : (diagExp A ⊔ diagExp B) (A.row i, A.col i) ≤ 1 := by
      change max (diagExp A (A.row i, A.col i))
          (diagExp B (A.row i, A.col i)) ≤ 1
      rw [hA]
      exact by
        simp only [Nat.max_le, le_refl, true_and]
        by_cases hB : ∃ j : Fin t, B.row j = A.row i ∧ B.col j = A.col i
        · rw [diagExp_apply, if_pos hB]
        · rw [diagExp_apply, if_neg hB]
          omega
    have hge_one : 1 ≤ (diagExp A ⊔ diagExp B) (A.row i, A.col i) := by
      change 1 ≤ max (diagExp A (A.row i, A.col i))
          (diagExp B (A.row i, A.col i))
      rw [hA]
      simp
    exact le_antisymm hle_one hge_one
  simpa [hsup] using hcoord

