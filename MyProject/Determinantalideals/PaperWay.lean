    exact Fin.mk_lt_mk.mpr (by
      have hj : j.1 < uClose A B - sClose A B := by
        simp [ClosePairStrictBlock.width]
      omega)
  have hBstrict : B.col jm < B.col i :=
    B.col.strictMono hjm_lt_i
  have hAiBi : A.col i = B.col i := by
    have hpEq :
        pairExt A (i.1 + 1) = pairExt B (i.1 + 1) := by
      exact pairExt_eq_of_mu_eq_right_gt_u
        A B hC.ne hC.mu_eq_right (by omega) (by omega)
    have hi₂ : i.1 + 1 ≤ t := by omega
    rw [EndpointSelection.pairExt_endpoint (I := A) (by omega) hi₂,
      EndpointSelection.pairExt_endpoint (I := B) (by omega) hi₂] at hpEq
    have hcolNat := congrArg Prod.snd hpEq
    apply Fin.ext
    simp at hcolNat
    omega
  have hBeq : B.col jm = B.col i := by
    exact hcol.trans hAiBi
  exact (ne_of_lt hBstrict) hBeq

