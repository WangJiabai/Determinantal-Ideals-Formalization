    _ =
      strictBDiagPart (m := m) (n := n) (t := t) (k := k) A B hC +
        (- ClosePairStrictBlock.StrictLaplaceRawIndex.bTailPartSum
          (m := m) (n := n) (t := t) (k := k) A B hC) := by
        congr 1
        rw [ClosePairStrictBlock.StrictLaplaceRawIndex.bTailPartSum]
        rw [← Finset.sum_neg_distrib]
        refine Finset.sum_congr rfl ?_
        intro σ _hσ
        exact bBlockTerm_poly_neg
          (m := m) (n := n) (t := t) (k := k) A B hC (1 : k) σ.1
