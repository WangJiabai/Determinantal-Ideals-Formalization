      Matrix.det
            (strictBBlockMatrix (m := m) (n := n) (t := t) (k := k) A B hC) *
          genericMinor (k := k) A =
        ∑ σ : Equiv.Perm (Fin (ClosePairStrictBlock.width A B)),
          (ClosePairStrictBlock.bBlockTerm
            (m := m) (n := n) (t := t) (k := k) A B hC 1 σ).poly := by
    simpa [strictBBlockMatrix, ClosePairStrictBlock.bBlockTerm] using
      (MonomialCoefficientMatrix.scaled_det_mul_minor_eq_sum_closePairTerm
        (m := m) (n := n) (t := t)
        (q := ClosePairStrictBlock.width A B) (k := k)
        (row := fun i : Fin (ClosePairStrictBlock.width A B) =>
          ClosePairStrictBlock.rowFin A B hC
            (ClosePairStrictBlock.bMiddlePos A B hC i))
        (col := fun i : Fin (ClosePairStrictBlock.width A B) =>
          ClosePairStrictBlock.colFin A B hC
            (ClosePairStrictBlock.bMiddlePos A B hC i))
        (zero := fun _ _ => False)
        A (1 : k))
