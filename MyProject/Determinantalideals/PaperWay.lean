      apply Fin.ext
      change rowCoord A B q.1 - 1 = (B.row qidx).1
      rw [ClosePairStrictBlock.rowCoord_of_bMiddle A B hmid]
      rw [EndpointSelection.rowExt_endpoint (I := B) (by omega) (by omega)]
      simp [qidx]
    have hAiBi : A.row i = B.row i := by
      have hpEq :
          pairExt A (i.1 + 1) = pairExt B (i.1 + 1) := by
        exact pairExt_eq_of_mu_eq_right_gt_u
          A B hC.ne hC.mu_eq_right (by omega) (by omega)
      have hi₂ : i.1 + 1 ≤ t := by omega
      rw [EndpointSelection.pairExt_endpoint (I := A) (by omega) hi₂,
        EndpointSelection.pairExt_endpoint (I := B) (by omega) hi₂] at hpEq
      have hrowNat := congrArg Prod.fst hpEq
      apply Fin.ext
      simp at hrowNat
      omega
    have hlt : qidx < i := by
      exact Fin.mk_lt_mk.mpr (by omega)
    have hBlt : B.row qidx < B.row i :=
      B.row.strictMono hlt
    have heq : B.row qidx = B.row i := by
      exact hqrow.symm.trans (hrow.trans hAiBi)
