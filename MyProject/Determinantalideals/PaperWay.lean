    let r : Fin (ClosePairStrictBlock.width A B) :=
      ⟨q.1 - uClose A B, by
        have hrep_lt' :
            q.1 < uClose A B + (uClose A B - sClose A B) := by
          simpa [ClosePairStrictBlock.width] using hrep_lt
        unfold ClosePairStrictBlock.width
        omega⟩
    have hq_eq_rep :
        q = ClosePairStrictBlock.aRepeatedMiddlePos A B hC r := by
      apply Fin.ext
      simp [ClosePairStrictBlock.aRepeatedMiddlePos, r]
      omega
    let midx : Fin t :=
      ⟨sClose A B + r.1, by
        have hu : uClose A B ≤ t :=
          le_trans (uClose_le_pClose A B hC.ne) (pClose_le A B)
        have hr : r.1 < uClose A B - sClose A B := by
          simpa [r, ClosePairStrictBlock.width] using r.2
        omega⟩
    have hqrow :
        ClosePairStrictBlock.rowFin A B hC q = A.row midx := by
      rw [hq_eq_rep]
