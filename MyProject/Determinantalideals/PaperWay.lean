/-- The principal row-side Laplace sign is `1`.

This corresponds to the paper's statement `σ_α = 1`. -/
lemma rowPrincipalChoice_sign_eq_one
    (A B : MinorIndex m n t)
    (hC : Close A B) :
    ClosePairStrictBlock.rowLaplaceSign
        (m := m) (n := n) (t := t) (k := k) A B hC
        (rowPrincipalChoice (m := m) (n := n) (t := t) A B hC) =
      (1 : k) := by
  classical
  simp only [ClosePairStrictBlock.rowLaplaceSign, ClosePairStrictBlock.laplaceShuffleSign,
