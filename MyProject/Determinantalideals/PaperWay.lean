    ord.toSyn (permExp A (Equiv.swap p q)) <
      ord.toSyn (diagExp A) := by
  classical
  have hswap_ne : (Equiv.swap p q : Equiv.Perm (Fin t)) ≠ 1 := by
    intro h
    have happly :
        (Equiv.swap p q : Equiv.Perm (Fin t)) p =
          (1 : Equiv.Perm (Fin t)) p := by
      rw [h]
    have hp_ne_q : p ≠ q := hpq
    simp at happly
    exact hp_ne_q happly.symm
  exact hdiag A (Equiv.swap p q) hswap_ne

/-- Gap branch, below-displacement order comparison.

This is the local `hdiag` step for the case where the failed middle `A` row
appears at an earlier minor diagonal slot. -/
lemma closePairThm21_case1_gap_minor_displacement_lt_of_below
    (ord : MonomialOrder (Fin m × Fin n))
    (hdiag : IsDiagonalTermOrder ord)
    (A B : MinorIndex m n t)
    (hC : Close A B)
    (_hrowLt :
      rowExt B (uClose A B) < rowExt A (uClose A B))
    (L : ClosePairStrictBlock.RowLaplaceChoice A B hC)
    (σ : Equiv.Perm (Fin (ClosePairStrictBlock.width A B)))
    (_hc :
      (closePairThm21_case1_rowTerm
        (m := m) (n := n) (t := t) (k := k) A B hC L σ).c ≠ 0)
    (U : Case1UVChain A B hC)
    (i : Fin U.q)
    (F : StatementBFailure A B hC L U)
    (hFi : F.i = i)
    (hzero :
      closePairThm21_case1_rowTermExp
        (m := m) (n := n) (t := t) (k := k) A B hC L σ
        (A.row F.idx, A.col F.idx) = 0)
    (habove : StatementBAbove A B hC L U i F.j)
    (hprevA :
      ∀ j : Fin U.q, j.1 < i.1 → StatementA A B hC L U j)
    (hprevB :
      ∀ j : Fin U.q, j.1 < i.1 → StatementB A B hC L U j)
    (_hprevC :
      ∀ j : Fin U.q, j.1 < i.1 → StatementC A B hC L σ U j)
    (q : Fin t)
    (hqbelow : q < F.idx)
    (hqrow : L.minorIndex.row q = A.row F.idx) :
    ord.toSyn
        (closePairThm21_case1_rowTermExp
          (m := m) (n := n) (t := t) (k := k) A B hC L σ)
      <
      ord.toSyn
        (headLcm ord
          (genericMinor (k := k) A)
          (genericMinor (k := k) B)) := by
  classical
  have hdisp_pos :
      1 ≤
        closePairThm21_case1_rowTermExp
          (m := m) (n := n) (t := t) (k := k) A B hC L σ
          (A.row F.idx, A.col q) :=
    closePairThm21_case1_rowTermExp_displaced_A_col_pos
      (m := m) (n := n) (t := t) (k := k)
      A B hC L σ U F q hqrow
  have hendpoint_gap :
      closePairThm21_case1_rowTermExp
          (m := m) (n := n) (t := t) (k := k) A B hC L σ
          (A.row F.idx, A.col F.idx)
        <
        headLcm ord (genericMinor (k := k) A) (genericMinor (k := k) B)
          (A.row F.idx, A.col F.idx) :=
    closePairThm21_case1_gap_endpoint_coord_gap
      (m := m) (n := n) (t := t) (k := k)
      ord hdiag A B hC L σ U F hzero
  have hcontrolled_above :
      ∀ s : Fin t,
        F.idx < s →
        s.1 < uClose A B →
        L.minorIndex.row s = A.row s := by
    intro s hs_gt hs_mid
    let x : ℕ := s.1 + 1
    have hxhi : x ≤ uClose A B := by
      dsimp [x]
      omega
    have hxlo_middle : sClose A B + 1 ≤ x := by
      have hs := F.idx_s
      have hval : F.idx.1 < s.1 := by simpa using hs_gt
      dsimp [x]
      omega
    have hsx :
        middlePaperIndexToFinOfClose A B hC x ⟨hxlo_middle, hxhi⟩ = s := by
      apply Fin.ext
      simp [middlePaperIndexToFinOfClose, x]
    have hFj_val : F.j = F.idx.1 + 1 := by
      have hs : sClose A B + 1 ≤ F.j :=
        le_trans (U.u_bounds F.i.succ).1 F.hjlo
      have hu : F.j ≤ uClose A B := by
        have htop := (U.u_bounds F.i.castSucc).2
        have hjhi := F.hjhi
        omega
      have hpos : 1 ≤ F.j := by omega
      simp [StatementBFailure.idx, middlePaperIndexToFinOfClose]
      omega
    have hFj_lt_x : F.j < x := by
      have hval : F.idx.1 < s.1 := by simpa using hs_gt
      dsimp [x]
      omega
    have hxlo_current : U.u i.succ ≤ x := by
      have hF_lo : U.u i.succ ≤ F.j := by
        simpa [hFi] using F.hjlo
      omega
    have hprincipal :
        L.minorRows s = ClosePairStrictBlock.aColumnPos A B hC s := by
      by_cases hxcur : x < U.u i.castSucc
      · have hAt :
            StatementBAt A B hC L U i x hxlo_current hxcur :=
          habove x hFj_lt_x hxcur hxlo_current
        simpa [StatementBAt, hsx, aColumnPosOfPaperMiddle] using hAt
      · have hprev_top : U.u i.castSucc ≤ x := Nat.le_of_not_gt hxcur
        have hprev_eq :
            L.minorRows
                (middlePaperIndexToFinOfClose A B hC x
                  (by exact ⟨hxlo_middle, hxhi⟩)) =
              aColumnPosOfPaperMiddle A B hC x
                (by exact ⟨hxlo_middle, hxhi⟩) :=
          closePairThm21_case1_prevB_minorRows_cover_u_top
            (m := m) (n := n) (t := t)
            A B hC L U i hprevB x hprev_top hxhi
        simpa [hsx, aColumnPosOfPaperMiddle] using hprev_eq
    calc
      L.minorIndex.row s =
          ClosePairStrictBlock.rowFin A B hC (L.minorRows s) := rfl
      _ = ClosePairStrictBlock.rowFin A B hC
          (ClosePairStrictBlock.aColumnPos A B hC s) := by rw [hprincipal]
      _ = A.row s := ClosePairStrictBlock.rowFin_aColumnPos A B hC s
  by_cases hswap_row : L.minorIndex.row F.idx = A.row q
  · exfalso
    have hLlt :
        L.minorIndex.row q < L.minorIndex.row F.idx :=
      L.minorIndex.row.strictMono hqbelow
    have hAlt : A.row q < A.row F.idx :=
      A.row.strictMono hqbelow
    rw [hqrow, hswap_row] at hLlt
    exact (not_lt_of_ge (le_of_lt hAlt)) hLlt
  · have hidx_row_gt :
        A.row F.idx < L.minorIndex.row F.idx := by
      calc
        A.row F.idx = L.minorIndex.row q := hqrow.symm
        _ < L.minorIndex.row F.idx :=
          L.minorIndex.row.strictMono hqbelow
    let z : Fin (ClosePairStrictBlock.size A B) := L.minorRows F.idx
    have hzrow :
        ClosePairStrictBlock.rowFin A B hC z =
          L.minorIndex.row F.idx := by
      rfl
    rcases ClosePairStrictBlock.block_cases_of_lt_size A B z.2 with
        hpre | hmid | hrep | htail
    · exfalso
      have hz_lt_s : z.1 < sClose A B := hpre
      let zidx : Fin t := ⟨z.1, by
        have hslt : sClose A B < t :=
          lt_of_lt_of_le (sClose_lt_pClose A B hC.ne) (pClose_le A B)
        omega⟩
      have hzrow_A :
          ClosePairStrictBlock.rowFin A B hC z = A.row zidx := by
        apply Fin.ext
        change ClosePairStrictBlock.rowCoord A B z.1 - 1 = (A.row zidx).1
        rw [ClosePairStrictBlock.rowCoord_of_prefix A B hz_lt_s]
        have hz_pos : 1 ≤ z.1 + 1 := by omega
        have hz_le_t : z.1 + 1 ≤ t := by
          have hslt : sClose A B < t :=
            lt_of_lt_of_le (sClose_lt_pClose A B hC.ne) (pClose_le A B)
          exact Nat.succ_le_of_lt (lt_trans hpre hslt)
        rw [EndpointSelection.rowExt_endpoint (I := A) hz_pos hz_le_t]
        have hzidx :
            (⟨z.1 + 1 - 1, by
              have hslt : sClose A B < t :=
                lt_of_lt_of_le (sClose_lt_pClose A B hC.ne) (pClose_le A B)
              omega⟩ : Fin t) = zidx := by
          apply Fin.ext
          simp [zidx]
        rw [hzidx]
        omega
      have hzidx_lt_F : zidx < F.idx := by
        exact Fin.mk_lt_mk.mpr (by
          exact lt_of_lt_of_le hz_lt_s F.idx_s)
      have hrow_lt : A.row zidx < A.row F.idx :=
        A.row.strictMono hzidx_lt_F
      have hrow_gt : A.row F.idx < A.row zidx := by
        calc
          A.row F.idx < L.minorIndex.row F.idx := hidx_row_gt
          _ = ClosePairStrictBlock.rowFin A B hC z := hzrow.symm
          _ = A.row zidx := hzrow_A
      exact (not_lt_of_ge (le_of_lt hrow_lt)) hrow_gt
    · exfalso
      let p : Fin (ClosePairStrictBlock.width A B) :=
        ⟨z.1 - sClose A B, by
          have hge : sClose A B ≤ z.1 := hmid.1
          have hlt : z.1 < uClose A B := hmid.2
          simp [ClosePairStrictBlock.width]
          omega⟩
      have hz_eq :
          z = ClosePairStrictBlock.bMiddlePos A B hC p := by
        apply Fin.ext
        change z.1 = sClose A B + (z.1 - sClose A B)
        exact (Nat.add_sub_of_le hmid.1).symm
      let jp : ℕ := sClose A B + p.1 + 1
      have hjp_hi : jp ≤ uClose A B := by
        have hpw : p.1 < uClose A B - sClose A B := p.2
        dsimp [jp]
        omega
      let midp : Fin t := ⟨sClose A B + p.1, by
        have hpw : p.1 < uClose A B - sClose A B := p.2
        have hu : uClose A B ≤ t :=
          le_trans (uClose_le_pClose A B hC.ne) (pClose_le A B)
        omega⟩
      have hzrow_B :
          ClosePairStrictBlock.rowFin A B hC z = B.row midp := by
        rw [hz_eq]
        simpa [midp] using
          ClosePairStrictBlock.rowFin_bMiddlePos A B hC p
      have hA_lt_B :
          A.row F.idx < B.row midp := by
        calc
          A.row F.idx < L.minorIndex.row F.idx := hidx_row_gt
          _ = ClosePairStrictBlock.rowFin A B hC z := hzrow.symm
          _ = B.row midp := hzrow_B
      have hAext :
          rowExt A F.j = (A.row F.idx).1 + 1 := by
        have hjlo : 1 ≤ F.j := by
          have hs : sClose A B + 1 ≤ F.j :=
            le_trans (U.u_bounds F.i.succ).1 F.hjlo
          omega
        have hjhi_t : F.j ≤ t := by
          have hu : F.j ≤ uClose A B := by
            have htop := (U.u_bounds F.i.castSucc).2
            have hjhi := F.hjhi
            omega
          exact le_trans hu
            (le_trans (uClose_le_pClose A B hC.ne) (pClose_le A B))
        rw [EndpointSelection.rowExt_endpoint (I := A) hjlo hjhi_t]
        simp [StatementBFailure.idx, middlePaperIndexToFinOfClose]
      have hBext :
          rowExt B jp = (B.row midp).1 + 1 := by
        have hjlo : 1 ≤ jp := by
          dsimp [jp]
          omega
        have hjhi_t : jp ≤ t := by
          exact le_trans hjp_hi
            (le_trans (uClose_le_pClose A B hC.ne) (pClose_le A B))
        rw [EndpointSelection.rowExt_endpoint (I := B) hjlo hjhi_t]
        simp [jp, midp]
      have hAext_lt_Bext :
          rowExt A F.j < rowExt B jp := by
        rw [hAext, hBext]
        exact Nat.succ_lt_succ
          (show (A.row F.idx).1 < (B.row midp).1 from hA_lt_B)
      have hpred_lt_A :
          rowExt B (U.v F.i.castSucc - 1) < rowExt A F.j :=
        U.row_A_interval_gt_B_pred F.i F.j F.hjlo F.hjhi
      have hpred_lt_B :
          rowExt B (U.v F.i.castSucc - 1) < rowExt B jp :=
        lt_trans hpred_lt_A hAext_lt_Bext
      have hv_le_p :
          U.v F.i.castSucc ≤ jp := by
        by_contra hnot_le
        have hvpos : 0 < U.v F.i.castSucc := by
          have hvlo := (U.v_bounds F.i.castSucc).1
          omega
        have hjp_le_pred :
            jp ≤ U.v F.i.castSucc - 1 := by
          omega
        have hmono : Monotone (rowExt B) := rowExt_monotone B
        have hleExt :
            rowExt B jp ≤ rowExt B (U.v F.i.castSucc - 1) :=
          hmono hjp_le_pred
        exact (not_lt_of_ge hleExt) hpred_lt_B
      have hv_le_p_at_i : U.v i.castSucc ≤ jp := by
        simpa [hFi] using hv_le_p
      have hjp_lo : sClose A B + 1 ≤ jp := by
        dsimp [jp]
        omega
      rcases
        closePairThm21_case1_prevA_cofactorRows_cover_v_top
          (m := m) (n := n) (t := t)
          A B hC L U i hprevA jp hv_le_p_at_i hjp_hi
        with ⟨rp, hcof⟩
      have hbm_eq :
          bMiddlePosOfPaperMiddle A B hC jp ⟨hjp_lo, hjp_hi⟩ =
            ClosePairStrictBlock.bMiddlePos A B hC p := by
        unfold bMiddlePosOfPaperMiddle
        congr 1
        apply Fin.ext
        simp [middlePaperIndexToWidthFinOfClose, jp, p]
      have hcof_eq :
          L.cofactorRows rp =
            ClosePairStrictBlock.bMiddlePos A B hC p :=
        hcof.trans hbm_eq
      have hminor_eq :
          L.minorRows F.idx =
            ClosePairStrictBlock.bMiddlePos A B hC p := by
        simpa [z] using hz_eq
      have hshuffle :
          L.shuffle (Sum.inl F.idx) = L.shuffle (Sum.inr rp) := by
        calc
          L.shuffle (Sum.inl F.idx) = L.minorRows F.idx :=
            (L.minorRows_eq_shuffle F.idx).symm
          _ = ClosePairStrictBlock.bMiddlePos A B hC p := hminor_eq
          _ = L.cofactorRows rp := hcof_eq.symm
          _ = L.shuffle (Sum.inr rp) := L.cofactorRows_eq_shuffle rp
      have hsum : Sum.inl F.idx = Sum.inr rp :=
        L.shuffle.injective hshuffle
      cases hsum
    · exfalso
      let r : Fin (ClosePairStrictBlock.width A B) :=
        ⟨z.1 - uClose A B, by
          have hsu : sClose A B ≤ uClose A B :=
            Nat.le_of_lt (sClose_lt_uClose A B hC.ne)
          have hrep_lt' :
              z.1 < uClose A B + (uClose A B - sClose A B) := by
            simpa [ClosePairStrictBlock.width] using hrep.2
          have htmp :
              z.1 - uClose A B + uClose A B <
                uClose A B + (uClose A B - sClose A B) := by
            simpa [Nat.sub_add_cancel hrep.1] using hrep_lt'
          unfold ClosePairStrictBlock.width
          omega⟩
      let midx : Fin t := ⟨sClose A B + r.1, by
        have hu : uClose A B ≤ t :=
          le_trans (uClose_le_pClose A B hC.ne) (pClose_le A B)
        have hr : r.1 < uClose A B - sClose A B := by
          simpa [r, ClosePairStrictBlock.width] using r.2
        omega⟩
      have hzrow_A :
          ClosePairStrictBlock.rowFin A B hC z = A.row midx := by
        apply Fin.ext
        change ClosePairStrictBlock.rowCoord A B z.1 - 1 = (A.row midx).1
        rw [ClosePairStrictBlock.rowCoord_of_aRepeatedMiddle A B hC hrep]
        have hpaper_pos :
            1 ≤ sClose A B + 1 + (z.1 - uClose A B) := by omega
        have hpaper_le_t :
            sClose A B + 1 + (z.1 - uClose A B) ≤ t := by
          have hu : uClose A B ≤ t :=
            le_trans (uClose_le_pClose A B hC.ne) (pClose_le A B)
          have hsu : sClose A B ≤ uClose A B :=
            Nat.le_of_lt (sClose_lt_uClose A B hC.ne)
          have hr :
              z.1 - uClose A B < uClose A B - sClose A B := by
            simpa [r, ClosePairStrictBlock.width] using r.2
          omega
        rw [EndpointSelection.rowExt_endpoint (I := A) hpaper_pos hpaper_le_t]
        have hidx :
            (⟨sClose A B + 1 + (z.1 - uClose A B) - 1, by
              have hu : uClose A B ≤ t :=
                le_trans (uClose_le_pClose A B hC.ne) (pClose_le A B)
              have hsu : sClose A B ≤ uClose A B :=
                Nat.le_of_lt (sClose_lt_uClose A B hC.ne)
              have hr :
                  z.1 - uClose A B < uClose A B - sClose A B := by
                simpa [r, ClosePairStrictBlock.width] using r.2
              omega⟩ : Fin t) = midx := by
          apply Fin.ext
          simp [midx, r]
        rw [hidx]
        omega
      have hF_lt_mid : F.idx < midx := by
        have hrow_lt_mid : A.row F.idx < A.row midx := by
          calc
            A.row F.idx < L.minorIndex.row F.idx := hidx_row_gt
            _ = ClosePairStrictBlock.rowFin A B hC z := hzrow.symm
            _ = A.row midx := hzrow_A
        exact (A.row.lt_iff_lt).mp hrow_lt_mid
      have hmid_u : midx.1 < uClose A B := by
        have hr : r.1 < uClose A B - sClose A B := by
          simpa [r, ClosePairStrictBlock.width] using r.2
        simp [midx]
        omega
      have hcontrolled_mid :
          L.minorIndex.row midx = A.row midx :=
        hcontrolled_above midx hF_lt_mid hmid_u
      have hF_eq_mid_row :
          L.minorIndex.row F.idx = A.row midx := by
        simpa [hzrow_A] using hzrow.symm
      have hrows_eq :
          L.minorIndex.row F.idx = L.minorIndex.row midx := by
        rw [hF_eq_mid_row, hcontrolled_mid]
      have hidx_eq : F.idx = midx :=
        L.minorIndex.row.injective hrows_eq
      exact (ne_of_lt hF_lt_mid) hidx_eq
    · let tailIdx : Fin t :=
        ⟨z.1 - ClosePairStrictBlock.width A B, by
          have hb := ClosePairStrictBlock.tail_index_bounds A B hC htail z.2
          omega⟩
      have htailIdx_ge_u : uClose A B ≤ tailIdx.1 := by
        have htail_ge : uClose A B + ClosePairStrictBlock.width A B ≤ z.1 :=
          htail
        simp [tailIdx]
        omega
      have hzrow_tail :
          ClosePairStrictBlock.rowFin A B hC z = A.row tailIdx := by
        apply Fin.ext
        change ClosePairStrictBlock.rowCoord A B z.1 - 1 =
          (A.row tailIdx).1
        rw [ClosePairStrictBlock.rowCoord_of_tail A B hC htail]
        have hb := ClosePairStrictBlock.tail_index_bounds A B hC htail z.2
        rw [EndpointSelection.rowExt_endpoint (I := A) hb.1 hb.2]
        have hidx :
            (⟨z.1 + 1 - ClosePairStrictBlock.width A B - 1, by
              have hb := ClosePairStrictBlock.tail_index_bounds A B hC htail z.2
              omega⟩ : Fin t) = tailIdx := by
          apply Fin.ext
          simp [tailIdx]
          omega
        rw [hidx]
        omega
      have hF_lt_tail : F.idx < tailIdx := by
        have hrow_lt_tail : A.row F.idx < A.row tailIdx := by
          calc
            A.row F.idx < L.minorIndex.row F.idx := hidx_row_gt
            _ = ClosePairStrictBlock.rowFin A B hC z := hzrow.symm
            _ = A.row tailIdx := hzrow_tail
        exact (A.row.lt_iff_lt).mp hrow_lt_tail
      by_cases htail_fixed :
          L.minorIndex.row tailIdx = A.row tailIdx
      · exfalso
        have hF_eq_tail_row :
            L.minorIndex.row F.idx = A.row tailIdx := by
          calc
            L.minorIndex.row F.idx =
                ClosePairStrictBlock.rowFin A B hC z := hzrow.symm
            _ = A.row tailIdx := hzrow_tail
        have hrows_eq :
            L.minorIndex.row F.idx = L.minorIndex.row tailIdx := by
          rw [hF_eq_tail_row, htail_fixed]
        have hidx_eq : F.idx = tailIdx :=
          L.minorIndex.row.injective hrows_eq
        exact (ne_of_lt hF_lt_tail) hidx_eq
      · /-
        The tail row at `tailIdx` is itself displaced.  This is the genuine
        finite chain that remains after the B-middle and fixed-tail branches
        have been removed.
        -/
        have htailIdx_shift :
            A.row tailIdx < L.minorIndex.row tailIdx := by
          calc
            A.row tailIdx = L.minorIndex.row F.idx := by
              calc
                A.row tailIdx = ClosePairStrictBlock.rowFin A B hC z :=
                  hzrow_tail.symm
                _ = L.minorIndex.row F.idx := hzrow
            _ < L.minorIndex.row tailIdx :=
              L.minorIndex.row.strictMono hF_lt_tail
        have htail_no_shift :
            ∀ d : ℕ,
              ∀ j : Fin t,
                t - j.1 = d →
                uClose A B ≤ j.1 →
                A.row j < L.minorIndex.row j →
                  False := by
          intro d
          refine Nat.strong_induction_on d ?_
          intro d ih j hd hj_tail hj_gt
          let w : Fin (ClosePairStrictBlock.size A B) := L.minorRows j
          have hwrow :
              ClosePairStrictBlock.rowFin A B hC w =
                L.minorIndex.row j := by
            rfl
          rcases ClosePairStrictBlock.block_cases_of_lt_size A B w.2 with
              hpre | hmid | hrep | htail'
          · let widx : Fin t := ⟨w.1, by
              have hw_lt_s : w.1 < sClose A B := hpre
              have hslt : sClose A B < t :=
                lt_of_lt_of_le (sClose_lt_pClose A B hC.ne) (pClose_le A B)
              omega⟩
            have hwrow_A :
                ClosePairStrictBlock.rowFin A B hC w = A.row widx := by
              apply Fin.ext
              change ClosePairStrictBlock.rowCoord A B w.1 - 1 =
                (A.row widx).1
              rw [ClosePairStrictBlock.rowCoord_of_prefix A B hpre]
              have hw_pos : 1 ≤ w.1 + 1 := by omega
              have hw_le_t : w.1 + 1 ≤ t := by
                have hw_lt_s : w.1 < sClose A B := hpre
                have hslt : sClose A B < t :=
                  lt_of_lt_of_le (sClose_lt_pClose A B hC.ne) (pClose_le A B)
                omega
              rw [EndpointSelection.rowExt_endpoint (I := A) hw_pos hw_le_t]
              have hwidx :
                  (⟨w.1 + 1 - 1, by
                    have hslt : sClose A B < t :=
                      lt_of_lt_of_le (sClose_lt_pClose A B hC.ne) (pClose_le A B)
                    omega⟩ : Fin t) = widx := by
                apply Fin.ext
                simp [widx]
              rw [hwidx]
              omega
            have hwidx_lt_j : widx < j := by
              exact Fin.mk_lt_mk.mpr
                (lt_of_lt_of_le hpre
                  (le_trans
                    (Nat.le_of_lt (sClose_lt_uClose A B hC.ne))
                    hj_tail))
            have hrow_lt : A.row widx < A.row j :=
              A.row.strictMono hwidx_lt_j
            have hrow_gt : A.row j < A.row widx := by
              calc
