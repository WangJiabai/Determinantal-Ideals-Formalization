/-- Expanding one raw column-side Laplace summand gives the corresponding full
Leibniz terms indexed by `rawColLaplacePerm`. -/
lemma rawColLaplaceSummand_eq_sum_rawColLaplacePerm_terms
    (A B : MinorIndex m n t)
    (hC : Close A B)
    (R : RawColLaplaceChoice A B hC) :
    rawColLaplaceSummand
        (m := m) (n := n) (t := t) (k := k) A B hC R =
      ∑ p : Equiv.Perm (Fin t) ×
          Equiv.Perm (Fin (ClosePairStrictBlock.width A B)),
        ClosePairStrictBlock.laplaceShuffleSign
            (k := MvPolynomial (Fin m × Fin n) k)
            (rawColLaplacePerm A B hC R p.1 p.2) *
          ∏ j : Fin (ClosePairStrictBlock.size A B),
            ClosePairStrictBlock.matrix
              (m := m) (n := n) (t := t) (k := k) A B
              (rawColLaplacePerm A B hC R p.1 p.2 j) j := by
  classical
  rw [rawColLaplaceSummand]
  rw [Matrix.det_apply', Matrix.det_apply']
  simp_rw [Finset.sum_mul, Finset.mul_sum]
  rw [Finset.sum_comm]
  rw [← Fintype.sum_prod_type']
  refine Finset.sum_congr rfl ?_
  rintro ⟨τ, σ⟩ _hp
  have hprod :=
    rawColLaplacePerm_product_split
      (m := m) (n := n) (t := t) A B hC R τ σ
      (ClosePairStrictBlock.matrix
        (m := m) (n := n) (t := t) (k := k) A B)
  have hsign :=
    rawColLaplacePerm_sign
      (m := m) (n := n) (t := t)
      (k := MvPolynomial (Fin m × Fin n) k) A B hC R τ σ
  rw [hsign, hprod]
  simp [rawColLaplaceSign, ClosePairStrictBlock.laplaceShuffleSign,
    MvPolynomial.C_mul]
  ring

/-- Inverse map used in `rawColLaplaceIndexEquiv`.

It factors a full Leibniz permutation into a raw, position-sorted column choice
and the two internal permutations. -/
noncomputable def rawColLaplaceIndexInv
    (A B : MinorIndex m n t)
    (hC : Close A B)
    (ρ : Equiv.Perm (Fin (ClosePairStrictBlock.size A B))) :
    Σ _R : RawColLaplaceChoice A B hC,
      Equiv.Perm (Fin t) ×
        Equiv.Perm (Fin (ClosePairStrictBlock.width A B)) := by
  classical
  let C := ClosePairStrictBlock.colPrincipalShuffle A B hC
  let h : Fin t ⊕ Fin (ClosePairStrictBlock.width A B) ≃
      Fin (ClosePairStrictBlock.size A B) :=
    C.trans ρ.symm
  let leftCols : Fin t → Fin (ClosePairStrictBlock.size A B) :=
    fun i => h (Sum.inl i)
  let rightCols :
      Fin (ClosePairStrictBlock.width A B) →
        Fin (ClosePairStrictBlock.size A B) :=
    fun i => h (Sum.inr i)
  have hleftCols : Function.Injective leftCols := by
    intro i j hij
    exact Sum.inl_injective (h.injective hij)
  have hrightCols : Function.Injective rightCols := by
    intro i j hij
    exact Sum.inr_injective (h.injective hij)
  let leftSort := Tuple.sort leftCols
  let rightSort := Tuple.sort rightCols
  let shuffle :
      Fin t ⊕ Fin (ClosePairStrictBlock.width A B) ≃
        Fin (ClosePairStrictBlock.size A B) :=
    (Equiv.sumCongr leftSort rightSort).trans h
  refine
    ⟨{ shuffle := shuffle
       minorColsPosStrict := ?_
       cofactorColsPosStrict := ?_ },
      (leftSort, rightSort)⟩
  · simpa [shuffle, leftCols, leftSort] using
      strictMono_val_comp_tuple_sort_of_injective leftCols hleftCols
  · simpa [shuffle, rightCols, rightSort] using
      strictMono_val_comp_tuple_sort_of_injective rightCols hrightCols

/-- The raw column indexing equivalence. -/
noncomputable def rawColLaplaceIndexEquiv
    (A B : MinorIndex m n t)
    (hC : Close A B) :
    (Σ _R : RawColLaplaceChoice A B hC,
        Equiv.Perm (Fin t) ×
          Equiv.Perm (Fin (ClosePairStrictBlock.width A B)))
      ≃
    Equiv.Perm (Fin (ClosePairStrictBlock.size A B)) := by
  classical
  refine
    { toFun := fun x => rawColLaplacePerm A B hC x.1 x.2.1 x.2.2
      invFun := rawColLaplaceIndexInv A B hC
      left_inv := ?_
      right_inv := ?_ }
  · rintro ⟨R, τ, σ⟩
    have hleftSort :
        Tuple.sort (fun i : Fin t => R.shuffle (Sum.inl (τ.symm i))) = τ := by
      apply tuple_sort_eq_of_strictMono_val_comp
      intro i j hij
      simpa using R.minorColsPosStrict hij
    have hrightSort :
        Tuple.sort
            (fun i : Fin (ClosePairStrictBlock.width A B) =>
              R.shuffle (Sum.inr (σ.symm i))) = σ := by
      apply tuple_sort_eq_of_strictMono_val_comp
      intro i j hij
      simpa using R.cofactorColsPosStrict hij
    cases R with
    | mk sh hminor hcofactor =>
    have hshuffle :
        (Equiv.sumCongr τ σ).trans
          ((ClosePairStrictBlock.colPrincipalShuffle A B hC).trans
            ((sh.symm.trans
              ((Equiv.sumCongr τ σ).trans
                (ClosePairStrictBlock.colPrincipalShuffle A B hC))).symm)) =
          sh := by
      apply Equiv.ext
      intro q
      simp
    simp [rawColLaplaceIndexInv, rawColLaplacePerm, hleftSort, hrightSort,
      hshuffle]
  · intro ρ
    ext q
    simp [rawColLaplaceIndexInv, rawColLaplacePerm]

