  let rowExp : (Fin m × Fin n) →₀ ℕ :=
    closePairThm21_case1_rowTermExp
      (m := m) (n := n) (t := t) (k := k) A B hC L σ
  let headExp : (Fin m × Fin n) →₀ ℕ :=
    headLcm ord
      (genericMinor (k := k) A)
      (genericMinor (k := k) B)
  let localExp : (Fin m × Fin n) →₀ ℕ :=
    closePairThm21_case1_BmiddlePartExp
      (m := m) (n := n) (t := t) (k := k) A B hC L σ
  let localDiag : (Fin m × Fin n) →₀ ℕ :=
    diagExp (ClosePairStrictBlock.bMiddleMinorIndex A B hC)
  let commonRow : (Fin m × Fin n) →₀ ℕ := rowExp - localExp
  let commonHead : (Fin m × Fin n) →₀ ℕ := headExp - localDiag
  have hlocal_le_row : localExp ≤ rowExp := by
    simpa [localExp, rowExp] using
      closePairThm21_case1_BmiddlePartExp_le_rowTermExp
        (m := m) (n := n) (t := t) (k := k) A B hC L σ
  have hdiag_le_head : localDiag ≤ headExp := by
    simpa [localDiag, headExp] using
      closePairThm21_case1_bMiddle_diagExp_le_headLcm
        (m := m) (n := n) (t := t) (k := k) ord hdiag A B hC
  have hrow_decomp : rowExp = localExp + commonRow := by
    ext x
    have hx := hlocal_le_row x
    dsimp [commonRow]
    omega
  have hhead_decomp : headExp = localDiag + commonHead := by
    ext x
    have hx := hdiag_le_head x
    dsimp [commonHead]
    omega
  have hcommon_eq : commonRow = commonHead := by
    /-
    This is the real common-residual statement for the `B`-middle splice.
    The previous `StatementA/B/C` hypotheses should identify the outside
    factors of `rowExp` and `headExp`.
    -/
    sorry
  have hhead_decomp_common : headExp = localDiag + commonRow := by
    rw [← hcommon_eq] at hhead_decomp
    exact hhead_decomp
  exact
    closePairThm21_case1_rowTermExp_lt_of_BmiddlePart_lt_of_common
      (m := m) (n := n) (t := t) (k := k)
      ord A B hC L σ commonRow hlocal
      (by simpa [rowExp, localExp, commonRow] using hrow_decomp)
      (by simpa [headExp, localDiag, commonRow] using hhead_decomp_common)

/-- Cofactor-only `B`-middle local-to-global splice with an explicitly supplied
common residual.

This lemma is deliberately only the mechanical splice: the concrete branch
that invokes it must prove that after removing the cofactor-only `B`-middle
local part, the remaining row-term exponent is exactly `diagExp A`. -/
lemma closePairThm21_case1_rowTermExp_lt_of_BmiddleCofactorPart_lt_of_common
    (ord : MonomialOrder (Fin m × Fin n))
    (hdiag : IsDiagonalTermOrder ord)
    (A B : MinorIndex m n t)
    (hC : Close A B)
    (L : ClosePairStrictBlock.RowLaplaceChoice A B hC)
    (sigma : Equiv.Perm (Fin (ClosePairStrictBlock.width A B)))
    (hlocal :
      ord.toSyn
          (closePairThm21_case1_BmiddleCofactorPartExp
            (m := m) (n := n) (t := t) A B hC L sigma)
        <
        ord.toSyn
          (diagExp (ClosePairStrictBlock.bMiddleMinorIndex A B hC)))
    (hcommon :
      closePairThm21_case1_rowTermExp
          (m := m) (n := n) (t := t) (k := k) A B hC L sigma -
        closePairThm21_case1_BmiddleCofactorPartExp
          (m := m) (n := n) (t := t) A B hC L sigma =
      diagExp A) :
    ord.toSyn
        (closePairThm21_case1_rowTermExp
          (m := m) (n := n) (t := t) (k := k) A B hC L sigma)
      <
      ord.toSyn
        (headLcm ord
          (genericMinor (k := k) A)
          (genericMinor (k := k) B)) := by
  classical
  let rowExp : (Fin m × Fin n) →₀ ℕ :=
    closePairThm21_case1_rowTermExp
      (m := m) (n := n) (t := t) (k := k) A B hC L sigma
  let headExp : (Fin m × Fin n) →₀ ℕ :=
    headLcm ord
      (genericMinor (k := k) A)
      (genericMinor (k := k) B)
  let cofExp : (Fin m × Fin n) →₀ ℕ :=
    MonomialCoefficientMatrix.permExp
      L.cofactorRow L.cofactorCol sigma
  let localExp : (Fin m × Fin n) →₀ ℕ :=
    closePairThm21_case1_BmiddleCofactorPartExp
      (m := m) (n := n) (t := t) A B hC L sigma
  let localDiag : (Fin m × Fin n) →₀ ℕ :=
    diagExp (ClosePairStrictBlock.bMiddleMinorIndex A B hC)
  let commonRow : (Fin m × Fin n) →₀ ℕ := rowExp - localExp
  have hlocal_le_cof : localExp ≤ cofExp := by
    simpa [localExp, cofExp] using
      closePairThm21_case1_BmiddleCofactorPartExp_le_cofExp
        (m := m) (n := n) (t := t) A B hC L sigma
  have hcof_le_row : cofExp ≤ rowExp := by
    intro x
    dsimp [cofExp, rowExp]
    rw [closePairThm21_case1_rowTermExp_eq
      (m := m) (n := n) (t := t) (k := k) A B hC L sigma]
    simp only [Finsupp.coe_add, Pi.add_apply]
    exact Nat.le_add_right _ _
  have hlocal_le_row : localExp ≤ rowExp :=
    le_trans hlocal_le_cof hcof_le_row
  have hrow_decomp : rowExp = localExp + commonRow := by
    ext x
    have hx := hlocal_le_row x
    dsimp [commonRow]
    omega
  have hcommonRow : commonRow = diagExp A := by
    simpa [commonRow, rowExp, localExp] using hcommon
  have hrow_decomp_A : rowExp = localExp + diagExp A := by
    rw [hrow_decomp, hcommonRow]
  have hhead_decomp : headExp = localDiag + diagExp A := by
    dsimp [headExp, localDiag]
    rw [headLcm_genericMinor_eq_sup_diagExp (k := k) ord hdiag A B]
    exact
      (bMiddleMinorIndex_diagExp_add_A_eq_sup
        (m := m) (n := n) (t := t) A B hC).symm
  exact
    toSyn_lt_of_local_lt_with_common
      (ord := ord) hlocal
      (by simpa [rowExp, localExp] using hrow_decomp_A)
      (by simpa [headExp, localDiag] using hhead_decomp)

/-- Cofactor-only `B`-middle local-to-global splice.

This is the interface that should replace the full `BmiddlePartExp` splice in
residual branches: the local part removes only the cofactor contribution in the
`B`-middle square.  The common residual equality is explicit because it belongs
to the concrete branch, not to this generic splice. -/
lemma closePairThm21_case1_rowTermExp_lt_of_BmiddleCofactorPart_lt
    (ord : MonomialOrder (Fin m × Fin n))
    (hdiag : IsDiagonalTermOrder ord)
    (A B : MinorIndex m n t)
    (hC : Close A B)
    (_hrowLt :
