/-! ### Raw row-subset Laplace layer

This layer avoids the overly strong direct equivalence

  RowLaplaceChoice × Perm t × Perm width ≃ Perm size.

Instead, we first prove a Laplace expansion over row subsets ordered by their
positions in the strict block matrix, and then normalize the nonzero terms to
`RowLaplaceChoice`, whose rows are ordered by the actual row variables.
-/

/-- Raw row-subset choice for the row-side Laplace expansion.

The two row groups are ordered by their positions in the strict block matrix.
This is the canonical indexing needed for a direct Laplace expansion. -/
structure RawRowLaplaceChoice
    (A B : MinorIndex m n t)
    (hC : Close A B) where
  shuffle :
    Fin t ⊕ Fin (ClosePairStrictBlock.width A B) ≃
      Fin (ClosePairStrictBlock.size A B)
  minorRowsPosStrict :
    StrictMono (fun i : Fin t => (shuffle (Sum.inl i)).1)
  cofactorRowsPosStrict :
    StrictMono
      (fun i : Fin (ClosePairStrictBlock.width A B) =>
        (shuffle (Sum.inr i)).1)

namespace RawRowLaplaceChoice

/-- The minor rows selected by a raw row-subset choice. -/
noncomputable def minorRows
    {A B : MinorIndex m n t}
    {hC : Close A B}
    (R : RawRowLaplaceChoice A B hC) :
    Fin t → Fin (ClosePairStrictBlock.size A B) :=
  fun i => R.shuffle (Sum.inl i)

/-- The cofactor rows selected by a raw row-subset choice. -/
noncomputable def cofactorRows
    {A B : MinorIndex m n t}
    {hC : Close A B}
    (R : RawRowLaplaceChoice A B hC) :
    Fin (ClosePairStrictBlock.width A B) →
      Fin (ClosePairStrictBlock.size A B) :=
  fun i => R.shuffle (Sum.inr i)

/-- Raw minor rows are position-injective. -/
lemma minorRows_injective
    {A B : MinorIndex m n t}
    {hC : Close A B}
    (R : RawRowLaplaceChoice A B hC) :
    Function.Injective R.minorRows := by
  intro i j hij
  have hval :
      (R.shuffle (Sum.inl i)).1 = (R.shuffle (Sum.inl j)).1 := by
    simpa [minorRows] using congrArg Fin.val hij
  apply Fin.ext
  exact congrArg Fin.val (StrictMono.injective R.minorRowsPosStrict hval)

/-- Raw cofactor rows are position-injective. -/
lemma cofactorRows_injective
    {A B : MinorIndex m n t}
    {hC : Close A B}
    (R : RawRowLaplaceChoice A B hC) :
    Function.Injective R.cofactorRows := by
  intro i j hij
  have hval :
      (R.shuffle (Sum.inr i)).1 = (R.shuffle (Sum.inr j)).1 := by
    simpa [cofactorRows] using congrArg Fin.val hij
  apply Fin.ext
  exact congrArg Fin.val (StrictMono.injective R.cofactorRowsPosStrict hval)

lemma ext_shuffle
    {A B : MinorIndex m n t}
    {hC : Close A B}
    {R S : RawRowLaplaceChoice A B hC}
    (h : R.shuffle = S.shuffle) :
    R = S := by
  cases R
  cases S
  cases h
  rfl

end RawRowLaplaceChoice

lemma strictMono_val_comp_tuple_sort_of_injective
    {a b : ℕ}
    (f : Fin a → Fin b)
    (hf : Function.Injective f) :
    StrictMono (fun i : Fin a => (f (Tuple.sort f i)).1) := by
  intro i j hij
  have hle : f (Tuple.sort f i) ≤ f (Tuple.sort f j) :=
    Tuple.monotone_sort f hij.le
  have hne : f (Tuple.sort f i) ≠ f (Tuple.sort f j) := by
    intro h
    have hs : Tuple.sort f i = Tuple.sort f j := hf h
    exact hij.ne ((Tuple.sort f).injective hs)
  have hneVal :
      (f (Tuple.sort f i)).1 ≠ (f (Tuple.sort f j)).1 := by
    intro hval
    exact hne (Fin.ext hval)
  exact lt_of_le_of_ne hle hneVal

lemma tuple_sort_eq_of_strictMono_val_comp
    {a b : ℕ}
    (f : Fin a → Fin b)
    (π : Equiv.Perm (Fin a))
    (hmono : StrictMono (fun i : Fin a => (f (π i)).1)) :
    Tuple.sort f = π := by
  have hmonoFin : StrictMono (fun i : Fin a => f (π i)) := by
    intro i j hij
    exact hmono hij
  have hcomp :
      f ∘ π = f ∘ Tuple.sort f :=
    (Tuple.comp_sort_eq_comp_iff_monotone (f := f) (σ := π)).2
      hmonoFin.monotone
  have hf : Function.Injective f := by
    intro x y hxy
    have hpre :
        (fun i : Fin a => f (π i)) (π.symm x) =
          (fun i : Fin a => f (π i)) (π.symm y) := by
      simpa using hxy
    have hxy' := hmonoFin.injective hpre
    simpa using congrArg π hxy'
  apply Equiv.ext
  intro i
  have hπ :
      π i = Tuple.sort f i :=
    hf (congr_fun hcomp i)
  exact hπ.symm

noncomputable instance rawRowLaplaceChoiceFintype
    (A B : MinorIndex m n t)
    (hC : Close A B) :
    Fintype (RawRowLaplaceChoice A B hC) := by
  classical
  let Shuffle : Type :=
    Fin t ⊕ Fin (ClosePairStrictBlock.width A B) ≃
      Fin (ClosePairStrictBlock.size A B)
  let α : Type :=
    {p : Shuffle //
      StrictMono (fun i : Fin t => (p (Sum.inl i)).1) ∧
      StrictMono
        (fun i : Fin (ClosePairStrictBlock.width A B) =>
          (p (Sum.inr i)).1)}
  let e : RawRowLaplaceChoice A B hC ≃ α :=
  {
    toFun R :=
      ⟨R.shuffle, R.minorRowsPosStrict, R.cofactorRowsPosStrict⟩
    invFun p :=
      { shuffle := p.1
        minorRowsPosStrict := p.2.1
        cofactorRowsPosStrict := p.2.2 }
    left_inv R := by
      cases R
      rfl
    right_inv p := by
      cases p
      rfl
  }
  exact Fintype.ofEquiv α e.symm

/-- The raw row-side Laplace sign attached to a position-ordered row subset. -/
noncomputable def rawRowLaplaceSign
    (A B : MinorIndex m n t)
    (hC : Close A B)
    (R : RawRowLaplaceChoice A B hC) : k :=
  ClosePairStrictBlock.laplaceShuffleSign
    (k := k)
    (R.shuffle.trans (ClosePairStrictBlock.sumFinToSize A B).symm) *
    ClosePairStrictBlock.laplaceShuffleSign
      (k := k)
      ((ClosePairStrictBlock.rowPrincipalShuffle A B hC).trans
        (ClosePairStrictBlock.sumFinToSize A B).symm)

/-- One raw row-side Laplace summand.

This is before normalizing the chosen rows into a `RowLaplaceChoice`. -/
noncomputable def rawRowLaplaceSummand
    (A B : MinorIndex m n t)
    (hC : Close A B)
    (R : RawRowLaplaceChoice A B hC) :
    MvPolynomial (Fin m × Fin n) k :=
  MvPolynomial.C
      (rawRowLaplaceSign
        (m := m) (n := n) (t := t) (k := k) A B hC R) *
    (Matrix.det
        (Matrix.submatrix
          (ClosePairStrictBlock.matrix
            (m := m) (n := n) (t := t) (k := k) A B)
          R.cofactorRows
          (ClosePairStrictBlock.bMiddlePos A B hC)) *
      Matrix.det
        (Matrix.submatrix
          (ClosePairStrictBlock.matrix
            (m := m) (n := n) (t := t) (k := k) A B)
          R.minorRows
          (ClosePairStrictBlock.aColumnPos A B hC)))

/-- The full permutation attached to a raw row choice and the two internal
Leibniz permutations. -/
noncomputable def rawRowLaplacePerm
    (A B : MinorIndex m n t)
    (hC : Close A B)
    (R : RawRowLaplaceChoice A B hC)
    (τ : Equiv.Perm (Fin t))
    (σ : Equiv.Perm (Fin (ClosePairStrictBlock.width A B))) :
    Equiv.Perm (Fin (ClosePairStrictBlock.size A B)) :=
  ((ClosePairStrictBlock.rowPrincipalShuffle A B hC).symm.trans
      (Equiv.sumCongr τ σ)).trans R.shuffle

@[simp] lemma rawRowLaplacePerm_aColumnPos
    (A B : MinorIndex m n t)
    (hC : Close A B)
    (R : RawRowLaplaceChoice A B hC)
    (τ : Equiv.Perm (Fin t))
    (σ : Equiv.Perm (Fin (ClosePairStrictBlock.width A B)))
    (j : Fin t) :
    rawRowLaplacePerm A B hC R τ σ
        (ClosePairStrictBlock.aColumnPos A B hC j) =
      R.minorRows (τ j) := by
  have hleft :
      (ClosePairStrictBlock.rowPrincipalShuffle A B hC).symm
          (ClosePairStrictBlock.aColumnPos A B hC j) =
        Sum.inl j := by
    simpa [ClosePairStrictBlock.rowPrincipalShuffle] using
      (ClosePairStrictBlock.rowPrincipalShuffle A B hC).left_inv (Sum.inl j)
  simp [rawRowLaplacePerm, hleft, RawRowLaplaceChoice.minorRows]

@[simp] lemma rawRowLaplacePerm_bMiddlePos
    (A B : MinorIndex m n t)
    (hC : Close A B)
    (R : RawRowLaplaceChoice A B hC)
    (τ : Equiv.Perm (Fin t))
    (σ : Equiv.Perm (Fin (ClosePairStrictBlock.width A B)))
    (j : Fin (ClosePairStrictBlock.width A B)) :
    rawRowLaplacePerm A B hC R τ σ
        (ClosePairStrictBlock.bMiddlePos A B hC j) =
      R.cofactorRows (σ j) := by
  have hright :
      (ClosePairStrictBlock.rowPrincipalShuffle A B hC).symm
          (ClosePairStrictBlock.bMiddlePos A B hC j) =
        Sum.inr j := by
    simpa [ClosePairStrictBlock.rowPrincipalShuffle] using
      (ClosePairStrictBlock.rowPrincipalShuffle A B hC).left_inv (Sum.inr j)
  simp [rawRowLaplacePerm, hright, RawRowLaplaceChoice.cofactorRows]

lemma rawRowLaplacePerm_product_split
    {Rng : Type*} [CommMonoid Rng]
    (A B : MinorIndex m n t)
    (hC : Close A B)
    (R : RawRowLaplaceChoice A B hC)
    (τ : Equiv.Perm (Fin t))
    (σ : Equiv.Perm (Fin (ClosePairStrictBlock.width A B)))
    (M : Matrix (Fin (ClosePairStrictBlock.size A B))
          (Fin (ClosePairStrictBlock.size A B)) Rng) :
    (∏ j : Fin (ClosePairStrictBlock.size A B),
        M (rawRowLaplacePerm A B hC R τ σ j) j) =
      (∏ j : Fin t,
        M (R.minorRows (τ j)) (ClosePairStrictBlock.aColumnPos A B hC j)) *
      (∏ j : Fin (ClosePairStrictBlock.width A B),
        M (R.cofactorRows (σ j)) (ClosePairStrictBlock.bMiddlePos A B hC j)) := by
  classical
  rw [← Equiv.prod_comp (ClosePairStrictBlock.rowPrincipalShuffle A B hC)
    (fun j : Fin (ClosePairStrictBlock.size A B) =>
      M (rawRowLaplacePerm A B hC R τ σ j) j)]
  rw [Fintype.prod_sum_type]
  simp [ClosePairStrictBlock.rowPrincipalShuffle]

omit [Nontrivial k] in
lemma rawRowLaplacePerm_sign
    (A B : MinorIndex m n t)
    (hC : Close A B)
    (R : RawRowLaplaceChoice A B hC)
    (τ : Equiv.Perm (Fin t))
    (σ : Equiv.Perm (Fin (ClosePairStrictBlock.width A B))) :
    ClosePairStrictBlock.laplaceShuffleSign
        (k := k) (rawRowLaplacePerm A B hC R τ σ) =
      rawRowLaplaceSign (m := m) (n := n) (t := t) (k := k) A B hC R *
        (ClosePairStrictBlock.laplaceShuffleSign (k := k) τ *
          ClosePairStrictBlock.laplaceShuffleSign (k := k) σ) := by
  classical
  let S := ClosePairStrictBlock.sumFinToSize A B
  let C := ClosePairStrictBlock.rowPrincipalShuffle A B hC
  let rrel : Equiv.Perm
      (Fin t ⊕ Fin (ClosePairStrictBlock.width A B)) :=
    R.shuffle.trans S.symm
  let crel : Equiv.Perm
      (Fin t ⊕ Fin (ClosePairStrictBlock.width A B)) :=
    C.trans S.symm
  have hconj :
      (S.trans (rawRowLaplacePerm A B hC R τ σ)).trans S.symm =
        crel.symm.trans ((Equiv.Perm.sumCongr τ σ).trans rrel) := by
    ext x
    simp [rawRowLaplacePerm, S, C, rrel, crel]
  have hsign :
      Equiv.Perm.sign (rawRowLaplacePerm A B hC R τ σ) =
      Equiv.Perm.sign
          (crel.symm.trans ((Equiv.Perm.sumCongr τ σ).trans rrel)) := by
    rw [← hconj]
    exact (Equiv.Perm.sign_trans_trans_symm
      (rawRowLaplacePerm A B hC R τ σ) S).symm
  unfold ClosePairStrictBlock.laplaceShuffleSign rawRowLaplaceSign
  rw [hsign]
  simp [ClosePairStrictBlock.laplaceShuffleSign, S, C, rrel, crel,
    Equiv.Perm.sign_trans, Equiv.Perm.sign_sumCongr,
    mul_assoc, mul_comm, mul_left_comm]

omit [Nontrivial k] in
/-- Expanding one raw row-side Laplace summand gives the corresponding full
Leibniz terms indexed by `rawRowLaplacePerm`.

This is the raw analogue of
`strictRowLaplaceSummand_eq_sum_rowLaplacePerm_terms`. -/
lemma rawRowLaplaceSummand_eq_sum_rawRowLaplacePerm_terms
    (A B : MinorIndex m n t)
    (hC : Close A B)
    (R : RawRowLaplaceChoice A B hC) :
    rawRowLaplaceSummand
        (m := m) (n := n) (t := t) (k := k) A B hC R =
      ∑ p : Equiv.Perm (Fin t) ×
          Equiv.Perm (Fin (ClosePairStrictBlock.width A B)),
        ClosePairStrictBlock.laplaceShuffleSign
            (k := MvPolynomial (Fin m × Fin n) k)
            (rawRowLaplacePerm A B hC R p.1 p.2) *
          ∏ j : Fin (ClosePairStrictBlock.size A B),
            ClosePairStrictBlock.matrix
              (m := m) (n := n) (t := t) (k := k) A B
              (rawRowLaplacePerm A B hC R p.1 p.2 j) j := by
  classical
  /-
  Prove exactly like `strictRowLaplaceSummand_eq_sum_rowLaplacePerm_terms`,
  but using `R.minorRows`, `R.cofactorRows`, and `R.shuffle`.

  Expected steps:
  * unfold `rawRowLaplaceSummand`;
  * expand both determinants by `Matrix.det_apply'`;
  * use a raw version of product split for `rawRowLaplacePerm`;
  * use a raw version of sign split for `rawRowLaplacePerm`.
  -/
  rw [rawRowLaplaceSummand]
  rw [Matrix.det_apply', Matrix.det_apply']
  simp_rw [Finset.sum_mul, Finset.mul_sum]
  rw [Finset.sum_comm]
  rw [← Fintype.sum_prod_type']
  refine Finset.sum_congr rfl ?_
  rintro ⟨τ, σ⟩ _hp
  have hprod :=
    rawRowLaplacePerm_product_split
      (m := m) (n := n) (t := t) A B hC R τ σ
      (ClosePairStrictBlock.matrix
        (m := m) (n := n) (t := t) (k := k) A B)
  have hsign :=
    rawRowLaplacePerm_sign
      (m := m) (n := n) (t := t)
      (k := MvPolynomial (Fin m × Fin n) k) A B hC R τ σ
  rw [hsign, hprod]
  simp [rawRowLaplaceSign, ClosePairStrictBlock.laplaceShuffleSign,
    MvPolynomial.C_mul]
  ring

/-- Inverse map used in `rawRowLaplaceIndexEquiv`.

It factors a full Leibniz permutation into a raw, position-sorted row choice
and the two internal permutations. -/
noncomputable def rawRowLaplaceIndexInv
    (A B : MinorIndex m n t)
    (hC : Close A B)
    (ρ : Equiv.Perm (Fin (ClosePairStrictBlock.size A B))) :
    Σ _R : RawRowLaplaceChoice A B hC,
      Equiv.Perm (Fin t) ×
        Equiv.Perm (Fin (ClosePairStrictBlock.width A B)) := by
  classical
  let C := ClosePairStrictBlock.rowPrincipalShuffle A B hC
  let h : Fin t ⊕ Fin (ClosePairStrictBlock.width A B) ≃
      Fin (ClosePairStrictBlock.size A B) :=
    C.trans ρ
  let leftRows : Fin t → Fin (ClosePairStrictBlock.size A B) :=
    fun i => h (Sum.inl i)
  let rightRows :
      Fin (ClosePairStrictBlock.width A B) →
        Fin (ClosePairStrictBlock.size A B) :=
    fun i => h (Sum.inr i)
  have hleftRows : Function.Injective leftRows := by
    intro i j hij
    exact Sum.inl_injective (h.injective hij)
  have hrightRows : Function.Injective rightRows := by
    intro i j hij
    exact Sum.inr_injective (h.injective hij)
  let leftSort := Tuple.sort leftRows
  let rightSort := Tuple.sort rightRows
  let shuffle :
      Fin t ⊕ Fin (ClosePairStrictBlock.width A B) ≃
        Fin (ClosePairStrictBlock.size A B) :=
    (Equiv.sumCongr leftSort rightSort).trans h
  refine
    ⟨{ shuffle := shuffle
       minorRowsPosStrict := ?_
       cofactorRowsPosStrict := ?_ },
      (leftSort.symm, rightSort.symm)⟩
  · simpa [shuffle, leftRows, leftSort] using
      strictMono_val_comp_tuple_sort_of_injective leftRows hleftRows
  · simpa [shuffle, rightRows, rightSort] using
      strictMono_val_comp_tuple_sort_of_injective rightRows hrightRows

/-- The raw indexing equivalence.

This one is intentionally weaker and cleaner than the old direct
`rowLaplaceIndexEquiv`: raw choices are ordered by matrix position, so every
full permutation determines such a raw choice uniquely. -/
noncomputable def rawRowLaplaceIndexEquiv
    (A B : MinorIndex m n t)
    (hC : Close A B) :
    (Σ _R : RawRowLaplaceChoice A B hC,
        Equiv.Perm (Fin t) ×
          Equiv.Perm (Fin (ClosePairStrictBlock.width A B)))
      ≃
    Equiv.Perm (Fin (ClosePairStrictBlock.size A B)) := by
  classical
  refine
    { toFun := fun x => rawRowLaplacePerm A B hC x.1 x.2.1 x.2.2
      invFun := rawRowLaplaceIndexInv A B hC
      left_inv := ?_
      right_inv := ?_ }
  · rintro ⟨R, τ, σ⟩
    have hleftSort :
        Tuple.sort (fun i : Fin t => R.shuffle (Sum.inl (τ i))) = τ.symm := by
      apply tuple_sort_eq_of_strictMono_val_comp
      intro i j hij
      simpa using R.minorRowsPosStrict hij
    have hrightSort :
        Tuple.sort
            (fun i : Fin (ClosePairStrictBlock.width A B) =>
              R.shuffle (Sum.inr (σ i))) = σ.symm := by
      apply tuple_sort_eq_of_strictMono_val_comp
      intro i j hij
      simpa using R.cofactorRowsPosStrict hij
    cases R with
    | mk sh hminor hcofactor =>
    have hshuffle :
        ((Equiv.symm τ).sumCongr (Equiv.symm σ)).trans
          ((ClosePairStrictBlock.rowPrincipalShuffle A B hC).trans
            (((ClosePairStrictBlock.rowPrincipalShuffle A B hC).symm.trans
              (Equiv.sumCongr τ σ)).trans sh)) =
          sh := by
      apply Equiv.ext
      intro q
      simp
    simp [rawRowLaplaceIndexInv, rawRowLaplacePerm, hleftSort, hrightSort,
      hshuffle]
  · intro ρ
    ext q
    simp [rawRowLaplaceIndexInv, rawRowLaplacePerm]

omit [Nontrivial k] in
/-- Raw row-subset Laplace expansion along the `B`-middle columns.

This is the direct Laplace expansion before normalizing row choices by actual
row variables. -/
lemma strict_row_laplace_expansion_raw_choices
    (A B : MinorIndex m n t)
    (hC : Close A B) :
    ClosePairStrictBlock.det
        (m := m) (n := n) (t := t) (k := k) A B =
      ∑ R : RawRowLaplaceChoice A B hC,
        rawRowLaplaceSummand
          (m := m) (n := n) (t := t) (k := k) A B hC R := by
  classical
  let detTerm : Equiv.Perm (Fin (ClosePairStrictBlock.size A B)) →
      MvPolynomial (Fin m × Fin n) k :=
    fun ρ =>
      ClosePairStrictBlock.laplaceShuffleSign
          (k := MvPolynomial (Fin m × Fin n) k) ρ *
        ∏ j : Fin (ClosePairStrictBlock.size A B),
          ClosePairStrictBlock.matrix
            (m := m) (n := n) (t := t) (k := k) A B (ρ j) j
  calc
    ClosePairStrictBlock.det
        (m := m) (n := n) (t := t) (k := k) A B =
      ∑ ρ : Equiv.Perm (Fin (ClosePairStrictBlock.size A B)), detTerm ρ := by
        rw [ClosePairStrictBlock.det, Matrix.det_apply']
        simp [detTerm, ClosePairStrictBlock.laplaceShuffleSign]
    _ =
      ∑ x :
          Σ R : RawRowLaplaceChoice A B hC,
            Equiv.Perm (Fin t) ×
              Equiv.Perm (Fin (ClosePairStrictBlock.width A B)),
        detTerm (rawRowLaplacePerm A B hC x.1 x.2.1 x.2.2) := by
        let e := rawRowLaplaceIndexEquiv
          (m := m) (n := n) (t := t) A B hC
        have hsum :
            (∑ x :
                Σ R : RawRowLaplaceChoice A B hC,
                  Equiv.Perm (Fin t) ×
                    Equiv.Perm (Fin (ClosePairStrictBlock.width A B)),
              detTerm (e x)) =
            ∑ ρ : Equiv.Perm (Fin (ClosePairStrictBlock.size A B)),
              detTerm ρ :=
          Fintype.sum_equiv e
            (fun x => detTerm (e x))
            detTerm
            (by intro x; rfl)
        simpa [e, rawRowLaplaceIndexEquiv, rawRowLaplacePerm] using hsum.symm
    _ =
      ∑ R : RawRowLaplaceChoice A B hC,
        rawRowLaplaceSummand
          (m := m) (n := n) (t := t) (k := k) A B hC R := by
        calc
          (∑ x :
              Σ R : RawRowLaplaceChoice A B hC,
                Equiv.Perm (Fin t) ×
                  Equiv.Perm (Fin (ClosePairStrictBlock.width A B)),
            detTerm (rawRowLaplacePerm A B hC x.1 x.2.1 x.2.2))
              =
            ∑ R : RawRowLaplaceChoice A B hC,
              ∑ p : Equiv.Perm (Fin t) ×
                  Equiv.Perm (Fin (ClosePairStrictBlock.width A B)),
                detTerm (rawRowLaplacePerm A B hC R p.1 p.2) := by
              exact
                Fintype.sum_sigma'
                  (fun R : RawRowLaplaceChoice A B hC =>
                    fun p : Equiv.Perm (Fin t) ×
                        Equiv.Perm (Fin (ClosePairStrictBlock.width A B)) =>
                      detTerm (rawRowLaplacePerm A B hC R p.1 p.2))
          _ =
            ∑ R : RawRowLaplaceChoice A B hC,
              rawRowLaplaceSummand
                (m := m) (n := n) (t := t) (k := k) A B hC R := by
              refine Finset.sum_congr rfl ?_
              intro R _hR
              exact
                (rawRowLaplaceSummand_eq_sum_rawRowLaplacePerm_terms
                  (m := m) (n := n) (t := t) (k := k) A B hC R).symm

namespace RawRowLaplaceChoice

/-- A raw row choice is sortable if both row groups have pairwise distinct
actual row variables.  In this case it can be normalized to a
`RowLaplaceChoice`. -/
def Sortable
    {A B : MinorIndex m n t}
    {hC : Close A B}
    (R : RawRowLaplaceChoice A B hC) : Prop :=
  Function.Injective
    (fun i : Fin t =>
      ClosePairStrictBlock.rowFin A B hC (R.minorRows i))

end RawRowLaplaceChoice

noncomputable instance sortableRawRowLaplaceChoiceFintype
    (A B : MinorIndex m n t)
    (hC : Close A B) :
    Fintype {R : RawRowLaplaceChoice A B hC // R.Sortable} := by
  classical
  infer_instance

noncomputable instance notSortableRawRowLaplaceChoiceFintype
    (A B : MinorIndex m n t)
    (hC : Close A B) :
    Fintype {R : RawRowLaplaceChoice A B hC // ¬ R.Sortable} := by
  classical
  infer_instance

