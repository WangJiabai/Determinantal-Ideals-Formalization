      ∀ j : Fin (ClosePairStrictBlock.width A B), L.cofactorRows j ∈ s := by
    intro j
    let q : Fin (ClosePairStrictBlock.size A B) := L.cofactorRows j
    let y : Fin t ⊕ Fin (ClosePairStrictBlock.width A B) :=
      (ClosePairStrictBlock.rowPrincipalShuffle A B hC).symm q
    have hy :
        ClosePairStrictBlock.rowPrincipalShuffle A B hC y = q := by
      dsimp [y]
      simp
    cases hcase : y with
    | inl i =>
        have hyq :
            ClosePairStrictBlock.aColumnPos A B hC i = q := by
          calc
            ClosePairStrictBlock.aColumnPos A B hC i =
                ClosePairStrictBlock.rowPrincipalShuffle A B hC (Sum.inl i) := rfl
            _ = ClosePairStrictBlock.rowPrincipalShuffle A B hC y := by rw [hcase]
            _ = q := hy
        have hleft : L.shuffle (Sum.inl i) = q := by
          calc
            L.shuffle (Sum.inl i) = L.minorRows i := (L.minorRows_eq_shuffle i).symm
            _ = ClosePairStrictBlock.aColumnPos A B hC i := congrFun hminor i
            _ = q := hyq
        have hright : L.shuffle (Sum.inr j) = q := by
          simpa [q] using (L.cofactorRows_eq_shuffle j).symm
        have hbad : Sum.inl i = Sum.inr j :=
          L.shuffle.injective (hleft.trans hright.symm)
        cases hbad
    | inr r =>
        have hyq :
            ClosePairStrictBlock.bMiddlePos A B hC r = q := by
          calc
            ClosePairStrictBlock.bMiddlePos A B hC r =
                ClosePairStrictBlock.rowPrincipalShuffle A B hC (Sum.inr r) := rfl
            _ = ClosePairStrictBlock.rowPrincipalShuffle A B hC y := by rw [hcase]
            _ = q := hy
        exact Finset.mem_image.mpr ⟨r, by simp, hyq⟩
  have hL :
      (fun j : Fin (ClosePairStrictBlock.width A B) => L.cofactorRows j) =
        s.orderEmbOfFin hcard := by
    exact Finset.orderEmbOfFin_unique hcard hL_mem L.cofactorRowsStrict
  exact hL.trans hB.symm

