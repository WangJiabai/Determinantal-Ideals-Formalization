             (ClosePairStrictBlock.bMiddleMinorIndex A B hC).col s)
          =
        if τ r = s then 1 else 0 := by
  classical
  let K : MinorIndex m n (ClosePairStrictBlock.width A B) :=
    ClosePairStrictBlock.bMiddleMinorIndex A B hC
  let E : (Fin m × Fin n) →₀ ℕ :=
    closePairThm21_case1_BmiddlePartExp
      (m := m) (n := n) (t := t) (k := k) A B hC L σ
  let τFun :
      Fin (ClosePairStrictBlock.width A B) →
        Fin (ClosePairStrictBlock.width A B) :=
    fun r => Classical.choose (hrow_exists r)
  have hτFun_hit :
      ∀ r,
        E (K.row r, K.col (τFun r)) = 1 := by
    intro r
    exact Classical.choose_spec (hrow_exists r)
  have hτFun_inj : Function.Injective τFun := by
    intro r₁ r₂ hτ
    exact hcol_unique (τFun r₁) r₁ r₂
      (by simpa [E, K] using hτFun_hit r₁)
      (by simpa [E, K, hτ] using hτFun_hit r₂)
  let τ : Equiv.Perm (Fin (ClosePairStrictBlock.width A B)) :=
