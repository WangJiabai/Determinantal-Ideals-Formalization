/-- The row-side cofactor exponent cannot contribute a prefix `A` diagonal
variable: its columns are the `B`-middle columns, strictly to the right of the
common prefix columns. -/
lemma closePairThm21_case1_cofactorExp_apply_A_prefix_diag_eq_zero
    (A B : MinorIndex m n t)
    (hC : Close A B)
    (L : ClosePairStrictBlock.RowLaplaceChoice A B hC)
    (σ : Equiv.Perm (Fin (ClosePairStrictBlock.width A B)))
