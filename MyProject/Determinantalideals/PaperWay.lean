        (by simpa [lower] using hjlo)
        (by simpa [upper] using hjhi)
        (by
          intro j' hjgt hjhi' hjlo'
          have hdist_lt : upper - j' < d := by
            omega
          exact
            ih (upper - j') hdist_lt j' rfl
              (by simpa [lower] using hjlo')
              (by simpa [upper] using hjhi'))
        hprevA hprevB hprevC
  intro j hN hjhi hjlo
