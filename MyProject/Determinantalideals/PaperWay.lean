lemma closePairThm21_case1_BmiddlePartExp_apply_actual_perm_of_clean_shape
    (A B : MinorIndex m n t)
    (hC : Close A B)
    (L : ClosePairStrictBlock.RowLaplaceChoice A B hC)
    (σ : Equiv.Perm (Fin (ClosePairStrictBlock.width A B)))
    (hBmiddle_apply_le_one :
      ∀ r s : Fin (ClosePairStrictBlock.width A B),
        closePairThm21_case1_BmiddlePartExp
          (m := m) (n := n) (t := t) (k := k) A B hC L σ
          ((ClosePairStrictBlock.bMiddleMinorIndex A B hC).row r,
           (ClosePairStrictBlock.bMiddleMinorIndex A B hC).col s) ≤ 1)
    (hrow_exists :
      ∀ r : Fin (ClosePairStrictBlock.width A B),
        ∃ s : Fin (ClosePairStrictBlock.width A B),
          closePairThm21_case1_BmiddlePartExp
            (m := m) (n := n) (t := t) (k := k) A B hC L σ
            ((ClosePairStrictBlock.bMiddleMinorIndex A B hC).row r,
             (ClosePairStrictBlock.bMiddleMinorIndex A B hC).col s) = 1)
    (hrow_unique :
      ∀ r s₁ s₂ : Fin (ClosePairStrictBlock.width A B),
        closePairThm21_case1_BmiddlePartExp
          (m := m) (n := n) (t := t) (k := k) A B hC L σ
          ((ClosePairStrictBlock.bMiddleMinorIndex A B hC).row r,
           (ClosePairStrictBlock.bMiddleMinorIndex A B hC).col s₁) = 1 →
        closePairThm21_case1_BmiddlePartExp
          (m := m) (n := n) (t := t) (k := k) A B hC L σ
          ((ClosePairStrictBlock.bMiddleMinorIndex A B hC).row r,
           (ClosePairStrictBlock.bMiddleMinorIndex A B hC).col s₂) = 1 →
