        (L.minorRows i)
        (ClosePairStrictBlock.aColumnPos A B hC j) =
      genericMatrix m n k (L.minorIndex.row i) (L.minorIndex.col j)
  rw [ClosePairStrictBlock.matrix_entry_of_not_zeroBlock_as_X'
    (m := m) (n := n) (t := t) (k := k) A B hC
    (ClosePairStrictBlock.not_zeroBlock_aColumnPos A B hC (L.minorRows i) j)]
