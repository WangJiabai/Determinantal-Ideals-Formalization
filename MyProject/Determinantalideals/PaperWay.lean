/-- On a `B`-middle square coordinate, the cofactor-only restricted part agrees
with the cofactor monomial exponent. -/
lemma closePairThm21_case1_BmiddleCofactorPartExp_apply_eq_cofExp
    (A B : MinorIndex m n t)
    (hC : Close A B)
    (L : ClosePairStrictBlock.RowLaplaceChoice A B hC)
    (sigma : Equiv.Perm (Fin (ClosePairStrictBlock.width A B)))
    (r s : Fin (ClosePairStrictBlock.width A B)) :
    closePairThm21_case1_BmiddleCofactorPartExp
        (m := m) (n := n) (t := t) A B hC L sigma
        ((ClosePairStrictBlock.bMiddleMinorIndex A B hC).row r,
         (ClosePairStrictBlock.bMiddleMinorIndex A B hC).col s) =
      MonomialCoefficientMatrix.permExp
        L.cofactorRow L.cofactorCol sigma
        ((ClosePairStrictBlock.bMiddleMinorIndex A B hC).row r,
         (ClosePairStrictBlock.bMiddleMinorIndex A B hC).col s) := by
  classical
  let K : MinorIndex m n (ClosePairStrictBlock.width A B) :=
    ClosePairStrictBlock.bMiddleMinorIndex A B hC
  change
    ((∑ r' : Fin (ClosePairStrictBlock.width A B),
        ∑ s' : Fin (ClosePairStrictBlock.width A B),
          Finsupp.single (K.row r', K.col s')
            (MonomialCoefficientMatrix.permExp
              L.cofactorRow L.cofactorCol sigma
              (K.row r', K.col s')))
      (K.row r, K.col s)) =
      MonomialCoefficientMatrix.permExp
        L.cofactorRow L.cofactorCol sigma (K.row r, K.col s)
  simp only [Finsupp.coe_finset_sum, Finset.sum_apply]
  rw [Finset.sum_eq_single r]
  · rw [Finset.sum_eq_single s]
    · rw [Finsupp.single_eq_same]
    · intro s' _ hs'
      have hcoord : (K.row r, K.col s') ≠ (K.row r, K.col s) := by
        intro hbad
        have hs_eq : s' = s := K.col.injective
