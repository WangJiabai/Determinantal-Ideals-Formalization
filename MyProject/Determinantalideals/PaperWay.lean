/-- Prefix induction over the Case 1 `u_i/v_i` chain. -/
lemma closePairThm21_case1_all_statements
    (ord : MonomialOrder (Fin m × Fin n))
    (hdiag : IsDiagonalTermOrder ord)
    (A B : MinorIndex m n t)
    (hC : Close A B)
    (hrowLt :
      rowExt B (uClose A B) < rowExt A (uClose A B))
    (L : ClosePairStrictBlock.RowLaplaceChoice A B hC)
    (σ : Equiv.Perm (Fin (ClosePairStrictBlock.width A B)))
    (hc :
      (closePairThm21_case1_rowTerm
        (m := m) (n := n) (t := t) (k := k) A B hC L σ).c ≠ 0)
    (hnot :
      ¬ ord.toSyn
          (closePairThm21_case1_rowTermExp
            (m := m) (n := n) (t := t) (k := k) A B hC L σ)
        <
        ord.toSyn
          (headLcm ord
            (genericMinor (k := k) A)
            (genericMinor (k := k) B)))
    (U : Case1UVChain A B hC) :
    (∀ i : Fin U.q, StatementB A B hC L U i) ∧
    (∀ i : Fin U.q, StatementC A B hC L σ U i) ∧
    (∀ i : Fin U.q, StatementA A B hC L U i) := by
  classical
  let PB : Fin U.q → Prop := fun i => StatementB A B hC L U i
  let PC : Fin U.q → Prop := fun i => StatementC A B hC L σ U i
  let PA : Fin U.q → Prop := fun i => StatementA A B hC L U i
  let P : ℕ → Prop :=
    fun N =>
      (∀ i : Fin U.q, i.1 < N → PB i) ∧
      (∀ i : Fin U.q, i.1 < N → PC i) ∧
      (∀ i : Fin U.q, i.1 < N → PA i)
  have hprefix : ∀ N : ℕ, N ≤ U.q → P N := by
    intro N hN
    induction N with
    | zero =>
        constructor
        · intro i hi
          omega
        constructor
        · intro i hi
          omega
        · intro i hi
          omega
    | succ N ih =>
        have hNlt : N < U.q := Nat.lt_of_succ_le hN
        let iN : Fin U.q := ⟨N, hNlt⟩
        have hprev : P N := ih (Nat.le_of_succ_le hN)
        rcases
          closePairThm21_case1_chain_step
            (m := m) (n := n) (t := t) (k := k)
            ord hdiag A B hC hrowLt L σ hc hnot U iN
            (by intro j hj; exact hprev.2.2 j hj)
            (by intro j hj; exact hprev.1 j hj)
            (by intro j hj; exact hprev.2.1 j hj)
          with ⟨hB, hCstmt, hA⟩
        constructor
        · intro i hi
          have hcases : i.1 < N ∨ i.1 = N := by omega
          rcases hcases with hlt | heq
          · exact hprev.1 i hlt
          · have hi' : i = iN := by
              apply Fin.ext
              exact heq
            simpa [hi'] using hB
        constructor
        · intro i hi
          have hcases : i.1 < N ∨ i.1 = N := by omega
          rcases hcases with hlt | heq
          · exact hprev.2.1 i hlt
          · have hi' : i = iN := by
              apply Fin.ext
              exact heq
            simpa [hi'] using hCstmt
        · intro i hi
          have hcases : i.1 < N ∨ i.1 = N := by omega
          rcases hcases with hlt | heq
          · exact hprev.2.2 i hlt
          · have hi' : i = iN := by
              apply Fin.ext
              exact heq
            simpa [hi'] using hA
  have hfull : P U.q := hprefix U.q le_rfl
  exact
    ⟨(by intro i; exact hfull.1 i i.2),
      (by intro i; exact hfull.2.1 i i.2),
      (by intro i; exact hfull.2.2 i i.2)⟩

