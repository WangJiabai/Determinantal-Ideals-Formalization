/-- If a raw row choice is not sortable, its selected minor determinant vanishes.

With the current definition of `Sortable`, non-sortable means exactly that the
selected minor rows repeat an actual row variable.  Since the columns are the
fixed `A`-columns, this gives two equal rows in the minor submatrix. -/
lemma rawRowLaplace_minorDet_eq_zero_of_not_sortable
    (A B : MinorIndex m n t)
    (hC : Close A B)
    (R : RawRowLaplaceChoice A B hC)
    (hbad : ¬ R.Sortable) :
    Matrix.det
      (Matrix.submatrix
        (ClosePairStrictBlock.matrix
          (m := m) (n := n) (t := t) (k := k) A B)
        R.minorRows
        (ClosePairStrictBlock.aColumnPos A B hC)) = 0 := by
  classical
  rw [RawRowLaplaceChoice.Sortable] at hbad
  rcases Function.not_injective_iff.mp hbad with ⟨i, j, hrow, hij⟩
  apply Matrix.det_zero_of_row_eq hij
  funext c
  change
    ClosePairStrictBlock.matrix
        (m := m) (n := n) (t := t) (k := k) A B
        (R.minorRows i) (ClosePairStrictBlock.aColumnPos A B hC c) =
      ClosePairStrictBlock.matrix
        (m := m) (n := n) (t := t) (k := k) A B
        (R.minorRows j) (ClosePairStrictBlock.aColumnPos A B hC c)
  rw [ClosePairStrictBlock.matrix_entry_of_not_zeroBlock_as_X'
    (m := m) (n := n) (t := t) (k := k) A B hC
    (ClosePairStrictBlock.not_zeroBlock_aColumnPos A B hC (R.minorRows i) c)]
  rw [ClosePairStrictBlock.matrix_entry_of_not_zeroBlock_as_X'
    (m := m) (n := n) (t := t) (k := k) A B hC
    (ClosePairStrictBlock.not_zeroBlock_aColumnPos A B hC (R.minorRows j) c)]
  simp [hrow]


omit [Nontrivial k] in
/-- If a raw row choice is not sortable, its raw summand vanishes.

After the new definition of `Sortable`, this means only that the selected
minor rows have repeated actual row variables.  Hence the minor determinant
factor is zero.  The cofactor rows are not involved here. -/
lemma rawRowLaplaceSummand_eq_zero_of_not_sortable
    (A B : MinorIndex m n t)
    (hC : Close A B)
    (R : RawRowLaplaceChoice A B hC)
    (hbad : ¬ R.Sortable) :
    rawRowLaplaceSummand
        (m := m) (n := n) (t := t) (k := k) A B hC R = 0 := by
  classical
  rw [rawRowLaplaceSummand]
  rw [rawRowLaplace_minorDet_eq_zero_of_not_sortable
    (m := m) (n := n) (t := t) (k := k) A B hC R hbad]
  simp


/-- Normalize a sortable raw row choice to the paper-style `RowLaplaceChoice`.

Only the selected minor rows are sorted by the actual row variables `rowFin`.
The cofactor rows stay in matrix-position order, because
`RowLaplaceChoice.cofactorRowsStrict` is a strictness condition on the
cofactor row positions, not on their actual `rowFin` variables. -/
noncomputable def rowChoiceOfSortableRaw
    (A B : MinorIndex m n t)
    (hC : Close A B)
    (R : RawRowLaplaceChoice A B hC)
    (hR : R.Sortable) :
    ClosePairStrictBlock.RowLaplaceChoice A B hC := by
  classical
  let minorRowFin : Fin t → Fin m :=
    fun i => ClosePairStrictBlock.rowFin A B hC (R.minorRows i)
  let minorSort : Equiv.Perm (Fin t) :=
    Tuple.sort minorRowFin
  let shuffle :
      Fin t ⊕ Fin (ClosePairStrictBlock.width A B) ≃
        Fin (ClosePairStrictBlock.size A B) :=
    (Equiv.sumCongr minorSort
      (Equiv.refl (Fin (ClosePairStrictBlock.width A B)))).trans R.shuffle
  refine
    { shuffle := shuffle
      minorRows := fun i => R.minorRows (minorSort i)
      cofactorRows := R.cofactorRows
      minorRows_eq_shuffle := ?_
      cofactorRows_eq_shuffle := ?_
      minorRowsStrict := ?_
      cofactorRowsStrict := ?_ }
  · intro i
    rfl
  · intro i
    rfl
  · /-
    The minor rows are sorted by actual row variables.
    Use:
      strictMono_val_comp_tuple_sort_of_injective minorRowFin hR
    -/
    intro i j hij
    have hmono :
        StrictMono (fun i : Fin t => (minorRowFin (minorSort i)).1) :=
      strictMono_val_comp_tuple_sort_of_injective minorRowFin hR
    exact hmono hij
  · /-
    Cofactor rows are NOT sorted by rowFin.  They remain position-sorted.
    This should be exactly `R.cofactorRowsPosStrict`.
    -/
    intro i j hij
    exact R.cofactorRowsPosStrict hij

@[simp] lemma rowChoiceOfSortableRaw_minorRows
    (A B : MinorIndex m n t)
    (hC : Close A B)
    (R : RawRowLaplaceChoice A B hC)
    (hR : R.Sortable)
    (i : Fin t) :
    (rowChoiceOfSortableRaw (m := m) (n := n) (t := t) A B hC R hR).minorRows i =
      R.minorRows
        (Tuple.sort
          (fun i => ClosePairStrictBlock.rowFin A B hC (R.minorRows i)) i) := by
  simp [rowChoiceOfSortableRaw]

@[simp] lemma rowChoiceOfSortableRaw_cofactorRows
    (A B : MinorIndex m n t)
    (hC : Close A B)
    (R : RawRowLaplaceChoice A B hC)
    (hR : R.Sortable)
    (i : Fin (ClosePairStrictBlock.width A B)) :
    (rowChoiceOfSortableRaw (m := m) (n := n) (t := t) A B hC R hR).cofactorRows i =
      R.cofactorRows i := by
  simp [rowChoiceOfSortableRaw]

@[simp] lemma rowChoiceOfSortableRaw_shuffle
    (A B : MinorIndex m n t)
    (hC : Close A B)
    (R : RawRowLaplaceChoice A B hC)
    (hR : R.Sortable) :
    (rowChoiceOfSortableRaw (m := m) (n := n) (t := t) A B hC R hR).shuffle =
      (Equiv.sumCongr
        (Tuple.sort
          (fun i => ClosePairStrictBlock.rowFin A B hC (R.minorRows i)))
        (Equiv.refl (Fin (ClosePairStrictBlock.width A B)))).trans R.shuffle := by
  simp [rowChoiceOfSortableRaw]

lemma rowLaplacePerm_rowChoiceOfSortableRaw
    (A B : MinorIndex m n t)
    (hC : Close A B)
    (R : RawRowLaplaceChoice A B hC)
    (hR : R.Sortable)
    (τ : Equiv.Perm (Fin t))
    (σ : Equiv.Perm (Fin (ClosePairStrictBlock.width A B))) :
    ClosePairStrictBlock.rowLaplacePerm A B hC
        (rowChoiceOfSortableRaw
          (m := m) (n := n) (t := t) A B hC R hR)
        τ σ =
      rawRowLaplacePerm A B hC R
        (τ.trans
          (Tuple.sort
            (fun i => ClosePairStrictBlock.rowFin A B hC (R.minorRows i))))
        σ := by
  ext x
  simp [ClosePairStrictBlock.rowLaplacePerm, rawRowLaplacePerm, rowChoiceOfSortableRaw,
    RawRowLaplaceChoice.minorRows]

/-- Forget a `RowLaplaceChoice` back to a position-sorted raw row choice.

The minor rows of a `RowLaplaceChoice` are sorted by actual row variables,
so we sort them back by matrix position to obtain a `RawRowLaplaceChoice`.
The cofactor rows are already position-sorted and are kept unchanged. -/
noncomputable def rawChoiceOfRowChoice
    (A B : MinorIndex m n t)
    (hC : Close A B)
    (L : ClosePairStrictBlock.RowLaplaceChoice A B hC) :
    RawRowLaplaceChoice A B hC := by
  classical
  let minorPosSort : Equiv.Perm (Fin t) :=
    Tuple.sort L.minorRows
  let shuffle :
      Fin t ⊕ Fin (ClosePairStrictBlock.width A B) ≃
        Fin (ClosePairStrictBlock.size A B) :=
    (Equiv.sumCongr minorPosSort
      (Equiv.refl (Fin (ClosePairStrictBlock.width A B)))).trans L.shuffle
  refine
    { shuffle := shuffle
      minorRowsPosStrict := ?_
      cofactorRowsPosStrict := ?_ }
  · /-
    Sorting `L.minorRows` by matrix position makes the raw minor rows
    position-strict.
    Need injectivity of `L.minorRows`, which follows from `L.shuffle`.
    -/
    have hminorInj : Function.Injective L.minorRows := by
      intro i j hij
      have h :
          L.shuffle (Sum.inl i) = L.shuffle (Sum.inl j) := by
        simpa [ClosePairStrictBlock.RowLaplaceChoice.minorRows_eq_shuffle] using hij
      exact Sum.inl_injective (L.shuffle.injective h)
    simpa [shuffle, minorPosSort, ClosePairStrictBlock.RowLaplaceChoice.minorRows_eq_shuffle]
      using strictMono_val_comp_tuple_sort_of_injective L.minorRows hminorInj
  · /-
    Cofactor rows are already position-strict in `RowLaplaceChoice`.
    -/
    intro i j hij
    simpa [shuffle, L.cofactorRows_eq_shuffle] using
      L.cofactorRowsStrict hij

lemma rawChoiceOfRowChoice_sortable
    (A B : MinorIndex m n t)
    (hC : Close A B)
    (L : ClosePairStrictBlock.RowLaplaceChoice A B hC) :
    (rawChoiceOfRowChoice (m := m) (n := n) (t := t) A B hC L).Sortable := by
  classical
  /-
  Because `L.minorRowsStrict` says the actual row variables of `L.minorRows`
  are strictly increasing, hence injective.  Composing with `minorPosSort`
  preserves injectivity.
  -/
  rw [RawRowLaplaceChoice.Sortable]
  intro i j hij
  apply (Tuple.sort L.minorRows).injective
  apply L.minorRowsStrict.injective
  change
      ClosePairStrictBlock.rowFin A B hC
          ((rawChoiceOfRowChoice (m := m) (n := n) (t := t) A B hC L).shuffle
            (Sum.inl i)) =
        ClosePairStrictBlock.rowFin A B hC
          ((rawChoiceOfRowChoice (m := m) (n := n) (t := t) A B hC L).shuffle
            (Sum.inl j)) at hij
  simp only [rawChoiceOfRowChoice, Equiv.trans_apply, Equiv.sumCongr_apply, Equiv.coe_refl,
    Sum.map_inl] at hij
  rw [← L.minorRows_eq_shuffle ((Tuple.sort L.minorRows) i),
    ← L.minorRows_eq_shuffle ((Tuple.sort L.minorRows) j)] at hij
  exact hij

omit [Nontrivial k] in
/-- The normalized row choice has the same Laplace summand as the original
sortable raw row choice. -/
lemma rawRowLaplaceSummand_eq_strictRowLaplaceSummand_of_sortable
    (A B : MinorIndex m n t)
    (hC : Close A B)
    (R : RawRowLaplaceChoice A B hC)
    (hR : R.Sortable) :
    rawRowLaplaceSummand
        (m := m) (n := n) (t := t) (k := k) A B hC R =
      strictRowLaplaceSummand
        (m := m) (n := n) (t := t) (k := k) A B hC
        (rowChoiceOfSortableRaw
          (m := m) (n := n) (t := t) A B hC R hR) := by
  classical
  let L : ClosePairStrictBlock.RowLaplaceChoice A B hC :=
    rowChoiceOfSortableRaw (m := m) (n := n) (t := t) A B hC R hR
  let s : Equiv.Perm (Fin t) :=
    Tuple.sort
      (fun i => ClosePairStrictBlock.rowFin A B hC (R.minorRows i))
  let detTerm : Equiv.Perm (Fin (ClosePairStrictBlock.size A B)) →
      MvPolynomial (Fin m × Fin n) k :=
    fun ρ =>
      ClosePairStrictBlock.laplaceShuffleSign
          (k := MvPolynomial (Fin m × Fin n) k) ρ *
        ∏ j : Fin (ClosePairStrictBlock.size A B),
          ClosePairStrictBlock.matrix
            (m := m) (n := n) (t := t) (k := k) A B (ρ j) j
  rw [rawRowLaplaceSummand_eq_sum_rawRowLaplacePerm_terms
    (m := m) (n := n) (t := t) (k := k) A B hC R]
  rw [strictRowLaplaceSummand_eq_sum_rowLaplacePerm_terms
    (m := m) (n := n) (t := t) (k := k) A B hC L]
  change
    (∑ p : Equiv.Perm (Fin t) ×
        Equiv.Perm (Fin (ClosePairStrictBlock.width A B)),
      detTerm (rawRowLaplacePerm A B hC R p.1 p.2)) =
    ∑ p : Equiv.Perm (Fin t) ×
        Equiv.Perm (Fin (ClosePairStrictBlock.width A B)),
      detTerm (ClosePairStrictBlock.rowLaplacePerm A B hC L p.1 p.2)
  let e :
      (Equiv.Perm (Fin t) ×
        Equiv.Perm (Fin (ClosePairStrictBlock.width A B))) ≃
      (Equiv.Perm (Fin t) ×
        Equiv.Perm (Fin (ClosePairStrictBlock.width A B))) :=
    { toFun := fun p => (p.1.trans s.symm, p.2)
      invFun := fun p => (p.1.trans s, p.2)
      left_inv := by
        intro p
        cases p with
        | mk τ σ =>
            apply Prod.ext
            · ext i
              simp [s]
            · rfl
      right_inv := by
        intro p
        cases p with
        | mk τ σ =>
            apply Prod.ext
            · ext i
              simp [s]
            · rfl }
  calc
    (∑ p : Equiv.Perm (Fin t) ×
        Equiv.Perm (Fin (ClosePairStrictBlock.width A B)),
      detTerm (rawRowLaplacePerm A B hC R p.1 p.2))
        =
      ∑ p : Equiv.Perm (Fin t) ×
          Equiv.Perm (Fin (ClosePairStrictBlock.width A B)),
        detTerm (ClosePairStrictBlock.rowLaplacePerm A B hC L
          (p.1.trans s.symm) p.2) := by
        refine Finset.sum_congr rfl ?_
        intro p _hp
        have hτ : (p.1.trans s.symm).trans s = p.1 := by
          ext i
          simp [s]
        have hperm :
            ClosePairStrictBlock.rowLaplacePerm A B hC L
                (p.1.trans s.symm) p.2 =
              rawRowLaplacePerm A B hC R p.1 p.2 := by
          rw [show L =
              rowChoiceOfSortableRaw
                (m := m) (n := n) (t := t) A B hC R hR from rfl]
          rw [rowLaplacePerm_rowChoiceOfSortableRaw
            (m := m) (n := n) (t := t) A B hC R hR
            (p.1.trans s.symm) p.2]
          simpa [s] using congrArg
            (fun τ' => rawRowLaplacePerm A B hC R τ' p.2) hτ
        rw [hperm]
    _ =
      ∑ p : Equiv.Perm (Fin t) ×
          Equiv.Perm (Fin (ClosePairStrictBlock.width A B)),
        detTerm (ClosePairStrictBlock.rowLaplacePerm A B hC L p.1 p.2) := by
        exact Fintype.sum_equiv e
          (fun p =>
            detTerm (ClosePairStrictBlock.rowLaplacePerm A B hC L
              (p.1.trans s.symm) p.2))
          (fun p =>
            detTerm (ClosePairStrictBlock.rowLaplacePerm A B hC L p.1 p.2))
          (by intro p; rfl)

/-- Sortable raw row choices are equivalent to `RowLaplaceChoice`.

Here `Sortable` only means that the minor rows have pairwise distinct actual
row variables.  Cofactor rows are kept in matrix-position order on both sides. -/
noncomputable def sortableRawRowChoiceEquivRowChoice
    (A B : MinorIndex m n t)
    (hC : Close A B) :
    {R : RawRowLaplaceChoice A B hC // R.Sortable} ≃
      ClosePairStrictBlock.RowLaplaceChoice A B hC := by
  classical
  refine
    { toFun := fun R =>
        rowChoiceOfSortableRaw
          (m := m) (n := n) (t := t) A B hC R.1 R.2
      invFun := fun L =>
        ⟨rawChoiceOfRowChoice
            (m := m) (n := n) (t := t) A B hC L,
          rawChoiceOfRowChoice_sortable
            (m := m) (n := n) (t := t) A B hC L⟩
      left_inv := ?_
      right_inv := ?_ }
  · /-
    Need sorting uniqueness twice:
    * raw -> row choice sorts minor rows by rowFin;
    * then row choice -> raw sorts those rows back by matrix position.

    Cofactor rows are unchanged throughout.
    -/
    intro R
    cases R with
    | mk R hR =>
      let minorRowFin : Fin t → Fin m :=
        fun i => ClosePairStrictBlock.rowFin A B hC (R.minorRows i)
      let minorSort : Equiv.Perm (Fin t) := Tuple.sort minorRowFin
      have hposSort :
          Tuple.sort
              (rowChoiceOfSortableRaw
                (m := m) (n := n) (t := t) A B hC R hR).minorRows =
            minorSort.symm := by
        apply tuple_sort_eq_of_strictMono_val_comp
        intro i j hij
        change
          (R.minorRows (minorSort (minorSort.symm i))).1 <
            (R.minorRows (minorSort (minorSort.symm j))).1
        simpa using R.minorRowsPosStrict hij
      apply Subtype.ext
      apply RawRowLaplaceChoice.ext_shuffle
      simp only [rawChoiceOfRowChoice]
      rw [hposSort]
      rw [rowChoiceOfSortableRaw_shuffle
        (m := m) (n := n) (t := t) A B hC R hR]
      ext x
      cases x with
      | inl i =>
          simp only [Equiv.trans_apply, Equiv.sumCongr_apply, Equiv.coe_refl,
            Sum.map_inl]
          have hs :
              (Tuple.sort
                (fun i => ClosePairStrictBlock.rowFin A B hC (R.minorRows i)))
                  (minorSort.symm i) = i := by
            change minorSort (minorSort.symm i) = i
            simp
          rw [hs]
      | inr i =>
          simp
  · /-
    Similar: row choice -> raw sorts by position, then raw -> row choice
    sorts by rowFin, recovering the original `RowLaplaceChoice`.
    Cofactor rows are unchanged.
    -/
    intro L
    let R : RawRowLaplaceChoice A B hC :=
      rawChoiceOfRowChoice (m := m) (n := n) (t := t) A B hC L
    let hR : R.Sortable :=
      rawChoiceOfRowChoice_sortable
        (m := m) (n := n) (t := t) A B hC L
    let minorPosSort : Equiv.Perm (Fin t) := Tuple.sort L.minorRows
    have hrowSort :
        Tuple.sort
            (fun i : Fin t =>
              ClosePairStrictBlock.rowFin A B hC (R.minorRows i)) =
          minorPosSort.symm := by
      apply tuple_sort_eq_of_strictMono_val_comp
      intro i j hij
      have hi : R.minorRows (minorPosSort.symm i) = L.minorRows i := by
        simpa [R, rawChoiceOfRowChoice, RawRowLaplaceChoice.minorRows,
          minorPosSort] using (L.minorRows_eq_shuffle i).symm
      have hj : R.minorRows (minorPosSort.symm j) = L.minorRows j := by
        simpa [R, rawChoiceOfRowChoice, RawRowLaplaceChoice.minorRows,
          minorPosSort] using (L.minorRows_eq_shuffle j).symm
      simpa [hi, hj] using L.minorRowsStrict hij
    apply ClosePairStrictBlock.RowLaplaceChoice.ext_data
    · change
        (rowChoiceOfSortableRaw
          (m := m) (n := n) (t := t) A B hC R hR).shuffle = L.shuffle
      rw [rowChoiceOfSortableRaw_shuffle
        (m := m) (n := n) (t := t) A B hC R hR]
      rw [hrowSort]
      ext x
      cases x with
      | inl i =>
          simp [R, rawChoiceOfRowChoice, minorPosSort]
      | inr i =>
          simp [R, rawChoiceOfRowChoice]
    · funext i
      change
        (rowChoiceOfSortableRaw
          (m := m) (n := n) (t := t) A B hC R hR).minorRows i =
          L.minorRows i
      rw [rowChoiceOfSortableRaw_minorRows
        (m := m) (n := n) (t := t) A B hC R hR i]
      rw [hrowSort]
      simpa [R, rawChoiceOfRowChoice, RawRowLaplaceChoice.minorRows,
        minorPosSort] using (L.minorRows_eq_shuffle i).symm
    · funext i
      change
        (rowChoiceOfSortableRaw
          (m := m) (n := n) (t := t) A B hC R hR).cofactorRows i =
          L.cofactorRows i
      rw [rowChoiceOfSortableRaw_cofactorRows
        (m := m) (n := n) (t := t) A B hC R hR i]
      simpa [R, rawChoiceOfRowChoice, RawRowLaplaceChoice.cofactorRows]
        using (L.cofactorRows_eq_shuffle i).symm

