          omega⟩ : Fin t) := by
    exact Fin.mk_lt_mk.mpr (by omega)
  have hAiBi : A.col i = B.col i := by
    have hpEq :
        pairExt A (i.1 + 1) = pairExt B (i.1 + 1) := by
      exact pairExt_eq_of_mu_eq_right_le_s A B hC.ne hC.mu_eq_right (by omega) (by omega)
    have hi₂ : i.1 + 1 ≤ t := by omega
    rw [EndpointSelection.pairExt_endpoint (I := A) (by omega) hi₂,
      EndpointSelection.pairExt_endpoint (I := B) (by omega) hi₂] at hpEq
    have hcolNat := congrArg Prod.snd hpEq
    apply Fin.ext
    simp at hcolNat
    omega
  have hBstrict :
      B.col i <
        B.col
          ⟨sClose A B + j.1, by
            have hj : j.1 < uClose A B - sClose A B := by
              simp [ClosePairStrictBlock.width]
            have hu : uClose A B ≤ t :=
              le_trans (uClose_le_pClose A B hC.ne) (pClose_le A B)
            omega⟩ :=
    B.col.strictMono hidx_lt
  have hBeq :
      B.col
          ⟨sClose A B + j.1, by
            have hj : j.1 < uClose A B - sClose A B := by
              simp [ClosePairStrictBlock.width]
            have hu : uClose A B ≤ t :=
              le_trans (uClose_le_pClose A B hC.ne) (pClose_le A B)
            omega⟩ =
        B.col i := by
    exact hcol.trans hAiBi
  exact (ne_of_gt hBstrict) hBeq

