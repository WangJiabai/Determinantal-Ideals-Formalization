      (ClosePairStrictBlock.bMiddlePos A B hC i).1 <
        (ClosePairStrictBlock.bMiddlePos A B hC j).1
    simp [ClosePairStrictBlock.bMiddlePos]
    have hij' : i.1 < j.1 := by
      simpa using hij
    omega
