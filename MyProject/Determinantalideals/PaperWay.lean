    (m := m) (n := n) (t := t) (k := k) A B hC]


lemma closePairThm21_equal_sPolynomial_eq_rawPolySum
    (ord : MonomialOrder (Fin m × Fin n))
    (hdiag : IsDiagonalTermOrder ord)
    (A B : MinorIndex m n t)
    (hC : Close A B) :
    ord.sPolynomial (genericMinor (k := k) A) (genericMinor (k := k) B) =
      ClosePairStrictBlock.StrictLaplaceRawIndex.rawPolySum
        (m := m) (n := n) (t := t) (k := k) A B hC := by
  classical
  have hsp :
      ord.sPolynomial (genericMinor (k := k) A) (genericMinor (k := k) B) =
        strictBDiagPart (m := m) (n := n) (t := t) (k := k) A B hC -
        strictCDiagPart (m := m) (n := n) (t := t) (k := k) A B hC :=
    closePair_sPolynomial_eq_diag_parts_of_close
      (m := m) (n := n) (t := t) (k := k) ord hdiag A B hC
  have hrow :
      ClosePairStrictBlock.det
          (m := m) (n := n) (t := t) (k := k) A B =
        strictBDiagPart (m := m) (n := n) (t := t) (k := k) A B hC -
        ClosePairStrictBlock.StrictLaplaceRawIndex.bTailPartSum
          (m := m) (n := n) (t := t) (k := k) A B hC -
        ClosePairStrictBlock.StrictLaplaceRawIndex.rowPartSum
          (m := m) (n := n) (t := t) (k := k) A B hC :=
    strict_row_laplace_expansion_signed_parts
      (m := m) (n := n) (t := t) (k := k) A B hC
  have hcol :
      ClosePairStrictBlock.det
          (m := m) (n := n) (t := t) (k := k) A B =
        strictCDiagPart (m := m) (n := n) (t := t) (k := k) A B hC +
        ClosePairStrictBlock.StrictLaplaceRawIndex.cTailPartSum
          (m := m) (n := n) (t := t) (k := k) A B hC +
        ClosePairStrictBlock.StrictLaplaceRawIndex.colPartSum
          (m := m) (n := n) (t := t) (k := k) A B hC :=
    strict_col_laplace_expansion_signed_parts
      (m := m) (n := n) (t := t) (k := k) A B hC
  have hfour :
      ord.sPolynomial (genericMinor (k := k) A) (genericMinor (k := k) B) =
        ClosePairStrictBlock.StrictLaplaceRawIndex.colPartSum
          (m := m) (n := n) (t := t) (k := k) A B hC +
        ClosePairStrictBlock.StrictLaplaceRawIndex.rowPartSum
          (m := m) (n := n) (t := t) (k := k) A B hC +
        ClosePairStrictBlock.StrictLaplaceRawIndex.cTailPartSum
          (m := m) (n := n) (t := t) (k := k) A B hC +
        ClosePairStrictBlock.StrictLaplaceRawIndex.bTailPartSum
          (m := m) (n := n) (t := t) (k := k) A B hC := by
    exact
      strict_four_part_identity_of_signed_laplace
        (P := MvPolynomial (Fin m × Fin n) k)
        (sPoly :=
          ord.sPolynomial (genericMinor (k := k) A) (genericMinor (k := k) B))
        (detM :=
          ClosePairStrictBlock.det
            (m := m) (n := n) (t := t) (k := k) A B)
        (bDiag :=
          strictBDiagPart (m := m) (n := n) (t := t) (k := k) A B hC)
        (cDiag :=
          strictCDiagPart (m := m) (n := n) (t := t) (k := k) A B hC)
        (rowPart :=
          ClosePairStrictBlock.StrictLaplaceRawIndex.rowPartSum
            (m := m) (n := n) (t := t) (k := k) A B hC)
        (colPart :=
          ClosePairStrictBlock.StrictLaplaceRawIndex.colPartSum
            (m := m) (n := n) (t := t) (k := k) A B hC)
        (bTailPart :=
          ClosePairStrictBlock.StrictLaplaceRawIndex.bTailPartSum
            (m := m) (n := n) (t := t) (k := k) A B hC)
        (cTailPart :=
          ClosePairStrictBlock.StrictLaplaceRawIndex.cTailPartSum
            (m := m) (n := n) (t := t) (k := k) A B hC)
        hsp hrow hcol
  calc
    ord.sPolynomial (genericMinor (k := k) A) (genericMinor (k := k) B)
        =
      ClosePairStrictBlock.StrictLaplaceRawIndex.colPartSum
        (m := m) (n := n) (t := t) (k := k) A B hC +
      ClosePairStrictBlock.StrictLaplaceRawIndex.rowPartSum
        (m := m) (n := n) (t := t) (k := k) A B hC +
      ClosePairStrictBlock.StrictLaplaceRawIndex.cTailPartSum
        (m := m) (n := n) (t := t) (k := k) A B hC +
      ClosePairStrictBlock.StrictLaplaceRawIndex.bTailPartSum
        (m := m) (n := n) (t := t) (k := k) A B hC := hfour
    _ =
      ClosePairStrictBlock.StrictLaplaceRawIndex.rawPolySum
        (m := m) (n := n) (t := t) (k := k) A B hC :=
      (strict_rawPolySum_eq_four_part_sums
        (m := m) (n := n) (t := t) (k := k) A B hC).symm


/-- Equality case, column-expansion non-principal term.

This is the column part of the paper's final displayed equality-case formula.
After `width = 1`, the cofactor determinant contributes a single variable, and
a direct exponent inspection shows that the term is strictly below the endpoint
lcm. -/
lemma closePairThm21_equal_colTerm_small
    (ord : MonomialOrder (Fin m × Fin n))
    (hdiag : IsDiagonalTermOrder ord)
    (A B : MinorIndex m n t)
    (hC : Close A B)
    (hrowEq :
      rowExt B (uClose A B) = rowExt A (uClose A B))
    (L : ClosePairStrictBlock.ColLaplaceChoice A B hC)
    (σ : Equiv.Perm (Fin (ClosePairStrictBlock.width A B)))
    (hL : L ≠ ClosePairStrictBlock.colPrincipalChoice A B hC)
    (hc :
      (closePairThm21_case2_colTerm
        (m := m) (n := n) (t := t) (k := k) A B hC L σ).c ≠ 0) :
    ∀ a : k, a ≠ 0 →
      ord.toSyn
        (ord.degree
          (MvPolynomial.monomial
            (closePairThm21_case2_colTerm
              (m := m) (n := n) (t := t) (k := k) A B hC L σ).d
            a *
            genericMinor (k := k)
              (closePairThm21_case2_colTerm
                (m := m) (n := n) (t := t) (k := k) A B hC L σ).K))
