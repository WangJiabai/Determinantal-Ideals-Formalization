        have hb := ClosePairStrictBlock.tail_index_bounds A B hC htail q.2
        omega⟩
    have hqrow :
        ClosePairStrictBlock.rowFin A B hC q = A.row qidx := by
      apply Fin.ext
      change rowCoord A B q.1 - 1 = (A.row qidx).1
      rw [ClosePairStrictBlock.rowCoord_of_tail A B hC htail]
      rw [EndpointSelection.rowExt_endpoint (I := A)
        (by
          have hb := ClosePairStrictBlock.tail_index_bounds A B hC htail q.2
          omega)
        (by
          have hb := ClosePairStrictBlock.tail_index_bounds A B hC htail q.2
          omega)]
      have hidx :
          (⟨q.1 + 1 - ClosePairStrictBlock.width A B - 1, by
            have hb := ClosePairStrictBlock.tail_index_bounds A B hC htail q.2
            omega⟩ : Fin t) = qidx := by
        apply Fin.ext
        simp [qidx]
        have hb := ClosePairStrictBlock.tail_index_bounds A B hC htail q.2
        omega
      rw [hidx]
      omega
    have hidx_eq : qidx = i := by
      apply A.row.injective
      exact hqrow.symm.trans hrow
    apply Fin.ext
    rw [ClosePairStrictBlock.aColumnPos_of_tail A B hC hnotPre_i hnotMid_i]
    have hval := congrArg Fin.val hidx_eq
    simp [qidx] at hval
    omega

