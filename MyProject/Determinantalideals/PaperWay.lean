  classical
  unfold MonomialCoefficientMatrix.permExp
  simp only [Finsupp.coe_finset_sum, Finset.sum_apply]
  refine Finset.sum_eq_zero ?_
  intro j _hj
  rw [Finsupp.single_apply]
  apply if_neg
  intro hp
  have hcol :
      ClosePairStrictBlock.colFin A B hC
          (ClosePairStrictBlock.bMiddlePos A B hC j) =
        A.col i := by
    simpa [ClosePairStrictBlock.RowLaplaceChoice.cofactorCol] using congrArg Prod.snd hp
  rw [ClosePairStrictBlock.colFin_bMiddlePos A B hC j] at hcol
  have hidx_lt :
      i <
        (⟨sClose A B + j.1, by
          have hj : j.1 < uClose A B - sClose A B := by
            simp [ClosePairStrictBlock.width]
          have hu : uClose A B ≤ t :=
