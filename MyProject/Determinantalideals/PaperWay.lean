/-- The `t × t` submatrix cut out by a row-side Laplace choice and the
fixed `A`-columns is the generic minor matrix attached to `L.minorIndex`. -/
lemma rowLaplaceChoice_minorSubmatrix_eq_genericMinor_matrix
    (A B : MinorIndex m n t)
    (hC : Close A B)
    (L : ClosePairStrictBlock.RowLaplaceChoice A B hC) :
    Matrix.submatrix
        (ClosePairStrictBlock.matrix
          (m := m) (n := n) (t := t) (k := k) A B)
