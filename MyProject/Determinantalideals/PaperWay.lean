lemma rowFin_bMiddlePos_injective
    (A B : MinorIndex m n t)
    (hC : Close A B) :
    Function.Injective
      (fun i : Fin (width A B) => rowFin A B hC (bMiddlePos A B hC i)) := by
  intro i j hij
  change rowFin A B hC (bMiddlePos A B hC i) =
    rowFin A B hC (bMiddlePos A B hC j) at hij
  rw [rowFin_bMiddlePos A B hC i, rowFin_bMiddlePos A B hC j] at hij
  have hidx := B.row.injective hij
  apply Fin.ext
  have hval := congrArg Fin.val hidx
  simpa using hval

lemma rowFin_aRepeatedMiddlePos_injective
    (A B : MinorIndex m n t)
