import Mathlib
import MyProject.Determinantalideals.Ideal
import MyProject.Determinantalideals.MinorTerms
import MyProject.Determinantalideals.DiagonalOrder
import Groebner.Groebner
import Groebner.Remainder
import Groebner.Ideal

namespace Determinantal

section paper3_1

open scoped BigOperators

variable {σ : Type*} {R : Type*}
variable [CommRing R]
variable (m : MonomialOrder σ)

/-
  This section formalizes Definition 3.1 of the paper in the special case r = 1,
  i.e. for ideals in `MvPolynomial σ R`.

  The paper's ambient object is a submodule U ⊆ P^r.
  Here we specialize to the ideal case:
    U = I ⊆ P = MvPolynomial σ R.
-/

/-- One summand `c * φ * G_i` in a paper-style Gröbner representation. -/
structure PaperRepTerm (G : Set (MvPolynomial σ R)) where
  coeff : R
  coeff_ne_zero : coeff ≠ 0
  mono : σ →₀ ℕ
  g : G

namespace PaperRepTerm

/-- Interpret one representation term as an actual polynomial. -/
noncomputable def toPolynomial {G : Set (MvPolynomial σ R)}
    (t : PaperRepTerm (R := R) G) : MvPolynomial σ R :=
  MvPolynomial.monomial t.mono t.coeff * (t.g : MvPolynomial σ R)

end PaperRepTerm

/--
The order condition appearing in Definition 3.1:
the head term of one summand is strictly larger than the next one.

In the `r = 1` specialization, we encode this by comparing the leading degrees
of the corresponding summand-polynomials.
-/
def PaperRepTerm.HeadGT {G : Set (MvPolynomial σ R)}
    (t₁ t₂ : PaperRepTerm (R := R) G) : Prop :=
  m.toSyn (m.degree (PaperRepTerm.toPolynomial t₂)) <
    m.toSyn (m.degree (PaperRepTerm.toPolynomial t₁))

/--
A paper-style Gröbner representation of `f` with respect to `G`
(Definition 3.1, specialized to the ideal case).

Concretely:
* `f` is written as a finite sum of terms `c_i * monomial φ_i * G_i`,
* and the leading heads of the summands strictly decrease from left to right.
-/
def IsPaperGroebnerRepresentation
    (G : Set (MvPolynomial σ R)) (f : MvPolynomial σ R) : Prop :=
  ∃ l : List (PaperRepTerm (R := R) G),
    f = (l.map PaperRepTerm.toPolynomial).sum ∧
    l.IsChain (PaperRepTerm.HeadGT (m := m))

/--
Definition 3.1 of the paper, specialized to the ideal case (`r = 1`).

That is, `G` is a Gröbner basis of the ideal `I` if:
* `G ⊆ I`, and
* every nonzero `f ∈ I` admits a paper-style Gröbner representation by `G`.
-/
def IsGroebnerBasis_paper3_1
    (G : Set (MvPolynomial σ R))
    (I : Ideal (MvPolynomial σ R)) : Prop :=
  G ⊆ I ∧
    ∀ ⦃f : MvPolynomial σ R⦄,
      f ∈ I → f ≠ 0 → IsPaperGroebnerRepresentation (m := m) G f

/-- If `g ∈ G`, then `leadingTerm g` belongs to the ideal generated by the
leading terms of elements of `G`. -/
lemma leadingTerm_mem_span_of_mem_G
    {G : Set (MvPolynomial σ R)}
    {g : MvPolynomial σ R}
    (hg : g ∈ G) :
    m.leadingTerm g ∈ Ideal.span (m.leadingTerm '' G) := by
  exact Ideal.subset_span ⟨g, hg, rfl⟩

/-- The ideal generated by leading terms of `G` is closed under multiplication
by a monomial polynomial on the left. -/
lemma monomial_mul_mem_span_of_leadingTerm_mem_span
    {G : Set (MvPolynomial σ R)}
    {d : σ →₀ ℕ} {c : R} {p : MvPolynomial σ R}
    (hp : p ∈ Ideal.span (m.leadingTerm '' G)) :
    MvPolynomial.monomial d c * p ∈ Ideal.span (m.leadingTerm '' G) := by
  simpa using (Ideal.span (m.leadingTerm '' G)).mul_mem_left (MvPolynomial.monomial d c) hp

/-- If one already knows the expected leading-term formula for a representation
summand `c * X^d * g`, then its leading term lies in `span (leadingTerm '' G)`. -/
lemma leadingTerm_mem_span_of_repTerm_of_formula
    {G : Set (MvPolynomial σ R)}
    (t : PaperRepTerm (R := R) G)
    (hformula :
      m.leadingTerm (PaperRepTerm.toPolynomial t) =
        MvPolynomial.monomial t.mono t.coeff *
          m.leadingTerm (t.g : MvPolynomial σ R)) :
    m.leadingTerm (PaperRepTerm.toPolynomial t) ∈
      Ideal.span (m.leadingTerm '' G) := by
  rw [hformula]
  exact monomial_mul_mem_span_of_leadingTerm_mem_span
    (m := m)
    (leadingTerm_mem_span_of_mem_G (m := m) t.g.property)

/-- Coefficient-sensitive step:
the leading term of one explicit summand `c * X^d * g`.

This is the place where, in practice, one often wants stronger assumptions
such as `NoZeroDivisors R` or a field assumption. -/
lemma leadingTerm_toPolynomial_formula
    [NoZeroDivisors R]
    {G : Set (MvPolynomial σ R)}
    (t : PaperRepTerm (R := R) G) :
    m.leadingTerm (PaperRepTerm.toPolynomial t) =
      MvPolynomial.monomial t.mono t.coeff *
        m.leadingTerm (t.g : MvPolynomial σ R) := by
  classical
  by_cases hg : (t.g : MvPolynomial σ R) = 0
  · simp [PaperRepTerm.toPolynomial, hg]
  · have hmono :
        MvPolynomial.monomial t.mono t.coeff ≠ (0 : MvPolynomial σ R) := by
      simpa using (MvPolynomial.monomial_eq_zero (s := t.mono)).not.mpr t.coeff_ne_zero
    rw [PaperRepTerm.toPolynomial, MonomialOrder.leadingTerm]
    rw [m.degree_mul hmono hg]
    simp [MonomialOrder.leadingTerm, MvPolynomial.monomial_mul, m.degree_monomial,
      t.coeff_ne_zero]

/-- If a paper representation evaluates to a nonzero polynomial, then the list
of summands is nonempty. -/
lemma paperRep_list_ne_nil_of_ne_zero
    {G : Set (MvPolynomial σ R)}
    {f : MvPolynomial σ R}
    {l : List (PaperRepTerm (R := R) G)}
    (hf : f ≠ 0)
    (hsum : f = (l.map PaperRepTerm.toPolynomial).sum) :
    l ≠ [] := by
  intro hl
  have : f = 0 := by
    simpa [hl] using hsum
  exact hf this

namespace PaperRepTerm

/-- The degree-comparison form of `HeadGT`. This is the form directly consumed by
mathlib's `degree_add_of_lt` / `leadingCoeff_add_of_lt`. -/
def HeadLT
    {G : Set (MvPolynomial σ R)}
    (t₁ t₂ : PaperRepTerm (R := R) G) : Prop :=
  m.toSyn (m.degree (PaperRepTerm.toPolynomial t₁)) <
    m.toSyn (m.degree (PaperRepTerm.toPolynomial t₂))

end PaperRepTerm

/-- If `q` has strictly smaller degree than `p`,
then adding `q` does not change the leading term. -/
lemma leadingTerm_add_eq_left_of_lt
    {p q : MvPolynomial σ R}
    (h : m.toSyn (m.degree q) < m.toSyn (m.degree p)) :
    m.leadingTerm (p + q) = m.leadingTerm p := by
  apply (m.leadingTerm_eq_leadingTerm_iff).2
  exact ⟨m.leadingCoeff_add_of_lt h, m.degree_add_of_lt h⟩

/-- Equality of leading terms implies equality of degrees. -/
lemma degree_eq_of_leadingTerm_eq
    {p q : MvPolynomial σ R}
    (h : m.leadingTerm p = m.leadingTerm q) :
    m.degree p = m.degree q := by
  exact (m.leadingTerm_eq_leadingTerm_iff).1 h |>.2

/-- Equality of leading terms implies equality of leading coefficients. -/
lemma leadingCoeff_eq_of_leadingTerm_eq
    {p q : MvPolynomial σ R}
    (h : m.leadingTerm p = m.leadingTerm q) :
    m.leadingCoeff p = m.leadingCoeff q := by
  exact (m.leadingTerm_eq_leadingTerm_iff).1 h |>.1

/-- Base case: the sum of a singleton list has the same leading term as its only element. -/
lemma leadingTerm_eq_leadingTerm_head_singleton
    {G : Set (MvPolynomial σ R)}
    (t : PaperRepTerm (R := R) G) :
    m.leadingTerm ((List.map PaperRepTerm.toPolynomial [t]).sum) =
      m.leadingTerm (PaperRepTerm.toPolynomial t) := by
  simp

/-- A useful extraction lemma from a `Chain'`: the first adjacent comparison. -/
lemma headLT_of_chain_cons_cons
    {G : Set (MvPolynomial σ R)}
    {t₁ t₂ : PaperRepTerm (R := R) G}
    {ts : List (PaperRepTerm (R := R) G)}
    (hchain : (t₁ :: t₂ :: ts).IsChain (PaperRepTerm.HeadGT (m := m))) :
    PaperRepTerm.HeadLT (m := m) t₂ t₁ := by
  simpa [PaperRepTerm.HeadGT, PaperRepTerm.HeadLT] using
    (List.isChain_cons_cons.mp hchain).1

/-- The tail of a chained list is again chained. -/
lemma chain_tail_of_chain_cons_cons
    {G : Set (MvPolynomial σ R)}
    {t₁ t₂ : PaperRepTerm (R := R) G}
    {ts : List (PaperRepTerm (R := R) G)}
    (hchain : (t₁ :: t₂ :: ts).IsChain (PaperRepTerm.HeadGT (m := m))) :
    (t₂ :: ts).IsChain (PaperRepTerm.HeadGT (m := m)) := by
  exact (List.isChain_cons_cons.mp hchain).2

/-- Every tail element in a strictly descending chain is strictly below the head. -/
lemma tail_terms_lt_head_of_chain
    {G : Set (MvPolynomial σ R)}
    (t : PaperRepTerm (R := R) G)
    (ts : List (PaperRepTerm (R := R) G))
    (hchain : (t :: ts).IsChain (PaperRepTerm.HeadGT (m := m))) :
    ∀ s ∈ ts,
      m.toSyn (m.degree (PaperRepTerm.toPolynomial s)) <
        m.toSyn (m.degree (PaperRepTerm.toPolynomial t)) := by
  induction ts generalizing t with
  | nil =>
      intro s hs
      simp at hs
  | cons u us ih =>
      intro s hs
      rcases List.mem_cons.mp hs with hsu | hs
      · subst s
        simpa [PaperRepTerm.HeadLT] using
          headLT_of_chain_cons_cons (m := m) (t₁ := t) (t₂ := u) (ts := us) hchain
      · have htu :
            m.toSyn (m.degree (PaperRepTerm.toPolynomial u)) <
              m.toSyn (m.degree (PaperRepTerm.toPolynomial t)) := by
          simpa [PaperRepTerm.HeadLT] using
            headLT_of_chain_cons_cons (m := m) (t₁ := t) (t₂ := u) (ts := us) hchain
        have hus :
            m.toSyn (m.degree (PaperRepTerm.toPolynomial s)) <
              m.toSyn (m.degree (PaperRepTerm.toPolynomial u)) := by
          exact ih u
            (chain_tail_of_chain_cons_cons (m := m) (t₁ := t) (t₂ := u) (ts := us) hchain)
            s hs
        exact lt_trans hus htu

/-- Inductive step helper: if the tail-sum has the same leading term as the first tail term,
and that first tail term is strictly below the head, then the full sum has the same leading term
as the head. -/
lemma leadingTerm_eq_head_of_cons_of_tail
    {G : Set (MvPolynomial σ R)}
    (t u : PaperRepTerm (R := R) G)
    (us : List (PaperRepTerm (R := R) G))
    (htail :
      m.leadingTerm ((List.map PaperRepTerm.toPolynomial (u :: us)).sum) =
        m.leadingTerm (PaperRepTerm.toPolynomial u))
    (hutu :
      m.toSyn (m.degree (PaperRepTerm.toPolynomial u)) <
        m.toSyn (m.degree (PaperRepTerm.toPolynomial t))) :
    m.leadingTerm ((List.map PaperRepTerm.toPolynomial (t :: u :: us)).sum) =
      m.leadingTerm (PaperRepTerm.toPolynomial t) := by
  have hdegTail :
      m.degree ((List.map PaperRepTerm.toPolynomial (u :: us)).sum) =
        m.degree (PaperRepTerm.toPolynomial u) := by
    exact degree_eq_of_leadingTerm_eq (m := m) htail
  have hsmall :
      m.toSyn (m.degree ((List.map PaperRepTerm.toPolynomial (u :: us)).sum)) <
        m.toSyn (m.degree (PaperRepTerm.toPolynomial t)) := by
    rw [hdegTail]
    exact hutu
  simpa using
    leadingTerm_add_eq_left_of_lt
      (m := m)
      (p := PaperRepTerm.toPolynomial t)
      (q := (List.map PaperRepTerm.toPolynomial (u :: us)).sum)
      hsmall

/-- The leading term of a strictly descending chain-sum is the leading term of its head. -/
lemma leadingTerm_eq_leadingTerm_head_of_chain_sum
    {G : Set (MvPolynomial σ R)}
    (t : PaperRepTerm (R := R) G)
    (ts : List (PaperRepTerm (R := R) G))
    (hchain : (t :: ts).IsChain (PaperRepTerm.HeadGT (m := m))) :
    m.leadingTerm ((List.map PaperRepTerm.toPolynomial (t :: ts)).sum) =
      m.leadingTerm (PaperRepTerm.toPolynomial t) := by
  induction ts generalizing t with
  | nil =>
      simp
  | cons u us ih =>
      have htailChain :
          (u :: us).IsChain (PaperRepTerm.HeadGT (m := m)) := by
        exact chain_tail_of_chain_cons_cons (m := m) (t₁ := t) (t₂ := u) (ts := us) hchain
      have htail :
          m.leadingTerm ((List.map PaperRepTerm.toPolynomial (u :: us)).sum) =
            m.leadingTerm (PaperRepTerm.toPolynomial u) := by
        exact ih u htailChain
      have htu :
          m.toSyn (m.degree (PaperRepTerm.toPolynomial u)) <
            m.toSyn (m.degree (PaperRepTerm.toPolynomial t)) := by
        simpa [PaperRepTerm.HeadLT] using
          headLT_of_chain_cons_cons (m := m) (t₁ := t) (t₂ := u) (ts := us) hchain
      exact
        leadingTerm_eq_head_of_cons_of_tail
          (m := m) t u us htail htu




/-
  ------------------------------------------------------------------
  Bridge lemmas from the paper-style "representation" definition
  to the "initial ideal / leading term span" definition.
  These are the genuinely nontrivial parts.
  ------------------------------------------------------------------
-/

/-- Final bridge lemma:
a paper-style Gröbner representation forces the leading term to lie in the
ideal generated by the leading terms of `G`. -/
lemma leadingTerm_mem_span_of_paperRep
    [NoZeroDivisors R]
    {G : Set (MvPolynomial σ R)}
    {f : MvPolynomial σ R}
    (hf : f ≠ 0)
    (hrep : IsPaperGroebnerRepresentation (m := m) G f) :
    m.leadingTerm f ∈ Ideal.span (m.leadingTerm '' G) := by
  rcases hrep with ⟨l, hsum, hchain⟩
  cases l with
  | nil =>
      have : f = 0 := by
        simpa using hsum
      exact False.elim (hf this)
  | cons t ts =>
      rw [hsum]
      rw [leadingTerm_eq_leadingTerm_head_of_chain_sum (m := m) t ts hchain]
      apply leadingTerm_mem_span_of_repTerm_of_formula (m := m) t
      exact leadingTerm_toPolynomial_formula (m := m) t


/-- Step 1: from the ideal-style Gröbner basis definition, the leading term of any
nonzero element of `I` lies in the span of the leading terms of `G`. -/
lemma leadingTerm_mem_span_image_of_isGroebnerBasis
    {G : Set (MvPolynomial σ R)}
    {I : Ideal (MvPolynomial σ R)}
    (hGB : m.IsGroebnerBasis G I)
    {f : MvPolynomial σ R}
    (hfI : f ∈ I) :
    m.leadingTerm f ∈ Ideal.span (m.leadingTerm '' G) := by
  rcases hGB with ⟨hGI, hlt⟩
  rw [← hlt]
  exact Ideal.subset_span ⟨f, hfI, rfl⟩




/--
Step 1. From membership in the span of `m.leadingTerm '' G`,
extract a finite subset of generators that already suffices.
-/
lemma exists_finite_subset_span_of_leadingTerm_mem_span
    {G : Set (MvPolynomial σ R)}
    {f : MvPolynomial σ R}
    (hmem : m.leadingTerm f ∈ Ideal.span (m.leadingTerm '' G)) :
    ∃ s : Finset (MvPolynomial σ R),
      ((↑s : Set (MvPolynomial σ R)) ⊆ G) ∧
      m.leadingTerm f ∈ Ideal.span (m.leadingTerm '' (↑s : Set (MvPolynomial σ R))) := by
  classical
  rcases Submodule.mem_span_finite_of_mem_span hmem with ⟨t, ht, hmemt⟩
  let pick : {x : MvPolynomial σ R // x ∈ t} → MvPolynomial σ R :=
    fun x => Classical.choose (ht x.2)
  let s : Finset (MvPolynomial σ R) := t.attach.image pick
  refine ⟨s, ?_, ?_⟩
  · intro g hg
    rcases Finset.mem_image.mp hg with ⟨x, -, rfl⟩
    exact (Classical.choose_spec (ht x.2)).1
  · refine Ideal.span_mono ?_ hmemt
    intro x hx
    have hxspec := Classical.choose_spec (ht hx)
    refine ⟨Classical.choose (ht hx), ?_, hxspec.2⟩
    exact Finset.mem_image.mpr ⟨⟨x, hx⟩, Finset.mem_attach _ _, rfl⟩

/--
Step 2. The leading term of a nonzero polynomial is itself a single monomial.
-/
lemma exists_monomial_eq_leadingTerm_of_ne_zero
    {f : MvPolynomial σ R}
    (hf : f ≠ 0) :
    ∃ d c, c ≠ 0 ∧
      m.leadingTerm f = MvPolynomial.monomial d c := by
  refine ⟨m.degree f, m.leadingCoeff f, ?_, rfl⟩
  simpa [MonomialOrder.leadingCoeff_eq_zero_iff] using hf

lemma exists_repr_over_finite_leadingTerms
    {s : Finset (MvPolynomial σ R)} {x : MvPolynomial σ R}
    (hmem : x ∈ Ideal.span (m.leadingTerm '' (↑s : Set (MvPolynomial σ R)))) :
    ∃ a : (↑s : Set (MvPolynomial σ R)) →₀ MvPolynomial σ R,
      x = (Finsupp.linearCombination (MvPolynomial σ R)
  (fun g : (↑s : Set (MvPolynomial σ R)) =>
    m.leadingTerm (g : MvPolynomial σ R))) a := by
  have hrange :
      m.leadingTerm '' (↑s : Set (MvPolynomial σ R)) =
        Set.range (fun g : (↑s : Set (MvPolynomial σ R)) =>
          m.leadingTerm (g : MvPolynomial σ R)) := by
    ext y
    simp
  rw [hrange] at hmem
  rcases (Finsupp.mem_span_range_iff_exists_finsupp
      (R := MvPolynomial σ R)
      (v := fun g : (↑s : Set (MvPolynomial σ R)) =>
        m.leadingTerm (g : MvPolynomial σ R))).mp hmem with
    ⟨a, ha⟩
  refine ⟨a, ?_⟩
  simpa [Finsupp.linearCombination_apply] using ha.symm

lemma exists_generator_of_monomial_mem_span_leadingTerms_field
    {B : Set (MvPolynomial σ R)}
    {x : MvPolynomial σ R}
    (hBunit : ∀ g ∈ B, IsUnit (m.leadingCoeff g))
    (hxmono : ∃ d a, a ≠ 0 ∧ x = MvPolynomial.monomial d a)
    (hmem : x ∈ Ideal.span (m.leadingTerm '' B)) :
    ∃ g ∈ B,
      ∃ d c, c ≠ 0 ∧
        x = MvPolynomial.monomial d c * m.leadingTerm g := by
  classical
  rcases hxmono with ⟨dx, ax, hax, rfl⟩
  have hmem' :
      MvPolynomial.monomial dx ax ∈
        Ideal.span
          ((fun d : σ →₀ ℕ => MvPolynomial.monomial d (1 : R)) ''
            (m.degree '' B)) := by
    have h := hmem
    rw [m.span_leadingTerm_eq_span_monomial hBunit] at h
    simpa [Set.image_image] using h
  have hx_support :
      dx ∈ (MvPolynomial.monomial dx ax : MvPolynomial σ R).support := by
    simp [MvPolynomial.support_monomial, hax]
  rcases (MvPolynomial.mem_ideal_span_monomial_image.mp hmem') dx hx_support with
    ⟨dg, hdg_mem, hdg_le⟩
  rcases hdg_mem with ⟨g, hgB, hdeg⟩
  let u := (hBunit g hgB).unit
  have hu : (u : R) = m.leadingCoeff g := (hBunit g hgB).unit_spec
  have hle : m.degree g ≤ dx := by
    simpa [hdeg] using hdg_le
  refine ⟨g, hgB, dx - m.degree g, ax * ↑u⁻¹, ?_, ?_⟩
  · intro hc
    have hmul := congrArg (fun z : R => z * (u : R)) hc
    simp only [mul_assoc, Units.inv_mul, mul_one, zero_mul] at hmul
    exact hax hmul
  · simp [MonomialOrder.leadingTerm, MvPolynomial.monomial_mul,
      tsub_add_cancel_of_le hle, ← hu, mul_assoc]

lemma exists_support_hit_of_monomial_eq_finite_sum
    {s : Finset (MvPolynomial σ R)} {x : MvPolynomial σ R}
    (hsunit : ∀ g ∈ (↑s : Set (MvPolynomial σ R)), IsUnit (m.leadingCoeff g))
    (hxmono : ∃ d a, a ≠ 0 ∧ x = MvPolynomial.monomial d a)
    {a : (↑s : Set (MvPolynomial σ R)) →₀ MvPolynomial σ R}
    (hEq :
      x = (Finsupp.linearCombination (MvPolynomial σ R)
  (fun g : (↑s : Set (MvPolynomial σ R)) =>
    m.leadingTerm (g : MvPolynomial σ R))) a) :
    ∃ g ∈ a.support,
      ∃ d c, c ≠ 0 ∧
        x = MvPolynomial.monomial d c * m.leadingTerm ((g : (↑s : Set (MvPolynomial σ R)))) := by
  classical
  let B : Set (MvPolynomial σ R) :=
    (fun g : (↑s : Set (MvPolynomial σ R)) => (g : MvPolynomial σ R)) ''
      (↑a.support : Set ((↑s : Set (MvPolynomial σ R))))
  have hmemB : x ∈ Ideal.span (m.leadingTerm '' B) := by
    rw [hEq, Finsupp.linearCombination_apply, Finsupp.sum]
    refine (Ideal.span (m.leadingTerm '' B)).sum_mem ?_
    intro g hg
    exact Ideal.mul_mem_left _ _ <|
      Ideal.subset_span ⟨(g : MvPolynomial σ R), ⟨g, hg, rfl⟩, rfl⟩
  rcases exists_generator_of_monomial_mem_span_leadingTerms_field
      (m := m) (B := B) (x := x)
      (by
        intro g hg
        rcases hg with ⟨g', hg', rfl⟩
        exact hsunit g' g'.property)
      hxmono hmemB with
    ⟨g, hgB, d, c, hc, hx⟩
  rcases hgB with ⟨g', hg', rfl⟩
  exact ⟨g', hg', d, c, hc, hx⟩

lemma exists_generator_of_monomial_mem_span_finite_leadingTerms
    {s : Finset (MvPolynomial σ R)}
    {x : MvPolynomial σ R}
    (hsunit : ∀ g ∈ (↑s : Set (MvPolynomial σ R)), IsUnit (m.leadingCoeff g))
    (hxmono : ∃ d a, a ≠ 0 ∧ x = MvPolynomial.monomial d a)
    (hmem : x ∈ Ideal.span (m.leadingTerm '' (↑s : Set (MvPolynomial σ R)))) :
    ∃ g ∈ (↑s : Set (MvPolynomial σ R)),
      ∃ d c, c ≠ 0 ∧
        x = MvPolynomial.monomial d c * m.leadingTerm g := by
  exact exists_generator_of_monomial_mem_span_leadingTerms_field
    (m := m) (B := (↑s : Set (MvPolynomial σ R))) (x := x)
    hsunit hxmono hmem


/--
Step 4. Specialize Step 3 to `x = m.leadingTerm f`.
-/
lemma exists_head_reduction_data_of_finite_leadingTerm_mem_span
    {s : Finset (MvPolynomial σ R)}
    {f : MvPolynomial σ R}
    (hsunit : ∀ g ∈ (↑s : Set (MvPolynomial σ R)), IsUnit (m.leadingCoeff g))
    (hf : f ≠ 0)
    (hmem : m.leadingTerm f ∈ Ideal.span (m.leadingTerm '' (↑s : Set (MvPolynomial σ R)))) :
    ∃ g ∈ (↑s : Set (MvPolynomial σ R)),
      ∃ d c, c ≠ 0 ∧
        m.leadingTerm f = MvPolynomial.monomial d c * m.leadingTerm g := by
  rcases exists_monomial_eq_leadingTerm_of_ne_zero (m := m) hf with ⟨d₀, c₀, hc₀, hx⟩
  exact exists_generator_of_monomial_mem_span_finite_leadingTerms
    (m := m) (s := s) (x := m.leadingTerm f)
    hsunit ⟨d₀, c₀, hc₀, hx⟩ hmem

set_option linter.unusedVariables false in
/--
Step 5. Final assembly: remove the finite-subset wrapper.
-/
lemma exists_head_reduction_data_of_leadingTerm_mem_span
    {G : Set (MvPolynomial σ R)}
    {f : MvPolynomial σ R}
    (hGunit : ∀ g ∈ G, IsUnit (m.leadingCoeff g))
    (hf : f ≠ 0)
    (hmem : m.leadingTerm f ∈ Ideal.span (m.leadingTerm '' G)) :
    ∃ (g : MvPolynomial σ R) (hg : g ∈ G) (d : σ →₀ ℕ) (c : R),
      c ≠ 0 ∧
      m.leadingTerm f =
        MvPolynomial.monomial d c * m.leadingTerm g := by
  rcases exists_finite_subset_span_of_leadingTerm_mem_span
      (m := m) (G := G) (f := f) hmem with
    ⟨s, hsG, hmems⟩
  rcases exists_head_reduction_data_of_finite_leadingTerm_mem_span
      (m := m) (s := s) (f := f)
      (fun g hg => hGunit g (hsG hg)) hf hmems with
    ⟨g, hgs, d, c, hc, hEq⟩
  exact ⟨g, hsG hgs, d, c, hc, hEq⟩



set_option linter.unusedVariables false in
/-- Step 3: build the one-step remainder after canceling the leading term. -/
lemma exists_remainder_of_isGroebnerBasis_step
    [NoZeroDivisors R]
    {G : Set (MvPolynomial σ R)}
    {I : Ideal (MvPolynomial σ R)}
    (hGB : m.IsGroebnerBasis G I)
    (hGunit : ∀ g ∈ G, IsUnit (m.leadingCoeff g))
    {f : MvPolynomial σ R}
    (hfI : f ∈ I)
    (hf : f ≠ 0) :
    ∃ (g : MvPolynomial σ R) (hg : g ∈ G) (d : σ →₀ ℕ) (c : R) (r : MvPolynomial σ R),
      c ≠ 0 ∧
      f = MvPolynomial.monomial d c * g + r ∧
      r ∈ I ∧
      (r = 0 ∨ m.toSyn (m.degree r) < m.toSyn (m.degree f)) := by
  classical
  have hmem : m.leadingTerm f ∈ Ideal.span (m.leadingTerm '' G) :=
    leadingTerm_mem_span_image_of_isGroebnerBasis (m := m) hGB hfI
  rcases exists_head_reduction_data_of_leadingTerm_mem_span
      (m := m) (G := G) (f := f) hGunit hf hmem with
    ⟨g, hg, d, c, hc, hlead⟩
  let term : MvPolynomial σ R := MvPolynomial.monomial d c * g
  let r : MvPolynomial σ R := f - term
  have hterm_mem : term ∈ I := by
    exact Ideal.mul_mem_left _ _ (hGB.1 hg)
  have hr_mem : r ∈ I := by
    exact I.sub_mem hfI hterm_mem
  have hterm_lead : m.leadingTerm term = m.leadingTerm f := by
    let T : PaperRepTerm (R := R) G :=
      { coeff := c
        coeff_ne_zero := hc
        mono := d
        g := ⟨g, hg⟩ }
    have hformula := leadingTerm_toPolynomial_formula (m := m) (t := T)
    simpa [T, PaperRepTerm.toPolynomial, term] using hformula.trans hlead.symm
  refine ⟨g, hg, d, c, r, hc, ?_, hr_mem, ?_⟩
  · simp [r, term]
  · by_cases hr0 : r = 0
    · exact Or.inl hr0
    · right
      have hdeg_term : m.degree term = m.degree f :=
        degree_eq_of_leadingTerm_eq (m := m) hterm_lead
      have hsupp :
          ∀ a ∈ r.support,
            (a ∈ f.support ∧ m.toSyn a < m.toSyn (m.degree f)) ∨
            (a ∈ term.support ∧ m.toSyn a < m.toSyn (m.degree term)) := by
        intro a ha
        simpa [r, MonomialOrder.toSyn_strictMono] using
          m.support_sub_of_leadingTerm_eq_leadingTerm
            (p := f) (q := term) hterm_lead.symm a ha
      have hdeg_ne : m.degree f ≠ 0 := by
        intro hzero
        have hdeg_r_mem : m.degree r ∈ r.support := by
          rw [MvPolynomial.mem_support_iff, ← MonomialOrder.leadingCoeff]
          exact (MonomialOrder.leadingCoeff_ne_zero_iff (m := m)).mpr hr0
        rcases hsupp (m.degree r) hdeg_r_mem with hlt | hlt
        · have hlt0 : m.toSyn (m.degree r) < 0 := by simpa [hzero] using hlt.2
          exact not_lt_of_ge (m.zero_le _) hlt0
        · have hlt0 : m.toSyn (m.degree r) < 0 := by
            simpa [hdeg_term, hzero] using hlt.2
          exact not_lt_of_ge (m.zero_le _) hlt0
      have hpos : m.toSyn 0 < m.toSyn (m.degree f) := by
        simpa using
          ((MonomialOrder.toSyn_lt_iff_ne_zero
            (m := m) (a := m.toSyn (m.degree f))).mpr
              ((m.toSyn_eq_zero_iff (m.degree f)).not.mpr hdeg_ne))
      exact (m.degree_lt_iff (f := r) hpos).mpr (by
        intro a ha
        rcases hsupp a ha with hlt | hlt
        · exact hlt.2
        · simpa [hdeg_term] using hlt.2)

/-- Step 4: prepend one head summand in front of a paper representation of a smaller remainder. -/
lemma paperRep_of_head_term_and_smaller_tail
    [NoZeroDivisors R]
    {G : Set (MvPolynomial σ R)}
    {f r g : MvPolynomial σ R}
    {d : σ →₀ ℕ} {c : R}
    (hc : c ≠ 0)
    (hg : g ∈ G)
    (hdecomp : f = MvPolynomial.monomial d c * g + r)
    (hr : IsPaperGroebnerRepresentation (m := m) G r)
    (hsmall : m.toSyn (m.degree r) < m.toSyn (m.degree f))
    (hhead :
      m.leadingTerm (MvPolynomial.monomial d c * g) = m.leadingTerm f) :
    IsPaperGroebnerRepresentation (m := m) G f := by
  classical
  rcases hr with ⟨l, hsum, hchain⟩
  let head : PaperRepTerm (R := R) G :=
    { coeff := c
      coeff_ne_zero := hc
      mono := d
      g := ⟨g, hg⟩ }
  refine ⟨head :: l, ?_, ?_⟩
  · simp [head, PaperRepTerm.toPolynomial, hsum, hdecomp]
  · cases l with
    | nil =>
        exact List.isChain_singleton head
    | cons u us =>
        refine List.IsChain.cons_cons ?_ hchain
        have hdeg_head :
            m.degree (PaperRepTerm.toPolynomial head) = m.degree f := by
          exact degree_eq_of_leadingTerm_eq (m := m) (by
            simpa [head, PaperRepTerm.toPolynomial] using hhead)
        have htail_lead :
            m.leadingTerm r = m.leadingTerm (PaperRepTerm.toPolynomial u) := by
          rw [hsum]
          exact leadingTerm_eq_leadingTerm_head_of_chain_sum
            (m := m) u us hchain
        have hdeg_u :
            m.degree (PaperRepTerm.toPolynomial u) = m.degree r :=
          (degree_eq_of_leadingTerm_eq (m := m) htail_lead).symm
        simpa [PaperRepTerm.HeadGT, hdeg_head, hdeg_u] using hsmall


/--
Conversely, from the usual ideal-style Gröbner basis definition
(`leadingTerm`-span equality), one can construct a paper-style Gröbner
representation for every nonzero `f ∈ I`.

This is the reduction / induction-on-leading-term direction.
-/
lemma exists_paperRep_of_IsGroebnerBasis
    [NoZeroDivisors R]
    {G : Set (MvPolynomial σ R)}
    {I : Ideal (MvPolynomial σ R)}
    (hGB : m.IsGroebnerBasis G I)
    (hGunit : ∀ g ∈ G, IsUnit (m.leadingCoeff g))
    {f : MvPolynomial σ R}
    (hfI : f ∈ I)
    (hf : f ≠ 0) :
    IsPaperGroebnerRepresentation (m := m) G f := by
  classical
  letI : WellFoundedRelation (σ →₀ ℕ) :=
    { rel := fun a b => m.toSyn a < m.toSyn b
      wf := InvImage.wf m.toSyn m.wf.wf }
  have hmem : m.leadingTerm f ∈ Ideal.span (m.leadingTerm '' G) :=
    leadingTerm_mem_span_image_of_isGroebnerBasis (m := m) hGB hfI
  rcases exists_head_reduction_data_of_leadingTerm_mem_span
      (m := m) (G := G) (f := f) hGunit hf hmem with
    ⟨g, hg, d, c, hc, hlead⟩
  let term : MvPolynomial σ R := MvPolynomial.monomial d c * g
  let r : MvPolynomial σ R := f - term
  have hdecomp : f = term + r := by
    simp [r, term]
  have hterm_mem : term ∈ I := by
    exact Ideal.mul_mem_left _ _ (hGB.1 hg)
  have hr_mem : r ∈ I := by
    exact I.sub_mem hfI hterm_mem
  have hterm_lead : m.leadingTerm term = m.leadingTerm f := by
    let T : PaperRepTerm (R := R) G :=
      { coeff := c
        coeff_ne_zero := hc
        mono := d
        g := ⟨g, hg⟩ }
    have hformula := leadingTerm_toPolynomial_formula (m := m) (t := T)
    simpa [T, PaperRepTerm.toPolynomial, term] using hformula.trans hlead.symm
  by_cases hr0 : r = 0
  · let head : PaperRepTerm (R := R) G :=
      { coeff := c
        coeff_ne_zero := hc
        mono := d
        g := ⟨g, hg⟩ }
    refine ⟨[head], ?_, ?_⟩
    · simpa [head, PaperRepTerm.toPolynomial, term, r, hr0] using hdecomp
    · exact List.isChain_singleton head
  · have hdeg_term : m.degree term = m.degree f :=
      degree_eq_of_leadingTerm_eq (m := m) hterm_lead
    have hsupp :
        ∀ a ∈ r.support,
          (a ∈ f.support ∧ m.toSyn a < m.toSyn (m.degree f)) ∨
          (a ∈ term.support ∧ m.toSyn a < m.toSyn (m.degree term)) := by
      intro a ha
      simpa [r, MonomialOrder.toSyn_strictMono] using
        m.support_sub_of_leadingTerm_eq_leadingTerm
          (p := f) (q := term) hterm_lead.symm a ha
    have hdeg_ne : m.degree f ≠ 0 := by
      intro hzero
      have hdeg_r_mem : m.degree r ∈ r.support := by
        rw [MvPolynomial.mem_support_iff, ← MonomialOrder.leadingCoeff]
        exact (MonomialOrder.leadingCoeff_ne_zero_iff (m := m)).mpr hr0
      rcases hsupp (m.degree r) hdeg_r_mem with hlt | hlt
      · have hlt0 : m.toSyn (m.degree r) < 0 := by
          simpa [hzero] using hlt.2
        exact not_lt_of_ge (m.zero_le _) hlt0
      · have hlt0 : m.toSyn (m.degree r) < 0 := by
          simpa [hdeg_term, hzero] using hlt.2
        exact not_lt_of_ge (m.zero_le _) hlt0
    have hpos : m.toSyn 0 < m.toSyn (m.degree f) := by
      simpa using
        ((MonomialOrder.toSyn_lt_iff_ne_zero
          (m := m) (a := m.toSyn (m.degree f))).mpr
            ((m.toSyn_eq_zero_iff (m.degree f)).not.mpr hdeg_ne))
    have hsmall : m.toSyn (m.degree r) < m.toSyn (m.degree f) :=
      (m.degree_lt_iff (f := r) hpos).mpr <| by
        intro a ha
        rcases hsupp a ha with hlt | hlt
        · exact hlt.2
        · simpa [hdeg_term] using hlt.2
    have hr :
        IsPaperGroebnerRepresentation (m := m) G r :=
      exists_paperRep_of_IsGroebnerBasis (G := G) (I := I) hGB hGunit hr_mem hr0
    exact
      paperRep_of_head_term_and_smaller_tail
        (m := m) (f := f) (r := r) (g := g) (d := d) (c := c)
        hc hg (by simpa [term] using hdecomp) hr hsmall
        (by simpa [term] using hterm_lead)
termination_by WellFounded.wrap
  ((isWellFounded_iff m.syn fun x x_1 => x < x_1).mp m.wf) (m.toSyn (m.degree f))
decreasing_by
  simpa [r] using hsmall



/-
  ------------------------------------------------------------------
  Now prove equivalence between the paper-style definition
  and the existing `IsGroebnerBasis`.
  ------------------------------------------------------------------
-/

/--
Definition 3.1 of the paper (specialized to ideals) is equivalent to the
usual ideal-theoretic Gröbner basis definition used in this project.
-/
theorem isGroebnerBasis_paper3_1_iff
    [NoZeroDivisors R]
    (G : Set (MvPolynomial σ R))
    (I : Ideal (MvPolynomial σ R))
    (hGunit : ∀ g ∈ G, IsUnit (m.leadingCoeff g)) :
    IsGroebnerBasis_paper3_1 m G I
      ↔ m.IsGroebnerBasis G I := by
  constructor
  · rintro ⟨hGI, hrepr⟩
    refine ⟨hGI, ?_⟩
    apply le_antisymm
    · refine Ideal.span_le.mpr ?_
      intro lt hlt
      rcases hlt with ⟨f, hfI, rfl⟩
      by_cases hf : f = 0
      · simp [hf]
      · exact leadingTerm_mem_span_of_paperRep
          (m := m) (G := G) (f := f) hf (hrepr hfI hf)
    · refine Ideal.span_mono ?_
      intro lt hlt
      rcases hlt with ⟨g, hgG, rfl⟩
      exact ⟨g, hGI hgG, rfl⟩
  · intro hGB
    refine ⟨hGB.1, ?_⟩
    intro f hfI hf
    exact exists_paperRep_of_IsGroebnerBasis
      (m := m) (G := G) (I := I) hGB hGunit hfI hf

end paper3_1









section paper_prop_1_0_pre

open scoped BigOperators

variable {σ : Type*}
variable {R : Type*} [CommRing R]

/-- The exponent of `lcm (Head f) (Head g)`. -/
noncomputable def headLcm
    (ord : MonomialOrder σ)
    (f g : MvPolynomial σ R) : σ →₀ ℕ :=
  ord.degree f ⊔ ord.degree g

/-
  ============================================================================
  Old definitions (kept for migration)
  ============================================================================
-/

/-- Old version: coefficients are aggregated by basis element `h : G`. -/
def AdjacentSmallSPolynomialRepOld
    (ord : MonomialOrder σ)
    (G : Set (MvPolynomial σ R))
    (f g : MvPolynomial σ R) : Prop :=
  ∃ a : G →₀ MvPolynomial σ R,
    ord.sPolynomial f g =
      Finsupp.linearCombination _ (fun h : G ↦ (h : MvPolynomial σ R)) a ∧
    ∀ h ∈ a.support,
      ∃ d : σ →₀ ℕ, ∃ c : R,
        c ≠ 0 ∧
        a h = MvPolynomial.monomial d c ∧
        (h : MvPolynomial σ R) ≠ 0 ∧
        ord.toSyn (ord.degree ((a h) * (h : MvPolynomial σ R))) <
          ord.toSyn (headLcm ord f g)

/-- Old chain definition, kept so that existing proofs do not break immediately. -/
def HasGoodChainOld
    (ord : MonomialOrder σ)
    (G : Set (MvPolynomial σ R))
    (f f' : MvPolynomial σ R) : Prop :=
  ∃ p : ℕ, ∃ F : Fin (p + 1) → MvPolynomial σ R,
    F 0 = f ∧
    F ⟨p, Nat.lt_succ_self p⟩ = f' ∧
    (∀ i, F i ∈ G) ∧
    (Finset.univ.sup (fun i : Fin (p + 1) ↦ ord.degree (F i)) = headLcm ord f f') ∧
    (∀ i : Fin p,
      AdjacentSmallSPolynomialRepOld ord G (F i.castSucc) (F i.succ))

/-
  ============================================================================
  New explicit-summand version
  ============================================================================
-/

/-- One explicit summand `c * X^d * h` occurring in a small `S`-polynomial
representation. The basis element is stored as a subtype of `G`, so membership
in `G` is carried automatically. -/
structure SmallSPolynomialSummand
    (σ : Type*)
    (R : Type*) [CommRing R]
    (G : Set (MvPolynomial σ R)) where
  g : {h : MvPolynomial σ R // h ∈ G}
  d : σ →₀ ℕ
  c : R
  hc : c ≠ 0

namespace SmallSPolynomialSummand

/-- The polynomial represented by one explicit summand. -/
@[simp] noncomputable def poly
    {G : Set (MvPolynomial σ R)}
    (s : SmallSPolynomialSummand σ R G) : MvPolynomial σ R :=
  MvPolynomial.monomial s.d s.c * (s.g : MvPolynomial σ R)

@[simp] lemma mem_G
    {G : Set (MvPolynomial σ R)}
    (s : SmallSPolynomialSummand σ R G) :
    (s.g : MvPolynomial σ R) ∈ G :=
  s.g.property

end SmallSPolynomialSummand

/-- New version: `S(f,g)` is written as an explicit finite sum of monomial multiples
of elements of `G`, and every summand is strictly below `headLcm ord f g`.

This is weaker/more flexible than the old `Finsupp`-aggregated encoding:
the same `g ∈ G` may now appear several times with different monomial coefficients. -/
def AdjacentSmallSPolynomialRep
    (ord : MonomialOrder σ)
    (G : Set (MvPolynomial σ R))
    (f g : MvPolynomial σ R) : Prop :=by
    classical
    exact
  ∃ S : Finset (SmallSPolynomialSummand σ R G),
    ord.sPolynomial f g = ∑ s ∈ S, s.poly ∧
    ∀ s ∈ S,
      ord.toSyn (ord.degree s.poly) <
        ord.toSyn (headLcm ord f g)

/-- New chain definition, synchronized with the new explicit-summand notion. -/
def HasGoodChain
    (ord : MonomialOrder σ)
    (G : Set (MvPolynomial σ R))
    (f f' : MvPolynomial σ R) : Prop :=
  ∃ p : ℕ, ∃ F : Fin (p + 1) → MvPolynomial σ R,
    F 0 = f ∧
    F ⟨p, Nat.lt_succ_self p⟩ = f' ∧
    (∀ i, F i ∈ G) ∧
    (Finset.univ.sup (fun i : Fin (p + 1) ↦ ord.degree (F i)) = headLcm ord f f') ∧
    (∀ i : Fin p,
      AdjacentSmallSPolynomialRep ord G (F i.castSucc) (F i.succ))

/-
  ============================================================================
  Bridge: old explicit coefficient data -> new explicit finite-sum data
  ============================================================================
-/

section bridge_old_to_new

open SmallSPolynomialSummand


/-- Turn one old-style support entry into one new explicit summand. -/
noncomputable def oldRepSummand
    (ord : MonomialOrder σ)
    (G : Set (MvPolynomial σ R))
    (f g : MvPolynomial σ R)
    (a : G →₀ MvPolynomial σ R)
    (hsmall :
      ∀ h ∈ a.support,
        ∃ d : σ →₀ ℕ, ∃ c : R,
          c ≠ 0 ∧
          a h = MvPolynomial.monomial d c ∧
          (h : MvPolynomial σ R) ≠ 0 ∧
          ord.toSyn (ord.degree ((a h) * (h : MvPolynomial σ R))) <
            ord.toSyn (headLcm ord f g))
    (h : {x // x ∈ a.support}) :
    SmallSPolynomialSummand σ R G := by
  classical
  let d : σ →₀ ℕ := Classical.choose (hsmall h.1 h.2)
  let hc :
      ∃ c : R,
        c ≠ 0 ∧
        a h.1 = MvPolynomial.monomial d c ∧
        (h.1 : MvPolynomial σ R) ≠ 0 ∧
        ord.toSyn (ord.degree ((a h.1) * (h.1 : MvPolynomial σ R))) <
          ord.toSyn (headLcm ord f g) :=
    Classical.choose_spec (hsmall h.1 h.2)
  let c : R := Classical.choose hc
  have hc_spec :
      c ≠ 0 ∧
      a h.1 = MvPolynomial.monomial d c ∧
      (h.1 : MvPolynomial σ R) ≠ 0 ∧
      ord.toSyn (ord.degree ((a h.1) * (h.1 : MvPolynomial σ R))) <
        ord.toSyn (headLcm ord f g) :=
    Classical.choose_spec hc
  exact
    { g := ⟨(h.1 : MvPolynomial σ R), h.1.property⟩
      d := d
      c := c
      hc := hc_spec.1 }

/-- The polynomial carried by `oldRepSummand` is exactly the old summand
`(a h) * h`. -/
lemma oldRepSummand_poly
    (ord : MonomialOrder σ)
    (G : Set (MvPolynomial σ R))
    (f g : MvPolynomial σ R)
    (a : G →₀ MvPolynomial σ R)
    (hsmall :
      ∀ h ∈ a.support,
        ∃ d : σ →₀ ℕ, ∃ c : R,
          c ≠ 0 ∧
          a h = MvPolynomial.monomial d c ∧
          (h : MvPolynomial σ R) ≠ 0 ∧
          ord.toSyn (ord.degree ((a h) * (h : MvPolynomial σ R))) <
            ord.toSyn (headLcm ord f g))
    (h : {x // x ∈ a.support}) :
    (oldRepSummand ord G f g a hsmall h).poly =
      (a h.1) * (h.1 : MvPolynomial σ R) := by
  classical
  unfold oldRepSummand
  let d : σ →₀ ℕ := Classical.choose (hsmall h.1 h.2)
  let hc :
      ∃ c : R,
        c ≠ 0 ∧
        a h.1 = MvPolynomial.monomial d c ∧
        (h.1 : MvPolynomial σ R) ≠ 0 ∧
        ord.toSyn (ord.degree ((a h.1) * (h.1 : MvPolynomial σ R))) <
          ord.toSyn (headLcm ord f g) :=
    Classical.choose_spec (hsmall h.1 h.2)
  let c : R := Classical.choose hc
  have hc_spec :
      c ≠ 0 ∧
      a h.1 = MvPolynomial.monomial d c ∧
      (h.1 : MvPolynomial σ R) ≠ 0 ∧
      ord.toSyn (ord.degree ((a h.1) * (h.1 : MvPolynomial σ R))) <
        ord.toSyn (headLcm ord f g) :=
    Classical.choose_spec hc
  change MvPolynomial.monomial d c * (h.1 : MvPolynomial σ R) =
    (a h.1) * (h.1 : MvPolynomial σ R)
  rw [hc_spec.2.1]


/-- Old representation implies new representation. -/
lemma adjacentRepOld_implies_new
    (ord : MonomialOrder σ)
    (G : Set (MvPolynomial σ R))
    (f g : MvPolynomial σ R) :
    AdjacentSmallSPolynomialRepOld ord G f g →
      AdjacentSmallSPolynomialRep ord G f g := by
  classical
  letI : DecidableEq σ := Classical.decEq σ
  rintro ⟨a, hs, hsmall⟩
  let S : Finset (SmallSPolynomialSummand σ R G) :=
    a.support.attach.image (fun h =>
      oldRepSummand ord G f g a hsmall h)
  refine ⟨S, ?_, ?_⟩
  · rw [hs]
    -- Convert the old aggregated `Finsupp.linearCombination` into an explicit finite sum.
    -- This `simp`/`simpa` line is the only place that may need a tiny local adjustment
    -- depending on the exact normal form of `Finsupp.linearCombination` in your build.
    unfold S
    rw [Finset.sum_image]
    · change (a.sum fun i c => c * (i : MvPolynomial σ R)) =
        ∑ x ∈ a.support.attach, (oldRepSummand ord G f g a hsmall x).poly
      simp_rw [oldRepSummand_poly]
      rw [Finsupp.sum]
      rw [← Finset.sum_attach]
    · intro x hx y hy hxy
      apply Subtype.ext
      apply Subtype.ext
      change ((oldRepSummand ord G f g a hsmall x).g : MvPolynomial σ R) =
        ((oldRepSummand ord G f g a hsmall y).g : MvPolynomial σ R)
      exact congrArg (fun s => ((s.g : {h : MvPolynomial σ R // h ∈ G}) :
        MvPolynomial σ R)) hxy
  · intro s hsS
    rcases Finset.mem_image.mp hsS with ⟨h, hh, rfl⟩
    rcases hsmall h.1 h.2 with ⟨d, c, hc, hac, _, hlt⟩
    rw [oldRepSummand_poly]
    exact hlt

end bridge_old_to_new

/-
  ============================================================================
  Bridge: old chains -> new chains
  ============================================================================
-/

lemma hasGoodChainOld_implies_new
    (ord : MonomialOrder σ)
    (G : Set (MvPolynomial σ R))
    (f f' : MvPolynomial σ R) :
    HasGoodChainOld ord G f f' →
      HasGoodChain ord G f f' := by
  rintro ⟨p, F, h0, hp, hmem, hsup, hadj⟩
  refine ⟨p, F, h0, hp, hmem, hsup, ?_⟩
  intro i
  exact adjacentRepOld_implies_new ord G (F i.castSucc) (F i.succ) (hadj i)

end paper_prop_1_0_pre







section paper3_2_reduction

open scoped BigOperators

variable {σ : Type*} {R : Type*}
variable [CommRing R] [NoZeroDivisors R]

/-!
This section now follows the standard-representation proof route for paper
Theorem 3.2.  The previous reduction/confluence route was removed because its
key sorting lemma is not derivable from `AdjacentSmallSPolynomialRep`: a finite
small representation need not have strictly decreasing summand heads.
-/

/-- A standard representation of `p` by elements of `G`, with every displayed
summand strictly below the degree bound `D`. -/
def HasStandardRepresentationBelow
    (ord : MonomialOrder σ)
    (G : Set (MvPolynomial σ R))
    (p : MvPolynomial σ R)
    (D : σ →₀ ℕ) : Prop := by
  classical
  exact
    ∃ L : List (SmallSPolynomialSummand σ R G),
      p = (L.map SmallSPolynomialSummand.poly).sum ∧
      ∀ s ∈ L,
        ord.toSyn (ord.degree s.poly) < ord.toSyn D

namespace HasStandardRepresentationBelow

omit [NoZeroDivisors R] in
/-- The adjacent small representation is exactly the standard representation
below `headLcm` for the adjacent pair. -/
lemma of_adjacentSmallSPolynomialRep
    (ord : MonomialOrder σ)
    {G : Set (MvPolynomial σ R)}
    {f g : MvPolynomial σ R}
    (hrep : AdjacentSmallSPolynomialRep ord G f g) :
    HasStandardRepresentationBelow ord G (ord.sPolynomial f g) (headLcm ord f g) := by
  rcases hrep with ⟨S, hsum, hsmall⟩
  refine ⟨S.toList, ?_, ?_⟩
  · simpa using hsum
  · intro s hs
    exact hsmall s (by simpa using hs)

omit [NoZeroDivisors R] in
/-- A standard representation below `D` is also one below any larger bound. -/
lemma mono_bound
    (ord : MonomialOrder σ)
    {G : Set (MvPolynomial σ R)}
    {p : MvPolynomial σ R}
    {D E : σ →₀ ℕ}
    (h : HasStandardRepresentationBelow ord G p D)
    (hDE : ord.toSyn D ≤ ord.toSyn E) :
    HasStandardRepresentationBelow ord G p E := by
  rcases h with ⟨S, hsum, hsmall⟩
  refine ⟨S, hsum, ?_⟩
  intro s hs
  exact lt_of_lt_of_le (hsmall s hs) hDE

end HasStandardRepresentationBelow

namespace SmallSPolynomialSummand

/-- Shift one standard-representation summand by a monomial. -/
noncomputable def shift
    {G : Set (MvPolynomial σ R)}
    (e : σ →₀ ℕ)
    (s : SmallSPolynomialSummand σ R G) :
    SmallSPolynomialSummand σ R G where
  g := s.g
  d := e + s.d
  c := s.c
  hc := s.hc

omit [NoZeroDivisors R] in
@[simp]
lemma shift_poly
    {G : Set (MvPolynomial σ R)}
    (e : σ →₀ ℕ)
    (s : SmallSPolynomialSummand σ R G) :
    (s.shift e).poly =
      MvPolynomial.monomial e (1 : R) * s.poly := by
  rw [shift, poly, poly, ← mul_assoc, MvPolynomial.monomial_mul]
  simp

omit [NoZeroDivisors R] in
lemma ne_zero_of_monic
    (ord : MonomialOrder σ)
    {G : Set (MvPolynomial σ R)}
    (hmonic : ∀ g ∈ G, ord.leadingCoeff g = 1)
    (s : SmallSPolynomialSummand σ R G) :
    (s.g : MvPolynomial σ R) ≠ 0 := by
  intro hg0
  have hlc : ord.leadingCoeff (s.g : MvPolynomial σ R) = 1 :=
    hmonic (s.g : MvPolynomial σ R) s.g.property
  simp only [hg0, MonomialOrder.leadingCoeff_zero] at hlc
  haveI : Nontrivial R := ⟨⟨s.c, 0, s.hc⟩⟩
  exact zero_ne_one hlc

lemma degree_poly
    (ord : MonomialOrder σ)
    {G : Set (MvPolynomial σ R)}
    (hmonic : ∀ g ∈ G, ord.leadingCoeff g = 1)
    (s : SmallSPolynomialSummand σ R G) :
    ord.degree s.poly = s.d + ord.degree (s.g : MvPolynomial σ R) := by
  classical
  have hmono :
      MvPolynomial.monomial s.d s.c ≠ (0 : MvPolynomial σ R) := by
    simpa using (MvPolynomial.monomial_eq_zero (s := s.d)).not.mpr s.hc
  have hg0 : (s.g : MvPolynomial σ R) ≠ 0 :=
    ne_zero_of_monic (ord := ord) hmonic s
  calc
    ord.degree s.poly =
        ord.degree (MvPolynomial.monomial s.d s.c * (s.g : MvPolynomial σ R)) := rfl
    _ = ord.degree (MvPolynomial.monomial s.d s.c) +
        ord.degree (s.g : MvPolynomial σ R) := ord.degree_mul hmono hg0
    _ = s.d + ord.degree (s.g : MvPolynomial σ R) := by
      rw [ord.degree_monomial]
      simp [s.hc]

end SmallSPolynomialSummand

lemma finsupp_tsub_add_tsub
    {a b c : σ →₀ ℕ}
    (hab : a ≤ b) (hbc : b ≤ c) :
    c - b + (b - a) = c - a := by
  ext x
  have habx : a x ≤ b x := hab x
  have hbcx : b x ≤ c x := hbc x
  exact tsub_add_tsub_cancel hbcx habx

omit [NoZeroDivisors R] in
lemma headLcm_le_of_degree_le
    (ord : MonomialOrder σ)
    {D : σ →₀ ℕ}
    {f g : MvPolynomial σ R}
    (hf : ord.degree f ≤ D)
    (hg : ord.degree g ≤ D) :
    headLcm ord f g ≤ D := by
  exact sup_le hf hg

omit [NoZeroDivisors R] in
lemma scaledSPolynomial_eq_scaled_sub_of_monic
    (ord : MonomialOrder σ)
    {G : Set (MvPolynomial σ R)}
    (hmonic : ∀ g ∈ G, ord.leadingCoeff g = 1)
    {D : σ →₀ ℕ}
    {f g : MvPolynomial σ R}
    (hfG : f ∈ G) (hgG : g ∈ G)
    (hfD : ord.degree f ≤ D) (hgD : ord.degree g ≤ D) :
    MvPolynomial.monomial (D - headLcm ord f g) (1 : R) *
        ord.sPolynomial f g =
      MvPolynomial.monomial (D - ord.degree f) (1 : R) * f -
        MvPolynomial.monomial (D - ord.degree g) (1 : R) * g := by
  classical
  have hfL : ord.degree f ≤ headLcm ord f g := le_sup_left
  have hgL : ord.degree g ≤ headLcm ord f g := le_sup_right
  have hLD : headLcm ord f g ≤ D :=
    headLcm_le_of_degree_le (ord := ord) hfD hgD
  have htf :
      D - headLcm ord f g + (headLcm ord f g - ord.degree f) =
        D - ord.degree f :=
    finsupp_tsub_add_tsub hfL hLD
  have htg :
      D - headLcm ord f g + (headLcm ord f g - ord.degree g) =
        D - ord.degree g :=
    finsupp_tsub_add_tsub hgL hLD
  rw [MonomialOrder.sPolynomial_def, mul_sub]
  simp only [headLcm, hmonic f hfG, hmonic g hgG]
  have htf' :
      D - (ord.degree f ⊔ ord.degree g) + (ord.degree f ⊔ ord.degree g - ord.degree f) =
        D - ord.degree f := by
    simpa [headLcm] using htf
  have htg' :
      D - (ord.degree f ⊔ ord.degree g) + (ord.degree f ⊔ ord.degree g - ord.degree g) =
        D - ord.degree g := by
    simpa [headLcm] using htg
  rw [← mul_assoc, MvPolynomial.monomial_mul]
  simp only [one_mul]
  rw [htf']
  rw [← mul_assoc, MvPolynomial.monomial_mul]
  simp only [one_mul]
  rw [htg']

omit [NoZeroDivisors R] in
lemma scaledSPolynomial_telescope_three
    (ord : MonomialOrder σ)
    {G : Set (MvPolynomial σ R)}
    (hmonic : ∀ g ∈ G, ord.leadingCoeff g = 1)
    {D : σ →₀ ℕ}
    {a b c : MvPolynomial σ R}
    (haG : a ∈ G) (hbG : b ∈ G) (hcG : c ∈ G)
    (haD : ord.degree a ≤ D) (hbD : ord.degree b ≤ D) (hcD : ord.degree c ≤ D) :
    MvPolynomial.monomial (D - headLcm ord a c) (1 : R) *
        ord.sPolynomial a c =
      MvPolynomial.monomial (D - headLcm ord a b) (1 : R) *
          ord.sPolynomial a b +
        MvPolynomial.monomial (D - headLcm ord b c) (1 : R) *
          ord.sPolynomial b c := by
  rw [scaledSPolynomial_eq_scaled_sub_of_monic
        (ord := ord) (G := G) hmonic haG hcG haD hcD]
  rw [scaledSPolynomial_eq_scaled_sub_of_monic
        (ord := ord) (G := G) hmonic haG hbG haD hbD]
  rw [scaledSPolynomial_eq_scaled_sub_of_monic
        (ord := ord) (G := G) hmonic hbG hcG hbD hcD]
  abel

omit [NoZeroDivisors R] in
lemma HasStandardRepresentationBelow.add
    (ord : MonomialOrder σ)
    {G : Set (MvPolynomial σ R)}
    {D : σ →₀ ℕ}
    {p q : MvPolynomial σ R}
    (hp : HasStandardRepresentationBelow ord G p D)
    (hq : HasStandardRepresentationBelow ord G q D) :
    HasStandardRepresentationBelow ord G (p + q) D := by
  rcases hp with ⟨Lp, hp_sum, hp_small⟩
  rcases hq with ⟨Lq, hq_sum, hq_small⟩
  refine ⟨Lp ++ Lq, ?_, ?_⟩
  · simp [List.map_append, hp_sum, hq_sum]
  · intro s hs
    rcases List.mem_append.mp hs with hs | hs
    · exact hp_small s hs
    · exact hq_small s hs

lemma HasStandardRepresentationBelow.monomial_mul
    (ord : MonomialOrder σ)
    {G : Set (MvPolynomial σ R)}
    (hmonic : ∀ g ∈ G, ord.leadingCoeff g = 1)
    {p : MvPolynomial σ R}
    {L D : σ →₀ ℕ}
    (hrep : HasStandardRepresentationBelow ord G p L)
    (hLD : L ≤ D) :
    HasStandardRepresentationBelow ord G
      (MvPolynomial.monomial (D - L) (1 : R) * p) D := by
  rcases hrep with ⟨S, hsum, hsmall⟩
  refine ⟨S.map (SmallSPolynomialSummand.shift (R := R) (D - L)), ?_, ?_⟩
  · rw [hsum]
    rw [← List.sum_map_mul_left]
    congr 1
    rw [List.map_map]
    apply List.map_congr_left
    intro s hs
    exact (SmallSPolynomialSummand.shift_poly (R := R) (D - L) s).symm
  · intro s hs
    rcases List.mem_map.mp hs with ⟨s₀, hs₀, rfl⟩
    have hdeg₀ :
        ord.degree s₀.poly =
          s₀.d + ord.degree (s₀.g : MvPolynomial σ R) :=
      SmallSPolynomialSummand.degree_poly (ord := ord) hmonic s₀
    have hdeg_shift :
        ord.degree (SmallSPolynomialSummand.shift (R := R) (D - L) s₀).poly =
          (D - L) + ord.degree s₀.poly := by
      rw [SmallSPolynomialSummand.degree_poly (ord := ord) hmonic, hdeg₀]
      change (D - L + s₀.d) + ord.degree (s₀.g : MvPolynomial σ R) =
        D - L + (s₀.d + ord.degree (s₀.g : MvPolynomial σ R))
      ac_rfl
    have hlt := hsmall s₀ hs₀
    have hlt' :
        ord.toSyn ((D - L) + ord.degree s₀.poly) <
          ord.toSyn ((D - L) + L) := by
      simpa [map_add] using add_lt_add_left hlt (ord.toSyn (D - L))
    have hDL : D - L + L = D := by
      exact tsub_add_cancel_of_le hLD
    calc
      ord.toSyn (ord.degree (SmallSPolynomialSummand.shift (R := R) (D - L) s₀).poly)
          = ord.toSyn ((D - L) + ord.degree s₀.poly) := by
            rw [hdeg_shift]
      _ < ord.toSyn D := by
            simpa [hDL] using hlt'

omit [NoZeroDivisors R] in
lemma list_sum_eq_zero_or_degree_lt_of_forall_degree_lt
    (ord : MonomialOrder σ)
    {D : σ →₀ ℕ}
    {L : List (MvPolynomial σ R)}
    (hL : ∀ p ∈ L, ord.toSyn (ord.degree p) < ord.toSyn D) :
    L.sum = 0 ∨ ord.toSyn (ord.degree L.sum) < ord.toSyn D := by
  induction L with
  | nil =>
      left
      simp
  | cons p L ih =>
      have hp : ord.toSyn (ord.degree p) < ord.toSyn D := hL p (by simp)
      have htail :
          ∀ q ∈ L, ord.toSyn (ord.degree q) < ord.toSyn D := by
        intro q hq
        exact hL q (by simp [hq])
      rcases ih htail with hzero | hlt
      · right
        simpa [hzero] using hp
      · by_cases hsum : (p :: L).sum = 0
        · left
          exact hsum
        · right
          refine lt_of_le_of_lt ord.degree_add_le ?_
          exact max_lt hp hlt

namespace SmallSPolynomialSummand

omit [NoZeroDivisors R] in
/-- Aggregate a list of explicit standard-representation summands as a
finitely supported coefficient function on the basis set `G`. -/
noncomputable def coeffFinsupp
    [DecidableEq σ]
    {G : Set (MvPolynomial σ R)}
    (L : List (SmallSPolynomialSummand σ R G)) :
    G →₀ MvPolynomial σ R :=
  (L.map fun s => Finsupp.single s.g (MvPolynomial.monomial s.d s.c)).sum

omit [NoZeroDivisors R] in
lemma coeffFinsupp_linearCombination
    [DecidableEq σ]
    {G : Set (MvPolynomial σ R)}
    (L : List (SmallSPolynomialSummand σ R G)) :
    Finsupp.linearCombination (MvPolynomial σ R)
        (fun g : G => (g : MvPolynomial σ R)) (coeffFinsupp (R := R) L) =
      (L.map SmallSPolynomialSummand.poly).sum := by
  classical
  induction L with
  | nil =>
      simp [coeffFinsupp]
  | cons s L ih =>
      change
        Finsupp.linearCombination (MvPolynomial σ R)
            (fun g : G => (g : MvPolynomial σ R))
            (Finsupp.single s.g (MvPolynomial.monomial s.d s.c) +
              coeffFinsupp (R := R) L) =
          s.poly + (L.map SmallSPolynomialSummand.poly).sum
      rw [map_add, Finsupp.linearCombination_single, ih]
      simp [SmallSPolynomialSummand.poly]

omit [NoZeroDivisors R] in
lemma coeffFinsupp_mul_eq_filter_sum
    [DecidableEq σ]
    {G : Set (MvPolynomial σ R)}
    [DecidableEq G]
    (L : List (SmallSPolynomialSummand σ R G))
    (g : G) :
    coeffFinsupp (R := R) L g * (g : MvPolynomial σ R) =
      ((L.filter fun s => decide (s.g = g)).map SmallSPolynomialSummand.poly).sum := by
  classical
  induction L with
  | nil =>
      simp [coeffFinsupp]
  | cons s L ih =>
      by_cases hsg : s.g = g
      · simp [coeffFinsupp, hsg, SmallSPolynomialSummand.poly, add_mul]
        simpa [coeffFinsupp] using ih
      · simp [coeffFinsupp, hsg]
        simpa [coeffFinsupp] using ih

end SmallSPolynomialSummand

namespace HasStandardRepresentationBelow

omit [NoZeroDivisors R] in
/-- Convert a list-style standard representation into a finitely supported
coefficient representation on `G`, keeping the strict degree bound after
combining repeated basis elements. -/
lemma to_finsupp_lt
    (ord : MonomialOrder σ)
    {G : Set (MvPolynomial σ R)}
    {p : MvPolynomial σ R}
    {D : σ →₀ ℕ}
    (h : HasStandardRepresentationBelow ord G p D) :
    ∃ q : G →₀ MvPolynomial σ R,
      p = Finsupp.linearCombination (MvPolynomial σ R)
          (fun g : G => (g : MvPolynomial σ R)) q ∧
      ∀ g : G,
        q g * (g : MvPolynomial σ R) = 0 ∨
          ord.toSyn (ord.degree (q g * (g : MvPolynomial σ R))) <
            ord.toSyn D := by
  classical
  rcases h with ⟨L, hsum, hsmall⟩
  refine ⟨SmallSPolynomialSummand.coeffFinsupp (R := R) L, ?_, ?_⟩
  · rw [SmallSPolynomialSummand.coeffFinsupp_linearCombination]
    exact hsum
  · intro g
    rw [SmallSPolynomialSummand.coeffFinsupp_mul_eq_filter_sum]
    apply list_sum_eq_zero_or_degree_lt_of_forall_degree_lt (ord := ord)
    intro q hq
    rcases List.mem_map.mp hq with ⟨s, hs, rfl⟩
    exact hsmall s (List.mem_of_mem_filter hs)

end HasStandardRepresentationBelow

lemma standardRepresentationBelow_scaled_sPolynomial_of_chain
    (ord : MonomialOrder σ)
    {G : Set (MvPolynomial σ R)}
    (hmonic : ∀ g ∈ G, ord.leadingCoeff g = 1)
    {D : σ →₀ ℕ} :
    ∀ (p : ℕ) (F : Fin (p + 1) → MvPolynomial σ R),
      (∀ i, F i ∈ G) →
      (∀ i, ord.degree (F i) ≤ D) →
      (∀ i : Fin p,
        AdjacentSmallSPolynomialRep ord G (F i.castSucc) (F i.succ)) →
      HasStandardRepresentationBelow ord G
        (MvPolynomial.monomial
            (D - headLcm ord (F 0) (F ⟨p, Nat.lt_succ_self p⟩)) (1 : R) *
          ord.sPolynomial (F 0) (F ⟨p, Nat.lt_succ_self p⟩))
        D := by
  intro p
  induction p with
  | zero =>
      intro F hmem hdeg hadj
      refine ⟨[], ?_, ?_⟩
      · simp
      · intro s hs
        simp at hs
  | succ p ih =>
      intro F hmem hdeg hadj
      let Ftail : Fin (p + 1) → MvPolynomial σ R := fun i => F i.succ
      have htail_mem : ∀ i, Ftail i ∈ G := by
        intro i
        exact hmem i.succ
      have htail_deg : ∀ i, ord.degree (Ftail i) ≤ D := by
        intro i
        exact hdeg i.succ
      have htail_adj :
          ∀ i : Fin p,
            AdjacentSmallSPolynomialRep ord G (Ftail i.castSucc) (Ftail i.succ) := by
        intro i
        simpa [Ftail] using hadj i.succ
      have hfirst₀ :
          HasStandardRepresentationBelow ord G
            (ord.sPolynomial (F (0 : Fin (p + 2))) (F (1 : Fin (p + 2))))
            (headLcm ord (F (0 : Fin (p + 2))) (F (1 : Fin (p + 2)))) := by
        simpa using
          HasStandardRepresentationBelow.of_adjacentSmallSPolynomialRep
            (ord := ord) (G := G) (hadj (0 : Fin (p + 1)))
      have hfirst_le :
          headLcm ord (F (0 : Fin (p + 2))) (F (1 : Fin (p + 2))) ≤ D := by
        exact headLcm_le_of_degree_le (ord := ord) (hdeg 0) (hdeg 1)
      have hfirst :
          HasStandardRepresentationBelow ord G
            (MvPolynomial.monomial
                (D - headLcm ord (F (0 : Fin (p + 2))) (F (1 : Fin (p + 2))))
                (1 : R) *
              ord.sPolynomial (F (0 : Fin (p + 2))) (F (1 : Fin (p + 2))))
            D :=
        HasStandardRepresentationBelow.monomial_mul
          (ord := ord) (G := G) hmonic hfirst₀ hfirst_le
      have htail :
          HasStandardRepresentationBelow ord G
            (MvPolynomial.monomial
                (D - headLcm ord (Ftail 0) (Ftail ⟨p, Nat.lt_succ_self p⟩))
                (1 : R) *
              ord.sPolynomial (Ftail 0) (Ftail ⟨p, Nat.lt_succ_self p⟩))
            D :=
        ih Ftail htail_mem htail_deg htail_adj
      have hsum :
          HasStandardRepresentationBelow ord G
            (MvPolynomial.monomial
                (D - headLcm ord (F (0 : Fin (p + 2))) (F (1 : Fin (p + 2))))
                (1 : R) *
              ord.sPolynomial (F (0 : Fin (p + 2))) (F (1 : Fin (p + 2))) +
             MvPolynomial.monomial
                (D - headLcm ord (F (1 : Fin (p + 2)))
                  (F ⟨p + 1, Nat.lt_succ_self (p + 1)⟩))
                (1 : R) *
              ord.sPolynomial (F (1 : Fin (p + 2)))
                (F ⟨p + 1, Nat.lt_succ_self (p + 1)⟩))
            D := by
        apply HasStandardRepresentationBelow.add (ord := ord)
        · exact hfirst
        · simpa [Ftail] using htail
      rw [scaledSPolynomial_telescope_three
            (ord := ord) (G := G) hmonic
            (a := F (0 : Fin (p + 2)))
            (b := F (1 : Fin (p + 2)))
            (c := F ⟨p + 1, Nat.lt_succ_self (p + 1)⟩)
            (D := D)
            (hmem 0) (hmem 1) (hmem ⟨p + 1, Nat.lt_succ_self (p + 1)⟩)
            (hdeg 0) (hdeg 1) (hdeg ⟨p + 1, Nat.lt_succ_self (p + 1)⟩)]
      exact hsum

/-- Paper condition `(7)` gives a standard representation below the endpoint
lcm for the endpoint `S`-polynomial.

This is the finite-chain telescoping step in the CGG proof: adjacent
representations are first lifted to the common endpoint bound and then summed
with the coefficients appearing in the usual decomposition of an endpoint
`S`-polynomial along a chain whose degree supremum is the endpoint lcm. -/
lemma standardRepresentationBelow_sPolynomial_of_hasGoodChain
    (ord : MonomialOrder σ)
    {G : Set (MvPolynomial σ R)}
    (hmonic : ∀ g ∈ G, ord.leadingCoeff g = 1)
    {f g : MvPolynomial σ R}
    (hchain : HasGoodChain ord G f g) :
    HasStandardRepresentationBelow ord G (ord.sPolynomial f g) (headLcm ord f g) := by
  classical
  rcases hchain with ⟨p, F, h0, hp, hmem, hsup, hadj⟩
  let D : σ →₀ ℕ := headLcm ord f g
  have hdeg : ∀ i, ord.degree (F i) ≤ D := by
    intro i
    have hi :
        ord.degree (F i) ≤
          Finset.univ.sup (fun j : Fin (p + 1) => ord.degree (F j)) :=
      Finset.le_sup
        (s := (Finset.univ : Finset (Fin (p + 1))))
        (f := fun j : Fin (p + 1) => ord.degree (F j))
        (by simp : i ∈ (Finset.univ : Finset (Fin (p + 1))))
    simpa [D, hsup] using hi
  have hscaled :
      HasStandardRepresentationBelow ord G
        (MvPolynomial.monomial
            (D - headLcm ord (F 0) (F ⟨p, Nat.lt_succ_self p⟩)) (1 : R) *
          ord.sPolynomial (F 0) (F ⟨p, Nat.lt_succ_self p⟩))
        D :=
    standardRepresentationBelow_scaled_sPolynomial_of_chain
      (ord := ord) (G := G) hmonic (D := D) p F hmem hdeg hadj
  simpa [D, h0, hp] using hscaled

omit [NoZeroDivisors R] in
private lemma degree_lt_of_left_ne_zero_of_degree_mul_lt_of_mem_nonZeroDivisors
    (ord : MonomialOrder σ)
    {p p' q : MvPolynomial σ R}
    (hp : p ≠ 0) (hq : ord.leadingCoeff q ∈ nonZeroDivisors _)
    (h : ord.toSyn (ord.degree (p * q)) < ord.toSyn (ord.degree (p' * q))) :
    ord.toSyn (ord.degree p) < ord.toSyn (ord.degree p') := by
  apply lt_of_le_of_lt' ord.degree_mul_le at h
  simpa [ord.degree_mul_of_right_mem_nonZeroDivisors hp hq] using h

omit [NoZeroDivisors R] in
private lemma degree_mul_lt_iff_left_lt_of_ne_zero_of_mem_nonZeroDivisors
    (ord : MonomialOrder σ)
    {p p' q : MvPolynomial σ R}
    (hp : p ≠ 0) (hq : ord.leadingCoeff q ∈ nonZeroDivisors _) :
    ord.toSyn (ord.degree (p * q)) < ord.toSyn (ord.degree (p' * q)) ↔
      ord.toSyn (ord.degree p) < ord.toSyn (ord.degree p') := by
  refine ⟨degree_lt_of_left_ne_zero_of_degree_mul_lt_of_mem_nonZeroDivisors
      (ord := ord) hp hq, ?_⟩
  intro h
  simpa [ord.degree_mul_of_right_mem_nonZeroDivisors hp hq,
    ord.degree_mul_of_right_mem_nonZeroDivisors
      (show p' ≠ 0 by contrapose! h; simp [h]) hq] using h

/-- Standard-representation form of Buchberger's criterion used by the paper.

Compared with `isGroebnerBasis_iff_isRemainder_sPolynomial_zero`, this accepts
the weaker paper-style input: each `S(g₁,g₂)` has a representation whose
summands are strictly below `lcm(Head g₁, Head g₂)`, rather than requiring a
division remainder with terms bounded by `degree (S(g₁,g₂))`. -/
lemma isGroebnerBasis_of_pairwise_standardRepresentationBelow
    (ord : MonomialOrder σ)
    (G : Set (MvPolynomial σ R))
    (I : Ideal (MvPolynomial σ R))
    (hspan : Ideal.span G = I)
    (hmonic : ∀ g ∈ G, ord.leadingCoeff g = 1)
    (hstd :
      ∀ f ∈ G, ∀ g ∈ G,
        HasStandardRepresentationBelow ord G (ord.sPolynomial f g) (headLcm ord f g)) :
    ord.IsGroebnerBasis G I := by
  classical
  have hunit : ∀ g ∈ G, IsUnit (ord.leadingCoeff g) := by
    intro g hg
    rw [hmonic g hg]
    exact isUnit_one
  have hGBspan : ord.IsGroebnerBasis G (Ideal.span G) := by
    have hG₀ {g : G} :
        ord.leadingCoeff (g : MvPolynomial σ R) ∈ nonZeroDivisors _ := by
      have hgunit : IsUnit (ord.leadingCoeff (g : MvPolynomial σ R)) :=
        hunit (g : MvPolynomial σ R) g.property
      exact hgunit.mem_nonZeroDivisors
    rw [MonomialOrder.IsGroebnerBasis.isGroebnerBasis_iff_subset_ideal_and_isRemainder_zero
      (G := G) (I := Ideal.span G) (hG := hunit)]
    refine ⟨Ideal.subset_span, ?_⟩
    intro p hp
    by_cases hpzero : p = 0
    · subst p
      simp
    have hpne0 : p ≠ 0 := hpzero
    simp_rw [MonomialOrder.IsRemainder.isRemainder_def, add_zero, ← map_add,
      ← ord.withBotDegree_mul_of_left_mem_nonZeroDivisors hG₀,
      ord.withBotDegree_le_withBotDegree_iff_of_ne_zero _ hpne0]
    refine ⟨?_, by simp⟩
    obtain ⟨f₀, G'₀, hG'₀, ⟨-, hsumf₀⟩⟩ :=
      Submodule.mem_span_iff_exists_finset_subset.mp hp
    let G' : Finset G :=
      G'₀.attach.image (β := G) (fun p => ⟨p.val, hG'₀ p.prop⟩)
    let f : G → MvPolynomial σ R := fun p => f₀ p
    convert_to ∑ a ∈ G', f a * a = p at hsumf₀
    · unfold G'
      rw [Finset.sum_image]
      · exact Finset.sum_attach .. |>.symm
      · simp [Function.Injective]
    clear_value G' f
    clear hG'₀ G'₀ f₀
    by_cases h :
        G'.sup (fun g => ord.toSyn <| ord.degree <| g.val * (f g)) ≤
          ord.toSyn (ord.degree p)
    · exact ⟨f, G', hsumf₀.symm, by simpa [mul_comm] using h⟩
    refine WellFounded.induction_bot WellFoundedLT.toWellFoundedRelation.wf
      (a := G'.sup fun g => ord.toSyn <| ord.degree <| g.val * (f g))
      (bot := ord.toSyn (ord.degree p))
      (C := fun a =>
        ord.toSyn (ord.degree p) ≤ a ∧
          ∃ (f : G → MvPolynomial σ R) (G' : Finset G),
            p = ∑ g ∈ G', (f g) * g ∧
            ∀ g ∈ G', (ord.toSyn <| ord.degree <| g.val * f g) ≤ a)
      (fun a ha_ne hx => ?_)
      ⟨le_of_lt (lt_of_not_ge h), f, G', hsumf₀.symm, by apply Finset.le_sup⟩ |>.2
    rcases hx with ⟨a_le, f, G', hsumf, h_deg_le⟩
    wlog hf_support : ∀ g, g ∉ G' → f g = 0 generalizing f
    · specialize this (fun g => if g ∈ G' then f g else 0)
      simp_all
    apply lt_of_le_of_ne' a_le at ha_ne
    have ha : ord.toSyn (ord.degree p) < a := ha_ne
    let degFgEqA (g : G) := (ord.toSyn <| ord.degree <| f g * g.val) = a
    let lt' (g : G) := if degFgEqA g then ord.leadingTerm (f g) else 0
    have hp := calc
      p = ∑ g ∈ G', f g * g := hsumf
      _ = ∑ g ∈ G' with degFgEqA g, ord.leadingTerm (f g) * g +
          ∑ g ∈ G', (f g - lt' g) * g := by
        simp [← Finset.sum_add_distrib, ← add_mul, ← ite_zero_mul, Finset.sum_filter,
          -ite_mul, lt']
    have h_a_gt_zero : 0 < a := bot_lt_of_lt ha
    let leadingTerm_mul_eq (p q : MvPolynomial σ R) :
        ord.leadingTerm p * q =
          ord.leadingCoeff p • (MvPolynomial.monomial (ord.degree p) 1 * q) := by
      rw [MvPolynomial.smul_eq_C_mul, ← mul_assoc, MvPolynomial.C_mul_monomial, mul_one,
        MonomialOrder.leadingTerm]
    obtain ⟨c, h_sum_sPoly⟩ :=
      ord.sPolynomial_decomposition_of_degree_sum_smul_le
        (d := a) (B := G'.filter degFgEqA)
        (g := fun g => MvPolynomial.monomial (ord.degree (f g)) 1 * g.val)
        (c := fun g => ord.leadingCoeff (f g))
        (hB := by
          intro b hb
          rw [ord.leadingCoeff_mul_of_right_mem_nonZeroDivisors'
            (f := MvPolynomial.monomial (ord.degree (f b)) (1 : R))
            (g := (b : MvPolynomial σ R)) hG₀]
          simp [hmonic (b : MvPolynomial σ R) b.property])
        (by
          simp only [Finset.mem_filter, and_imp, degFgEqA]
          intro b hb hba
          have hfb0 : f b ≠ 0 := by
            intro hfb
            have hzero :
                ord.toSyn (ord.degree (f b * (b : MvPolynomial σ R))) = 0 := by
              simp [hfb]
            rw [hzero] at hba
            exact (ne_of_gt h_a_gt_zero) hba.symm
          have hone : (1 : R) ≠ 0 := by
            intro h1
            haveI : Subsingleton R := subsingleton_of_zero_eq_one h1.symm
            exact hfb0 (Subsingleton.elim _ _)
          have hmonone :
              MvPolynomial.monomial (ord.degree (f b)) (1 : R) ≠ 0 := by
            simpa using (MvPolynomial.monomial_eq_zero (s := ord.degree (f b))).not.mpr hone
          have hba' :
              ord.toSyn (ord.degree (f b) + ord.degree (b : MvPolynomial σ R)) = a := by
            rw [ord.degree_mul_of_right_mem_nonZeroDivisors hfb0 hG₀] at hba
            simpa [map_add] using hba
          rw [ord.degree_mul_of_right_mem_nonZeroDivisors hmonone hG₀, map_add]
          simpa [ord.degree_monomial, hone] using hba')
        (by
          simp only [leadingTerm_mul_eq] at hp
          simp only [← sub_eq_iff_eq_add.mpr hp]
          apply lt_of_le_of_lt ord.degree_sub_le
          simp only [sup_lt_iff, ha, true_and]
          apply lt_of_le_of_lt ord.degree_sum_le
          simp only [Finset.sup_lt_iff h_a_gt_zero, lt']
          intro g hg
          wlog hdeg : degFgEqA g
          · simpa [hdeg] using lt_of_le_of_ne (mul_comm g.val _ ▸ h_deg_le g hg) hdeg
          simp only [hdeg, ↓reduceIte]
          by_cases h' : f g - ord.leadingTerm (f g) = 0
          · simp [h_a_gt_zero, h']
          apply lt_of_le_of_lt' (h_deg_le g hg)
          rw [mul_comm g.val,
            degree_mul_lt_iff_left_lt_of_ne_zero_of_mem_nonZeroDivisors
              (ord := ord) h' hG₀]
          exact ord.degree_sub_leadingTerm_lt_degree
            (ord.degree_ne_zero_of_sub_leadingTerm_ne_zero h'))
    conv at h_sum_sPoly =>
      simp only [← leadingTerm_mul_eq]
      rhs
      simp only [ord.sPolynomial_monomial_mul_of_mem_nonZeroDivisors hG₀ hG₀,
        ← G'.filter degFgEqA |>.sum_coe_sort]
    have hstd_finsupp (g₁ g₂ : G'.filter degFgEqA) :
        ∃ q : G →₀ MvPolynomial σ R,
          ord.sPolynomial (g₁.val : MvPolynomial σ R) (g₂.val : MvPolynomial σ R) =
            Finsupp.linearCombination (MvPolynomial σ R)
              (fun g : G => (g : MvPolynomial σ R)) q ∧
          ∀ g : G,
            q g * (g : MvPolynomial σ R) = 0 ∨
              ord.toSyn (ord.degree (q g * (g : MvPolynomial σ R))) <
                ord.toSyn (headLcm ord
                  (g₁.val : MvPolynomial σ R) (g₂.val : MvPolynomial σ R)) := by
      exact HasStandardRepresentationBelow.to_finsupp_lt
        (ord := ord) (G := G)
        (p := ord.sPolynomial (g₁.val : MvPolynomial σ R) (g₂.val : MvPolynomial σ R))
        (D := headLcm ord (g₁.val : MvPolynomial σ R) (g₂.val : MvPolynomial σ R))
        (hstd (g₁.val : MvPolynomial σ R) g₁.val.property
          (g₂.val : MvPolynomial σ R) g₂.val.property)
    let q (g₁ g₂ : G'.filter degFgEqA) := Classical.choose (hstd_finsupp g₁ g₂)
    have hq_eq (g₁ g₂ : G'.filter degFgEqA) :
        ord.sPolynomial (g₁.val : MvPolynomial σ R) (g₂.val : MvPolynomial σ R) =
          Finsupp.linearCombination (MvPolynomial σ R)
            (fun g : G => (g : MvPolynomial σ R)) (q g₁ g₂) := by
      dsimp [q]
      exact (Classical.choose_spec (hstd_finsupp g₁ g₂)).1
    have hq (g₁ g₂ : G'.filter degFgEqA) :
        ∀ g : G,
          q g₁ g₂ g * (g : MvPolynomial σ R) = 0 ∨
            ord.toSyn (ord.degree (q g₁ g₂ g * (g : MvPolynomial σ R))) <
              ord.toSyn (headLcm ord
                (g₁.val : MvPolynomial σ R) (g₂.val : MvPolynomial σ R)) := by
      dsimp [q]
      exact (Classical.choose_spec (hstd_finsupp g₁ g₂)).2
    clear_value q
    let G'' : Finset G := G' ∪
      (G'.filter degFgEqA).attach.biUnion fun b₁ =>
        (G'.filter degFgEqA).attach.biUnion fun b₂ => (q b₁ b₂).support
    have hq_sum (g₁ g₂ : G'.filter degFgEqA) :
        ord.sPolynomial (g₁.val : MvPolynomial σ R) (g₂.val : MvPolynomial σ R) =
          ∑ g ∈ G'', q g₁ g₂ g * (g : MvPolynomial σ R) :=
    by
      rw [hq_eq g₁ g₂]
      rw [Finsupp.linearCombination_apply_of_mem_supported
        (l := (q g₁ g₂)) (s := G'')
        (hs := by
          simp only [Finset.coe_union, Finset.coe_biUnion, Finset.coe_attach, Set.mem_univ,
            Set.iUnion_true, Finsupp.mem_supported, G'']
          apply Set.subset_union_of_subset_right
          exact Set.subset_iUnion₂_of_subset g₁ g₂ subset_rfl)]
      simp [smul_eq_mul]
    simp_rw [hq_sum] at h_sum_sPoly
    simp_rw [Finset.mul_sum, ← mul_assoc, Finset.smul_sum,
      ← smul_mul_assoc, MvPolynomial.smul_monomial, Finset.sum_comm (t := G''), ← Finset.sum_mul,
      smul_eq_mul (α := R), mul_one] at h_sum_sPoly
    convert_to p = _ + ∑ g ∈ G'', (f g - lt' g) * g using 2 at hp
    · exact Finset.sum_subset (by simp [G'']) (by simp_intro .. [hf_support, lt'])
    simp_rw [h_sum_sPoly, ← Finset.sum_add_distrib, ← add_mul] at hp
    refine ⟨ord.toSyn (ord.degree p) ⊔
        G''.sup fun g => ord.toSyn <| ord.degree <| ?f' g * g.val,
      (?_ : _ < _), by simp, ?f', G'', by exact hp, ?le_max⟩
    case le_max =>
      intro g hg
      rw [mul_comm]
      exact le_trans (Finset.le_sup (s := G'')
          (f := fun g => ord.toSyn <| ord.degree (?f' g * g.val)) (by assumption))
        le_sup_right
    clear hp h_sum_sPoly
    simp only [Finset.univ_eq_attach, add_mul, sup_lt_iff, ha,
      Finset.sup_lt_iff h_a_gt_zero, true_and]
    intro g hg'
    apply lt_of_le_of_lt ord.degree_add_le
    apply max_lt
    · simp_rw [Finset.sum_mul]
      refine lt_of_le_of_lt ord.degree_sum_le <| (Finset.sup_lt_iff h_a_gt_zero).mpr ?_
      simp only [Finset.mem_attach, forall_const]
      intro g₁
      refine lt_of_le_of_lt ord.degree_sum_le <| (Finset.sup_lt_iff h_a_gt_zero).mpr ?_
      simp only [Finset.mem_attach, forall_const]
      intro g₂
      obtain hq_small := hq g₁ g₂ g
      rcases hq_small with hq_zero | hq_lt
      · rw [mul_assoc, hq_zero]
        simp [h_a_gt_zero]
      · rw [mul_assoc]
        apply lt_of_le_of_lt ord.degree_mul_le
        rw [AddEquiv.map_add]
        refine add_lt_of_add_lt_right ?_ (ord.degree_monomial_le _)
        apply lt_of_lt_of_le
          (add_lt_add_right (by
            simpa [mul_comm] using hq_lt) _)
        rw [headLcm]
        rw [← AddEquiv.map_add,
          tsub_add_cancel_of_le <| sup_le_sup (by simp) (by simp)]
        have hfgg₁ := (G'.mem_filter.mp g₁.2).2
        have hfgg₂ := (G'.mem_filter.mp g₂.2).2
        unfold degFgEqA at hfgg₁ hfgg₂
        rw [ord.degree_mul_of_right_mem_nonZeroDivisors (by
          by_contra! hfg0
          simp only [hfg0, zero_mul, MonomialOrder.degree_zero, map_zero] at hfgg₁
          exact (ne_of_lt h_a_gt_zero) hfgg₁) hG₀,
          ← ord.toSyn.eq_symm_apply] at hfgg₁
        rw [ord.degree_mul_of_right_mem_nonZeroDivisors (by
          by_contra! hfg0
          simp only [hfg0, zero_mul, MonomialOrder.degree_zero, map_zero] at hfgg₂
          exact (ne_of_lt h_a_gt_zero) hfgg₂) hG₀,
          ← ord.toSyn.eq_symm_apply] at hfgg₂
        · simp [hfgg₁, hfgg₂]
    · by_cases hdeg : degFgEqA g
      swap
      · by_cases hg'G' : g ∈ G'
        · simp [hdeg, lt', lt_of_le_of_ne (mul_comm (f g) g ▸ h_deg_le g hg'G') hdeg]
        · simp [hg'G', h_a_gt_zero, lt', hf_support]
      simp only [hdeg, ↓reduceIte, lt']
      by_cases hLTgg' : f g - ord.leadingTerm (f g) = 0
      · rw [hLTgg']
        simp [h_a_gt_zero]
      have hdeg_eq : ord.toSyn (ord.degree (f g * (g : MvPolynomial σ R))) = a := by
        simpa [degFgEqA] using hdeg
      rw [← hdeg] at ha h_a_gt_zero
      apply ne_of_lt at h_a_gt_zero
      rw [ne_eq, eq_comm, MonomialOrder.toSyn_eq_zero_iff] at h_a_gt_zero
      have hfg0 : f g ≠ 0 := by
        have := ord.ne_zero_of_degree_ne_zero h_a_gt_zero
        contrapose! this
        simp [this]
      rw [ord.degree_mul_of_right_mem_nonZeroDivisors hLTgg' hG₀]
      have hsub_lt :
          ord.toSyn (ord.degree (f g - ord.leadingTerm (f g))) <
            ord.toSyn (ord.degree (f g)) :=
        ord.degree_sub_leadingTerm_lt_degree
          (ord.degree_ne_zero_of_sub_leadingTerm_ne_zero hLTgg')
      have hfg_deg :
          ord.toSyn (ord.degree (f g) + ord.degree (g : MvPolynomial σ R)) = a := by
        have hdeg' : ord.toSyn (ord.degree (f g * (g : MvPolynomial σ R))) = a := hdeg_eq
        rw [ord.degree_mul_of_right_mem_nonZeroDivisors hfg0 hG₀] at hdeg'
        simpa [map_add] using hdeg'
      have hlt_add :
          ord.toSyn (ord.degree (f g - ord.leadingTerm (f g)) +
              ord.degree (g : MvPolynomial σ R)) <
            ord.toSyn (ord.degree (f g) + ord.degree (g : MvPolynomial σ R)) := by
        simpa [map_add]
          using add_lt_add_right hsub_lt (ord.toSyn (ord.degree (g : MvPolynomial σ R)))
      simpa [map_add, hfg_deg] using hlt_add
  simpa [hspan] using hGBspan

/-- Main theorem via the standard-representation route:

    pairwise good chains
      -> standard representations below lcms for all `S`-polynomials
      -> ordinary Gröbner basis
      -> Definition 3.1 paper-style Gröbner basis. -/
lemma isGroebnerBasis_paper3_1_of_pairwise_hasGoodChain
    (ord : MonomialOrder σ)
    (G : Set (MvPolynomial σ R))
    (I : Ideal (MvPolynomial σ R))
    (hspan : Ideal.span G = I)
    (hmonic : ∀ g ∈ G, ord.leadingCoeff g = 1)
    (hchain : ∀ f ∈ G, ∀ f' ∈ G, HasGoodChain ord G f f') :
    IsGroebnerBasis_paper3_1 ord G I := by
  have hunit : ∀ g ∈ G, IsUnit (ord.leadingCoeff g) := by
    intro g hg
    rw [hmonic g hg]
    exact isUnit_one
  have hstd :
      ∀ f ∈ G, ∀ g ∈ G,
        HasStandardRepresentationBelow ord G (ord.sPolynomial f g) (headLcm ord f g) := by
    intro f hf g hg
    exact standardRepresentationBelow_sPolynomial_of_hasGoodChain
      (ord := ord) (G := G) hmonic (hchain f hf g hg)
  have hGB : ord.IsGroebnerBasis G I :=
    isGroebnerBasis_of_pairwise_standardRepresentationBelow
      (ord := ord) (G := G) (I := I) hspan hmonic hstd
  exact (isGroebnerBasis_paper3_1_iff (m := ord) G I hunit).mpr hGB


end paper3_2_reduction





section paper_prop_1_0

variable {σ : Type*}
variable {R : Type*} [CommRing R]




lemma isGroebnerBasis_of_pairwise_hasGoodChain
    [NoZeroDivisors R]
    (ord : MonomialOrder σ)
    (G : Set (MvPolynomial σ R))
    (I : Ideal (MvPolynomial σ R))
    (hspan : Ideal.span G = I)
    (hmonic : ∀ g ∈ G, ord.leadingCoeff g = 1)
    (hchain : ∀ f ∈ G, ∀ f' ∈ G, HasGoodChain ord G f f') :
    ord.IsGroebnerBasis G I := by
  have hunit : ∀ g ∈ G, IsUnit (ord.leadingCoeff g) := by
    intro g hg
    rw [hmonic g hg]
    exact isUnit_one
  exact
    (isGroebnerBasis_paper3_1_iff (m := ord) G I hunit).mp <|
      isGroebnerBasis_paper3_1_of_pairwise_hasGoodChain
        (ord := ord) (G := G) (I := I)
        hspan hmonic hchain

/-- Migration wrapper: if you still only have old-style chains proved, this lets you
use them without changing the final theorem statement immediately. -/
lemma isGroebnerBasis_of_pairwise_hasGoodChain_old
    [NoZeroDivisors R]
    (ord : MonomialOrder σ)
    (G : Set (MvPolynomial σ R))
    (I : Ideal (MvPolynomial σ R))
    (hspan : Ideal.span G = I)
    (hmonic : ∀ g ∈ G, ord.leadingCoeff g = 1)
    (hchain : ∀ f ∈ G, ∀ f' ∈ G, HasGoodChainOld ord G f f') :
    ord.IsGroebnerBasis G I := by
  apply isGroebnerBasis_of_pairwise_hasGoodChain
    (ord := ord) (G := G) (I := I)
    hspan hmonic
  intro f hf f' hf'
  exact hasGoodChainOld_implies_new ord G f f' (hchain f hf f' hf')

end paper_prop_1_0







section paper1_1

variable {m n t : ℕ}

/-
`MinorIndex m n t` is assumed to be:
structure MinorIndex (m n t : ℕ) where
  row : Fin t ↪o Fin m
  col : Fin t ↪o Fin n
-/

/-- Paper-style 1-based row sequence with sentinels:
`rowExt I 0 = 0`, `rowExt I j = I.row (j-1) + 1` for `1 ≤ j ≤ t`,
and `rowExt I j = m+1` for `j > t`. -/
def rowExt (I : MinorIndex m n t) (j : ℕ) : ℕ :=
  if h0 : j = 0 then
    0
  else if hj : j ≤ t then
    ((I.row ⟨j - 1, by omega⟩ : Fin m).1 + 1)
  else
    m + 1

/-- Paper-style 1-based column sequence with sentinels:
`colExt I 0 = 0`, `colExt I j = I.col (j-1) + 1` for `1 ≤ j ≤ t`,
and `colExt I j = n+1` for `j > t`. -/
def colExt (I : MinorIndex m n t) (j : ℕ) : ℕ :=
  if h0 : j = 0 then
    0
  else if hj : j ≤ t then
    ((I.col ⟨j - 1, by omega⟩ : Fin n).1 + 1)
  else
    n + 1

/-- `diffAt I J j` means that the `j`-th paper-position (`j = 1, ..., t`)
has different row/column data in `I` and `J`.

We use paper-style 1-based indexing on `ℕ`; for `j = 0` or `j > t`, this is `False`. -/
def diffAt (I J : MinorIndex m n t) (j : ℕ) : Prop :=
  match j with
  | 0 => False
  | k + 1 =>
      if hk : k < t then
        (I.row ⟨k, hk⟩, I.col ⟨k, hk⟩) ≠ (J.row ⟨k, hk⟩, J.col ⟨k, hk⟩)
      else
        False

lemma diffAt_symm
    (I J : MinorIndex m n t) (j : ℕ) :
    diffAt I J j ↔ diffAt J I j := by
  cases j with
  | zero =>
      simp [diffAt]
  | succ k =>
      by_cases hk : k < t
      · simp [diffAt, hk, ne_comm];grind
      · simp [diffAt, hk]

/-- Paper's
`p := max { i : (α_i, β_i) ≠ (α'_i, β'_i) }`.

If there is no such index, `Nat.findGreatest` returns `0`. -/
noncomputable def pClose (I J : MinorIndex m n t) : ℕ := by
  classical
  exact Nat.findGreatest (diffAt I J) t



/-- Predicate for paper's
`s := max { j : j < p, α_j < α'_{j+1}, β_j < β'_{j+1} }`. -/
def sPred (I J : MinorIndex m n t) (j : ℕ) : Prop :=
  j < pClose I J ∧
    rowExt I j < rowExt J (j + 1) ∧
    colExt I j < colExt J (j + 1)

/-- Paper's `s`. Note that `j = 0` is allowed, thanks to the sentinel values. -/
noncomputable def sClose (I J : MinorIndex m n t) : ℕ := by
  classical
  exact Nat.findGreatest (sPred I J) (pClose I J)


/-- Predicate for paper's
`u := min { k : s < k, α'_k < α_{k+1}, β'_k < β_{k+1} }`.

This is the paper's third index, renamed to `uClose` to avoid conflict with
the ambient minor size parameter `t`. -/
def uPred (I J : MinorIndex m n t) (k : ℕ) : Prop :=
  sClose I J < k ∧
    rowExt J k < rowExt I (k + 1) ∧
    colExt J k < colExt I (k + 1)

/-- Paper's third index `t`, renamed here as `uClose`.

We define it as the least `k` satisfying `uPred`. In the intended applications
(one later proves `I ≠ J` / `Close I J` hypotheses), such a `k` exists. If Lean
cannot find one definitionally, we fall back to the ambient size `t`. -/
noncomputable def uClose (I J : MinorIndex m n t) : ℕ := by
  classical
  exact if h : ∃ k, uPred I J k then Nat.find h else t

/-- Raw row coordinates of the paper's `μ = μ((α,β),(α',β'))`.

This is the piecewise sequence
`(α₁,…,α_s, α'_{s+1},…,α'_u, α_{u+1},…,α_r)` in 0-based Lean indexing. -/
noncomputable def muRow (I J : MinorIndex m n t) (k : Fin t) : Fin m :=
  if k.1 + 1 ≤ sClose I J then
    I.row k
  else if k.1 + 1 ≤ uClose I J then
    J.row k
  else
    I.row k

/-- Raw column coordinates of the paper's `μ = μ((α,β),(α',β'))`.

This is the piecewise sequence
`(β₁,…,β_s, β'_{s+1},…,β'_u, β_{u+1},…,β_r)` in 0-based Lean indexing. -/
noncomputable def muCol (I J : MinorIndex m n t) (k : Fin t) : Fin n :=
  if k.1 + 1 ≤ sClose I J then
    I.col k
  else if k.1 + 1 ≤ uClose I J then
    J.col k
  else
    I.col k

def strictMonoToOrderEmbedding
    {α β : Type*} [LinearOrder α] [LinearOrder β]
    (f : α → β) (hf : StrictMono f) : α ↪o β :=
  { toFun := f
    inj' := hf.injective
    map_rel_iff' := by
      intro a b
      constructor
      · intro hab
        by_contra hba
        have hlt : b < a := lt_of_not_ge hba
        have h' : f b < f a := hf hlt
        exact not_lt_of_ge hab h'
      · intro hab
        exact hf.monotone hab }


lemma exists_diffAt
    (I J : MinorIndex m n t)
    (hIJ : I ≠ J) :
    ∃ j ≤ t, diffAt I J j := by
  have hdiff : ∃ k : Fin t, (I.row k, I.col k) ≠ (J.row k, J.col k) := by
    by_contra h
    push_neg at h
    apply hIJ
    cases I with
    | mk rowI colI =>
      cases J with
      | mk rowJ colJ =>
        simp only [Prod.mk.injEq, MinorIndex.mk.injEq] at h ⊢
        have hrow : rowI = rowJ := by
          ext k
          have h:=h k
          refine Fin.val_eq_of_eq ?_
          exact h.1
        have hcol : colI = colJ := by
          ext k
          have h:=h k
          refine Fin.val_eq_of_eq ?_
          exact h.2
        simp [hrow, hcol]
  rcases hdiff with ⟨k, hk⟩
  refine ⟨k.1 + 1, Nat.succ_le_of_lt k.2, ?_⟩
  simpa [diffAt, k.2] using hk

lemma pClose_spec
    (I J : MinorIndex m n t)
    (hIJ : I ≠ J) :
    diffAt I J (pClose I J) := by
  classical
  rcases exists_diffAt I J hIJ with ⟨j, hjle, hj⟩
  unfold pClose
  exact Nat.findGreatest_spec hjle hj


lemma pClose_le
    (I J : MinorIndex m n t) :
    pClose I J ≤ t := by
    classical
    unfold pClose
    exact Nat.findGreatest_le t

lemma rowExt_zero_lt_one
    (I : MinorIndex m n t) :
    rowExt I 0 < rowExt I 1 := by
  unfold rowExt
  by_cases h1 : 1 ≤ t
  · simp [h1]
  · simp [h1]

lemma colExt_zero_lt_one
    (I : MinorIndex m n t) :
    colExt I 0 < colExt I 1 := by
  unfold colExt
  by_cases h1 : 1 ≤ t
  · simp [h1]
  · simp [h1]

lemma sPred_zero_of_ne
    (I J : MinorIndex m n t)
    (hIJ : I ≠ J) :
    sPred I J 0 := by
  have hp : 0 < pClose I J := by
    have hspec : diffAt I J (pClose I J) := pClose_spec I J hIJ
    by_contra h0
    have hz : pClose I J = 0 := Nat.eq_zero_of_not_pos h0
    simp [hz, diffAt] at hspec
  refine ⟨hp, ?_, ?_⟩
  · simpa [rowExt] using (rowExt_zero_lt_one J)
  · simpa [colExt] using (colExt_zero_lt_one J)

lemma sClose_lt_pClose
    (I J : MinorIndex m n t)
    (hIJ : I ≠ J) :
    sClose I J < pClose I J := by
  classical
  letI : DecidablePred (sPred I J) := fun a =>
    Classical.propDecidable (sPred I J a)
  have h0pred : sPred I J 0 := sPred_zero_of_ne I J hIJ
  have hspec : sPred I J (sClose I J) := by
    unfold sClose
    exact Nat.findGreatest_spec (show 0 ≤ pClose I J by omega) h0pred
  exact hspec.1

lemma sClose_lt_uClose
    (I J : MinorIndex m n t)
    (hIJ : I ≠ J) :
    sClose I J < uClose I J := by
  classical
  letI : DecidablePred (uPred I J) := fun a =>
    Classical.propDecidable (uPred I J a)
  have hs : sClose I J < pClose I J := sClose_lt_pClose I J hIJ
  have hp : pClose I J ≤ t := pClose_le I J
  unfold uClose
  split_ifs with h
  · exact (Nat.find_spec h).1
  · exact lt_of_lt_of_le hs hp

lemma sClose_spec
    (I J : MinorIndex m n t)
    (hIJ : I ≠ J) :
    sPred I J (sClose I J) := by
  classical
  letI : DecidablePred (sPred I J) := fun a =>
    Classical.propDecidable (sPred I J a)
  have h0 : sPred I J 0 := sPred_zero_of_ne I J hIJ
  unfold sClose
  exact Nat.findGreatest_spec (show 0 ≤ pClose I J by omega) h0

lemma uPred_pClose
    (I J : MinorIndex m n t)
    (hIJ : I ≠ J) :
    uPred I J (pClose I J) := by
  classical
  let p := pClose I J
  have hs : sClose I J < p := by
    simpa [p] using sClose_lt_pClose I J hIJ
  have hp_le : p ≤ t := by
    simpa [p] using pClose_le I J
  have hp_diff : diffAt I J p := by
    simpa [p] using pClose_spec I J hIJ
  have hp_pos : 0 < p := by
    by_contra hp0
    have hpz : p = 0 := Nat.eq_zero_of_not_pos hp0
    have : diffAt I J 0 := by
      simpa [p, hpz] using hp_diff
    simp [diffAt] at this
  refine ⟨by simpa [p] using hs, ?_, ?_⟩
  · -- rowExt J p < rowExt I (p+1)
    by_cases hp1 : p + 1 ≤ t
    · have hp_lt_t : p < t := by
        omega
      let k0 : Fin t := ⟨p - 1, by omega⟩
      let k1 : Fin t := ⟨p, hp_lt_t⟩
      have hnodiff : ¬ diffAt I J (p + 1) := by
        intro hd
        have hle : p + 1 ≤ p := Nat.le_findGreatest hp1 hd
        omega
      have hpair_eq : (I.row k1, I.col k1) = (J.row k1, J.col k1) := by
        by_contra hneq
        exact hnodiff (by
          simpa [diffAt, p, hp1, hp_lt_t, k1] using hneq)
      have hrowJp : rowExt J p = (J.row k0).1 + 1 := by
        unfold rowExt
        simp [p, hp_pos.ne', hp_le, k0]
      have hrowIp1 : rowExt I (p + 1) = (I.row k1).1 + 1 := by
        unfold rowExt
        simp [p, hp1, k1]
      have hk01 : k0 < k1 := by
        simp only [Fin.mk_lt_mk, tsub_lt_self_iff, zero_lt_one, and_true, k0, k1]
        exact Nat.zero_lt_of_lt hs
      have hinc : (J.row k0).1 + 1 < (J.row k1).1 + 1 := by
        exact Nat.succ_lt_succ <| by
          simpa using (J.row.strictMono hk01)
      rw [hrowJp, hrowIp1]
      grind
    · let k0 : Fin t := ⟨p - 1, by omega⟩
      have hrowJp : rowExt J p = (J.row k0).1 + 1 := by
        unfold rowExt
        simp [p, hp_pos.ne', hp_le, k0]
      have hrowIp1 : rowExt I (p + 1) = m + 1 := by
        unfold rowExt
        simp [p, hp1]
      rw [hrowJp, hrowIp1]
      exact Nat.succ_lt_succ (J.row k0).2
  · -- colExt J p < colExt I (p+1)
    by_cases hp1 : p + 1 ≤ t
    · have hp_lt_t : p < t := by
        omega
      let k0 : Fin t := ⟨p - 1, by omega⟩
      let k1 : Fin t := ⟨p, hp_lt_t⟩
      have hnodiff : ¬ diffAt I J (p + 1) := by
        intro hd
        have hle : p + 1 ≤ p := Nat.le_findGreatest hp1 hd
        omega
      have hpair_eq : (I.row k1, I.col k1) = (J.row k1, J.col k1) := by
        by_contra hneq
        exact hnodiff (by
          simpa [diffAt, p, hp1, hp_lt_t, k1] using hneq)
      have hcolJp : colExt J p = (J.col k0).1 + 1 := by
        unfold colExt
        simp [p, hp_pos.ne', hp_le, k0]
      have hcolIp1 : colExt I (p + 1) = (I.col k1).1 + 1 := by
        unfold colExt
        simp [p, hp1, k1]
      have hk01 : k0 < k1 := by
        simp only [Fin.mk_lt_mk, tsub_lt_self_iff, zero_lt_one, and_true, k0, k1]
        exact Nat.zero_lt_of_lt hs
      have hinc : (J.col k0).1 + 1 < (J.col k1).1 + 1 := by
        exact Nat.succ_lt_succ <| by
          simpa using (J.col.strictMono hk01)
      rw [hcolJp, hcolIp1]
      grind
    · let k0 : Fin t := ⟨p - 1, by omega⟩
      have hcolJp : colExt J p = (J.col k0).1 + 1 := by
        unfold colExt
        simp [p, hp_pos.ne', hp_le, k0]
      have hcolIp1 : colExt I (p + 1) = n + 1 := by
        unfold colExt
        simp [p, hp1]
      rw [hcolJp, hcolIp1]
      exact Nat.succ_lt_succ (J.col k0).2

lemma uClose_spec
    (I J : MinorIndex m n t)
    (hIJ : I ≠ J) :
    uPred I J (uClose I J) := by
  classical
  have hp : uPred I J (pClose I J) := uPred_pClose I J hIJ
  unfold uClose
  split_ifs with h
  · exact Nat.find_spec h
  · exfalso
    exact h ⟨pClose I J, hp⟩

lemma uClose_le_pClose
    (I J : MinorIndex m n t)
    (hIJ : I ≠ J) :
    uClose I J ≤ pClose I J := by
  classical
  have hp : uPred I J (pClose I J) := uPred_pClose I J hIJ
  unfold uClose
  split_ifs with h
  · exact Nat.find_le hp
  · exfalso
    exact h ⟨pClose I J, hp⟩

lemma rowExt_monotone (I : MinorIndex m n t) : Monotone (rowExt I) := by
  intro i j hij
  unfold rowExt
  by_cases hi0 : i = 0
  · subst hi0
    split_ifs <;> grind
  · by_cases hj0 : j = 0
    · subst hj0
      simp_all only [nonpos_iff_eq_zero]
    · by_cases hjt : j ≤ t
      · have hit : i ≤ t := le_trans hij hjt
        simp only [hi0, ↓reduceDIte, hit, hj0, hjt, add_le_add_iff_right, Fin.val_fin_le,
          OrderEmbedding.le_iff_le, Fin.mk_le_mk, tsub_le_iff_right, ge_iff_le]
        have hk :
            (⟨i - 1, by omega⟩ : Fin t) ≤ ⟨j - 1, by omega⟩ := by
          simpa using (show i - 1 ≤ j - 1 by exact Nat.sub_le_sub_right hij 1)
        exact Nat.le_add_of_sub_le hk
      · by_cases hit : i ≤ t
        · simp [hi0, hj0, hit, hjt]
        · simp [hi0, hj0, hit, hjt]

lemma colExt_monotone (I : MinorIndex m n t) : Monotone (colExt I) := by
  intro i j hij
  unfold colExt
  by_cases hi0 : i = 0
  · subst hi0
    split_ifs <;> omega
  · by_cases hj0 : j = 0
    · omega
    · by_cases hjt : j ≤ t
      · have hit : i ≤ t := le_trans hij hjt
        simp only [hi0, ↓reduceDIte, hit, hj0, hjt, add_le_add_iff_right, Fin.val_fin_le,
          OrderEmbedding.le_iff_le, Fin.mk_le_mk, tsub_le_iff_right, ge_iff_le]
        have hk :
            (⟨i - 1, by omega⟩ : Fin t) ≤ ⟨j - 1, by omega⟩ := by
          simpa using (show i - 1 ≤ j - 1 by omega)
        exact Nat.le_add_of_sub_le hk
      · by_cases hit : i ≤ t
        · simp [hi0, hj0, hit, hjt]
        · simp [hi0, hj0, hit, hjt]

lemma muRow_strictMono_of_ne
    (I J : MinorIndex m n t)
    (hIJ : I ≠ J) :
    StrictMono (muRow I J) := by
  intro a b hab
  have hsSpec : sPred I J (sClose I J) := sClose_spec I J hIJ
  have huSpec : uPred I J (uClose I J) := uClose_spec I J hIJ
  have hsu : sClose I J < uClose I J := sClose_lt_uClose I J hIJ
  have hmonoI : Monotone (rowExt I) := rowExt_monotone I
  have hmonoJ : Monotone (rowExt J) := rowExt_monotone J
  by_cases haS : a.1 + 1 ≤ sClose I J
  · by_cases hbU : b.1 + 1 ≤ uClose I J
    · by_cases hbS : b.1 + 1 ≤ sClose I J
      · -- both in the left block: both come from `I.row`
        simpa [muRow, haS, hbS] using I.row.strictMono hab
      · -- left block to middle block
        have hs1_le_b : sClose I J + 1 ≤ b.1 + 1 := by
          omega
        have hleft :
            rowExt I (a.1 + 1) ≤ rowExt I (sClose I J) := by
          exact hmonoI haS
        have hright :
            rowExt J (sClose I J + 1) ≤ rowExt J (b.1 + 1) := by
          exact hmonoJ hs1_le_b
        have hbound :
            rowExt I (sClose I J) < rowExt J (sClose I J + 1) := by
          exact hsSpec.2.1
        have hnat :
            rowExt I (a.1 + 1) < rowExt J (b.1 + 1) := by
          exact lt_of_le_of_lt hleft (lt_of_lt_of_le hbound hright)
        have hA :
            rowExt I (a.1 + 1) = (muRow I J a).1 + 1 := by
          simp [rowExt, muRow, haS]
        have hB :
            rowExt J (b.1 + 1) = (muRow I J b).1 + 1 := by
          simp [rowExt, muRow, hbS, hbU]
        rw [hA, hB] at hnat
        have hnat' : (muRow I J a).1 < (muRow I J b).1 := by
          exact Nat.lt_of_succ_lt_succ hnat
        simpa using hnat'
    · -- `b` is in the right block, so both endpoints come from `I.row`
      have hbS : ¬ b.1 + 1 ≤ sClose I J := by
        omega
      simpa [muRow, haS, hbS, hbU] using I.row.strictMono hab
  · by_cases haU : a.1 + 1 ≤ uClose I J
    · by_cases hbU : b.1 + 1 ≤ uClose I J
      · -- both in the middle block: both come from `J.row`
        have hbS : ¬ b.1 + 1 ≤ sClose I J := by
          omega
        simpa [muRow, haS, haU, hbS, hbU] using J.row.strictMono hab
      · -- middle block to right block
        have hu1_le_b : uClose I J + 1 ≤ b.1 + 1 := by
          omega
        have hleft :
            rowExt J (a.1 + 1) ≤ rowExt J (uClose I J) := by
          exact hmonoJ haU
        have hright :
            rowExt I (uClose I J + 1) ≤ rowExt I (b.1 + 1) := by
          exact hmonoI hu1_le_b
        have hbound :
            rowExt J (uClose I J) < rowExt I (uClose I J + 1) := by
          exact huSpec.2.1
        have hnat :
            rowExt J (a.1 + 1) < rowExt I (b.1 + 1) := by
          exact lt_of_le_of_lt hleft (lt_of_lt_of_le hbound hright)
        have hA :
            rowExt J (a.1 + 1) = (muRow I J a).1 + 1 := by
          simp [rowExt, muRow, haS, haU]
        have hbS : ¬ b.1 + 1 ≤ sClose I J := by
          omega
        have hB :
            rowExt I (b.1 + 1) = (muRow I J b).1 + 1 := by
          simp [rowExt, muRow, hbS, hbU]
        rw [hA, hB] at hnat
        have hnat' : (muRow I J a).1 < (muRow I J b).1 := by
          exact Nat.lt_of_succ_lt_succ hnat
        simpa using hnat'
    · -- `a` is already in the right block, hence so is `b`;
      -- both come from `I.row`
      have hbU : ¬ b.1 + 1 ≤ uClose I J := by
        omega
      have hbS : ¬ b.1 + 1 ≤ sClose I J := by
        omega
      simpa [muRow, haS, haU, hbS, hbU] using I.row.strictMono hab

lemma muCol_strictMono_of_ne
    (I J : MinorIndex m n t)
    (hIJ : I ≠ J) :
    StrictMono (muCol I J) := by
  intro a b hab
  have hsSpec : sPred I J (sClose I J) := sClose_spec I J hIJ
  have huSpec : uPred I J (uClose I J) := uClose_spec I J hIJ
  have hsu : sClose I J < uClose I J := sClose_lt_uClose I J hIJ
  have hmonoI : Monotone (colExt I) := colExt_monotone I
  have hmonoJ : Monotone (colExt J) := colExt_monotone J
  by_cases haS : a.1 + 1 ≤ sClose I J
  · by_cases hbU : b.1 + 1 ≤ uClose I J
    · by_cases hbS : b.1 + 1 ≤ sClose I J
      · -- both in the left block
        simpa [muCol, haS, hbS] using I.col.strictMono hab
      · -- left block to middle block
        have hs1_le_b : sClose I J + 1 ≤ b.1 + 1 := by
          omega
        have hleft :
            colExt I (a.1 + 1) ≤ colExt I (sClose I J) := by
          exact hmonoI haS
        have hright :
            colExt J (sClose I J + 1) ≤ colExt J (b.1 + 1) := by
          exact hmonoJ hs1_le_b
        have hbound :
            colExt I (sClose I J) < colExt J (sClose I J + 1) := by
          exact hsSpec.2.2
        have hnat :
            colExt I (a.1 + 1) < colExt J (b.1 + 1) := by
          exact lt_of_le_of_lt hleft (lt_of_lt_of_le hbound hright)
        have hA :
            colExt I (a.1 + 1) = (muCol I J a).1 + 1 := by
          simp [colExt, muCol, haS]
        have hB :
            colExt J (b.1 + 1) = (muCol I J b).1 + 1 := by
          simp [colExt, muCol, hbS, hbU]
        rw [hA, hB] at hnat
        have hnat' : (muCol I J a).1 < (muCol I J b).1 := by
          exact Nat.lt_of_succ_lt_succ hnat
        simpa using hnat'
    · -- left block to right block: both endpoints come from I.col
      have hbS : ¬ b.1 + 1 ≤ sClose I J := by
        omega
      simpa [muCol, haS, hbS, hbU] using I.col.strictMono hab
  · by_cases haU : a.1 + 1 ≤ uClose I J
    · by_cases hbU : b.1 + 1 ≤ uClose I J
      · -- both in the middle block
        have hbS : ¬ b.1 + 1 ≤ sClose I J := by
          omega
        simpa [muCol, haS, haU, hbS, hbU] using J.col.strictMono hab
      · -- middle block to right block
        have hu1_le_b : uClose I J + 1 ≤ b.1 + 1 := by
          omega
        have hleft :
            colExt J (a.1 + 1) ≤ colExt J (uClose I J) := by
          exact hmonoJ haU
        have hright :
            colExt I (uClose I J + 1) ≤ colExt I (b.1 + 1) := by
          exact hmonoI hu1_le_b
        have hbound :
            colExt J (uClose I J) < colExt I (uClose I J + 1) := by
          exact huSpec.2.2
        have hnat :
            colExt J (a.1 + 1) < colExt I (b.1 + 1) := by
          exact lt_of_le_of_lt hleft (lt_of_lt_of_le hbound hright)
        have hA :
            colExt J (a.1 + 1) = (muCol I J a).1 + 1 := by
          simp [colExt, muCol, haS, haU]
        have hbS : ¬ b.1 + 1 ≤ sClose I J := by
          omega
        have hB :
            colExt I (b.1 + 1) = (muCol I J b).1 + 1 := by
          simp [colExt, muCol, hbS, hbU]
        rw [hA, hB] at hnat
        have hnat' : (muCol I J a).1 < (muCol I J b).1 := by
          exact Nat.lt_of_succ_lt_succ hnat
        simpa using hnat'
    · -- both in the right block
      have hbU : ¬ b.1 + 1 ≤ uClose I J := by
        omega
      have hbS : ¬ b.1 + 1 ≤ sClose I J := by
        omega
      simpa [muCol, haS, haU, hbS, hbU] using I.col.strictMono hab


/-
At this point, the "raw" paper definitions are done.

To package `muRow` and `muCol` into an actual `MinorIndex m n t`, you still need
the cross-boundary monotonicity lemmas coming from the paper's inequalities
(essentially the content around Lemma 1.4).

  hrow : StrictMono (muRow I J)
  hcol : StrictMono (muCol I J)

-/
noncomputable def mu
    (I J : MinorIndex m n t)
    (hIJ : I ≠ J) :
    MinorIndex m n t :=
  { row := strictMonoToOrderEmbedding (muRow I J) (muRow_strictMono_of_ne I J hIJ)
    col := strictMonoToOrderEmbedding (muCol I J) (muCol_strictMono_of_ne I J hIJ) }

lemma eq_at_succ_of_mu_eq_left
    (I J : MinorIndex m n t)
    (hIJ : I ≠ J)
    (hmu : mu I J hIJ = I) :
    let k : Fin t := ⟨sClose I J, by
      have hp : pClose I J ≤ t := pClose_le I J
      have hs : sClose I J < pClose I J := sClose_lt_pClose I J hIJ
      omega⟩
    (J.row k = I.row k) ∧ (J.col k = I.col k) := by
  dsimp
  let k : Fin t := ⟨sClose I J, by
    have hp : pClose I J ≤ t := pClose_le I J
    have hs : sClose I J < pClose I J := sClose_lt_pClose I J hIJ
    omega⟩
  have hk_not_le_s : ¬ k.1 + 1 ≤ sClose I J := by
    simp [k]
  have hk_le_u : k.1 + 1 ≤ uClose I J := by
    simpa [k] using Nat.succ_le_of_lt (sClose_lt_uClose I J hIJ)
  have hrow_eq : (mu I J hIJ).row k = I.row k := by
    exact congrArg (fun M : MinorIndex m n t => M.row k) hmu
  have hcol_eq : (mu I J hIJ).col k = I.col k := by
    exact congrArg (fun M : MinorIndex m n t => M.col k) hmu
  constructor
  · simpa [mu, strictMonoToOrderEmbedding, muRow, hk_not_le_s, hk_le_u] using hrow_eq
  · simpa [mu, strictMonoToOrderEmbedding, muCol, hk_not_le_s, hk_le_u] using hcol_eq


lemma sPred_succ_of_mu_eq_left
    (I J : MinorIndex m n t)
    (hIJ : I ≠ J)
    (hmu : mu I J hIJ = I)
    (hsp : sClose I J + 1 < pClose I J) :
    sPred I J (sClose I J + 1) := by
  let k0 : Fin t := ⟨sClose I J, by
    have hp : pClose I J ≤ t := pClose_le I J
    have hs : sClose I J < pClose I J := sClose_lt_pClose I J hIJ
    exact Nat.lt_of_lt_of_le hs hp⟩
  let k1 : Fin t := ⟨sClose I J + 1, by
    have hp : pClose I J ≤ t := pClose_le I J
    exact Nat.lt_of_lt_of_le hsp hp⟩
  have heq : (J.row k0 = I.row k0) ∧ (J.col k0 = I.col k0) := by
    simpa [k0] using (eq_at_succ_of_mu_eq_left I J hIJ hmu)
  have hk01 : k0 < k1 := by
    change sClose I J < sClose I J + 1
    exact lt_add_one (sClose I J)
  have hJrow : J.row k0 < J.row k1 := J.row.strictMono hk01
  have hJcol : J.col k0 < J.col k1 := J.col.strictMono hk01
  have hIrow : I.row k0 < J.row k1 := by
    simpa [heq.1] using hJrow
  have hIcol : I.col k0 < J.col k1 := by
    simpa [heq.2] using hJcol
  have hs1_le_t : sClose I J + 1 ≤ t := by
    have hp : pClose I J ≤ t := pClose_le I J
    have hs : sClose I J < pClose I J := sClose_lt_pClose I J hIJ
    exact Nat.le_trans hs hp
  have hs2_le_t : sClose I J + 2 ≤ t := by
    have hp : pClose I J ≤ t := pClose_le I J
    exact Nat.le_trans hsp hp
  have hrowExtI :
      rowExt I (sClose I J + 1) = (I.row k0).1 + 1 := by
    unfold rowExt
    simp [k0, hs1_le_t]
  have hrowExtJ :
      rowExt J (sClose I J + 2) = (J.row k1).1 + 1 := by
    unfold rowExt
    simp [k1, hs2_le_t]
  have hcolExtI :
      colExt I (sClose I J + 1) = (I.col k0).1 + 1 := by
    unfold colExt
    simp [k0, hs1_le_t]
  have hcolExtJ :
      colExt J (sClose I J + 2) = (J.col k1).1 + 1 := by
    unfold colExt
    simp [k1, hs2_le_t]
  refine ⟨hsp, ?_, ?_⟩
  · have hnat : (I.row k0).1 + 1 < (J.row k1).1 + 1 := by
      exact Nat.succ_lt_succ (by simpa using hIrow)
    simpa [hrowExtI, hrowExtJ] using hnat
  · have hnat : (I.col k0).1 + 1 < (J.col k1).1 + 1 := by
      exact Nat.succ_lt_succ (by simpa using hIcol)
    simpa [hcolExtI, hcolExtJ] using hnat

lemma succ_sClose_eq_pClose_of_mu_eq_left
    (I J : MinorIndex m n t)
    (hIJ : I ≠ J)
    (hmu : mu I J hIJ = I) :
    sClose I J + 1 = pClose I J := by
  have hle : sClose I J + 1 ≤ pClose I J := by
    have hs : sClose I J < pClose I J := sClose_lt_pClose I J hIJ
    exact Order.add_one_le_iff.mpr hs
  have hnotlt : ¬ sClose I J + 1 < pClose I J := by
    intro hsp
    have hsPred : sPred I J (sClose I J + 1) :=
      sPred_succ_of_mu_eq_left I J hIJ hmu hsp
    classical
    letI : DecidablePred (sPred I J) := fun a =>
      Classical.propDecidable (sPred I J a)
    have hsle : sClose I J + 1 ≤ sClose I J := by
      unfold sClose
      exact Nat.le_findGreatest (show sClose I J + 1 ≤ pClose I J by omega) hsPred
    simp at hsle
  simp only [not_lt] at hnotlt
  exact Eq.symm (Nat.le_antisymm hnotlt hle)

/-Lemma 1.2-/
lemma mu_ne_left
    (I J : MinorIndex m n t)
    (hIJ : I ≠ J) :
    mu I J hIJ ≠ I := by
  intro hmu
  have hsltp : sClose I J < pClose I J := sClose_lt_pClose I J hIJ
  have hple : pClose I J ≤ t := pClose_le I J
  let k : Fin t := ⟨sClose I J, by omega⟩
  have heq :
      (J.row k = I.row k) ∧ (J.col k = I.col k) := by
    simpa [k] using
      (eq_at_succ_of_mu_eq_left I J hIJ hmu)
  have hsp : sClose I J + 1 = pClose I J :=
    succ_sClose_eq_pClose_of_mu_eq_left I J hIJ hmu
  have hp : diffAt I J (pClose I J) :=
    pClose_spec I J hIJ
  have hp' : diffAt I J (sClose I J + 1) := by
    simpa [hsp] using hp
  have hklt : sClose I J < t := by
    omega
  have hneq :
      (I.row k, I.col k) ≠ (J.row k, J.col k) := by
    simpa [diffAt, hklt, k] using hp'
  have hpair :
      (I.row k, I.col k) = (J.row k, J.col k) := by
    exact Prod.ext heq.1.symm heq.2.symm
  exact hneq hpair

lemma mu_congr_proof
    (I J : MinorIndex m n t)
    {h₁ h₂ : I ≠ J} :
    mu I J h₁ = mu I J h₂ := by
  have : h₁ = h₂ := Subsingleton.elim _ _
  subst this
  rfl


end paper1_1

section paper1_3
variable {m n t : ℕ}

def Close (I J : MinorIndex m n t) : Prop :=
  ∃ hIJ : I ≠ J, mu I J hIJ = J ∧ mu J I hIJ.symm = I

lemma Close.ne
    {I J : MinorIndex m n t}
    (h : Close I J) :
    I ≠ J := h.choose

lemma Close.symm {I J : MinorIndex m n t} (h : Close I J) : Close J I := by
  rcases h with ⟨hIJ, hμIJ, hμJI⟩
  exact ⟨hIJ.symm, hμJI, hμIJ⟩

lemma Close.mu_eq_right
    {I J : MinorIndex m n t}
    (h : Close I J) :
    mu I J h.choose = J := h.choose_spec.1

lemma Close.mu_eq_left
    {I J : MinorIndex m n t}
    (h : Close I J) :
    mu J I h.choose.symm = I := h.choose_spec.2

end paper1_3


section paper1_4

variable {m n t : ℕ}

/-- Paper-style pair at 1-based position `j`. -/
def pairExt (I : MinorIndex m n t) (j : ℕ) : ℕ × ℕ :=
  (rowExt I j, colExt I j)


lemma pClose_eq_symm
    (I J : MinorIndex m n t) :
    pClose I J = pClose J I := by
  classical
  by_cases hIJ : I = J
  · subst hIJ
    rfl
  · have hle₁ : pClose I J ≤ pClose J I := by
      have hp : diffAt I J (pClose I J) := pClose_spec I J hIJ
      have hp' : diffAt J I (pClose I J) := (diffAt_symm I J _).mp hp
      exact Nat.le_findGreatest (pClose_le I J) hp'
    have hle₂ : pClose J I ≤ pClose I J := by
      have hp : diffAt J I (pClose J I) := by exact pClose_spec J I fun a ↦ hIJ (id (Eq.symm a))
      have hp' : diffAt I J (pClose J I) := (diffAt_symm J I _).mp hp
      exact Nat.le_findGreatest (pClose_le J I) hp'
    exact le_antisymm hle₁ hle₂

/-! ### Step-strictness of the extended sequences -/

lemma rowExt_step_lt
    (I : MinorIndex m n t)
    {j : ℕ}
    (hj1 : 1 ≤ j)
    (hjt : j < t) :
    rowExt I j < rowExt I (j + 1) := by
  let k0 : Fin t := ⟨j - 1, by omega⟩
  let k1 : Fin t := ⟨j, hjt⟩
  have hk01 : k0 < k1 := by
    simp [k0, k1]
    omega
  have hfin : I.row k0 < I.row k1 := I.row.strictMono hk01
  have hj_le_t : j ≤ t := by
    omega
  have hj1_le_t : j + 1 ≤ t := by
    omega
  have hrowj : rowExt I j = (I.row k0).1 + 1 := by
    unfold rowExt
    grind
  have hrowj1 : rowExt I (j + 1) = (I.row k1).1 + 1 := by
    unfold rowExt
    simp [hj1_le_t, k1]
  have hnat : (I.row k0).1 + 1 < (I.row k1).1 + 1 := by
    exact Nat.succ_lt_succ <| by
      simpa using hfin
  simpa [hrowj, hrowj1] using hnat

lemma colExt_step_lt
    (I : MinorIndex m n t)
    {j : ℕ}
    (hj1 : 1 ≤ j)
    (hjt : j < t) :
    colExt I j < colExt I (j + 1) := by
  let k0 : Fin t := ⟨j - 1, by omega⟩
  let k1 : Fin t := ⟨j, hjt⟩
  have hk01 : k0 < k1 := by
    simp [k0, k1]
    omega
  have hfin : I.col k0 < I.col k1 := I.col.strictMono hk01
  have hj_le_t : j ≤ t := by
    omega
  have hj1_le_t : j + 1 ≤ t := by
    omega
  have hcolj : colExt I j = (I.col k0).1 + 1 := by
    unfold colExt
    grind
  have hcolj1 : colExt I (j + 1) = (I.col k1).1 + 1 := by
    unfold colExt
    simp [hj1_le_t, k1]
  have hnat : (I.col k0).1 + 1 < (I.col k1).1 + 1 := by
    exact Nat.succ_lt_succ <| by
      simpa using hfin
  simpa [hcolj, hcolj1] using hnat

lemma rowExt_lt_of_lt
    (I : MinorIndex m n t)
    {i j : ℕ}
    (hi₁ : 1 ≤ i)
    (hij : i < j)
    (hj₂ : j ≤ t) :
    rowExt I i < rowExt I j := by
  let ki : Fin t := ⟨i - 1, by omega⟩
  let kj : Fin t := ⟨j - 1, by omega⟩
  have hk : ki < kj := by
    simp [ki, kj]
    omega
  have hfin : I.row ki < I.row kj := I.row.strictMono hk
  have hi₂ : i ≤ t := le_trans (Nat.le_of_lt hij) hj₂
  have hrowi : rowExt I i = (I.row ki).1 + 1 := by
    unfold rowExt
    have hi0 : i ≠ 0 := by omega
    simp [hi0, hi₂, ki]
  have hrowj : rowExt I j = (I.row kj).1 + 1 := by
    unfold rowExt
    have hj0 : j ≠ 0 := by omega
    simp [hj0, hj₂, kj]
  have hnat : (I.row ki).1 + 1 < (I.row kj).1 + 1 := by
    exact Nat.succ_lt_succ (by simpa using hfin)
  simpa [hrowi, hrowj] using hnat

lemma colExt_lt_of_lt
    (I : MinorIndex m n t)
    {i j : ℕ}
    (hi₁ : 1 ≤ i)
    (hij : i < j)
    (hj₂ : j ≤ t) :
    colExt I i < colExt I j := by
  let ki : Fin t := ⟨i - 1, by omega⟩
  let kj : Fin t := ⟨j - 1, by omega⟩
  have hk : ki < kj := by
    simp [ki, kj]
    omega
  have hfin : I.col ki < I.col kj := I.col.strictMono hk
  have hi₂ : i ≤ t := le_trans (Nat.le_of_lt hij) hj₂
  have hcoli : colExt I i = (I.col ki).1 + 1 := by
    unfold colExt
    have hi0 : i ≠ 0 := by omega
    simp [hi0, hi₂, ki]
  have hcolj : colExt I j = (I.col kj).1 + 1 := by
    unfold colExt
    have hj0 : j ≠ 0 := by omega
    simp [hj0, hj₂, kj]
  have hnat : (I.col ki).1 + 1 < (I.col kj).1 + 1 := by
    exact Nat.succ_lt_succ (by simpa using hfin)
  simpa [hcoli, hcolj] using hnat

/-! ### `diffAt` and `pairExt` on the genuine range `1..t` -/

lemma diffAt_iff_pairExt_ne
    (I J : MinorIndex m n t)
    {j : ℕ}
    (hj1 : 1 ≤ j)
    (hj2 : j ≤ t) :
    diffAt I J j ↔ pairExt I j ≠ pairExt J j := by
  cases j with
  | zero =>
      omega
  | succ k =>
      have hk : k < t := by
        omega
      simp [diffAt, pairExt, rowExt, colExt, hk, hj2]
      grind

/-! ### Equality of pairs before `s` and after `u` under `mu I J = J` -/

lemma pairExt_eq_of_mu_eq_right_le_s
    (I J : MinorIndex m n t)
    (hIJ : I ≠ J)
    (hmu : mu I J hIJ = J)
    {j : ℕ}
    (hj1 : 1 ≤ j)
    (hj2 : j ≤ sClose I J) :
    pairExt I j = pairExt J j := by
  let k : Fin t := ⟨j - 1, by
    have hs : sClose I J < pClose I J := sClose_lt_pClose I J hIJ
    have hp : pClose I J ≤ t := pClose_le I J
    omega⟩
  have hrow_eq : (mu I J hIJ).row k = J.row k := by
    exact congrArg (fun M : MinorIndex m n t => M.row k) hmu
  have hcol_eq : (mu I J hIJ).col k = J.col k := by
    exact congrArg (fun M : MinorIndex m n t => M.col k) hmu
  have hk_le_s : k.1 + 1 ≤ sClose I J := by
    simp [k]
    omega
  have hrow0 : I.row k = J.row k := by
    simpa [mu, strictMonoToOrderEmbedding, muRow, hk_le_s] using hrow_eq
  have hcol0 : I.col k = J.col k := by
    simpa [mu, strictMonoToOrderEmbedding, muCol, hk_le_s] using hcol_eq
  have hj_le_t : j ≤ t := by
    have hs : sClose I J < pClose I J := sClose_lt_pClose I J hIJ
    exact le_trans hj2 <| le_trans (Nat.le_of_lt hs) (pClose_le I J)
  have hrowExtI : rowExt I j = (I.row k).1 + 1 := by
    unfold rowExt
    grind
  have hrowExtJ : rowExt J j = (J.row k).1 + 1 := by
    unfold rowExt
    grind
  have hcolExtI : colExt I j = (I.col k).1 + 1 := by
    unfold colExt
    grind
  have hcolExtJ : colExt J j = (J.col k).1 + 1 := by
    unfold colExt
    grind
  apply Prod.ext
  · simp only [pairExt]
    rw [hrowExtI, hrowExtJ, hrow0]
  · simp only [pairExt]
    rw [hcolExtI, hcolExtJ, hcol0]

lemma pairExt_eq_of_mu_eq_right_gt_u
    (I J : MinorIndex m n t)
    (hIJ : I ≠ J)
    (hmu : mu I J hIJ = J)
    {j : ℕ}
    (hj1 : uClose I J < j)
    (hj2 : j ≤ t) :
    pairExt I j = pairExt J j := by
  have hjpos : 0 < j := by
    omega
  let k : Fin t := ⟨j - 1, by omega⟩
  have hrow_eq : (mu I J hIJ).row k = J.row k := by
    exact congrArg (fun M : MinorIndex m n t => M.row k) hmu
  have hcol_eq : (mu I J hIJ).col k = J.col k := by
    exact congrArg (fun M : MinorIndex m n t => M.col k) hmu
  have hk_succ : k.1 + 1 = j := by
    simp only [k]
    exact Nat.sub_add_cancel hjpos
  have hk_not_le_s : ¬ k.1 + 1 ≤ sClose I J := by
    rw [hk_succ]
    have hsltu : sClose I J < uClose I J := sClose_lt_uClose I J hIJ
    omega
  have hk_not_le_u : ¬ k.1 + 1 ≤ uClose I J := by
    simp [k]
    omega
  have hrow0 : I.row k = J.row k := by
    simpa [mu, strictMonoToOrderEmbedding, muRow, hk_not_le_s, hk_not_le_u] using hrow_eq
  have hcol0 : I.col k = J.col k := by
    simpa [mu, strictMonoToOrderEmbedding, muCol, hk_not_le_s, hk_not_le_u] using hcol_eq
  have hrowExtI : rowExt I j = (I.row k).1 + 1 := by
    unfold rowExt
    simp [hjpos.ne', hj2, k]
  have hrowExtJ : rowExt J j = (J.row k).1 + 1 := by
    unfold rowExt
    simp [hjpos.ne', hj2, k]
  have hcolExtI : colExt I j = (I.col k).1 + 1 := by
    unfold colExt
    simp [hjpos.ne', hj2, k]
  have hcolExtJ : colExt J j = (J.col k).1 + 1 := by
    unfold colExt
    simp [hjpos.ne', hj2, k]
  apply Prod.ext
  · simp only [pairExt]
    rw [hrowExtI, hrowExtJ, hrow0]
  · simp only [pairExt]
    rw [hcolExtI, hcolExtJ, hcol0]

/-! ### `sClose + 1` is the first differing position under `mu I J = J` -/

lemma not_diffAt_lt_succ_sClose_of_mu_eq_right
    (I J : MinorIndex m n t)
    (hIJ : I ≠ J)
    (hmu : mu I J hIJ = J)
    {j : ℕ}
    (hj1 : 1 ≤ j)
    (hjlt : j < sClose I J + 1) :
    ¬ diffAt I J j := by
  have hj2 : j ≤ sClose I J := by
    omega
  have hEq : pairExt I j = pairExt J j :=
    pairExt_eq_of_mu_eq_right_le_s I J hIJ hmu hj1 hj2
  have hj_le_t : j ≤ t := by
    have hs : sClose I J < pClose I J := sClose_lt_pClose I J hIJ
    exact le_trans hj2 <| le_trans (Nat.le_of_lt hs) (pClose_le I J)
  intro hdiff
  exact ((diffAt_iff_pairExt_ne I J hj1 hj_le_t).mp hdiff) hEq

lemma diffAt_succ_sClose_of_mu_eq_right
    (I J : MinorIndex m n t)
    (hIJ : I ≠ J) :
    diffAt I J (sClose I J + 1) := by
  let q := sClose I J + 1
  have hq_le_p : q ≤ pClose I J := by
    have hs : sClose I J < pClose I J := sClose_lt_pClose I J hIJ
    omega
  by_cases hqp : q = pClose I J
  · simpa [q, hqp] using pClose_spec I J hIJ
  · have hqp_lt : q < pClose I J := by
      omega
    by_contra hnd
    have hq_le_t : q ≤ t := by
      exact le_trans hq_le_p (pClose_le I J)
    have hEq : pairExt I q = pairExt J q := by
      apply Classical.byContradiction
      intro hneq
      exact hnd ((diffAt_iff_pairExt_ne I J (by omega) hq_le_t).2 hneq)
    have hrow : rowExt I q < rowExt J (q + 1) := by
      have hEqRow : rowExt I q = rowExt J q := congrArg Prod.fst hEq
      have hstep : rowExt J q < rowExt J (q + 1) := by
        exact rowExt_step_lt J (by omega) (by
          exact lt_of_lt_of_le hqp_lt (pClose_le I J))
      exact hEqRow ▸ hstep
    have hcol : colExt I q < colExt J (q + 1) := by
      have hEqCol : colExt I q = colExt J q := congrArg Prod.snd hEq
      have hstep : colExt J q < colExt J (q + 1) := by
        exact colExt_step_lt J (by omega) (by
          exact lt_of_lt_of_le hqp_lt (pClose_le I J))
      exact hEqCol ▸ hstep
    have hsPred : sPred I J q := ⟨hqp_lt, hrow, hcol⟩
    classical
    letI : DecidablePred (sPred I J) := fun a =>
      Classical.propDecidable (sPred I J a)
    have hle : q ≤ sClose I J := by
      unfold sClose
      exact Nat.le_findGreatest (show q ≤ pClose I J by exact hq_le_p) hsPred
    omega

lemma firstDiff_succ_sClose_of_mu_eq_right
    (I J : MinorIndex m n t)
    (hIJ : I ≠ J)
    (hmu : mu I J hIJ = J) :
    diffAt I J (sClose I J + 1) ∧
      ∀ j : ℕ, 1 ≤ j → j < sClose I J + 1 → ¬ diffAt I J j := by
  constructor
  · exact diffAt_succ_sClose_of_mu_eq_right I J hIJ
  · intro j hj1 hjlt
    exact not_diffAt_lt_succ_sClose_of_mu_eq_right I J hIJ hmu hj1 hjlt

/-! ### Tail-agreement after `uClose` and a minimality principle for `uClose` -/

lemma tailAgree_after_u_of_mu_eq_right
    (I J : MinorIndex m n t)
    (hIJ : I ≠ J)
    (hmu : mu I J hIJ = J) :
    ∀ j : ℕ, uClose I J < j → j ≤ t → pairExt I j = pairExt J j := by
  intro j hj1 hj2
  exact pairExt_eq_of_mu_eq_right_gt_u I J hIJ hmu hj1 hj2

lemma uPred_of_tailAgree
    (I J : MinorIndex m n t)
    (q : ℕ)
    (hsq : sClose I J < q)
    (hqle : q ≤ t)
    (htail : ∀ j : ℕ, q < j → j ≤ t → pairExt I j = pairExt J j) :
    uPred I J q := by
  refine ⟨hsq, ?_, ?_⟩
  · by_cases hqt : q < t
    · have hEq : pairExt I (q + 1) = pairExt J (q + 1) := htail (q + 1) (by omega) (by omega)
      have hEqRow : rowExt I (q + 1) = rowExt J (q + 1) := congrArg Prod.fst hEq
      have hstep : rowExt J q < rowExt J (q + 1) := rowExt_step_lt J (by omega) hqt
      exact Nat.lt_of_lt_of_eq hstep (Eq.symm hEqRow)
    · have hqeq : q = t := by omega
      subst hqeq
      unfold rowExt
      by_cases ht0 : q = 0
      · grind
      · have htnz : q ≠ 0 := ht0
        simp [htnz]
  · by_cases hqt : q < t
    · have hEq : pairExt I (q + 1) = pairExt J (q + 1) := htail (q + 1) (by omega) (by omega)
      have hEqCol : colExt I (q + 1) = colExt J (q + 1) := congrArg Prod.snd hEq
      have hstep : colExt J q < colExt J (q + 1) := colExt_step_lt J (by omega) hqt
      grind
    · have hqeq : q = t := by omega
      subst hqeq
      unfold colExt
      by_cases ht0 : q = 0
      · grind
      · have htnz : q ≠ 0 := ht0
        simp [htnz]

lemma uClose_le_of_tailAgree
    (I J : MinorIndex m n t)
    (q : ℕ)
    (hsq : sClose I J < q)
    (hqle : q ≤ t)
    (htail : ∀ j : ℕ, q < j → j ≤ t → pairExt I j = pairExt J j) :
    uClose I J ≤ q := by
  classical
  have huq : uPred I J q := uPred_of_tailAgree I J q hsq hqle htail
  unfold uClose
  split_ifs with h
  · exact Nat.find_le huq
  · exfalso
    exact h ⟨q, huq⟩

/-! ### Lemma 1.4(i)

The integers `s` and `t` attached to `(I,J)` coincide with the corresponding
integers for `(J,I)`. In our notation the paper's second index `t` is `uClose`. -/

/-- Lemma 1.4(i), first half: `s = s'`. -/
lemma close_sClose_eq_symm
    (I J : MinorIndex m n t)
    (hC : Close I J) :
    sClose I J = sClose J I := by
  have hIJ : I ≠ J := hC.ne
  have hμIJ : mu I J hIJ = J := by
    simpa using hC.mu_eq_right
  have hμJI : mu J I hIJ.symm = I := by
    simpa using hC.mu_eq_left
  have hfirstIJ := firstDiff_succ_sClose_of_mu_eq_right I J hIJ hμIJ
  have hfirstJI := firstDiff_succ_sClose_of_mu_eq_right J I hIJ.symm hμJI
  have hdiffIJ : diffAt I J (sClose I J + 1) := hfirstIJ.1
  have hdiffJI : diffAt I J (sClose J I + 1) := by
    exact (diffAt_symm J I _).mp hfirstJI.1
  have hle₁ : sClose I J + 1 ≤ sClose J I + 1 := by
    by_contra hlt
    have hlt' : sClose J I + 1 < sClose I J + 1 := lt_of_not_ge hlt
    have hnd : ¬ diffAt I J (sClose J I + 1) :=
      hfirstIJ.2 (sClose J I + 1) (by omega) hlt'
    exact hnd hdiffJI
  have hle₂ : sClose J I + 1 ≤ sClose I J + 1 := by
    by_contra hlt
    have hlt' : sClose I J + 1 < sClose J I + 1 := lt_of_not_ge hlt
    have hnd : ¬ diffAt J I (sClose I J + 1) :=
      hfirstJI.2 (sClose I J + 1) (by omega) hlt'
    exact hnd ((diffAt_symm I J _).mp hdiffIJ)
  omega

/-- Lemma 1.4(i), second half: `t = t'`.
Here the paper's second index `t` is our `uClose`. -/
lemma close_uClose_eq_symm
    (I J : MinorIndex m n t)
    (hC : Close I J) :
    uClose I J = uClose J I := by
  have hIJ : I ≠ J := hC.ne
  have hμIJ : mu I J hIJ = J := by
    simpa using hC.mu_eq_right
  have hμJI : mu J I hIJ.symm = I := by
    simpa using hC.mu_eq_left
  have hsEq : sClose I J = sClose J I := close_sClose_eq_symm I J hC
  have hle₁ : uClose I J ≤ uClose J I := by
    apply uClose_le_of_tailAgree (I := I) (J := J) (q := uClose J I)
    · rw [hsEq]
      exact sClose_lt_uClose J I hIJ.symm
    · exact le_trans (uClose_le_pClose J I hIJ.symm) (pClose_le J I)
    · intro j hj₁ hj₂
      have htail : pairExt J j = pairExt I j :=
        tailAgree_after_u_of_mu_eq_right J I hIJ.symm hμJI j hj₁ hj₂
      simpa [eq_comm] using htail
  have hle₂ : uClose J I ≤ uClose I J := by
    apply uClose_le_of_tailAgree (I := J) (J := I) (q := uClose I J)
    · rw [← hsEq]
      exact sClose_lt_uClose I J hIJ
    · exact le_trans (uClose_le_pClose I J hIJ) (pClose_le I J)
    · intro j hj₁ hj₂
      exact Eq.symm (tailAgree_after_u_of_mu_eq_right I J hIJ hμIJ j hj₁ hj₂)
  exact le_antisymm hle₁ hle₂

/-! ### Lemma 1.4(ii)

For every `s+1 ≤ i,j ≤ t`, the pair at position `i` in `I` is different
from the pair at position `j` in `J`. -/

lemma mid_le_t_of_close
    (I J : MinorIndex m n t)
    (hC : Close I J)
    {j : ℕ}
    (hj : j ≤ uClose I J) :
    j ≤ t := by
  exact le_trans hj (le_trans (uClose_le_pClose I J hC.ne) (pClose_le I J))

lemma pairExt_mu_eq_right_of_mid
    (I J : MinorIndex m n t)
    (hIJ : I ≠ J)
    {j : ℕ}
    (hj1 : sClose I J + 1 ≤ j)
    (hj2 : j ≤ uClose I J) :
    pairExt (mu I J hIJ) j = pairExt J j := by
  have hjt : j ≤ t := by
    exact le_trans hj2 (le_trans (uClose_le_pClose I J hIJ) (pClose_le I J))
  have hj0 : j ≠ 0 := by
    omega
  have hns : ¬ j ≤ sClose I J := by
    omega
  apply Prod.ext
  · unfold pairExt rowExt
    simp [mu, strictMonoToOrderEmbedding, muRow, hj0, hjt]
    grind
  · unfold pairExt colExt
    simp [mu, strictMonoToOrderEmbedding, muCol, hj0, hjt]
    grind

lemma pairExt_mu_eq_left_of_mid
    (I J : MinorIndex m n t)
    (hC : Close I J)
    {i : ℕ}
    (hi1 : sClose I J + 1 ≤ i)
    (hi2 : i ≤ uClose I J) :
    pairExt (mu J I hC.ne.symm) i = pairExt I i := by
  have hsEq : sClose I J = sClose J I := close_sClose_eq_symm I J hC
  have huEq : uClose I J = uClose J I := close_uClose_eq_symm I J hC
  have hi1' : sClose J I + 1 ≤ i := by
    rwa [← hsEq]
  have hi2' : i ≤ uClose J I := by
    rwa [← huEq]
  simpa using
    (pairExt_mu_eq_right_of_mid (I := J) (J := I) (hIJ := hC.ne.symm) hi1' hi2')

/-! ### The implication chain used in Lemma 1.4(iii)(iv)

For `s+1 < i ≤ t`, the paper uses the local chain
`α'_i ≤ α_i ⇒ β_i ≤ β'_{i-1} ⇒ β_i < β'_i ⇒ α'_i ≤ α_{i-1} ⇒ α'_{i-1} < α_{i-1}`.
Only the first arrow is still missing below; the remaining three local steps are already
formalized. -/

/-- First local arrow in the paper's implication chain. -/
lemma close_chain_row_le_to_prev_col_le
    (I J : MinorIndex m n t)
    (hIJ : I ≠ J)
    {i : ℕ}
    (hi₁ : sClose I J + 1 < i)
    (hi₂ : i ≤ uClose I J)
    (hrow :
      rowExt J i ≤ rowExt I i) :
    colExt I i ≤ colExt J (i - 1) := by
  classical
  by_contra hnot
  have hi_pos : 0 < i := by
    omega
  have hi_le_t : i ≤ t := by
    exact le_trans hi₂ <| le_trans (uClose_le_pClose I J hIJ) (pClose_le I J)
  have him1_pos : 1 ≤ i - 1 := by
    omega
  have him1_lt_t : i - 1 < t := by
    omega
  have hstep_row : rowExt J (i - 1) < rowExt J i := by
    have : rowExt J (i - 1) < rowExt J ((i - 1) + 1) := by
      exact rowExt_step_lt J him1_pos him1_lt_t
    simpa [Nat.sub_add_cancel hi_pos] using this
  have hrow_prev_lt_i : rowExt J (i - 1) < rowExt I i := by
    exact lt_of_lt_of_le hstep_row hrow
  have hcol_prev_lt_i : colExt J (i - 1) < colExt I i := by
    exact lt_of_not_ge hnot
  have him1_uPred : uPred I J (i - 1) := by
    refine ⟨?_, ?_, ?_⟩
    · omega
    · simpa [Nat.sub_add_cancel hi_pos] using hrow_prev_lt_i
    · simpa [Nat.sub_add_cancel hi_pos] using hcol_prev_lt_i
  have hu_le_prev : uClose I J ≤ i - 1 := by
    unfold uClose
    split_ifs with h
    · exact Nat.find_le him1_uPred
    · exfalso
      exact h ⟨pClose I J, uPred_pClose I J hIJ⟩
  have : i ≤ i - 1 := by
    exact le_trans hi₂ hu_le_prev
  omega

/-- Second local arrow in the paper's implication chain. -/
lemma close_chain_prev_col_le_to_col_lt
    (I J : MinorIndex m n t)
    (hIJ : I ≠ J)
    {i : ℕ}
    (hi₁ : sClose I J + 1 < i)
    (hi₂ : i ≤ uClose I J)
    (hcol :
      colExt I i ≤ colExt J (i - 1)) :
    colExt I i < colExt J i := by
  have hit : i ≤ t := by
    exact le_trans hi₂ <| le_trans (uClose_le_pClose I J hIJ) (pClose_le I J)
  have hi_pos : 0 < i := by
    omega
  have hi1_pos : 1 ≤ i - 1 := by
    omega
  have hi1_lt_t : i - 1 < t := by
    omega
  have hstep : colExt J (i - 1) < colExt J i := by
    have : colExt J (i - 1) < colExt J ((i - 1) + 1) := by
      exact colExt_step_lt J hi1_pos hi1_lt_t
    simpa [Nat.sub_add_cancel hi_pos] using this
  exact lt_of_le_of_lt hcol hstep

/-- Third local arrow in the paper's implication chain. -/
lemma close_chain_col_lt_to_prev_row_le
    (I J : MinorIndex m n t)
    (hIJ : I ≠ J)
    {i : ℕ}
    (hi₁ : sClose I J + 1 < i)
    (hi₂ : i ≤ uClose I J)
    (hcol :
      colExt I i < colExt J i) :
    rowExt J i ≤ rowExt I (i - 1) := by
  by_contra hnot
  have hrow : rowExt I (i - 1) < rowExt J i := by
    exact lt_of_not_ge hnot
  have hi_pos : 0 < i := by
    omega
  have hi_le_t : i ≤ t := by
    exact le_trans hi₂ <| le_trans (uClose_le_pClose I J hIJ) (pClose_le I J)
  have him1_pos : 1 ≤ i - 1 := by
    omega
  have him1_lt_t : i - 1 < t := by
    omega
  have hstep_col : colExt I (i - 1) < colExt I i := by
    have : colExt I (i - 1) < colExt I ((i - 1) + 1) := by
      exact colExt_step_lt I him1_pos him1_lt_t
    simpa [Nat.sub_add_cancel hi_pos] using this
  have hcol_prev : colExt I (i - 1) < colExt J i := by
    exact lt_of_lt_of_le hstep_col (Nat.le_of_lt hcol)
  have hsPred : sPred I J (i - 1) := by
    refine ⟨?_, ?_, ?_⟩
    · have hu_le_p : uClose I J ≤ pClose I J := uClose_le_pClose I J hIJ
      omega
    · simpa [Nat.sub_add_cancel hi_pos] using hrow
    · simpa [Nat.sub_add_cancel hi_pos] using hcol_prev
  classical
  letI : DecidablePred (sPred I J) := fun a =>
    Classical.propDecidable (sPred I J a)
  have him1_le_s : i - 1 ≤ sClose I J := by
    unfold sClose
    have him1_le_p : i - 1 ≤ pClose I J := by
      have hu_le_p : uClose I J ≤ pClose I J := uClose_le_pClose I J hIJ
      omega
    exact Nat.le_findGreatest him1_le_p hsPred
  omega

/-- Fourth local arrow in the paper's implication chain. -/
lemma close_chain_prev_row_le_to_prev_row_lt
    (I J : MinorIndex m n t)
    (hIJ : I ≠ J)
    {i : ℕ}
    (hi₁ : sClose I J + 1 < i)
    (hi₂ : i ≤ uClose I J)
    (hrow :
      rowExt J i ≤ rowExt I (i - 1)) :
    rowExt J (i - 1) < rowExt I (i - 1) := by
  have hit : i ≤ t := by
    exact le_trans hi₂ <| le_trans (uClose_le_pClose I J hIJ) (pClose_le I J)
  have hi_pos : 0 < i := by
    omega
  have hi1_pos : 1 ≤ i - 1 := by
    omega
  have hi1_lt_t : i - 1 < t := by
    omega
  have hstep : rowExt J (i - 1) < rowExt J i := by
    have : rowExt J (i - 1) < rowExt J ((i - 1) + 1) := by
      exact rowExt_step_lt J hi1_pos hi1_lt_t
    simpa [Nat.sub_add_cancel hi_pos] using this
  exact Nat.lt_of_lt_of_le hstep hrow

/-- Packaged local implication chain. -/
lemma close_chain_at_index
    (I J : MinorIndex m n t)
    (hIJ : I ≠ J)
    {i : ℕ}
    (hi₁ : sClose I J + 1 < i)
    (hi₂ : i ≤ uClose I J)
    (hrow :
      rowExt J i ≤ rowExt I i) :
    rowExt J (i - 1) < rowExt I (i - 1) := by
  have h1 : colExt I i ≤ colExt J (i - 1) :=
    close_chain_row_le_to_prev_col_le I J hIJ hi₁ hi₂ hrow
  have h2 : colExt I i < colExt J i :=
    close_chain_prev_col_le_to_col_lt I J hIJ hi₁ hi₂ h1
  have h3 : rowExt J i ≤ rowExt I (i - 1) :=
    close_chain_col_lt_to_prev_row_le I J hIJ hi₁ hi₂ h2
  exact close_chain_prev_row_le_to_prev_row_lt I J hIJ hi₁ hi₂ h3

/-! ### Lemma 1.4(iii)

If `α_t = α'_t`, then `t = s+1`.

In our notation, the paper's `t` is `uClose I J`, so the hypothesis is that
the row-coordinates of `I` and `J` agree at the common index `uClose I J`. -/

/-- Lemma 1.4(iii). -/
lemma close_uClose_eq_succ_of_rowEq
    (I J : MinorIndex m n t)
    (hC : Close I J)
    (hrowEq :
      rowExt I (uClose I J) = rowExt J (uClose I J)) :
    uClose I J = sClose I J + 1 := by
  have hIJ : I ≠ J := hC.ne
  have hsltu : sClose I J < uClose I J := sClose_lt_uClose I J hIJ
  have hle : sClose I J + 1 ≤ uClose I J := by
    exact Order.add_one_le_iff.mpr hsltu
  have hu_le : uClose I J ≤ sClose I J + 1 := by
    by_contra hnot
    have hgt : sClose I J + 1 < uClose I J := by
      exact Nat.lt_of_not_le hnot
    have h1 := close_chain_row_le_to_prev_col_le I J hIJ hgt le_rfl hrowEq.symm.le
    have h2 := close_chain_prev_col_le_to_col_lt I J hIJ hgt le_rfl h1
    have h3 := close_chain_col_lt_to_prev_row_le I J hIJ hgt le_rfl h2
    have hu_pos : 0 < uClose I J := by
      exact Nat.zero_lt_of_lt hsltu
    have hu1_pos : 1 ≤ uClose I J - 1 := by
      omega
    have hu1_lt_t : uClose I J - 1 < t := by
      have hu_le_t : uClose I J ≤ t := by
        exact le_trans (uClose_le_pClose I J hIJ) (pClose_le I J)
      exact Nat.sub_one_lt_of_le hu_pos hu_le_t
    have hstepI : rowExt I (uClose I J - 1) < rowExt I (uClose I J) := by
      have :
          rowExt I (uClose I J - 1) <
            rowExt I ((uClose I J - 1) + 1) := by
        exact rowExt_step_lt I hu1_pos hu1_lt_t
      simpa [Nat.sub_add_cancel hu_pos] using this
    have hlt : rowExt J (uClose I J) < rowExt I (uClose I J) := by
      exact lt_of_le_of_lt h3 hstepI
    have : rowExt I (uClose I J) < rowExt I (uClose I J) := by
      simp [hrowEq] at hlt
    exact lt_irrefl _ this
  exact le_antisymm hu_le hle


/-- Case `α_t = α'_t`: then the middle block has length one. -/
lemma close_pairExt_ne_mid_of_rowEq
    (I J : MinorIndex m n t)
    (hC : Close I J)
    (hrowEq :
      rowExt I (uClose I J) = rowExt J (uClose I J))
    {i j : ℕ}
    (hi₁ : sClose I J + 1 ≤ i)
    (hi₂ : i ≤ uClose I J)
    (hj₁ : sClose I J + 1 ≤ j)
    (hj₂ : j ≤ uClose I J) :
    pairExt I i ≠ pairExt J j := by
  have hIJ : I ≠ J := hC.ne
  have hu : uClose I J = sClose I J + 1 :=
    close_uClose_eq_succ_of_rowEq I J hC hrowEq
  have hi : i = uClose I J := by
    omega
  have hj : j = uClose I J := by
    omega
  have hu_le_t : uClose I J ≤ t := by
    exact le_trans (uClose_le_pClose I J hIJ) (pClose_le I J)
  have hu_pos : 1 ≤ uClose I J := by
    have hsltu : sClose I J < uClose I J := sClose_lt_uClose I J hIJ
    omega
  have hneq : pairExt I (uClose I J) ≠ pairExt J (uClose I J) := by
    have hdiff₁ : diffAt I J (sClose I J + 1) :=
      diffAt_succ_sClose_of_mu_eq_right I J hIJ
    have hdiffu : diffAt I J (uClose I J) := by
      simpa [hu] using hdiff₁
    exact (diffAt_iff_pairExt_ne I J hu_pos hu_le_t).mp hdiffu
  simpa [hi, hj] using hneq

/-! ### Lemma 1.4(iv)

If `α'_t < α_t`, then:
1. for every `s+1 ≤ i ≤ t`, one has `α'_i < α_i`;
2. for every `s+1 ≤ j < t`, one has `β_j < β_{j+1} ≤ β'_j`;
3. moreover, if `s+1 < t`, then `β_t < β'_t`.

Again the paper's second index `t` is our `uClose I J`. -/

/-- Lemma 1.4(iv), first inequality chain on the row side:
for every middle index `i`, one has `α'_i < α_i`. -/
lemma close_row_chain_of_uClose_row_lt
    (I J : MinorIndex m n t)
    (hrowLt :
      rowExt J (uClose I J) < rowExt I (uClose I J)) :
    ∀ i : ℕ, sClose I J + 1 ≤ i → i ≤ uClose I J →
      rowExt J i < rowExt I i := by
  have hIJ : I ≠ J := by
    intro hEq
    subst hEq
    exact lt_irrefl _ hrowLt
  have hmain :
      ∀ d j : ℕ,
        uClose I J - j = d →
        sClose I J + 1 ≤ j →
        j ≤ uClose I J →
        rowExt J j < rowExt I j := by
    intro d
    induction d with
    | zero =>
        intro j hd hj₁ hj₂
        have hj : j = uClose I J := by
          omega
        subst hj
        exact hrowLt
    | succ d ih =>
        intro j hd hj₁ hj₂
        have hj_lt_u : j < uClose I J := by
          omega
        have hd' : uClose I J - (j + 1) = d := by
          omega
        have hnext :
            rowExt J (j + 1) < rowExt I (j + 1) := by
          exact ih (j + 1) hd' (by omega) (by omega)
        have hprev :
            rowExt J ((j + 1) - 1) < rowExt I ((j + 1) - 1) := by
          exact close_chain_at_index
            I J hIJ
            (i := j + 1)
            (by omega)
            (by omega)
            (Nat.le_of_lt hnext)
        simpa using hprev
  intro i hi₁ hi₂
  exact hmain (uClose I J - i) i rfl hi₁ hi₂

/-- The middle-step strict column increase in `I`. -/
lemma close_col_step_lt_mid
    (I J : MinorIndex m n t)
    (hC : Close I J) :
    ∀ j : ℕ, sClose I J + 1 ≤ j → j < uClose I J →
      colExt I j < colExt I (j + 1) := by
  intro j hj₁ hj₂
  have hIJ : I ≠ J := hC.ne
  have hu_le_t : uClose I J ≤ t := by
    exact le_trans (uClose_le_pClose I J hIJ) (pClose_le I J)
  have hj_pos : 0 < j := by
    omega
  have hj_le_t : j ≤ t := by
    omega
  have hj1_le_t : j + 1 ≤ t := by
    omega
  let k0 : Fin t := ⟨j - 1, by omega⟩
  let k1 : Fin t := ⟨j, by omega⟩
  have hk01 : k0 < k1 := by
    simp [k0, k1]
    omega
  have hfin : I.col k0 < I.col k1 := I.col.strictMono hk01
  have hcolj : colExt I j = (I.col k0).1 + 1 := by
    unfold colExt
    simp [hj_pos.ne', hj_le_t, k0]
  have hcolj1 : colExt I (j + 1) = (I.col k1).1 + 1 := by
    unfold colExt
    simp [hj1_le_t, k1]
  have hnat : (I.col k0).1 + 1 < (I.col k1).1 + 1 := by
    exact Nat.succ_lt_succ <| by
      simpa using hfin
  simpa [hcolj, hcolj1] using hnat

/-- Lemma 1.4(iv), second inequality chain on the column side:
for every `s+1 ≤ j < t`, one has `β_j < β_{j+1} ≤ β'_j`. -/
lemma close_col_chain_of_uClose_row_lt
    (I J : MinorIndex m n t)
    (hC : Close I J)
    (hrowLt :
      rowExt J (uClose I J) < rowExt I (uClose I J)) :
    ∀ j : ℕ, sClose I J + 1 ≤ j → j < uClose I J →
      colExt I j < colExt I (j + 1) ∧
      colExt I (j + 1) ≤ colExt J j := by
  intro j hj₁ hj₂
  have hIJ : I ≠ J := hC.ne
  have hrowj1 : rowExt J (j + 1) < rowExt I (j + 1) := by
    exact close_row_chain_of_uClose_row_lt I J hrowLt (j + 1) (by omega) (by omega)
  have hle_row : rowExt J (j + 1) ≤ rowExt I (j + 1) := Nat.le_of_lt hrowj1
  have hcol_le : colExt I (j + 1) ≤ colExt J j := by
    exact close_chain_row_le_to_prev_col_le I J hIJ (by omega) (by omega) hle_row
  have hcol_lt : colExt I j < colExt I (j + 1) := by
    exact close_col_step_lt_mid I J hC j hj₁ hj₂
  exact ⟨hcol_lt, hcol_le⟩

/-- Lemma 1.4(iv), final strict inequality when `s+1 < t`:
one has `β_t < β'_t`. -/
lemma close_last_col_lt_uClose_col_of_uClose_row_lt
    (I J : MinorIndex m n t)
    (hC : Close I J)
    (hrowLt :
      rowExt J (uClose I J) < rowExt I (uClose I J))
    (hst : sClose I J + 1 < uClose I J) :
    colExt I (uClose I J) < colExt J (uClose I J) := by
  have hIJ : I ≠ J := hC.ne
  have hu_pos : 0 < uClose I J := by
    have hsltu : sClose I J < uClose I J := sClose_lt_uClose I J hIJ
    omega
  have hu_le_t : uClose I J ≤ t := by
    exact le_trans (uClose_le_pClose I J hIJ) (pClose_le I J)
  have hchain :
      colExt I (uClose I J - 1) < colExt I (uClose I J) ∧
      colExt I (uClose I J) ≤ colExt J (uClose I J - 1) := by
    have hpred_ge : sClose I J + 1 ≤ uClose I J - 1 := by
      omega
    have hpred_lt : uClose I J - 1 < uClose I J := by
      omega
    simpa [Nat.sub_add_cancel hu_pos] using
      close_col_chain_of_uClose_row_lt I J hC hrowLt (uClose I J - 1) hpred_ge hpred_lt
  have hstepJ : colExt J (uClose I J - 1) < colExt J (uClose I J) := by
    have hu1_pos : 1 ≤ uClose I J - 1 := by
      omega
    have hu1_lt_t : uClose I J - 1 < t := by
      omega
    have : colExt J (uClose I J - 1) < colExt J ((uClose I J - 1) + 1) := by
      exact colExt_step_lt J hu1_pos hu1_lt_t
    simpa [Nat.sub_add_cancel hu_pos] using this
  exact lt_of_le_of_lt hchain.2 hstepJ

/-- Case `α'_t < α_t`: use Lemma 1.4(iv) to force all middle pairs to be distinct. -/
lemma close_pairExt_ne_mid_of_uClose_row_lt
    (I J : MinorIndex m n t)
    (hC : Close I J)
    (hrowLt :
      rowExt J (uClose I J) < rowExt I (uClose I J))
    {i j : ℕ}
    (hi₁ : sClose I J + 1 ≤ i)
    (hi₂ : i ≤ uClose I J)
    (hj₁ : sClose I J + 1 ≤ j)
    (hj₂ : j ≤ uClose I J) :
    pairExt I i ≠ pairExt J j := by
  intro heq
  by_cases hij : i < j
  · have hi_lt_u : i < uClose I J := by
      omega
    have hcolchain :
        colExt I i < colExt I (i + 1) ∧
        colExt I (i + 1) ≤ colExt J i := by
      exact close_col_chain_of_uClose_row_lt
        I J hC hrowLt i hi₁ hi_lt_u
    have hmonoJ : Monotone (colExt J) := colExt_monotone J
    have hi_le_j : i ≤ j := Nat.le_of_lt hij
    have hJi_le_Jj : colExt J i ≤ colExt J j := hmonoJ hi_le_j
    have hstrict : colExt I i < colExt J j := by
      exact lt_of_lt_of_le hcolchain.1 (le_trans hcolchain.2 hJi_le_Jj)
    have hEqCol : colExt I i = colExt J j := congrArg Prod.snd heq
    exact (Nat.ne_of_lt hstrict) hEqCol
  · have hj_le_i : j ≤ i := by
      omega
    have hrowj : rowExt J j < rowExt I j := by
      exact close_row_chain_of_uClose_row_lt I J hrowLt j hj₁ hj₂
    have hmonoI : Monotone (rowExt I) := rowExt_monotone I
    have hIj_le_Ii : rowExt I j ≤ rowExt I i := hmonoI hj_le_i
    have hstrict : rowExt J j < rowExt I i := by
      exact lt_of_lt_of_le hrowj hIj_le_Ii
    have hEqRow : rowExt I i = rowExt J j := congrArg Prod.fst heq
    exact (Nat.ne_of_lt hstrict) hEqRow.symm

/-- Lemma 1.4(ii). -/
lemma close_pairExt_ne_mid
    (I J : MinorIndex m n t)
    (hC : Close I J)
    {i j : ℕ}
    (hi₁ : sClose I J + 1 ≤ i)
    (hi₂ : i ≤ uClose I J)
    (hj₁ : sClose I J + 1 ≤ j)
    (hj₂ : j ≤ uClose I J) :
    pairExt I i ≠ pairExt J j := by
  have huEq : uClose I J = uClose J I := close_uClose_eq_symm I J hC
  have hsEq : sClose I J = sClose J I := close_sClose_eq_symm I J hC
  intro heq
  have htri := lt_trichotomy (rowExt J (uClose I J)) (rowExt I (uClose I J))
  rcases htri with hlt | heqRow | hgt
  · exact (close_pairExt_ne_mid_of_uClose_row_lt I J hC hlt hi₁ hi₂ hj₁ hj₂) heq
  · exact (close_pairExt_ne_mid_of_rowEq I J hC heqRow.symm hi₁ hi₂ hj₁ hj₂) heq
  · have hj₁' : sClose J I + 1 ≤ j := by
      rwa [← hsEq]
    have hj₂' : j ≤ uClose J I := by
      rwa [← huEq]
    have hi₁' : sClose J I + 1 ≤ i := by
      rwa [← hsEq]
    have hi₂' : i ≤ uClose J I := by
      rwa [← huEq]
    have hneq' :
        pairExt J j ≠ pairExt I i := by
      have hgt' : rowExt I (uClose J I) < rowExt J (uClose J I) := by
        simpa [huEq] using hgt
      exact close_pairExt_ne_mid_of_uClose_row_lt J I hC.symm hgt' hj₁' hj₂' hi₁' hi₂'
    exact hneq' heq.symm

end paper1_4

section paper1_5

variable {m n t : ℕ}

/-- The distance used in the induction of CGG Prop. 1.5. -/
def closeDist (I J : MinorIndex m n t) : ℕ :=
  ∑ k : Fin t,
    (Nat.dist (I.row k).1 (J.row k).1 +
      Nat.dist (I.col k).1 (J.col k).1)

/-- Every pair of `K` comes from either the left endpoint `I` or the right endpoint `J`. -/
def PairExtFromEndpoints
    (I J K : MinorIndex m n t) : Prop :=
  ∀ i : ℕ, 1 ≤ i → i ≤ t →
    pairExt K i = pairExt I i ∨ pairExt K i = pairExt J i

/-- A paper-1.5 style chain of indices:
`F 0 = I`, `F p = J`, and every adjacent pair is `Close`. -/
def IndexCloseChain
    (I J : MinorIndex m n t)
    (p : ℕ)
    (F : Fin (p + 1) → MinorIndex m n t) : Prop :=
  F 0 = I ∧
  F ⟨p, Nat.lt_succ_self p⟩ = J ∧
  (∀ i : Fin p, Close (F i.castSucc) (F i.succ))

/-- Every term of the chain uses only pairs coming from the two endpoints. -/
def IndexChainUsesOnlyEndpoints
    (I J : MinorIndex m n t)
    (p : ℕ)
    (F : Fin (p + 1) → MinorIndex m n t) : Prop :=
  ∀ q : Fin (p + 1), PairExtFromEndpoints I J (F q)

lemma closeDist_comm
    (I J : MinorIndex m n t) :
    closeDist I J = closeDist J I := by
  unfold closeDist
  refine Finset.sum_congr rfl ?_
  intro k hk
  simp [Nat.dist_comm]

lemma PairExtFromEndpoints.refl_left
    (I J : MinorIndex m n t) :
    PairExtFromEndpoints I J I := by
  intro i hi₁ hi₂
  exact Or.inl rfl

lemma PairExtFromEndpoints.refl_right
    (I J : MinorIndex m n t) :
    PairExtFromEndpoints I J J := by
  intro i hi₁ hi₂
  exact Or.inr rfl

lemma pairExt_mu_eq_left_le_s
    (I J : MinorIndex m n t)
    (hIJ : I ≠ J)
    {i : ℕ}
    (hi₁ : 1 ≤ i)
    (hi₂ : i ≤ sClose I J) :
    pairExt (mu I J hIJ) i = pairExt I i := by
  let k : Fin t := ⟨i - 1, by
    have hs : sClose I J < pClose I J := sClose_lt_pClose I J hIJ
    have hp : pClose I J ≤ t := pClose_le I J
    omega⟩
  have hk_eq : k.1 + 1 = i := by
    simp only [k]
    exact Nat.sub_add_cancel hi₁
  have hk_le_s : k.1 + 1 ≤ sClose I J := by
    simpa [hk_eq] using hi₂
  have hi_t : i ≤ t := by
    have hs : sClose I J < pClose I J := sClose_lt_pClose I J hIJ
    exact le_trans hi₂ <| le_trans (Nat.le_of_lt hs) (pClose_le I J)
  have hrow :
      rowExt (mu I J hIJ) i = rowExt I i := by
    unfold rowExt
    have hi0 : i ≠ 0 := by omega
    simp [hi0, hi_t, mu, strictMonoToOrderEmbedding, muRow, k, hk_le_s]
  have hcol :
      colExt (mu I J hIJ) i = colExt I i := by
    unfold colExt
    have hi0 : i ≠ 0 := by omega
    simp [hi0, hi_t, mu, strictMonoToOrderEmbedding, muCol, k, hk_le_s]
  exact Prod.ext hrow hcol

lemma pairExt_mu_eq_left_gt_u
    (I J : MinorIndex m n t)
    (hIJ : I ≠ J)
    {i : ℕ}
    (hi₁ : uClose I J < i)
    (hi₂ : i ≤ t) :
    pairExt (mu I J hIJ) i = pairExt I i := by
  have hi0 : 0 < i := by omega
  let k : Fin t := ⟨i - 1, by omega⟩
  have hk_eq : k.1 + 1 = i := by
    simp only [k]
    exact Nat.sub_add_cancel hi0
  have hk_not_le_s : ¬ k.1 + 1 ≤ sClose I J := by
    rw [hk_eq]
    have hsu : sClose I J < uClose I J := sClose_lt_uClose I J hIJ
    omega
  have hk_not_le_u : ¬ k.1 + 1 ≤ uClose I J := by
    rw [hk_eq]
    omega
  have hrow :
      rowExt (mu I J hIJ) i = rowExt I i := by
    unfold rowExt
    have hi0' : i ≠ 0 := by omega
    simp [hi0', hi₂, mu, strictMonoToOrderEmbedding, muRow, k, hk_not_le_s, hk_not_le_u]
  have hcol :
      colExt (mu I J hIJ) i = colExt I i := by
    unfold colExt
    have hi0' : i ≠ 0 := by omega
    simp [hi0', hi₂, mu, strictMonoToOrderEmbedding, muCol, k, hk_not_le_s, hk_not_le_u]
  exact Prod.ext hrow hcol

/-- At each genuine paper-position, `μ(I,J)` takes its pair either from `I` or from `J`. -/
lemma mu_pairExt_eq_left_or_right
    (I J : MinorIndex m n t)
    (hIJ : I ≠ J)
    {i : ℕ}
    (hi₁ : 1 ≤ i)
    (hi₂ : i ≤ t) :
    pairExt (mu I J hIJ) i = pairExt I i ∨
      pairExt (mu I J hIJ) i = pairExt J i := by
  by_cases hiS : i ≤ sClose I J
  · left
    exact pairExt_mu_eq_left_le_s I J hIJ hi₁ hiS
  · by_cases hiU : i ≤ uClose I J
    · right
      exact pairExt_mu_eq_right_of_mid I J hIJ (by omega) hiU
    · left
      exact pairExt_mu_eq_left_gt_u I J hIJ (by omega) hi₂

lemma mu_pairExtFromEndpoints
    (I J : MinorIndex m n t)
    (hIJ : I ≠ J) :
    PairExtFromEndpoints I J (mu I J hIJ) := by
  intro i hi₁ hi₂
  exact mu_pairExt_eq_left_or_right I J hIJ hi₁ hi₂

/-- If a point uses only pairs from `I` and `μ(I,J)`,
then it already uses only pairs from `I` and `J`. -/
lemma pairExtFromEndpoints_trans_of_mu
    (I J : MinorIndex m n t)
    (hIJ : I ≠ J)
    {K L : MinorIndex m n t}
    (hK : K = mu I J hIJ)
    (hL : PairExtFromEndpoints I K L) :
    PairExtFromEndpoints I J L := by
  intro i hi₁ hi₂
  rcases hL i hi₁ hi₂ with hLI | hLK
  · exact Or.inl hLI
  · subst hK
    rcases mu_pairExt_eq_left_or_right I J hIJ hi₁ hi₂ with hKI | hKJ
    · exact Or.inl (hLK.trans hKI)
    · exact Or.inr (hLK.trans hKJ)

/-- If a point uses only pairs from `μ(I,J)` and `J`,
 then it already uses only pairs from `I` and `J`. -/
lemma pairExtFromEndpoints_trans_of_mu'
    (I J : MinorIndex m n t)
    (hIJ : I ≠ J)
    {K L : MinorIndex m n t}
    (hK : K = mu I J hIJ)
    (hL : PairExtFromEndpoints K J L) :
    PairExtFromEndpoints I J L := by
  intro i hi₁ hi₂
  rcases hL i hi₁ hi₂ with hLK | hLJ
  · subst hK
    rcases mu_pairExt_eq_left_or_right I J hIJ hi₁ hi₂ with hKI | hKJ
    · exact Or.inl (hLK.trans hKI)
    · exact Or.inr (hLK.trans hKJ)
  · exact Or.inr hLJ

/-- Base case for Prop. 1.5: if `I` and `J` are already close, take the 2-term chain. -/
lemma exists_indexCloseChain_of_close
    (I J : MinorIndex m n t)
    (hC : Close I J) :
    ∃ p : ℕ, ∃ F : Fin (p + 1) → MinorIndex m n t,
      IndexCloseChain I J p F ∧
      IndexChainUsesOnlyEndpoints I J p F := by
  classical
  refine ⟨1, ?_, ?_, ?_⟩
  · intro q
    exact if q.1 = 0 then I else J
  · constructor
    · simp
    · constructor
      · simp
      · intro i
        have hi : i = 0 := Fin.eq_zero i
        subst hi
        simp [hC]
  · intro q
    fin_cases q
    · simpa using (PairExtFromEndpoints.refl_left (I := I) (J := J))
    · simpa using (PairExtFromEndpoints.refl_right (I := I) (J := J))

/-- If `I` and `J` are not close, at least one of the two directed `μ`-steps
fails to reach the other endpoint. -/
lemma not_close_oriented
    (I J : MinorIndex m n t)
    (hIJ : I ≠ J)
    (hNC : ¬ Close I J) :
    mu I J hIJ ≠ J ∨ mu J I hIJ.symm ≠ I := by
  by_cases h₁ : mu I J hIJ = J
  · right
    intro h₂
    exact hNC ⟨hIJ, h₁, h₂⟩
  · exact Or.inl h₁

/-- Prop. 1.5, part (a): the intermediate point `μ(I,J)` is strictly closer to `I`
provided it is not already equal to `J`. -/
lemma closeDist_mu_lt_left_of_ne_right
    (I J : MinorIndex m n t)
    (hIJ : I ≠ J)
    (hμ : mu I J hIJ ≠ J) :
    closeDist (mu I J hIJ) I < closeDist I J := by
  classical
  unfold closeDist
  refine Finset.sum_lt_sum ?_ ?_
  · intro k hk
    by_cases hs : k.1 + 1 ≤ sClose I J
    · simp [mu, strictMonoToOrderEmbedding, muRow, muCol, hs]
    · by_cases hu : k.1 + 1 ≤ uClose I J
      · simp [mu, strictMonoToOrderEmbedding, muRow, muCol, hs, hu, Nat.dist_comm]
      · simp [mu, strictMonoToOrderEmbedding, muRow, muCol, hs, hu]
  · rcases exists_diffAt (mu I J hIJ) J hμ with ⟨j, hjt, hdiffμJ⟩
    have hj1 : 1 ≤ j := by
      cases j with
      | zero =>
          simp [diffAt] at hdiffμJ
      | succ j =>
          omega
    let k : Fin t := ⟨j - 1, by omega⟩
    have hk_succ : k.1 + 1 = j := by
      simp [k, Nat.sub_add_cancel hj1]
    have hnot_mid : ¬ (sClose I J < j ∧ j ≤ uClose I J) := by
      intro hmid
      have hEq : pairExt (mu I J hIJ) j = pairExt J j := by
        apply Prod.ext
        · unfold pairExt rowExt
          have hj0 : j ≠ 0 := by omega
          have hk_not_le_s : ¬ k.1 + 1 ≤ sClose I J := by
            rw [hk_succ]
            omega
          have hk_le_u : k.1 + 1 ≤ uClose I J := by
            rw [hk_succ]
            omega
          simp [mu, strictMonoToOrderEmbedding, muRow, hj0, hjt, k, hk_not_le_s, hk_le_u]
        · unfold pairExt colExt
          have hj0 : j ≠ 0 := by omega
          have hk_not_le_s : ¬ k.1 + 1 ≤ sClose I J := by
            rw [hk_succ]
            omega
          have hk_le_u : k.1 + 1 ≤ uClose I J := by
            rw [hk_succ]
            omega
          simp [mu, strictMonoToOrderEmbedding, muCol, hj0, hjt, k, hk_not_le_s, hk_le_u]
      have hneq :
          pairExt (mu I J hIJ) j ≠ pairExt J j :=
        (diffAt_iff_pairExt_ne (mu I J hIJ) J hj1 hjt).mp hdiffμJ
      exact hneq hEq
    have hside : j ≤ sClose I J ∨ uClose I J < j := by
      omega
    have hEqμI : pairExt (mu I J hIJ) j = pairExt I j := by
      cases hside with
      | inl hjs =>
          apply Prod.ext
          · unfold pairExt rowExt
            have hj0 : j ≠ 0 := by omega
            have hk_le_s : k.1 + 1 ≤ sClose I J := by
              rw [hk_succ]
              exact hjs
            simp [mu, strictMonoToOrderEmbedding, muRow, hj0, hjt, k, hk_le_s]
          · unfold pairExt colExt
            have hj0 : j ≠ 0 := by omega
            have hk_le_s : k.1 + 1 ≤ sClose I J := by
              rw [hk_succ]
              exact hjs
            simp [mu, strictMonoToOrderEmbedding, muCol, hj0, hjt, k, hk_le_s]
      | inr huj =>
          apply Prod.ext
          · unfold pairExt rowExt
            have hj0 : j ≠ 0 := by omega
            have hk_not_le_s : ¬ k.1 + 1 ≤ sClose I J := by
              rw [hk_succ]
              have hsltu : sClose I J < uClose I J := sClose_lt_uClose I J hIJ
              omega
            have hk_not_le_u : ¬ k.1 + 1 ≤ uClose I J := by
              rw [hk_succ]
              omega
            simp [mu, strictMonoToOrderEmbedding, muRow, hj0, hjt, k, hk_not_le_s, hk_not_le_u]
          · unfold pairExt colExt
            have hj0 : j ≠ 0 := by omega
            have hk_not_le_s : ¬ k.1 + 1 ≤ sClose I J := by
              rw [hk_succ]
              have hsltu : sClose I J < uClose I J := sClose_lt_uClose I J hIJ
              omega
            have hk_not_le_u : ¬ k.1 + 1 ≤ uClose I J := by
              rw [hk_succ]
              omega
            simp [mu, strictMonoToOrderEmbedding, muCol, hj0, hjt, k, hk_not_le_s, hk_not_le_u]
    have hneqμJ :
        pairExt (mu I J hIJ) j ≠ pairExt J j :=
      (diffAt_iff_pairExt_ne (mu I J hIJ) J hj1 hjt).mp hdiffμJ
    have hneqIJ : pairExt I j ≠ pairExt J j := by
      intro hEq
      exact hneqμJ (hEqμI.trans hEq)
    have hdiffIJ : diffAt I J j :=
      (diffAt_iff_pairExt_ne I J hj1 hjt).mpr hneqIJ
    have hdiffIJ' : diffAt I J (k.1 + 1) := by
      simpa [hk_succ] using hdiffIJ
    have hrawneq : (I.row k, I.col k) ≠ (J.row k, J.col k) := by
      simpa [diffAt, k, k.2] using hdiffIJ'
    have hrow_or_col : I.row k ≠ J.row k ∨ I.col k ≠ J.col k := by
      by_cases hrow : I.row k = J.row k
      · right
        intro hcol
        apply hrawneq
        exact Prod.ext hrow hcol
      · exact Or.inl hrow
    have hf0 :
        Nat.dist ((mu I J hIJ).row k).1 (I.row k).1 +
            Nat.dist ((mu I J hIJ).col k).1 (I.col k).1 = 0 := by
      cases hside with
      | inl hjs =>
          have hk_le_s : k.1 + 1 ≤ sClose I J := by
            rw [hk_succ]
            exact hjs
          simp [mu, strictMonoToOrderEmbedding, muRow, muCol, hk_le_s]
      | inr huj =>
          have hk_not_le_s : ¬ k.1 + 1 ≤ sClose I J := by
            rw [hk_succ]
            have hsltu : sClose I J < uClose I J := sClose_lt_uClose I J hIJ
            omega
          have hk_not_le_u : ¬ k.1 + 1 ≤ uClose I J := by
            rw [hk_succ]
            omega
          simp [mu, strictMonoToOrderEmbedding, muRow, muCol, hk_not_le_s, hk_not_le_u]
    have hgpos :
        0 <
          Nat.dist (I.row k).1 (J.row k).1 +
            Nat.dist (I.col k).1 (J.col k).1 := by
      rcases hrow_or_col with hrow | hcol
      · have hrowv : (I.row k).1 ≠ (J.row k).1 := by
          intro hval
          apply hrow
          exact Fin.ext hval
        have hdist : 0 < Nat.dist (I.row k).1 (J.row k).1 := Nat.dist_pos_of_ne hrowv
        omega
      · have hcolv : (I.col k).1 ≠ (J.col k).1 := by
          intro hval
          apply hcol
          exact Fin.ext hval
        have hdist : 0 < Nat.dist (I.col k).1 (J.col k).1 := Nat.dist_pos_of_ne hcolv
        omega
    refine ⟨k, by simp, ?_⟩
    rw [hf0]
    exact hgpos

/-- Prop. 1.5, part (b): the intermediate point `μ(I,J)` is strictly closer to `J`
provided it is not already equal to `J`. -/
lemma closeDist_mu_lt_right_of_ne_right
    (I J : MinorIndex m n t)
    (hIJ : I ≠ J) :
    closeDist (mu I J hIJ) J < closeDist I J := by
  classical
  unfold closeDist
  refine Finset.sum_lt_sum ?_ ?_
  · intro k hk
    by_cases hs : k.1 + 1 ≤ sClose I J
    · simp [mu, strictMonoToOrderEmbedding, muRow, muCol, hs]
    · by_cases hu : k.1 + 1 ≤ uClose I J
      · simp [mu, strictMonoToOrderEmbedding, muRow, muCol, hs, hu]
      · simp [mu, strictMonoToOrderEmbedding, muRow, muCol, hs, hu]
  · have hsltp : sClose I J < pClose I J := sClose_lt_pClose I J hIJ
    have hple : pClose I J ≤ t := pClose_le I J
    have hslt : sClose I J < t := lt_of_lt_of_le hsltp hple
    let k : Fin t := ⟨sClose I J, hslt⟩
    have hk_not_le_s : ¬ k.1 + 1 ≤ sClose I J := by
      simp [k]
    have hk_le_u : k.1 + 1 ≤ uClose I J := by
      simpa [k] using Nat.succ_le_of_lt (sClose_lt_uClose I J hIJ)
    have hf0 :
        Nat.dist ((mu I J hIJ).row k).1 (J.row k).1 +
            Nat.dist ((mu I J hIJ).col k).1 (J.col k).1 = 0 := by
      simp [mu, strictMonoToOrderEmbedding, muRow, muCol, k, hk_not_le_s, hk_le_u]
    have hdiff : diffAt I J (sClose I J + 1) :=
      diffAt_succ_sClose_of_mu_eq_right I J hIJ
    have hrawneq : (I.row k, I.col k) ≠ (J.row k, J.col k) := by
      simpa [diffAt, k, hslt] using hdiff
    have hrow_or_col : I.row k ≠ J.row k ∨ I.col k ≠ J.col k := by
      by_cases hrow : I.row k = J.row k
      · right
        intro hcol
        apply hrawneq
        exact Prod.ext hrow hcol
      · exact Or.inl hrow
    have hgpos :
        0 <
          Nat.dist (I.row k).1 (J.row k).1 +
            Nat.dist (I.col k).1 (J.col k).1 := by
      rcases hrow_or_col with hrow | hcol
      · have hrowv : (I.row k).1 ≠ (J.row k).1 := by
          intro hval
          apply hrow
          exact Fin.ext hval
        have hdist : 0 < Nat.dist (I.row k).1 (J.row k).1 :=
          Nat.dist_pos_of_ne hrowv
        omega
      · have hcolv : (I.col k).1 ≠ (J.col k).1 := by
          intro hval
          apply hcol
          exact Fin.ext hval
        have hdist : 0 < Nat.dist (I.col k).1 (J.col k).1 :=
          Nat.dist_pos_of_ne hcolv
        omega
    refine ⟨k, by simp, ?_⟩
    rw [hf0]
    exact hgpos

/-- Concatenate two close-chains. -/
lemma indexCloseChain_append
    {I K J : MinorIndex m n t}
    {p q : ℕ}
    {F : Fin (p + 1) → MinorIndex m n t}
    {G : Fin (q + 1) → MinorIndex m n t}
    (hF : IndexCloseChain I K p F)
    (hG : IndexCloseChain K J q G)
    (hFep : IndexChainUsesOnlyEndpoints I J p F)
    (hGep : IndexChainUsesOnlyEndpoints I J q G) :
    ∃ r : ℕ, ∃ H : Fin (r + 1) → MinorIndex m n t,
      IndexCloseChain I J r H ∧
      IndexChainUsesOnlyEndpoints I J r H := by
  classical
  rcases hF with ⟨hF0, hFp, hFadj⟩
  rcases hG with ⟨hG0, hGq, hGadj⟩
  let H : Fin (p + q + 1) → MinorIndex m n t := fun r =>
    if hr : r.1 ≤ p then
      F ⟨r.1, by omega⟩
    else
      G ⟨r.1 - p, by
        have hrlt : r.1 < p + q + 1 := r.2
        omega⟩
  refine ⟨p + q, H, ?_, ?_⟩
  · constructor
    · have h0 : (0 : ℕ) ≤ p := Nat.zero_le p
      simpa [H, h0] using hF0
    · constructor
      · by_cases hq0 : q = 0
        · subst hq0
          have hKJ : K = J := by
            simpa using hG0.symm.trans hGq
          have hlast : (p : ℕ) ≤ p := le_rfl
          simpa [H, hlast, hKJ] using hFp
        · have hlast : ¬ (p + q ≤ p) := by omega
          simpa [H, hlast, hq0] using hGq
      · intro i
        by_cases hip : i.1 < p
        · let j : Fin p := ⟨i.1, hip⟩
          have hcast : (i.castSucc).1 ≤ p := by
            simpa using (le_of_lt hip : i.1 ≤ p)
          have hsucc : (i.succ).1 ≤ p := by
            simpa using (Nat.succ_le_of_lt hip : i.1 + 1 ≤ p)
          have hHi : H i.castSucc = F j.castSucc := by
            exact dif_pos hcast
          have hHnext : H i.succ = F j.succ := by
            exact dif_pos hip
          rw [hHi, hHnext]
          exact hFadj j
        · by_cases hieq : i.1 = p
          · have hqpos : 0 < q := by
              have hi_lt : i.1 < p + q := i.2
              omega
            have hcast : (i.castSucc).1 ≤ p := by
              simp [hieq]
            have hsucc : ¬ (i.succ).1 ≤ p := by
              simp [hieq]
            have hHi : H i.castSucc = K := by
              unfold H
              simp [hieq, hFp]
            have hHnext : H i.succ = G ⟨1, by omega⟩ := by
              unfold H
              simp [hieq]
            have hmid : Close K (G ⟨1, by omega⟩) := by
              simpa [hG0] using hGadj ⟨0, hqpos⟩
            rw [hHi, hHnext]
            exact hmid
          · have hgt : p < i.1 := by omega
            let j : Fin q := ⟨i.1 - p, by
              have hi_lt : i.1 < p + q := i.2
              omega⟩
            have hcast : ¬ (i.castSucc).1 ≤ p := by
              simpa using (not_le_of_gt hgt : ¬ i.1 ≤ p)
            have hsucc : ¬ (i.succ).1 ≤ p := by
              have hs : p < i.1 + 1 := Nat.lt_succ_of_lt hgt
              simpa using (not_le_of_gt hs : ¬ (i.1 + 1 ≤ p))
            have hHi : H i.castSucc = G j.castSucc := by
              exact dif_neg hcast
            have hidx : (⟨i.1 + 1 - p, by
              have hi_lt : i.1 < p + q := i.2
              omega⟩ : Fin (q + 1)) = j.succ := by
              apply Fin.ext
              simp [j]
              omega
            have hHnext : H i.succ = G j.succ := by
              have htmp : H i.succ = G ⟨i.1 + 1 - p, by
                  have hi_lt : i.1 < p + q := i.2
                  omega⟩ := by
                unfold H
                simp only [Fin.val_succ, Order.add_one_le_iff]
                exact dif_neg hip
              exact htmp.trans (by rw [hidx])
            rw [hHi, hHnext]
            exact hGadj j
  · intro r
    by_cases hr : r.1 ≤ p
    · simpa [H, hr] using hFep ⟨r.1, by omega⟩
    · simpa [H, hr] using hGep ⟨r.1 - p, by
        have hrlt : r.1 < p + q + 1 := r.2
        omega⟩

/-- Strong-induction form of Prop. 1.5. -/
theorem exists_indexCloseChain_aux
    (N : ℕ) :
    ∀ I J : MinorIndex m n t,
      closeDist I J ≤ N →
      I ≠ J →
      ∃ p : ℕ, ∃ F : Fin (p + 1) → MinorIndex m n t,
        IndexCloseChain I J p F ∧
        IndexChainUsesOnlyEndpoints I J p F := by
  intro I J hdist hIJ
  have hstrong :
      ∀ N : ℕ,
        ∀ I J : MinorIndex m n t,
          closeDist I J ≤ N →
          I ≠ J →
          (∃ p : ℕ, ∃ F : Fin (p + 1) → MinorIndex m n t,
              IndexCloseChain I J p F ∧
              IndexChainUsesOnlyEndpoints I J p F) ∧
          (∃ p : ℕ, ∃ F : Fin (p + 1) → MinorIndex m n t,
              IndexCloseChain J I p F ∧
              IndexChainUsesOnlyEndpoints J I p F) := by
    intro N
    refine Nat.strong_induction_on N ?_
    intro N ih I J hdist hIJ
    by_cases hC : Close I J
    · exact
        ⟨exists_indexCloseChain_of_close I J hC,
         exists_indexCloseChain_of_close J I hC.symm⟩
    · rcases not_close_oriented I J hIJ hC with hμ | hμ
      · let K : MinorIndex m n t := mu I J hIJ
        have hK : K = mu I J hIJ := rfl
        have hIK_ne : I ≠ K := by
          intro hEq
          have hne : K ≠ I := by
            simpa [hK] using (mu_ne_left I J hIJ)
          exact hne hEq.symm
        have hKJ_ne : K ≠ J := by
          simpa [hK] using hμ
        have hIK_lt : closeDist I K < N := by
          have hlt' : closeDist K I < closeDist I J := by
            simpa [hK] using
              (closeDist_mu_lt_left_of_ne_right I J hIJ hμ)
          have hlt : closeDist I K < closeDist I J := by
            simpa [closeDist_comm] using hlt'
          exact lt_of_lt_of_le hlt hdist
        have hKJ_lt : closeDist K J < N := by
          have hlt : closeDist K J < closeDist I J := by
            simpa [hK] using
              (closeDist_mu_lt_right_of_ne_right I J hIJ)
          exact lt_of_lt_of_le hlt hdist
        have hrecIK :=
          ih (closeDist I K) hIK_lt I K le_rfl hIK_ne
        have hrecKJ :=
          ih (closeDist K J) hKJ_lt K J le_rfl hKJ_ne
        rcases hrecIK with ⟨hIK, hKI⟩
        rcases hrecKJ with ⟨hKJ, hJK⟩
        have hK_from_IJ : PairExtFromEndpoints I J K := by
          exact mu_pairExtFromEndpoints I J hIJ
        have hK_from_JI : PairExtFromEndpoints J I K := by
          intro i hi₁ hi₂
          rcases hK_from_IJ i hi₁ hi₂ with hKI | hKJ
          · exact Or.inr hKI
          · exact Or.inl hKJ
        rcases hIK with ⟨p₁, F₁, hF₁, hF₁ep⟩
        rcases hKJ with ⟨p₂, F₂, hF₂, hF₂ep⟩
        have hF₁epIJ : IndexChainUsesOnlyEndpoints I J p₁ F₁ := by
          intro q
          exact
            pairExtFromEndpoints_trans_of_mu
              (I := I) (J := J) (hIJ := hIJ)
              (K := K) (L := F₁ q) hK (hF₁ep q)
        have hF₂epIJ : IndexChainUsesOnlyEndpoints I J p₂ F₂ := by
          intro q
          exact
            pairExtFromEndpoints_trans_of_mu'
              (I := I) (J := J) (hIJ := hIJ)
              (K := K) (L := F₂ q) hK (hF₂ep q)
        have hforw :
            ∃ p : ℕ, ∃ F : Fin (p + 1) → MinorIndex m n t,
              IndexCloseChain I J p F ∧
              IndexChainUsesOnlyEndpoints I J p F := by
          exact indexCloseChain_append hF₁ hF₂ hF₁epIJ hF₂epIJ
        rcases hJK with ⟨p₃, F₃, hF₃, hF₃ep⟩
        rcases hKI with ⟨p₄, F₄, hF₄, hF₄ep⟩
        have hF₃epJI : IndexChainUsesOnlyEndpoints J I p₃ F₃ := by
          intro q i hi₁ hi₂
          rcases hF₃ep q i hi₁ hi₂ with hJq | hKq
          · exact Or.inl hJq
          · rcases hK_from_JI i hi₁ hi₂ with hKJ | hKI
            · exact Or.inl (hKq.trans hKJ)
            · exact Or.inr (hKq.trans hKI)
        have hF₄epJI : IndexChainUsesOnlyEndpoints J I p₄ F₄ := by
          intro q i hi₁ hi₂
          rcases hF₄ep q i hi₁ hi₂ with hKq | hIq
          · rcases hK_from_JI i hi₁ hi₂ with hKJ | hKI
            · exact Or.inl (hKq.trans hKJ)
            · exact Or.inr (hKq.trans hKI)
          · exact Or.inr hIq
        have hback :
            ∃ p : ℕ, ∃ F : Fin (p + 1) → MinorIndex m n t,
              IndexCloseChain J I p F ∧
              IndexChainUsesOnlyEndpoints J I p F := by
          exact indexCloseChain_append hF₃ hF₄ hF₃epJI hF₄epJI
        exact ⟨hforw, hback⟩
      · let K : MinorIndex m n t := mu J I hIJ.symm
        have hK : K = mu J I hIJ.symm := rfl
        have hJK_ne : J ≠ K := by
          intro hEq
          have hne : K ≠ J := by
            simpa [hK] using (mu_ne_left J I hIJ.symm)
          exact hne hEq.symm
        have hKI_ne : K ≠ I := by
          simpa [hK] using hμ
        have hJK_lt : closeDist J K < N := by
          have hlt' : closeDist K J < closeDist J I := by
            simpa [hK] using
              (closeDist_mu_lt_left_of_ne_right J I hIJ.symm hμ)
          have hlt : closeDist J K < closeDist I J := by
            simpa [closeDist_comm] using hlt'
          exact lt_of_lt_of_le hlt hdist
        have hKI_lt : closeDist K I < N := by
          have hlt' : closeDist K I < closeDist J I := by
            simpa [hK] using
              (closeDist_mu_lt_right_of_ne_right J I hIJ.symm)
          have hlt : closeDist K I < closeDist I J := by
            simpa [closeDist_comm] using hlt'
          exact lt_of_lt_of_le hlt hdist
        have hrecJK :=
          ih (closeDist J K) hJK_lt J K le_rfl hJK_ne
        have hrecKI :=
          ih (closeDist K I) hKI_lt K I le_rfl hKI_ne
        rcases hrecJK with ⟨hJK, hKJ⟩
        rcases hrecKI with ⟨hKI, hIK⟩
        have hK_from_JI : PairExtFromEndpoints J I K := by
          exact mu_pairExtFromEndpoints J I hIJ.symm
        have hK_from_IJ : PairExtFromEndpoints I J K := by
          intro i hi₁ hi₂
          rcases hK_from_JI i hi₁ hi₂ with hKJ | hKI
          · exact Or.inr hKJ
          · exact Or.inl hKI
        rcases hIK with ⟨p₁, F₁, hF₁, hF₁ep⟩
        rcases hKJ with ⟨p₂, F₂, hF₂, hF₂ep⟩
        have hF₁epIJ : IndexChainUsesOnlyEndpoints I J p₁ F₁ := by
          intro q i hi₁ hi₂
          rcases hF₁ep q i hi₁ hi₂ with hIq | hKq
          · exact Or.inl hIq
          · rcases hK_from_IJ i hi₁ hi₂ with hKI | hKJ
            · exact Or.inl (hKq.trans hKI)
            · exact Or.inr (hKq.trans hKJ)
        have hF₂epIJ : IndexChainUsesOnlyEndpoints I J p₂ F₂ := by
          intro q i hi₁ hi₂
          rcases hF₂ep q i hi₁ hi₂ with hKq | hJq
          · rcases hK_from_IJ i hi₁ hi₂ with hKI | hKJ
            · exact Or.inl (hKq.trans hKI)
            · exact Or.inr (hKq.trans hKJ)
          · exact Or.inr hJq
        have hforw :
            ∃ p : ℕ, ∃ F : Fin (p + 1) → MinorIndex m n t,
              IndexCloseChain I J p F ∧
              IndexChainUsesOnlyEndpoints I J p F := by
          exact indexCloseChain_append hF₁ hF₂ hF₁epIJ hF₂epIJ
        rcases hJK with ⟨p₃, F₃, hF₃, hF₃ep⟩
        rcases hKI with ⟨p₄, F₄, hF₄, hF₄ep⟩
        have hF₃epJI : IndexChainUsesOnlyEndpoints J I p₃ F₃ := by
          intro q i hi₁ hi₂
          rcases hF₃ep q i hi₁ hi₂ with hJq | hKq
          · exact Or.inl hJq
          · rcases hK_from_JI i hi₁ hi₂ with hKJ | hKI
            · exact Or.inl (hKq.trans hKJ)
            · exact Or.inr (hKq.trans hKI)
        have hF₄epJI : IndexChainUsesOnlyEndpoints J I p₄ F₄ := by
          intro q
          exact
            pairExtFromEndpoints_trans_of_mu'
              (I := J) (J := I) (hIJ := hIJ.symm)
              (K := K) (L := F₄ q) hK (hF₄ep q)
        have hback :
            ∃ p : ℕ, ∃ F : Fin (p + 1) → MinorIndex m n t,
              IndexCloseChain J I p F ∧
              IndexChainUsesOnlyEndpoints J I p F := by
          exact indexCloseChain_append hF₃ hF₄ hF₃epJI hF₄epJI
        exact ⟨hforw, hback⟩
  exact (hstrong N I J hdist hIJ).1

/-- CGG Prop. 1.5 in index-chain form. -/
theorem exists_indexCloseChain
    (I J : MinorIndex m n t)
    (hIJ : I ≠ J) :
    ∃ p : ℕ, ∃ F : Fin (p + 1) → MinorIndex m n t,
      IndexCloseChain I J p F ∧
      IndexChainUsesOnlyEndpoints I J p F := by
  simpa using
    (exists_indexCloseChain_aux (m := m) (n := n) (t := t) (N := closeDist I J)
      I J le_rfl hIJ)

end paper1_5

section paper1_5_bridge

variable {m n t : ℕ}
variable {k : Type*} [CommRing k] [Nontrivial k]

/-!
Bridge lemmas from the paper's combinatorial chain (Prop. 1.5)
to the Groebner-basis API (`HasGoodChain`, `AdjacentSmallSPolynomialRep`, etc.).
-/

/-- If every position of `K` comes from one of the two endpoints `I,J`,
then the diagonal exponent of `K` is bounded by the join of the endpoint
diagonal exponents.

This is the key combinatorial-to-monomial bridge extracted from Prop. 1.5. -/
lemma diagExp_le_sup_of_pairExtFromEndpoints
    {I J K : MinorIndex m n t}
    (hK : PairExtFromEndpoints I J K) :
    diagExp K ≤ diagExp I ⊔ diagExp J := by
  change ∀ x, diagExp K x ≤ (diagExp I ⊔ diagExp J) x
  intro x
  rcases x with ⟨a, b⟩
  by_cases hx : ∃ i : Fin t, K.row i = a ∧ K.col i = b
  · rcases hx with ⟨i, hrowKi, hcolKi⟩
    have hi₁ : 1 ≤ i.1 + 1 := by omega
    have hi₂ : i.1 + 1 ≤ t := by
      exact Nat.succ_le_of_lt i.2
    have hpair :
        pairExt K (i.1 + 1) = pairExt I (i.1 + 1) ∨
          pairExt K (i.1 + 1) = pairExt J (i.1 + 1) :=
      hK (i.1 + 1) hi₁ hi₂
    have hrowExtK : rowExt K (i.1 + 1) = (K.row i).1 + 1 := by
      unfold rowExt
      simp [i.2]
    have hcolExtK : colExt K (i.1 + 1) = (K.col i).1 + 1 := by
      unfold colExt
      simp [i.2]
    have hKdiag : diagExp K (a, b) = 1 := by
      rw [diagExp_apply]
      exact if_pos ⟨i, hrowKi, hcolKi⟩
    rcases hpair with hKI | hKJ
    · have hrowExtI : rowExt I (i.1 + 1) = (I.row i).1 + 1 := by
        unfold rowExt
        simp [i.2]
      have hcolExtI : colExt I (i.1 + 1) = (I.col i).1 + 1 := by
        unfold colExt
        simp [i.2]
      have hEqRowExt : rowExt K (i.1 + 1) = rowExt I (i.1 + 1) :=
        congrArg Prod.fst hKI
      have hEqColExt : colExt K (i.1 + 1) = colExt I (i.1 + 1) :=
        congrArg Prod.snd hKI
      have hrowIK : I.row i = K.row i := by
        apply Fin.ext
        rw [hrowExtK, hrowExtI] at hEqRowExt
        omega
      have hcolIK : I.col i = K.col i := by
        apply Fin.ext
        rw [hcolExtK, hcolExtI] at hEqColExt
        omega
      have hIdiag : diagExp I (a, b) = 1 := by
        rw [diagExp_apply]
        refine if_pos ?_
        exact ⟨i, hrowIK.trans hrowKi, hcolIK.trans hcolKi⟩
      rw [hKdiag]
      change 1 ≤ max (diagExp I (a, b)) (diagExp J (a, b))
      rw [hIdiag]
      simp
    · have hrowExtJ : rowExt J (i.1 + 1) = (J.row i).1 + 1 := by
        unfold rowExt
        simp [i.2]
      have hcolExtJ : colExt J (i.1 + 1) = (J.col i).1 + 1 := by
        unfold colExt
        simp [i.2]
      have hEqRowExt : rowExt K (i.1 + 1) = rowExt J (i.1 + 1) :=
        congrArg Prod.fst hKJ
      have hEqColExt : colExt K (i.1 + 1) = colExt J (i.1 + 1) :=
        congrArg Prod.snd hKJ
      have hrowJK : J.row i = K.row i := by
        apply Fin.ext
        rw [hrowExtK, hrowExtJ] at hEqRowExt
        omega
      have hcolJK : J.col i = K.col i := by
        apply Fin.ext
        rw [hcolExtK, hcolExtJ] at hEqColExt
        omega
      have hJdiag : diagExp J (a, b) = 1 := by
        rw [diagExp_apply]
        refine if_pos ?_
        exact ⟨i, hrowJK.trans hrowKi, hcolJK.trans hcolKi⟩
      rw [hKdiag]
      change 1 ≤ max (diagExp I (a, b)) (diagExp J (a, b))
      rw [hJdiag]
      simp
  · have hKzero : diagExp K (a, b) = 0 := by
      rw [diagExp_apply]
      exact if_neg hx
    rw [hKzero]
    exact Nat.zero_le _

/-- Under a diagonal term order, the `headLcm` of two minors is exactly the join
of their diagonal exponent vectors. -/
lemma headLcm_genericMinor_eq_sup_diagExp
    (ord : MonomialOrder (Fin m × Fin n))
    (hdiag : IsDiagonalTermOrder ord)
    (I J : MinorIndex m n t) :
    headLcm ord (genericMinor (k := k) I) (genericMinor J) =
      diagExp I ⊔ diagExp J := by
  unfold headLcm
  rw [degree_minor_eq_diagExp ord hdiag I,
      degree_minor_eq_diagExp ord hdiag J]

/-- A convenient degree bound once one already knows a diagonal-exponent bound. -/
lemma degree_minor_le_headLcm_of_diagExp_le
    (ord : MonomialOrder (Fin m × Fin n))
    (hdiag : IsDiagonalTermOrder ord)
    {I J K : MinorIndex m n t}
    (hdeg : diagExp K ≤ diagExp I ⊔ diagExp J) :
    ord.degree (genericMinor (k := k) K) ≤
      headLcm ord (genericMinor (k := k) I) (genericMinor (k := k) J) := by
  rw [degree_minor_eq_diagExp (k := k) ord hdiag K]
  rw [headLcm_genericMinor_eq_sup_diagExp (k := k) ord hdiag I J]
  exact hdeg

/-- Degree bound for a minor occurring in a Prop. 1.5 chain. -/
lemma degree_minor_le_headLcm_of_pairExtFromEndpoints
    (ord : MonomialOrder (Fin m × Fin n))
    (hdiag : IsDiagonalTermOrder ord)
    {I J K : MinorIndex m n t}
    (hK : PairExtFromEndpoints I J K) :
    ord.degree (genericMinor (k := k) K) ≤
      headLcm ord (genericMinor (k := k) I) (genericMinor (k := k) J) := by
  exact degree_minor_le_headLcm_of_diagExp_le
    (k := k) ord hdiag (I := I) (J := J) (K := K)
    (diagExp_le_sup_of_pairExtFromEndpoints hK)

omit [Nontrivial k] in
/-- Every term of an index close-chain gives a generator of `minorSet`. -/
lemma indexCloseChain_term_mem_minorSet
    {p : ℕ}
    {F : Fin (p + 1) → MinorIndex m n t} :
    ∀ q : Fin (p + 1),
      genericMinor (F q) ∈ minorSet (k := k) t := by
  intro q
  exact minor_mem_minorSet (k := k) (F q)

omit [Nontrivial k] in
/-- If every term of an index-chain has degree bounded by the endpoint `headLcm`,
then the supremum of all degrees along the chain is exactly that endpoint `headLcm`
because the two endpoints are themselves present in the chain. -/
lemma indexCloseChain_sup_eq_headLcm_of_degree_le
    (ord : MonomialOrder (Fin m × Fin n))
    {I J : MinorIndex m n t}
    {p : ℕ}
    {F : Fin (p + 1) → MinorIndex m n t}
    (hchain : IndexCloseChain I J p F)
    (hdeg :
      ∀ q : Fin (p + 1),
        ord.degree (genericMinor (k := k) (F q)) ≤
          headLcm ord (genericMinor I) (genericMinor (k := k) J)) :
    Finset.univ.sup (fun q : Fin (p + 1) ↦ ord.degree (genericMinor (k := k) (F q))) =
      headLcm ord (genericMinor I) (genericMinor (k := k) J) := by
  rcases hchain with ⟨h0, hp, _hclose⟩
  apply le_antisymm
  · refine Finset.sup_le ?_
    intro q hq
    exact hdeg q
  · rw [headLcm]
    refine sup_le_iff.mpr ?_
    constructor
    · simpa [h0] using
        (Finset.le_sup
          (s := (Finset.univ : Finset (Fin (p + 1))))
          (f := fun q : Fin (p + 1) ↦ ord.degree (genericMinor (k := k) (F q)))
          (by simp : (0 : Fin (p + 1)) ∈ (Finset.univ : Finset (Fin (p + 1)))))
    · simpa [hp] using
        (Finset.le_sup
          (s := (Finset.univ : Finset (Fin (p + 1))))
          (f := fun q : Fin (p + 1) ↦ ord.degree (genericMinor (k := k) (F q)))
          (by
            simp : (⟨p, Nat.lt_succ_self p⟩ : Fin (p + 1)) ∈
              (Finset.univ : Finset (Fin (p + 1)))))

/-- In particular, the degree condition in `HasGoodChain` follows from the endpoint-only
property in Prop. 1.5 together with the diagonal-order degree computation for minors. -/
lemma indexCloseChain_sup_eq_headLcm_of_usesOnlyEndpoints
    (ord : MonomialOrder (Fin m × Fin n))
    (hdiag : IsDiagonalTermOrder ord)
    {I J : MinorIndex m n t}
    {p : ℕ}
    {F : Fin (p + 1) → MinorIndex m n t}
    (hchain : IndexCloseChain I J p F)
    (huse : IndexChainUsesOnlyEndpoints I J p F) :
    Finset.univ.sup (fun q : Fin (p + 1) ↦ ord.degree (genericMinor (k := k) (F q))) =
      headLcm ord (genericMinor (k := k) I) (genericMinor (k := k) J) := by
  apply indexCloseChain_sup_eq_headLcm_of_degree_le (k := k) (ord := ord) hchain
  intro q
  exact degree_minor_le_headLcm_of_pairExtFromEndpoints ord hdiag (huse q)

omit [Nontrivial k] in
/-- Turn an index-chain into a polynomial good chain, provided the degree-sup equality
and the adjacent small-`S` representations are available. -/
lemma hasGoodChain_of_indexCloseChain
    (ord : MonomialOrder (Fin m × Fin n))
    {I J : MinorIndex m n t}
    {p : ℕ}
    {F : Fin (p + 1) → MinorIndex m n t}
    (hchain : IndexCloseChain I J p F)
    (hsup :
      Finset.univ.sup (fun q : Fin (p + 1) ↦ ord.degree (genericMinor (k := k) (F q))) =
        headLcm ord (genericMinor (k := k) I) (genericMinor (k := k) J))
    (hadj :
      ∀ i : Fin p,
        AdjacentSmallSPolynomialRep
          ord
          (minorSet (m := m) (n := n) (k := k) t)
          (genericMinor (k := k) (F i.castSucc))
          (genericMinor (k := k) (F i.succ))) :
    HasGoodChain
      ord
      (minorSet (m := m) (n := n) (k := k) t)
      (genericMinor (k := k) I)
      (genericMinor (k := k) J) := by
  rcases hchain with ⟨h0, hp, hclose⟩
  refine ⟨p, (fun q ↦ genericMinor (k := k) (F q)), ?_⟩
  refine ⟨by simp [h0], ?_⟩
  refine ⟨by simp [hp], ?_⟩
  refine ⟨?_, ?_, ?_⟩
  · intro q
    exact minor_mem_minorSet (k := k) (F q)
  · simpa using hsup
  · intro i
    exact hadj i

/-- A more convenient packaged version: Prop. 1.5 gives an index-chain,
and Prop. 2.1 (for close pairs) gives the adjacent small-`S` representations;
together they produce a polynomial good chain between the two minors. -/
theorem hasGoodChain_minor_of_prop1_5_closeRep
    (ord : MonomialOrder (Fin m × Fin n))
    (hdiag : IsDiagonalTermOrder ord)
    {I J : MinorIndex m n t}
    (h15 :
      ∃ p : ℕ, ∃ F : Fin (p + 1) → MinorIndex m n t,
        IndexCloseChain I J p F ∧
        IndexChainUsesOnlyEndpoints I J p F)
    (hcloseRep :
      ∀ A B : MinorIndex m n t,
        Close A B →
        AdjacentSmallSPolynomialRep
          ord
          (minorSet (m := m) (n := n) (k := k) t)
          (genericMinor (k := k) A)
          (genericMinor (k := k) B)) :
    HasGoodChain
      ord
      (minorSet (m := m) (n := n) (k := k) t)
      (genericMinor (k := k) I)
      (genericMinor (k := k) J) := by
  rcases h15 with ⟨p, F, hchain, huse⟩
  refine hasGoodChain_of_indexCloseChain (k := k) (ord := ord) (I := I) (J := J)
    (p := p) (F := F) hchain ?_ ?_
  · exact indexCloseChain_sup_eq_headLcm_of_usesOnlyEndpoints
      (k := k) (ord := ord) hdiag hchain huse
  · intro i
    exact hcloseRep _ _ (hchain.2.2 i)

omit [Nontrivial k] in
/-- Reduce the pairwise `HasGoodChain` condition on `minorSet` to the corresponding
statement indexed by `MinorIndex`. -/
lemma pairwise_hasGoodChain_minorSet_of_index
    (ord : MonomialOrder (Fin m × Fin n))
    (hindex :
      ∀ I J : MinorIndex m n t,
        HasGoodChain
          ord
          (minorSet (k := k) t)
          (genericMinor I)
          (genericMinor J)) :
    ∀ f ∈ minorSet t,
      ∀ g ∈ minorSet t,
        HasGoodChain
          ord
          (minorSet (k := k) t)
          f g := by
  intro f hf g hg
  rcases hf with ⟨I, rfl⟩
  rcases hg with ⟨J, rfl⟩
  exact hindex I J

/-- Final bridge to Prop. 1.0:
once one has indexwise good chains for all pairs of minors, the whole minor family is a
Groebner basis of the determinantal ideal. -/
theorem minorSet_isGroebnerBasis_of_diagonal_order_and_indexHasGoodChains
    [NoZeroDivisors k]
    (ord : MonomialOrder (Fin m × Fin n))
    (hdiag : IsDiagonalTermOrder ord)
    (hindex :
      ∀ I J : MinorIndex m n t,
        HasGoodChain
          ord
          (minorSet (m := m) (n := n) (k := k) t)
          (genericMinor (k := k) I)
          (genericMinor (k := k) J)) :
    ord.IsGroebnerBasis
      (minorSet (m := m) (n := n) (k := k) t)
      (detIdeal m n t k) := by
  apply isGroebnerBasis_of_pairwise_hasGoodChain
    (ord := ord)
    (G := minorSet (m := m) (n := n) (k := k) t)
    (I := detIdeal m n t k)
  · rfl
  · intro g hg
    rcases hg with ⟨I, rfl⟩
    simpa using leadingCoeff_minor_eq_one (k := k) (ord := ord) hdiag I
  · exact pairwise_hasGoodChain_minorSet_of_index (k := k) (ord := ord) hindex

omit [Nontrivial k] in
lemma hasGoodChain_refl_minor
    (ord : MonomialOrder (Fin m × Fin n))
    (I : MinorIndex m n t) :
    HasGoodChain
      ord
      (minorSet (m := m) (n := n) (k := k) t)
      (genericMinor (k := k) I)
      (genericMinor (k := k) I) := by
  refine ⟨0, (fun _ : Fin (0 + 1) => genericMinor (k := k) I), ?_⟩
  refine ⟨rfl, ?_⟩
  refine ⟨rfl, ?_⟩
  refine ⟨?_, ?_, ?_⟩
  · intro q
    exact minor_mem_minorSet (k := k) I
  · simp [headLcm]
  · intro i
    exact Fin.elim0 i

end paper1_5_bridge

namespace SmallSPolynomialSummand

variable {m n t : ℕ}
variable {k : Type*} [CommRing k]


noncomputable def ofCoeff
    {G : Set (MvPolynomial (Fin m × Fin n) k)}
    (g : G) (coeffPoly : MvPolynomial (Fin m × Fin n) k)
    (d : (Fin m × Fin n) →₀ ℕ)
    (hc : MvPolynomial.coeff d coeffPoly ≠ 0) :
    SmallSPolynomialSummand (Fin m × Fin n) k G where
  g := g
  d := d
  c := MvPolynomial.coeff d coeffPoly
  hc := hc


@[simp] lemma ofCoeff_poly
    {G : Set (MvPolynomial (Fin m × Fin n) k)}
    (g : G) (coeffPoly : MvPolynomial (Fin m × Fin n) k)
    (d : (Fin m × Fin n) →₀ ℕ)
    (hc : MvPolynomial.coeff d coeffPoly ≠ 0) :
    (ofCoeff (G := G) g coeffPoly d hc).poly =
      MvPolynomial.monomial d (MvPolynomial.coeff d coeffPoly) *
        (g : MvPolynomial (Fin m × Fin n) k) := rfl

end SmallSPolynomialSummand

section adjacentSmallSPolynomialRep_of_finsupp_monomial_certificate

variable {m n t : ℕ}
variable {k : Type*} [CommRing k]


/-- Convert a paper-style coefficient certificate into the explicit finite-summand
form required by `AdjacentSmallSPolynomialRep`.

This is only a packaging lemma: it does not prove the determinantal straightening
identity.  The identity and the strict smallness estimates are supplied by the
paper Theorem 2.1 certificate below. -/
lemma adjacentSmallSPolynomialRep_of_finsupp_monomial_certificate
    (ord : MonomialOrder (Fin m × Fin n))
    {G : Set (MvPolynomial (Fin m × Fin n) k)}
    {f g : MvPolynomial (Fin m × Fin n) k}
    (q : G →₀ MvPolynomial (Fin m × Fin n) k)
    (hlin :
      ord.sPolynomial f g =
        Finsupp.linearCombination
          (MvPolynomial (Fin m × Fin n) k)
          (fun h : G => (h : MvPolynomial (Fin m × Fin n) k)) q)
    (hsmall :
      ∀ h : G, ∀ d ∈ (q h).support,
        ord.toSyn
          (ord.degree
            (MvPolynomial.monomial d (MvPolynomial.coeff d (q h)) *
              (h : MvPolynomial (Fin m × Fin n) k))) <
        ord.toSyn (headLcm ord f g)) :
    AdjacentSmallSPolynomialRep ord G f g := by
  classical
  let T :=
    q.support.attach.sigma
      (fun h : {x // x ∈ q.support} =>
        (q h.1).support.attach)
  let mkSummand
      (x : (h : {x // x ∈ q.support}) × {d // d ∈ (q h.1).support}) :
      SmallSPolynomialSummand (Fin m × Fin n) k G :=
    SmallSPolynomialSummand.ofCoeff
      (G := G) x.1.1 (q x.1.1) x.2.1
      (MvPolynomial.mem_support_iff.mp x.2.2)
  let S : Finset (SmallSPolynomialSummand (Fin m × Fin n) k G) :=
    T.image mkSummand
  refine ⟨S, ?_, ?_⟩
  · have hinj : ∀ x ∈ T, ∀ y ∈ T, mkSummand x = mkSummand y → x = y := by
      intro x hx y hy hxy
      cases x with
      | mk gx dx =>
      cases y with
      | mk gy dy =>
      simp only [mkSummand, SmallSPolynomialSummand.ofCoeff] at hxy
      have hg : gx.1 = gy.1 := by
        exact Subtype.ext
          (congrArg
            (fun s => ((s.g : G) : MvPolynomial (Fin m × Fin n) k)) hxy)
      have hd : dx.1 = dy.1 := by
        exact congrArg SmallSPolynomialSummand.d hxy
      have hgx : gx = gy := Subtype.ext hg
      subst gy
      have hdx : dx = dy := Subtype.ext hd
      subst dy
      rfl
    change ord.sPolynomial f g = ∑ s ∈ S, s.poly
    rw [Finset.sum_image]
    · dsimp [S, T, mkSummand]
      rw [hlin]
      rw [Finsupp.linearCombination_apply, Finsupp.sum]
      simp_rw [smul_eq_mul]
      rw [Finset.sum_sigma]
      rw [← Finset.sum_attach]
      apply Finset.sum_congr rfl
      intro h hh
      have hqsum :
          q h.1 =
            ∑ d ∈ (q h.1).support,
              MvPolynomial.monomial d (MvPolynomial.coeff d (q h.1)) :=
        (q h.1).as_sum
      calc
        q h.1 * (h.1 : MvPolynomial (Fin m × Fin n) k)
            =
          (∑ d ∈ (q h.1).support,
              MvPolynomial.monomial d (MvPolynomial.coeff d (q h.1))) *
            (h.1 : MvPolynomial (Fin m × Fin n) k) := by
              conv_lhs => rw [hqsum]
        _ =
          ∑ d ∈ (q h.1).support,
            MvPolynomial.monomial d (MvPolynomial.coeff d (q h.1)) *
              (h.1 : MvPolynomial (Fin m × Fin n) k) := by
              rw [Finset.sum_mul]
        _ =
          ∑ s ∈ (q h.1).support.attach,
            (MvPolynomial.monomial
                (SmallSPolynomialSummand.ofCoeff
                  (G := G) h.1 (q h.1) s.1
                  (MvPolynomial.mem_support_iff.mp s.2)).d)
              (SmallSPolynomialSummand.ofCoeff
                  (G := G) h.1 (q h.1) s.1
                  (MvPolynomial.mem_support_iff.mp s.2)).c *
              ↑(SmallSPolynomialSummand.ofCoeff
                  (G := G) h.1 (q h.1) s.1
                  (MvPolynomial.mem_support_iff.mp s.2)).g := by
              rw [← Finset.sum_attach]
              simp [SmallSPolynomialSummand.ofCoeff]
    · intro x hx y hy hxy
      exact hinj x hx y hy hxy
  · intro s hs
    rcases Finset.mem_image.mp hs with ⟨x, hxT, rfl⟩
    rcases x with ⟨h, d⟩
    simpa [mkSummand, SmallSPolynomialSummand.ofCoeff,
      SmallSPolynomialSummand.poly] using hsmall h.1 d.1 d.2

/-! ### Local input for the paper Theorem 2.1 close-pair proof -/


lemma closePair_mu_eqs
    (A B : MinorIndex m n t)
    (hC : Close A B) :
    mu A B hC.ne = B ∧ mu B A hC.ne.symm = A := by
  exact ⟨hC.mu_eq_right, hC.mu_eq_left⟩


lemma closePair_sClose_eq_swap
    (A B : MinorIndex m n t)
    (hC : Close A B) :
    sClose A B = sClose B A := by
  exact close_sClose_eq_symm A B hC


lemma closePair_uClose_eq_swap
    (A B : MinorIndex m n t)
    (hC : Close A B) :
    uClose A B = uClose B A := by
  exact close_uClose_eq_symm A B hC


lemma closePair_middle_pairs_distinct
    (A B : MinorIndex m n t)
    (hC : Close A B)
    {i j : ℕ}
    (hi₁ : sClose A B + 1 ≤ i)
    (hi₂ : i ≤ uClose A B)
    (hj₁ : sClose A B + 1 ≤ j)
    (hj₂ : j ≤ uClose A B) :
    pairExt A i ≠ pairExt B j := by
  exact close_pairExt_ne_mid A B hC hi₁ hi₂ hj₁ hj₂


lemma closePair_mu_middle_eq_right
    (A B : MinorIndex m n t)
    (hC : Close A B)
    {j : ℕ}
    (hj₁ : sClose A B + 1 ≤ j)
    (hj₂ : j ≤ uClose A B) :
    pairExt (mu A B hC.ne) j = pairExt B j := by
  exact pairExt_mu_eq_right_of_mid A B hC.ne hj₁ hj₂


lemma closePair_mu_middle_eq_left
    (A B : MinorIndex m n t)
    (hC : Close A B)
    {i : ℕ}
    (hi₁ : sClose A B + 1 ≤ i)
    (hi₂ : i ≤ uClose A B) :
    pairExt (mu B A hC.ne.symm) i = pairExt A i := by
  exact pairExt_mu_eq_left_of_mid A B hC hi₁ hi₂

lemma closePair_headLcm_eq_sup_diagExp
    [Nontrivial k]
    (ord : MonomialOrder (Fin m × Fin n))
    (hdiag : IsDiagonalTermOrder ord)
    (A B : MinorIndex m n t) :
    headLcm ord (genericMinor (k := k) A) (genericMinor (k := k) B) =
      diagExp A ⊔ diagExp B := by
  exact headLcm_genericMinor_eq_sup_diagExp (k := k) ord hdiag A B

lemma closePair_sPolynomial_eq_scaled_minors
    [Nontrivial k]
    (ord : MonomialOrder (Fin m × Fin n))
    (hdiag : IsDiagonalTermOrder ord)
    (A B : MinorIndex m n t) :
    ord.sPolynomial (genericMinor (k := k) A) (genericMinor (k := k) B) =
      MvPolynomial.monomial
          (headLcm ord (genericMinor (k := k) A) (genericMinor (k := k) B) -
            diagExp A) (1 : k) *
        genericMinor (k := k) A -
      MvPolynomial.monomial
          (headLcm ord (genericMinor (k := k) A) (genericMinor (k := k) B) -
            diagExp B) (1 : k) *
        genericMinor (k := k) B := by
  classical
  let G : Set (MvPolynomial (Fin m × Fin n) k) :=
    minorSet (m := m) (n := n) (k := k) t
  have hmonic : ∀ g ∈ G, ord.leadingCoeff g = 1 := by
    intro g hg
    rcases hg with ⟨K, rfl⟩
    exact leadingCoeff_minor_eq_one (k := k) (ord := ord) hdiag K
  have hscaled :=
    scaledSPolynomial_eq_scaled_sub_of_monic
      (R := k) (σ := Fin m × Fin n) (ord := ord) (G := G)
      hmonic
      (D := headLcm ord (genericMinor (k := k) A) (genericMinor (k := k) B))
      (f := genericMinor (k := k) A)
      (g := genericMinor (k := k) B)
      (minor_mem_minorSet (k := k) A)
      (minor_mem_minorSet (k := k) B)
      (by simp [headLcm])
      (by simp [headLcm])
  simpa [G, degree_minor_eq_diagExp (k := k) ord hdiag A,
    degree_minor_eq_diagExp (k := k) ord hdiag B] using hscaled

end adjacentSmallSPolynomialRep_of_finsupp_monomial_certificate


section paper2_1_phase1

/-- One displayed monomial-multiple-of-a-minor term in the paper's Theorem 2.1
straightening formula.  Later phases are responsible for constructing the finite
set/list of such terms from the close middle block. -/
structure ClosePairThm21Term (m n t : ℕ) (k : Type*) [CommRing k] where
  K : MinorIndex m n t
  d : (Fin m × Fin n) →₀ ℕ
  c : k

namespace ClosePairThm21Term

variable {m n t : ℕ}
variable {k : Type*} [CommRing k]

/-- The coefficient monomial attached to one Theorem 2.1 term. -/
noncomputable def coeffPoly (T : ClosePairThm21Term m n t k) :
    MvPolynomial (Fin m × Fin n) k :=
  MvPolynomial.monomial T.d T.c

/-- The `minorSet` generator attached to one Theorem 2.1 term. -/
noncomputable def generator (T : ClosePairThm21Term m n t k) :
    minorSet (m := m) (n := n) (k := k) t :=
  ⟨genericMinor (k := k) T.K, minor_mem_minorSet (k := k) T.K⟩

/-- Interpret one Theorem 2.1 term as an actual polynomial summand. -/
noncomputable def poly (T : ClosePairThm21Term m n t k) :
    MvPolynomial (Fin m × Fin n) k :=
  T.coeffPoly * genericMinor (k := k) T.K

@[simp] lemma generator_val (T : ClosePairThm21Term m n t k) :
    ((T.generator : minorSet (m := m) (n := n) (k := k) t) :
        MvPolynomial (Fin m × Fin n) k) =
      genericMinor (k := k) T.K := rfl

@[simp] lemma poly_eq (T : ClosePairThm21Term m n t k) :
    T.poly =
      MvPolynomial.monomial T.d T.c * genericMinor (k := k) T.K := rfl

/-- Turn a finite family of paper Theorem 2.1 terms into the coefficient family
over `minorSet` used by `Finsupp.linearCombination`.  Terms with the same minor
are combined in the coefficient polynomial for that generator. -/
noncomputable def termsFinsupp
    (S : Finset (ClosePairThm21Term m n t k)) :
    (minorSet (m := m) (n := n) (k := k) t) →₀
      MvPolynomial (Fin m × Fin n) k :=
  S.sum fun T => Finsupp.single T.generator T.coeffPoly

/-- The contribution of a single paper term to the coefficient polynomial of a
fixed minor-set generator.  This is noncomputable only because equality in the
polynomial subtype is decided classically. -/
noncomputable def coeffForGenerator
    (h : minorSet (m := m) (n := n) (k := k) t)
    (T : ClosePairThm21Term m n t k) :
    MvPolynomial (Fin m × Fin n) k := by
  classical
  exact if T.generator = h then T.coeffPoly else 0

lemma termsFinsupp_apply
    (S : Finset (ClosePairThm21Term m n t k))
    (h : minorSet (m := m) (n := n) (k := k) t) :
    termsFinsupp (m := m) (n := n) (t := t) (k := k) S h =
      ∑ T ∈ S, coeffForGenerator h T := by
  classical
  induction S using Finset.induction_on with
  | empty =>
      simp [termsFinsupp]
  | insert T S hTS ih =>
      rw [termsFinsupp, Finset.sum_insert hTS]
      rw [Finset.sum_insert hTS]
      have ih' :
          (∑ c ∈ S,
              (Finsupp.single c.generator c.coeffPoly :
                (minorSet (m := m) (n := n) (k := k) t) →₀
                  MvPolynomial (Fin m × Fin n) k) h) =
            ∑ x ∈ S, coeffForGenerator h x := by
        simpa [termsFinsupp] using ih
      have hsingle :
          (Finsupp.single T.generator T.coeffPoly :
            (minorSet (m := m) (n := n) (k := k) t) →₀
              MvPolynomial (Fin m × Fin n) k) h =
            coeffForGenerator h T := by
        by_cases hgen : T.generator = h
        · subst h
          simp [coeffForGenerator]
        · simp [coeffForGenerator, hgen]
      have hsum_apply :
          (∑ x ∈ S,
              (Finsupp.single x.generator x.coeffPoly :
                (minorSet (m := m) (n := n) (k := k) t) →₀
                  MvPolynomial (Fin m × Fin n) k)) h =
            ∑ c ∈ S,
              (Finsupp.single c.generator c.coeffPoly :
                (minorSet (m := m) (n := n) (k := k) t) →₀
                  MvPolynomial (Fin m × Fin n) k) h := by
        exact Finsupp.finset_sum_apply S
          (fun x : ClosePairThm21Term m n t k =>
            (Finsupp.single x.generator x.coeffPoly :
              (minorSet (m := m) (n := n) (k := k) t) →₀
                MvPolynomial (Fin m × Fin n) k))
          h
      simp only [Finsupp.coe_add, Pi.add_apply]
      rw [hsum_apply, ih', hsingle]

lemma linearCombination_termsFinsupp
    (S : Finset (ClosePairThm21Term m n t k)) :
    Finsupp.linearCombination
        (MvPolynomial (Fin m × Fin n) k)
        (fun h : minorSet (m := m) (n := n) (k := k) t =>
          (h : MvPolynomial (Fin m × Fin n) k))
        (termsFinsupp (m := m) (n := n) (t := t) (k := k) S) =
      ∑ T ∈ S, T.poly := by
  classical
  simp [termsFinsupp, Finsupp.linearCombination_apply, poly, coeffPoly]

lemma exists_term_of_mem_termsFinsupp_support
    {S : Finset (ClosePairThm21Term m n t k)}
    {h : minorSet (m := m) (n := n) (k := k) t}
    {d : (Fin m × Fin n) →₀ ℕ}
    (hd :
      d ∈
        (termsFinsupp (m := m) (n := n) (t := t) (k := k) S h).support) :
    ∃ T ∈ S, T.generator = h ∧ T.d = d := by
  classical
  have hcoeff :
      MvPolynomial.coeff d
          (termsFinsupp (m := m) (n := n) (t := t) (k := k) S h) ≠ 0 :=
    MvPolynomial.mem_support_iff.mp hd
  by_contra hno
  push_neg at hno
  have hcoeff_zero :
      MvPolynomial.coeff d
          (termsFinsupp (m := m) (n := n) (t := t) (k := k) S h) = 0 := by
    rw [termsFinsupp_apply]
    rw [MvPolynomial.coeff_sum]
    refine Finset.sum_eq_zero ?_
    intro T hT
    by_cases hgen : T.generator = h
    · have hdne : d ≠ T.d := by
        intro hEq
        exact hno T hT hgen hEq.symm
      simp only [coeffForGenerator, minorSet_eq_range, hgen, ↓reduceIte, coeffPoly,
        MvPolynomial.coeff_monomial, ite_eq_right_iff]
      intro hEq
      exact (hdne hEq.symm).elim
    · simp [coeffForGenerator, hgen]
  exact hcoeff hcoeff_zero

/-- Phase-1 packaging lemma: once later phases provide a finite paper-style
Theorem 2.1 sum formula and prove each displayed monomial multiple is below the
endpoint head-lcm, this lemma turns those data into the exact `Finsupp`
certificate required by `closePair_thm21_finsupp_monomial_certificate`. -/
lemma finsupp_monomial_certificate_of_term_sum
    (ord : MonomialOrder (Fin m × Fin n))
    (A B : MinorIndex m n t)
    (S : Finset (ClosePairThm21Term m n t k))
    (hlin :
      ord.sPolynomial (genericMinor (k := k) A) (genericMinor (k := k) B) =
        ∑ T ∈ S, T.poly)
    (hsmall :
      ∀ T ∈ S, ∀ a : k, a ≠ 0 →
        ord.toSyn
          (ord.degree
            (MvPolynomial.monomial T.d a * genericMinor (k := k) T.K)) <
        ord.toSyn
          (headLcm ord
            (genericMinor (k := k) A)
            (genericMinor (k := k) B))) :
    ∃ q :
      (minorSet (m := m) (n := n) (k := k) t) →₀
        MvPolynomial (Fin m × Fin n) k,
      ord.sPolynomial (genericMinor (k := k) A) (genericMinor (k := k) B) =
        Finsupp.linearCombination
          (MvPolynomial (Fin m × Fin n) k)
          (fun h :
            (minorSet (m := m) (n := n) (k := k) t) =>
            (h : MvPolynomial (Fin m × Fin n) k)) q ∧
      ∀ h :
          (minorSet (m := m) (n := n) (k := k) t),
        ∀ d ∈ (q h).support,
          ord.toSyn
            (ord.degree
              (MvPolynomial.monomial d (MvPolynomial.coeff d (q h)) *
                (h : MvPolynomial (Fin m × Fin n) k))) <
          ord.toSyn
            (headLcm ord
              (genericMinor (k := k) A)
              (genericMinor (k := k) B)) := by
  classical
  let q :=
    termsFinsupp (m := m) (n := n) (t := t) (k := k) S
  refine ⟨q, ?_, ?_⟩
  · rw [hlin]
    exact (linearCombination_termsFinsupp
      (m := m) (n := n) (t := t) (k := k) S).symm
  · intro h d hd
    have hcoeff :
        MvPolynomial.coeff d (q h) ≠ 0 :=
      MvPolynomial.mem_support_iff.mp hd
    rcases exists_term_of_mem_termsFinsupp_support
        (m := m) (n := n) (t := t) (k := k)
        (S := S) (h := h) (d := d) hd with
      ⟨T, hT, hgen, hdT⟩
    subst d
    have hval :
        (h : MvPolynomial (Fin m × Fin n) k) =
          genericMinor (k := k) T.K := by
      rw [← hgen]
      rfl
    simpa [q, hval] using
      hsmall T hT (MvPolynomial.coeff T.d (q h)) hcoeff

end ClosePairThm21Term

end paper2_1_phase1

section paper2_1_phase2

variable {m n t : ℕ}

/-- The middle interval `s+1, ..., u` attached to a close pair in the paper's
Theorem 2.1 proof.  The paper calls the upper endpoint `t`; this file uses
`uClose` to avoid clashing with the size of the minors. -/
noncomputable def closeMiddle (A B : MinorIndex m n t) : Finset ℕ :=
  Finset.Icc (sClose A B + 1) (uClose A B)

lemma mem_closeMiddle_iff
    (A B : MinorIndex m n t)
    {i : ℕ} :
    i ∈ closeMiddle A B ↔
      sClose A B + 1 ≤ i ∧ i ≤ uClose A B := by
  simp [closeMiddle]

lemma closeMiddle_left_mem
    (A B : MinorIndex m n t)
    (hC : Close A B) :
    sClose A B + 1 ∈ closeMiddle A B := by
  rw [mem_closeMiddle_iff]
  exact ⟨le_rfl, Nat.succ_le_of_lt (sClose_lt_uClose A B hC.ne)⟩

lemma closeMiddle_nonempty
    (A B : MinorIndex m n t)
    (hC : Close A B) :
    (closeMiddle A B).Nonempty := by
  exact ⟨sClose A B + 1, closeMiddle_left_mem A B hC⟩

lemma closeMiddle_pos
    (A B : MinorIndex m n t)
    {i : ℕ}
    (hi : i ∈ closeMiddle A B) :
    1 ≤ i := by
  rw [mem_closeMiddle_iff] at hi
  omega

lemma closeMiddle_le_uClose
    (A B : MinorIndex m n t)
    {i : ℕ}
    (hi : i ∈ closeMiddle A B) :
    i ≤ uClose A B := by
  exact (mem_closeMiddle_iff A B).mp hi |>.2

lemma closeMiddle_le_t
    (A B : MinorIndex m n t)
    (hC : Close A B)
    {i : ℕ}
    (hi : i ∈ closeMiddle A B) :
    i ≤ t := by
  exact le_trans (closeMiddle_le_uClose A B hi)
    (le_trans (uClose_le_pClose A B hC.ne) (pClose_le A B))

lemma closeMiddle_toFin_val
    (A B : MinorIndex m n t)
    (hC : Close A B)
    {i : ℕ}
    (hi : i ∈ closeMiddle A B) :
    ((⟨i - 1, by
        have hi_pos : 1 ≤ i := closeMiddle_pos A B hi
        have hi_t : i ≤ t := closeMiddle_le_t A B hC hi
        omega⟩ : Fin t).1 + 1) = i := by
  exact Nat.sub_add_cancel (closeMiddle_pos A B hi)

/-- Convert a paper-position in the close middle interval to the corresponding
zero-based `Fin t` index. -/
noncomputable def closeMiddleFin
    (A B : MinorIndex m n t)
    (hC : Close A B)
    (i : {i : ℕ // i ∈ closeMiddle A B}) :
    Fin t :=
  ⟨i.1 - 1, by
    have hi_pos : 1 ≤ i.1 := closeMiddle_pos A B i.2
    have hi_t : i.1 ≤ t := closeMiddle_le_t A B hC i.2
    omega⟩

lemma closeMiddleFin_val_succ
    (A B : MinorIndex m n t)
    (hC : Close A B)
    (i : {i : ℕ // i ∈ closeMiddle A B}) :
    (closeMiddleFin A B hC i).1 + 1 = i.1 := by
  exact Nat.sub_add_cancel (closeMiddle_pos A B i.2)

lemma closeMiddleFin_injective
    (A B : MinorIndex m n t)
    (hC : Close A B) :
    Function.Injective (closeMiddleFin A B hC) := by
  intro i j hij
  apply Subtype.ext
  have hval := congrArg (fun q : Fin t => q.1) hij
  have hi := closeMiddleFin_val_succ A B hC i
  have hj := closeMiddleFin_val_succ A B hC j
  omega

lemma closeMiddle_pairExt_ne
    (A B : MinorIndex m n t)
    (hC : Close A B)
    {i j : ℕ}
    (hi : i ∈ closeMiddle A B)
    (hj : j ∈ closeMiddle A B) :
    pairExt A i ≠ pairExt B j := by
  rw [mem_closeMiddle_iff] at hi hj
  exact closePair_middle_pairs_distinct A B hC hi.1 hi.2 hj.1 hj.2

lemma closeMiddle_pairExt_ne_same
    (A B : MinorIndex m n t)
    (hC : Close A B)
    {i : ℕ}
    (hi : i ∈ closeMiddle A B) :
    pairExt A i ≠ pairExt B i := by
  exact closeMiddle_pairExt_ne A B hC hi hi

lemma closeMiddle_pairExt_B_ne_A
    (A B : MinorIndex m n t)
    (hC : Close A B)
    {i j : ℕ}
    (hi : i ∈ closeMiddle A B)
    (hj₁ : 1 ≤ j)
    (hj₂ : j ≤ t) :
    pairExt B i ≠ pairExt A j := by
  rw [mem_closeMiddle_iff] at hi
  intro heq
  by_cases hjs : j ≤ sClose A B
  · have hAjBj : pairExt A j = pairExt B j := by
      exact pairExt_eq_of_mu_eq_right_le_s
        A B hC.ne hC.mu_eq_right hj₁ hjs
    have hi₂ : i ≤ t :=
      le_trans hi.2 (le_trans (uClose_le_pClose A B hC.ne) (pClose_le A B))
    have hlt : rowExt B j < rowExt B i :=
      rowExt_lt_of_lt B hj₁ (by omega) hi₂
    have hrow : rowExt B i = rowExt B j := by
      exact congrArg Prod.fst (heq.trans hAjBj)
    exact (Nat.ne_of_lt hlt) hrow.symm
  · by_cases hju : j ≤ uClose A B
    · have hjmid : sClose A B + 1 ≤ j ∧ j ≤ uClose A B := by
        omega
      have hneq :
          pairExt A j ≠ pairExt B i :=
        close_pairExt_ne_mid A B hC hjmid.1 hjmid.2 hi.1 hi.2
      exact hneq heq.symm
    · have hAjBj : pairExt A j = pairExt B j := by
        exact pairExt_eq_of_mu_eq_right_gt_u
          A B hC.ne hC.mu_eq_right (by omega) hj₂
      have hi₁ : 1 ≤ i := by omega
      have hlt : rowExt B i < rowExt B j :=
        rowExt_lt_of_lt B hi₁ (by omega) hj₂
      have hrow : rowExt B i = rowExt B j := by
        exact congrArg Prod.fst (heq.trans hAjBj)
      exact (Nat.ne_of_lt hlt) hrow

lemma closeMiddle_pairExt_A_ne_B
    (A B : MinorIndex m n t)
    (hC : Close A B)
    {i j : ℕ}
    (hi : i ∈ closeMiddle A B)
    (hj₁ : 1 ≤ j)
    (hj₂ : j ≤ t) :
    pairExt A i ≠ pairExt B j := by
  have hi' : i ∈ closeMiddle B A := by
    have hs := close_sClose_eq_symm A B hC
    have hu := close_uClose_eq_symm A B hC
    rw [mem_closeMiddle_iff] at hi ⊢
    constructor
    · simpa [hs] using hi.1
    · simpa [hu] using hi.2
  exact closeMiddle_pairExt_B_ne_A B A hC.symm hi' hj₁ hj₂

lemma closeMiddle_mu_eq_right
    (A B : MinorIndex m n t)
    (hC : Close A B)
    {i : ℕ}
    (hi : i ∈ closeMiddle A B) :
    pairExt (mu A B hC.ne) i = pairExt B i := by
  rw [mem_closeMiddle_iff] at hi
  exact closePair_mu_middle_eq_right A B hC hi.1 hi.2

lemma closeMiddle_mu_eq_left
    (A B : MinorIndex m n t)
    (hC : Close A B)
    {i : ℕ}
    (hi : i ∈ closeMiddle A B) :
    pairExt (mu B A hC.ne.symm) i = pairExt A i := by
  rw [mem_closeMiddle_iff] at hi
  exact closePair_mu_middle_eq_left A B hC hi.1 hi.2

lemma closeMiddle_pairExt_A_mem_endpoint_left
    (A B : MinorIndex m n t)
    {i : ℕ}
    (_hi : i ∈ closeMiddle A B) :
    pairExt A i = pairExt A i ∨ pairExt A i = pairExt B i := by
  exact Or.inl rfl

lemma closeMiddle_pairExt_B_mem_endpoint_right
    (A B : MinorIndex m n t)
    {i : ℕ}
    (_hi : i ∈ closeMiddle A B) :
    pairExt B i = pairExt A i ∨ pairExt B i = pairExt B i := by
  exact Or.inr rfl

end paper2_1_phase2

section paper2_1_phase3

variable {m n t : ℕ}
variable {k : Type*} [CommRing k] [Nontrivial k]

/-!
Phase 3: positionwise endpoint selections.

The straightening terms in the proof of Theorem 2.1 are minors whose diagonal
pairs are selected, position by position, from the two endpoint minors.  This
section packages that construction independently from the determinant identity:
once the selected row and column sequences are known to be strictly increasing,
they form a `MinorIndex`, and its diagonal exponent is bounded by the endpoint
head-lcm.
-/

/-- A monotone positionwise selection of diagonal pairs from two endpoint
minors.  The Boolean records which endpoint supplies each row/column pair; the
separate `rowFun`/`colFun` fields keep the strict monotonicity hypotheses easy
to state and reuse. -/
structure EndpointSelection (A B : MinorIndex m n t) where
  rowFun : Fin t → Fin m
  colFun : Fin t → Fin n
  chooseRight : Fin t → Bool
  row_eq_endpoint :
    ∀ i : Fin t, rowFun i = if chooseRight i then B.row i else A.row i
  col_eq_endpoint :
    ∀ i : Fin t, colFun i = if chooseRight i then B.col i else A.col i
  rowStrict : StrictMono rowFun
  colStrict : StrictMono colFun

namespace EndpointSelection

variable {A B : MinorIndex m n t}

/-- Convert a strictly monotone endpoint selection into the corresponding
minor index. -/
def toMinorIndex (S : EndpointSelection A B) : MinorIndex m n t :=
  { row := strictMonoToOrderEmbedding S.rowFun S.rowStrict
    col := strictMonoToOrderEmbedding S.colFun S.colStrict }

@[simp] lemma toMinorIndex_row
    (S : EndpointSelection A B) (i : Fin t) :
    S.toMinorIndex.row i = S.rowFun i := rfl

@[simp] lemma toMinorIndex_col
    (S : EndpointSelection A B) (i : Fin t) :
    S.toMinorIndex.col i = S.colFun i := rfl

lemma row_eq_left_of_chooseRight_eq_false
    (S : EndpointSelection A B) {i : Fin t}
    (hi : S.chooseRight i = false) :
    S.toMinorIndex.row i = A.row i := by
  have h := S.row_eq_endpoint i
  simp [hi] at h
  simpa [toMinorIndex, strictMonoToOrderEmbedding] using h

lemma col_eq_left_of_chooseRight_eq_false
    (S : EndpointSelection A B) {i : Fin t}
    (hi : S.chooseRight i = false) :
    S.toMinorIndex.col i = A.col i := by
  have h := S.col_eq_endpoint i
  simp [hi] at h
  simpa [toMinorIndex, strictMonoToOrderEmbedding] using h

lemma row_eq_right_of_chooseRight_eq_true
    (S : EndpointSelection A B) {i : Fin t}
    (hi : S.chooseRight i = true) :
    S.toMinorIndex.row i = B.row i := by
  have h := S.row_eq_endpoint i
  simp [hi] at h
  simpa [toMinorIndex, strictMonoToOrderEmbedding] using h

lemma col_eq_right_of_chooseRight_eq_true
    (S : EndpointSelection A B) {i : Fin t}
    (hi : S.chooseRight i = true) :
    S.toMinorIndex.col i = B.col i := by
  have h := S.col_eq_endpoint i
  simp [hi] at h
  simpa [toMinorIndex, strictMonoToOrderEmbedding] using h

lemma rowExt_toMinorIndex
    (S : EndpointSelection A B)
    {j : ℕ}
    (hj₁ : 1 ≤ j)
    (hj₂ : j ≤ t) :
    rowExt S.toMinorIndex j =
      (S.toMinorIndex.row ⟨j - 1, by omega⟩ : Fin m).1 + 1 := by
  have hne : j ≠ 0 := by omega
  unfold rowExt
  simp [hne, hj₂]

lemma colExt_toMinorIndex
    (S : EndpointSelection A B)
    {j : ℕ}
    (hj₁ : 1 ≤ j)
    (hj₂ : j ≤ t) :
    colExt S.toMinorIndex j =
      (S.toMinorIndex.col ⟨j - 1, by omega⟩ : Fin n).1 + 1 := by
  have hne : j ≠ 0 := by omega
  unfold colExt
  simp [hne, hj₂]

lemma rowExt_endpoint
    (I : MinorIndex m n t)
    {j : ℕ}
    (hj₁ : 1 ≤ j)
    (hj₂ : j ≤ t) :
    rowExt I j = (I.row ⟨j - 1, by omega⟩ : Fin m).1 + 1 := by
  have hne : j ≠ 0 := by omega
  unfold rowExt
  simp [hne, hj₂]

lemma colExt_endpoint
    (I : MinorIndex m n t)
    {j : ℕ}
    (hj₁ : 1 ≤ j)
    (hj₂ : j ≤ t) :
    colExt I j = (I.col ⟨j - 1, by omega⟩ : Fin n).1 + 1 := by
  have hne : j ≠ 0 := by omega
  unfold colExt
  simp [hne, hj₂]

lemma pairExt_endpoint
    (I : MinorIndex m n t)
    {j : ℕ}
    (hj₁ : 1 ≤ j)
    (hj₂ : j ≤ t) :
    pairExt I j =
      ((I.row ⟨j - 1, by omega⟩ : Fin m).1 + 1,
        (I.col ⟨j - 1, by omega⟩ : Fin n).1 + 1) := by
  unfold pairExt
  rw [rowExt_endpoint I hj₁ hj₂, colExt_endpoint I hj₁ hj₂]

/-- At every valid paper position, the selected minor has the same diagonal
pair as one of the two endpoint minors. -/
lemma pairExt_toMinorIndex_eq_left_or_right
    (S : EndpointSelection A B)
    {j : ℕ}
    (hj₁ : 1 ≤ j)
    (hj₂ : j ≤ t) :
    pairExt S.toMinorIndex j = pairExt A j ∨
      pairExt S.toMinorIndex j = pairExt B j := by
  let i : Fin t := ⟨j - 1, by omega⟩
  have hrowS :
      rowExt S.toMinorIndex j =
        (S.toMinorIndex.row i : Fin m).1 + 1 := by
    simpa [i] using S.rowExt_toMinorIndex hj₁ hj₂
  have hcolS :
      colExt S.toMinorIndex j =
        (S.toMinorIndex.col i : Fin n).1 + 1 := by
    simpa [i] using S.colExt_toMinorIndex hj₁ hj₂
  have hrowA :
      rowExt A j = (A.row i : Fin m).1 + 1 := by
    simpa [i] using rowExt_endpoint (I := A) hj₁ hj₂
  have hcolA :
      colExt A j = (A.col i : Fin n).1 + 1 := by
    simpa [i] using colExt_endpoint (I := A) hj₁ hj₂
  have hrowB :
      rowExt B j = (B.row i : Fin m).1 + 1 := by
    simpa [i] using rowExt_endpoint (I := B) hj₁ hj₂
  have hcolB :
      colExt B j = (B.col i : Fin n).1 + 1 := by
    simpa [i] using colExt_endpoint (I := B) hj₁ hj₂
  cases hchoose : S.chooseRight i
  · left
    have hrow : S.toMinorIndex.row i = A.row i :=
      S.row_eq_left_of_chooseRight_eq_false hchoose
    have hcol : S.toMinorIndex.col i = A.col i :=
      S.col_eq_left_of_chooseRight_eq_false hchoose
    apply Prod.ext
    · simp only [pairExt]
      rw [hrowS, hrowA, hrow]
    · simp only [pairExt]
      rw [hcolS, hcolA, hcol]
  · right
    have hrow : S.toMinorIndex.row i = B.row i :=
      S.row_eq_right_of_chooseRight_eq_true hchoose
    have hcol : S.toMinorIndex.col i = B.col i :=
      S.col_eq_right_of_chooseRight_eq_true hchoose
    apply Prod.ext
    · simp only [pairExt]
      rw [hrowS, hrowB, hrow]
    · simp only [pairExt]
      rw [hcolS, hcolB, hcol]

lemma toMinorIndex_pairExtFromEndpoints
    (S : EndpointSelection A B) :
    PairExtFromEndpoints A B S.toMinorIndex := by
  intro j hj₁ hj₂
  exact S.pairExt_toMinorIndex_eq_left_or_right hj₁ hj₂

lemma diagExp_toMinorIndex_le_sup
    (S : EndpointSelection A B) :
    diagExp S.toMinorIndex ≤ diagExp A ⊔ diagExp B := by
  exact diagExp_le_sup_of_pairExtFromEndpoints
    (S.toMinorIndex_pairExtFromEndpoints)

lemma degree_toMinorIndex_le_headLcm
    (ord : MonomialOrder (Fin m × Fin n))
    (hdiag : IsDiagonalTermOrder ord)
    (S : EndpointSelection A B) :
    ord.degree (genericMinor (k := k) S.toMinorIndex) ≤
      headLcm ord
        (genericMinor (k := k) A)
        (genericMinor (k := k) B) := by
  exact degree_minor_le_headLcm_of_pairExtFromEndpoints
    (k := k) ord hdiag
    (S.toMinorIndex_pairExtFromEndpoints)

end EndpointSelection

end paper2_1_phase3

section paper2_1_phase4

variable {m n t : ℕ}
variable {k : Type*} [CommRing k] [Nontrivial k]

/-!
Phase 4, route 2: reduce the smallness part of Theorem 2.1 to an exponent
calculation.

Instead of trying to compare the full products directly, later phases only need
to prove the paper-style exponent facts for every displayed summand:

* the exponent `d + diagExp K` is bounded by `diagExp A ⊔ diagExp B`;
* at one variable it is strictly smaller.

The lemmas below turn those two combinatorial facts into the exact strict
`headLcm` inequality required by the Finsupp certificate.
-/

lemma finsupp_lt_of_le_of_apply_lt
    {σ : Type*}
    {a b : σ →₀ ℕ}
    (hle : a ≤ b)
    {x : σ}
    (hx : a x < b x) :
    a < b := by
  refine lt_iff_le_not_ge.mpr ⟨hle, ?_⟩
  intro hge
  have hEq : a = b := le_antisymm hle hge
  have hxEq : a x = b x := congrArg (fun e : σ →₀ ℕ => e x) hEq
  rw [hxEq] at hx
  exact (Nat.lt_irrefl (b x)) hx

lemma toSyn_lt_of_le_of_apply_lt
    {σ : Type*}
    (ord : MonomialOrder σ)
    {a b : σ →₀ ℕ}
    (hle : a ≤ b)
    {x : σ}
    (hx : a x < b x) :
    ord.toSyn a < ord.toSyn b := by
  exact (MonomialOrder.toSyn_strictMono ord)
    (finsupp_lt_of_le_of_apply_lt hle hx)

lemma degree_monomial_mul_genericMinor_le_add_diagExp
    (ord : MonomialOrder (Fin m × Fin n))
    (hdiag : IsDiagonalTermOrder ord)
    (K : MinorIndex m n t)
    (d : (Fin m × Fin n) →₀ ℕ)
    (a : k) :
    ord.toSyn
        (ord.degree
          (MvPolynomial.monomial d a * genericMinor (k := k) K)) ≤
      ord.toSyn (d + diagExp K) := by
  refine le_trans ord.degree_mul_le ?_
  simp [map_add, ord.degree_monomial_le,
    degree_minor_eq_diagExp (k := k) ord hdiag K]

lemma degree_monomial_mul_genericMinor_lt_of_add_diagExp_lt
    (ord : MonomialOrder (Fin m × Fin n))
    (hdiag : IsDiagonalTermOrder ord)
    (K : MinorIndex m n t)
    (d : (Fin m × Fin n) →₀ ℕ)
    (a : k)
    {D : (Fin m × Fin n) →₀ ℕ}
    (hlt : ord.toSyn (d + diagExp K) < ord.toSyn D) :
    ord.toSyn
        (ord.degree
          (MvPolynomial.monomial d a * genericMinor (k := k) K)) <
      ord.toSyn D := by
  exact lt_of_le_of_lt
    (degree_monomial_mul_genericMinor_le_add_diagExp
      (k := k) ord hdiag K d a)
    hlt

namespace ClosePairThm21Term

lemma small_of_add_diagExp_lt
    (ord : MonomialOrder (Fin m × Fin n))
    (hdiag : IsDiagonalTermOrder ord)
    (A B : MinorIndex m n t)
    (T : ClosePairThm21Term m n t k)
    (hlt :
      ord.toSyn (T.d + diagExp T.K) <
        ord.toSyn
          (headLcm ord
            (genericMinor (k := k) A)
            (genericMinor (k := k) B))) :
    ∀ a : k, a ≠ 0 →
      ord.toSyn
        (ord.degree
          (MvPolynomial.monomial T.d a * genericMinor (k := k) T.K)) <
      ord.toSyn
        (headLcm ord
          (genericMinor (k := k) A)
          (genericMinor (k := k) B)) := by
  intro a _ha
  exact degree_monomial_mul_genericMinor_lt_of_add_diagExp_lt
    (k := k) ord hdiag T.K T.d a hlt

lemma small_of_le_sup_and_gap
    (ord : MonomialOrder (Fin m × Fin n))
    (hdiag : IsDiagonalTermOrder ord)
    (A B : MinorIndex m n t)
    (T : ClosePairThm21Term m n t k)
    (hle : T.d + diagExp T.K ≤ diagExp A ⊔ diagExp B)
    (hgap :
      ∃ x : Fin m × Fin n,
        (T.d + diagExp T.K) x < (diagExp A ⊔ diagExp B) x) :
    ∀ a : k, a ≠ 0 →
      ord.toSyn
        (ord.degree
          (MvPolynomial.monomial T.d a * genericMinor (k := k) T.K)) <
      ord.toSyn
        (headLcm ord
          (genericMinor (k := k) A)
          (genericMinor (k := k) B)) := by
  rcases hgap with ⟨x, hx⟩
  have hltSup :
      ord.toSyn (T.d + diagExp T.K) <
        ord.toSyn (diagExp A ⊔ diagExp B) :=
    toSyn_lt_of_le_of_apply_lt ord hle hx
  have hltHead :
      ord.toSyn (T.d + diagExp T.K) <
        ord.toSyn
          (headLcm ord
            (genericMinor (k := k) A)
            (genericMinor (k := k) B)) := by
    simpa [headLcm_genericMinor_eq_sup_diagExp (k := k) ord hdiag A B]
      using hltSup
  exact T.small_of_add_diagExp_lt (k := k) ord hdiag A B hltHead

/-- Route-2 packaging lemma using a direct monomial-order bound for every
displayed summand. -/
lemma finsupp_monomial_certificate_of_term_sum_add_diagExp_lt
    (ord : MonomialOrder (Fin m × Fin n))
    (hdiag : IsDiagonalTermOrder ord)
    (A B : MinorIndex m n t)
    (S : Finset (ClosePairThm21Term m n t k))
    (hlin :
      ord.sPolynomial (genericMinor (k := k) A) (genericMinor (k := k) B) =
        ∑ T ∈ S, T.poly)
    (hsmall :
      ∀ T ∈ S,
        ord.toSyn (T.d + diagExp T.K) <
          ord.toSyn
            (headLcm ord
              (genericMinor (k := k) A)
              (genericMinor (k := k) B))) :
    ∃ q :
      (minorSet (m := m) (n := n) (k := k) t) →₀
        MvPolynomial (Fin m × Fin n) k,
      ord.sPolynomial (genericMinor (k := k) A) (genericMinor (k := k) B) =
        Finsupp.linearCombination
          (MvPolynomial (Fin m × Fin n) k)
          (fun h :
            (minorSet (m := m) (n := n) (k := k) t) =>
            (h : MvPolynomial (Fin m × Fin n) k)) q ∧
      ∀ h :
          (minorSet (m := m) (n := n) (k := k) t),
        ∀ d ∈ (q h).support,
          ord.toSyn
            (ord.degree
              (MvPolynomial.monomial d (MvPolynomial.coeff d (q h)) *
                (h : MvPolynomial (Fin m × Fin n) k))) <
          ord.toSyn
            (headLcm ord
              (genericMinor (k := k) A)
              (genericMinor (k := k) B)) := by
  classical
  exact
    finsupp_monomial_certificate_of_term_sum
      (m := m) (n := n) (t := t) (k := k)
      ord A B S hlin
      (by
        intro T hT a ha
        exact T.small_of_add_diagExp_lt
          (k := k) ord hdiag A B (hsmall T hT) a ha)

/-- Route-2 packaging lemma in the form expected from the paper proof: each
summand exponent is bounded by the endpoint sup and has a strict gap at some
variable. -/
lemma finsupp_monomial_certificate_of_term_sum_le_sup_gap
    (ord : MonomialOrder (Fin m × Fin n))
    (hdiag : IsDiagonalTermOrder ord)
    (A B : MinorIndex m n t)
    (S : Finset (ClosePairThm21Term m n t k))
    (hlin :
      ord.sPolynomial (genericMinor (k := k) A) (genericMinor (k := k) B) =
        ∑ T ∈ S, T.poly)
    (hle :
      ∀ T ∈ S, T.d + diagExp T.K ≤ diagExp A ⊔ diagExp B)
    (hgap :
      ∀ T ∈ S,
        ∃ x : Fin m × Fin n,
          (T.d + diagExp T.K) x < (diagExp A ⊔ diagExp B) x) :
    ∃ q :
      (minorSet (m := m) (n := n) (k := k) t) →₀
        MvPolynomial (Fin m × Fin n) k,
      ord.sPolynomial (genericMinor (k := k) A) (genericMinor (k := k) B) =
        Finsupp.linearCombination
          (MvPolynomial (Fin m × Fin n) k)
          (fun h :
            (minorSet (m := m) (n := n) (k := k) t) =>
            (h : MvPolynomial (Fin m × Fin n) k)) q ∧
      ∀ h :
          (minorSet (m := m) (n := n) (k := k) t),
        ∀ d ∈ (q h).support,
          ord.toSyn
            (ord.degree
              (MvPolynomial.monomial d (MvPolynomial.coeff d (q h)) *
                (h : MvPolynomial (Fin m × Fin n) k))) <
          ord.toSyn
            (headLcm ord
              (genericMinor (k := k) A)
              (genericMinor (k := k) B)) := by
  classical
  refine
    finsupp_monomial_certificate_of_term_sum_add_diagExp_lt
      (m := m) (n := n) (t := t) (k := k)
      ord hdiag A B S hlin ?_
  intro T hT
  rcases hgap T hT with ⟨x, hx⟩
  have hltSup :
      ord.toSyn (T.d + diagExp T.K) <
        ord.toSyn (diagExp A ⊔ diagExp B) :=
    toSyn_lt_of_le_of_apply_lt ord (hle T hT) hx
  simpa [headLcm_genericMinor_eq_sup_diagExp (k := k) ord hdiag A B]
    using hltSup

end ClosePairThm21Term

end paper2_1_phase4

section paper2_1_phase5

variable {m n t : ℕ}
variable {k : Type*} [CommRing k] [Nontrivial k]

/-!
Phase 5: the route-2 data object for the close-pair Theorem 2.1 proof.

After Phase 4, the remaining paper work can be isolated as the construction of
a finite family of displayed Theorem 2.1 terms satisfying a linear identity and
the exponent bound/gap estimates.  This section packages exactly that data and
proves that it is sufficient for the final Finsupp certificate.
-/

/-- The exact Finsupp certificate required by the close-pair part of the paper
route.  This definition is only an abbreviation for the proposition already
appearing in `closePair_thm21_finsupp_monomial_certificate`. -/
def ClosePairThm21FinsuppCertificate
    (ord : MonomialOrder (Fin m × Fin n))
    (A B : MinorIndex m n t) : Prop :=
  ∃ q :
    (minorSet (m := m) (n := n) (k := k) t) →₀
      MvPolynomial (Fin m × Fin n) k,
    ord.sPolynomial (genericMinor (k := k) A) (genericMinor (k := k) B) =
      Finsupp.linearCombination
        (MvPolynomial (Fin m × Fin n) k)
        (fun h :
          (minorSet (m := m) (n := n) (k := k) t) =>
          (h : MvPolynomial (Fin m × Fin n) k)) q ∧
    ∀ h :
        (minorSet (m := m) (n := n) (k := k) t),
      ∀ d ∈ (q h).support,
        ord.toSyn
          (ord.degree
            (MvPolynomial.monomial d (MvPolynomial.coeff d (q h)) *
              (h : MvPolynomial (Fin m × Fin n) k))) <
        ord.toSyn
          (headLcm ord
            (genericMinor (k := k) A)
            (genericMinor (k := k) B))

/-- Route-2 proof data for the close-pair Theorem 2.1 certificate.

The intended later construction is the explicit straightening formula from the
paper.  Each term is a monomial multiple of a `t × t` minor; Phase 4 reduces
the smallness proof to the two exponent fields below. -/
structure ClosePairThm21Data
    (ord : MonomialOrder (Fin m × Fin n))
    (A B : MinorIndex m n t) where
  terms : Finset (ClosePairThm21Term m n t k)
  linear_identity :
    ord.sPolynomial (genericMinor (k := k) A) (genericMinor (k := k) B) =
      ∑ T ∈ terms, T.poly
  term_small :
    ∀ T ∈ terms, ∀ a : k, a ≠ 0 →
      ord.toSyn
        (ord.degree
          (MvPolynomial.monomial T.d a * genericMinor (k := k) T.K)) <
      ord.toSyn
        (headLcm ord
          (genericMinor (k := k) A)
          (genericMinor (k := k) B))

namespace ClosePairThm21Route2Data

variable {ord : MonomialOrder (Fin m × Fin n)}
variable {A B : MinorIndex m n t}

omit [Nontrivial k] in
lemma term_small
    (D : ClosePairThm21Data (m := m) (n := n) (t := t) (k := k) ord A B)
 :
    ∀ T ∈ D.terms, ∀ a : k, a ≠ 0 →
      ord.toSyn
        (ord.degree
          (MvPolynomial.monomial T.d a * genericMinor (k := k) T.K)) <
      ord.toSyn
        (headLcm ord
          (genericMinor (k := k) A)
          (genericMinor (k := k) B)) := by
  intro T hT a ha
  exact D.term_small T hT a ha

end ClosePairThm21Route2Data

omit [Nontrivial k] in
/-- Route-2 data for the close-pair part of Theorem 2.1 gives the exact
`Finsupp` certificate used by the good-chain API. -/
lemma closePairThm21FinsuppCertificate_of_data
    (ord : MonomialOrder (Fin m × Fin n))
    {A B : MinorIndex m n t}
    (D : ClosePairThm21Data (m := m) (n := n) (t := t) (k := k) ord A B) :
    ClosePairThm21FinsuppCertificate (m := m) (n := n) (t := t) (k := k) ord A B := by
  exact
    ClosePairThm21Term.finsupp_monomial_certificate_of_term_sum
      (m := m) (n := n) (t := t) (k := k)
      ord A B D.terms D.linear_identity D.term_small

omit [Nontrivial k] in
/-- The close-pair Theorem 2.1 data is exactly the adjacent small
`S`-polynomial representation required for a good chain. -/
lemma adjacentSmallSPolynomialRep_of_closePairThm21Data
    (ord : MonomialOrder (Fin m × Fin n))
    {A B : MinorIndex m n t}
    (D : ClosePairThm21Data (m := m) (n := n) (t := t) (k := k) ord A B) :
    AdjacentSmallSPolynomialRep
      ord
      (minorSet (m := m) (n := n) (k := k) t)
      (genericMinor (k := k) A)
      (genericMinor (k := k) B) := by
  rcases closePairThm21FinsuppCertificate_of_data
      (m := m) (n := n) (t := t) (k := k) ord D with
    ⟨q, hlin, hsmall⟩
  exact
    adjacentSmallSPolynomialRep_of_finsupp_monomial_certificate
      (ord := ord) q hlin hsmall

end paper2_1_phase5

section paper2_1

variable {m n t : ℕ}
universe u
variable {k : Type u} [CommRing k] [Nontrivial k]

/-- Paper-route assembly lemma with the remaining §2.1 determinant expansion
isolated as close-pair Theorem 2.1 data.

This is the formal counterpart of: Prop. 1.5 reduces arbitrary pairs of minors
to close adjacent pairs, and the close-pair straightening formula supplies the
small `S`-polynomial representations. -/
theorem minor_hasGoodChain_of_closePairThm21Data
    (ord : MonomialOrder (Fin m × Fin n))
    (hdiag : IsDiagonalTermOrder ord)
    (hdata :
      ∀ A B : MinorIndex m n t,
        Close A B →
          ClosePairThm21Data (m := m) (n := n) (t := t) (k := k) ord A B)
    (I J : MinorIndex m n t) :
    HasGoodChain
      ord
      (minorSet (m := m) (n := n) (k := k) t)
      (genericMinor (k := k) I)
      (genericMinor (k := k) J) := by
  classical
  by_cases hIJ : I = J
  · subst J
    exact hasGoodChain_refl_minor (k := k) ord I
  · exact
      hasGoodChain_minor_of_prop1_5_closeRep
        (k := k) ord hdiag
        (exists_indexCloseChain (m := m) (n := n) (t := t) I J hIJ)
        (by
          intro A B hC
          exact
            adjacentSmallSPolynomialRep_of_closePairThm21Data
              (m := m) (n := n) (t := t) (k := k)
              ord (hdata A B hC))

/-! ### Monomial determinant coefficients

Laplace cofactors in the proof of Theorem 2.1 are determinants of matrices
whose entries are either generic variables or zero.  This namespace gives the
generic finite family of `ClosePairThm21Term`s obtained by expanding such a
cofactor determinant and multiplying by a fixed `t × t` minor.
-/
namespace MonomialCoefficientMatrix

variable {q : ℕ}


/-- A `q × q` coefficient matrix with entries either `0` or a generic variable. -/
noncomputable def matrix
    (row : Fin q → Fin m)
    (col : Fin q → Fin n)
    (zero : Fin q → Fin q → Prop) :
    Matrix (Fin q) (Fin q) (MvPolynomial (Fin m × Fin n) k) := by
  classical
  exact fun i j => if zero i j then 0 else MvPolynomial.X (row i, col j)

/-- Exponent vector of a nonzero Leibniz monomial of a monomial coefficient
matrix.  The determinant convention uses entries `(σ j,j)`. -/
noncomputable def permExp
    (row : Fin q → Fin m)
    (col : Fin q → Fin n)
    (σ : Equiv.Perm (Fin q)) :
    (Fin m × Fin n) →₀ ℕ :=
  ∑ j : Fin q, Finsupp.single (row (σ j), col j) 1

lemma permExp_apply_of_row_injective
    (row : Fin q → Fin m)
    (col : Fin q → Fin n)
    (σ : Equiv.Perm (Fin q))
    (hrow : Function.Injective row)
    (a : Fin m)
    (b : Fin n) :
    permExp row col σ (a, b) =
      if ∃ j : Fin q, row (σ j) = a ∧ col j = b then 1 else 0 := by
  classical
  by_cases h : ∃ j : Fin q, row (σ j) = a ∧ col j = b
  · rcases h with ⟨i, hirow, hicol⟩
    have hpair :
        ∀ j : Fin q, ((row (σ j), col j) = (a, b)) ↔ j = i := by
      intro j
      constructor
      · intro hj
        have hrowji : row (σ j) = row (σ i) := by
          calc
            row (σ j) = a := by simpa using congrArg Prod.fst hj
            _ = row (σ i) := hirow.symm
        have hσ : σ j = σ i := hrow hrowji
        exact σ.injective hσ
      · intro hj
        subst hj
        simp [hirow, hicol]
    simp [permExp, Finsupp.single_apply, hpair]
    subst hirow hicol
    simp_all only [Prod.mk.injEq, exists_eq]
  · have hpairFalse :
        ∀ j : Fin q, (row (σ j), col j) ≠ (a, b) := by
      intro j hj
      exact h ⟨j, by simpa using congrArg Prod.fst hj,
        by simpa using congrArg Prod.snd hj⟩
    simp only [permExp, Finsupp.coe_finset_sum, Finset.sum_apply, ne_eq,
      hpairFalse, not_false_eq_true, Finsupp.single_eq_of_ne',
      Finset.sum_const_zero, h, ↓reduceIte]

lemma permExp_apply_of_col_injective
    (row : Fin q → Fin m)
    (col : Fin q → Fin n)
    (σ : Equiv.Perm (Fin q))
    (hcol : Function.Injective col)
    (a : Fin m)
    (b : Fin n) :
    permExp row col σ (a, b) =
      if ∃ j : Fin q, row (σ j) = a ∧ col j = b then 1 else 0 := by
  classical
  by_cases h : ∃ j : Fin q, row (σ j) = a ∧ col j = b
  · rcases h with ⟨i, hirow, hicol⟩
    have hpair :
        ∀ j : Fin q, ((row (σ j), col j) = (a, b)) ↔ j = i := by
      intro j
      constructor
      · intro hj
        have hcolji : col j = col i := by
          calc
            col j = b := by simpa using congrArg Prod.snd hj
            _ = col i := hicol.symm
        exact hcol hcolji
      · intro hj
        subst hj
        simp [hirow, hicol]
    simp [permExp, Finsupp.single_apply, hpair]
    subst hirow hicol
    simp_all only [Prod.mk.injEq, exists_eq]
  · have hpairFalse :
        ∀ j : Fin q, (row (σ j), col j) ≠ (a, b) := by
      intro j hj
      exact h ⟨j, by simpa using congrArg Prod.fst hj,
        by simpa using congrArg Prod.snd hj⟩
    simp only [permExp, Finsupp.coe_finset_sum, Finset.sum_apply, ne_eq,
      hpairFalse, not_false_eq_true, Finsupp.single_eq_of_ne',
      Finset.sum_const_zero, h, ↓reduceIte]

lemma permExp_pos_iff_exists
    (row : Fin q → Fin m)
    (col : Fin q → Fin n)
    (σ : Equiv.Perm (Fin q))
    (a : Fin m)
    (b : Fin n) :
    1 ≤ permExp row col σ (a, b) ↔
      ∃ j : Fin q, row (σ j) = a ∧ col j = b := by
  classical
  constructor
  · intro hpos
    by_contra hnone
    have hzero :
        permExp row col σ (a, b) = 0 := by
      unfold permExp
      simp only [Finsupp.coe_finset_sum, Finset.sum_apply]
      apply Finset.sum_eq_zero
      intro j _hj
      rw [Finsupp.single_apply]
      apply if_neg
      intro hp
      exact hnone ⟨j,
        by simpa using congrArg Prod.fst hp,
        by simpa using congrArg Prod.snd hp⟩
    omega
  · rintro ⟨j, hrow, hcol⟩
    unfold permExp
    simp only [Finsupp.coe_finset_sum, Finset.sum_apply]
    have hterm :
        Finsupp.single (row (σ j), col j) 1 (a, b) = 1 := by
      rw [Finsupp.single_apply]
      simp [hrow, hcol]
    calc
      1 = Finsupp.single (row (σ j), col j) 1 (a, b) := hterm.symm
      _ ≤ ∑ x : Fin q,
          Finsupp.single (row (σ x), col x) 1 (a, b) :=
        Finset.single_le_sum
          (s := Finset.univ)
          (f := fun x : Fin q =>
            Finsupp.single (row (σ x), col x) 1 (a, b))
          (by
            intro x _hx
            exact Nat.zero_le _)
          (Finset.mem_univ j)

lemma exists_of_permExp_pos
    (row : Fin q → Fin m)
    (col : Fin q → Fin n)
    (σ : Equiv.Perm (Fin q))
    (a : Fin m)
    (b : Fin n)
    (hpos : 1 ≤ permExp row col σ (a, b)) :
    ∃ j : Fin q, row (σ j) = a ∧ col j = b := by
  exact (permExp_pos_iff_exists row col σ a b).1 hpos

/-- Signed coefficient of a Leibniz monomial, set to zero if the permutation
hits a zero entry. -/
noncomputable def permCoeffWithZero
    (zero : Fin q → Fin q → Prop)
    (σ : Equiv.Perm (Fin q)) : k := by
  classical
  exact
    if ∃ j : Fin q, zero (σ j) j then
      0
    else
      permCoeff (k := k) σ

/-- One determinant monomial from a monomial coefficient matrix. -/
noncomputable def permTerm
    (row : Fin q → Fin m)
    (col : Fin q → Fin n)
    (zero : Fin q → Fin q → Prop)
    (σ : Equiv.Perm (Fin q)) :
    MvPolynomial (Fin m × Fin n) k :=
  MvPolynomial.monomial
    (permExp row col σ)
    (permCoeffWithZero (k := k) zero σ)

omit [Nontrivial k] in
lemma det_leibnizTerm_eq_permTerm
    (row : Fin q → Fin m)
    (col : Fin q → Fin n)
    (zero : Fin q → Fin q → Prop)
    (σ : Equiv.Perm (Fin q)) :
    ((((Equiv.Perm.sign σ : ℤˣ) : ℤ) :
        MvPolynomial (Fin m × Fin n) k)) *
        ∏ j : Fin q, matrix (m := m) (n := n) (k := k) row col zero (σ j) j =
      permTerm (m := m) (n := n) (k := k) row col zero σ := by
  classical
  by_cases hzero : ∃ j : Fin q, zero (σ j) j
  · rcases hzero with ⟨j, hj⟩
    have hzeroEx : ∃ j : Fin q, zero (σ j) j := ⟨j, hj⟩
    have hprod :
        (∏ j : Fin q, matrix (m := m) (n := n) (k := k) row col zero (σ j) j) = 0 := by
      refine Finset.prod_eq_zero (Finset.mem_univ j) ?_
      simp [matrix, hj]
    simp [permTerm, permCoeffWithZero, hzeroEx, hprod]
  · have hentry :
        ∀ j : Fin q,
          matrix (m := m) (n := n) (k := k) row col zero (σ j) j =
            MvPolynomial.X (row (σ j), col j) := by
      intro j
      have hz : ¬ zero (σ j) j := by
        intro hz
        exact hzero ⟨j, hz⟩
      simp [matrix, hz]
    simp_rw [hentry]
    rw [permTerm]
    simp only [permCoeffWithZero, hzero, ↓reduceIte]
    change MvPolynomial.C (permCoeff (k := k) σ) *
        ∏ j : Fin q,
          (MvPolynomial.monomial
            (Finsupp.single (row (σ j), col j) 1) 1 :
              MvPolynomial (Fin m × Fin n) k) =
      MvPolynomial.monomial (permExp row col σ) (permCoeff (k := k) σ)
    symm
    simpa [permExp, permTerm, permCoeffWithZero, hzero, permCoeff, MvPolynomial.X] using
      (MvPolynomial.monomial_sum_index
        (s := Finset.univ)
        (f := fun j : Fin q => Finsupp.single (row (σ j), col j) 1)
        (a := permCoeff (k := k) σ))

omit [Nontrivial k] in
lemma det_eq_sum_permTerm
    (row : Fin q → Fin m)
    (col : Fin q → Fin n)
    (zero : Fin q → Fin q → Prop) :
    Matrix.det (matrix (m := m) (n := n) (k := k) row col zero) =
      ∑ σ : Equiv.Perm (Fin q),
        permTerm (m := m) (n := n) (k := k) row col zero σ := by
  classical
  rw [Matrix.det_apply']
  refine Finset.sum_congr rfl ?_
  intro σ hσ
  exact det_leibnizTerm_eq_permTerm
    (m := m) (n := n) (q := q) (k := k) row col zero σ

/-- One determinant monomial, multiplied by a fixed minor, as a
`ClosePairThm21Term`. -/
noncomputable def closePairTerm
    (row : Fin q → Fin m)
    (col : Fin q → Fin n)
    (zero : Fin q → Fin q → Prop)
    (K : MinorIndex m n t)
    (a : k)
    (σ : Equiv.Perm (Fin q)) :
    ClosePairThm21Term m n t k :=
  { K := K
    d := permExp row col σ
    c := a * permCoeffWithZero (k := k) zero σ }

omit [Nontrivial k] in
lemma closePairTerm_poly
    (row : Fin q → Fin m)
    (col : Fin q → Fin n)
    (zero : Fin q → Fin q → Prop)
    (K : MinorIndex m n t)
    (a : k)
    (σ : Equiv.Perm (Fin q)) :
    (closePairTerm
        (m := m) (n := n) (t := t) (q := q) (k := k)
        row col zero K a σ).poly =
      MvPolynomial.C a *
        permTerm (m := m) (n := n) (q := q) (k := k) row col zero σ *
          genericMinor (k := k) K := by
  classical
  by_cases hzero : ∃ j : Fin q, zero (σ j) j
  · simp [closePairTerm, ClosePairThm21Term.poly, ClosePairThm21Term.coeffPoly,
      permTerm, permCoeffWithZero, hzero]
  · simp [closePairTerm, ClosePairThm21Term.poly, ClosePairThm21Term.coeffPoly,
      permTerm, permCoeffWithZero, hzero, MvPolynomial.C_mul_monomial]

omit [Nontrivial k] in
lemma scaled_det_mul_minor_eq_sum_closePairTerm
    (row : Fin q → Fin m)
    (col : Fin q → Fin n)
    (zero : Fin q → Fin q → Prop)
    (K : MinorIndex m n t)
    (a : k) :
    MvPolynomial.C a *
        (Matrix.det (matrix (m := m) (n := n) (k := k) row col zero) *
          genericMinor (k := k) K) =
      ∑ σ : Equiv.Perm (Fin q),
        (closePairTerm
          (m := m) (n := n) (t := t) (q := q) (k := k)
          row col zero K a σ).poly := by
  classical
  rw [det_eq_sum_permTerm row col zero]
  rw [Finset.sum_mul, Finset.mul_sum]
  refine Finset.sum_congr rfl ?_
  intro σ hσ
  rw [closePairTerm_poly
    (m := m) (n := n) (t := t) (q := q) (k := k) row col zero K a σ]
  ring

end MonomialCoefficientMatrix

/-! ### Strict-case enlarged matrix for Paper Theorem 2.1

The strict case of the paper constructs a square matrix whose rows and columns
are

  `A[1..s], B[s+1..u], A[s+1..u], A[u+1..t]`.

The repeated `A[s+1..u]` rows against the `B[s+1..u]` columns form the zero
block.  The definitions in this namespace make that matrix explicit while
keeping the paper-style 1-based coordinates separate from the final
`MvPolynomial.X` variables.
-/
namespace ClosePairStrictBlock


/-- The width of the close middle interval `[s+1,u]`. -/
noncomputable def width (A B : MinorIndex m n t) : ℕ :=
  uClose A B - sClose A B

/-- The size of the enlarged square matrix in the strict case. -/
noncomputable def size (A B : MinorIndex m n t) : ℕ :=
  t + width A B

lemma width_pos_of_close
    (A B : MinorIndex m n t)
    (hC : Close A B) :
    0 < width A B := by
  have hsu : sClose A B < uClose A B := sClose_lt_uClose A B hC.ne
  unfold width
  omega

lemma size_eq
    (A B : MinorIndex m n t) :
    size A B = t + (uClose A B - sClose A B) := rfl

/-- Convert a paper-style 1-based coordinate to a Lean `Fin`, returning `none`
for the sentinels `0` and `N+1`. -/
def paperCoordToFin (N x : ℕ) : Option (Fin N) :=
  if h0 : x = 0 then
    none
  else if hN : x ≤ N then
    some ⟨x - 1, by omega⟩
  else
    none

@[simp] lemma paperCoordToFin_zero (N : ℕ) :
    paperCoordToFin N 0 = none := by
  simp [paperCoordToFin]

lemma paperCoordToFin_of_pos_le
    {N x : ℕ}
    (hpos : 0 < x)
    (hle : x ≤ N) :
    paperCoordToFin N x = some ⟨x - 1, by omega⟩ := by
  simp [paperCoordToFin, Nat.ne_of_gt hpos, hle]

lemma rowExt_pos_of_pos_le
    (I : MinorIndex m n t)
    {j : ℕ}
    (hjpos : 1 ≤ j)
    (hjt : j ≤ t) :
    0 < rowExt I j := by
  have hjne : j ≠ 0 := by omega
  unfold rowExt
  simp [hjne, hjt]

lemma rowExt_le_m_of_pos_le
    (I : MinorIndex m n t)
    {j : ℕ}
    (hjpos : 1 ≤ j)
    (hjt : j ≤ t) :
    rowExt I j ≤ m := by
  have hjne : j ≠ 0 := by omega
  unfold rowExt
  simp [hjne, hjt]

lemma colExt_pos_of_pos_le
    (I : MinorIndex m n t)
    {j : ℕ}
    (hjpos : 1 ≤ j)
    (hjt : j ≤ t) :
    0 < colExt I j := by
  have hjne : j ≠ 0 := by omega
  unfold colExt
  simp [hjne, hjt]

lemma colExt_le_n_of_pos_le
    (I : MinorIndex m n t)
    {j : ℕ}
    (hjpos : 1 ≤ j)
    (hjt : j ≤ t) :
    colExt I j ≤ n := by
  have hjne : j ≠ 0 := by omega
  unfold colExt
  simp [hjne, hjt]

/-- A generic-matrix entry addressed by paper-style 1-based coordinates. -/
noncomputable def entryOfPaperCoords
    (row col : ℕ) :
    MvPolynomial (Fin m × Fin n) k :=
  match paperCoordToFin m row, paperCoordToFin n col with
  | some r, some c => MvPolynomial.X (r, c)
  | _, _ => 0

omit [Nontrivial k] in
lemma entryOfPaperCoords_of_pos_le
    {row col : ℕ}
    (hrowPos : 0 < row)
    (hrowLe : row ≤ m)
    (hcolPos : 0 < col)
    (hcolLe : col ≤ n) :
    entryOfPaperCoords (m := m) (n := n) (k := k) row col =
      MvPolynomial.X
        ((⟨row - 1, by omega⟩ : Fin m),
          (⟨col - 1, by omega⟩ : Fin n)) := by
  simp [entryOfPaperCoords,
    paperCoordToFin_of_pos_le hrowPos hrowLe,
    paperCoordToFin_of_pos_le hcolPos hcolLe]

/-- The second, `B`-middle block: zero-based positions `s .. u-1`. -/
noncomputable def bMiddle (A B : MinorIndex m n t) (q : ℕ) : Prop :=
  sClose A B ≤ q ∧ q < uClose A B

/-- The third, repeated `A`-middle block: zero-based positions
`u .. u+(u-s)-1`. -/
noncomputable def aRepeatedMiddle (A B : MinorIndex m n t) (q : ℕ) : Prop :=
  uClose A B ≤ q ∧ q < uClose A B + width A B

/-- The initial `A` block: zero-based positions before `s`. -/
noncomputable def prefixBlock (A B : MinorIndex m n t) (q : ℕ) : Prop :=
  q < sClose A B

/-- The final `A` block after the repeated middle block. -/
noncomputable def tailBlock (A B : MinorIndex m n t) (q : ℕ) : Prop :=
  uClose A B + width A B ≤ q

lemma bMiddle_index_bounds
    (A B : MinorIndex m n t)
    (hC : Close A B)
    {q : ℕ}
    (hq : bMiddle A B q) :
    1 ≤ q + 1 ∧ q + 1 ≤ t := by
  have hu_le_t : uClose A B ≤ t :=
    le_trans (uClose_le_pClose A B hC.ne) (pClose_le A B)
  unfold bMiddle at hq
  omega

lemma prefix_index_bounds
    (A B : MinorIndex m n t)
    (hC : Close A B)
    {q : ℕ}
    (hq : prefixBlock A B q) :
    1 ≤ q + 1 ∧ q + 1 ≤ t := by
  have hs_lt_t : sClose A B < t :=
    lt_of_lt_of_le (sClose_lt_pClose A B hC.ne) (pClose_le A B)
  unfold prefixBlock at hq
  omega

lemma aRepeatedMiddle_index_bounds
    (A B : MinorIndex m n t)
    (hC : Close A B)
    {q : ℕ}
    (hq : aRepeatedMiddle A B q) :
    1 ≤ sClose A B + 1 + (q - uClose A B) ∧
      sClose A B + 1 + (q - uClose A B) ≤ t := by
  have hsu : sClose A B < uClose A B := sClose_lt_uClose A B hC.ne
  have hu_le_t : uClose A B ≤ t :=
    le_trans (uClose_le_pClose A B hC.ne) (pClose_le A B)
  unfold aRepeatedMiddle width at hq
  omega

lemma tail_index_bounds
    (A B : MinorIndex m n t)
    (hC : Close A B)
    {q : ℕ}
    (hqTail : tailBlock A B q)
    (hqSize : q < size A B) :
    1 ≤ q + 1 - width A B ∧ q + 1 - width A B ≤ t := by
  have hsu : sClose A B < uClose A B := sClose_lt_uClose A B hC.ne
  unfold tailBlock width at hqTail
  unfold size width at hqSize
  unfold width
  omega

/-- Row coordinate of the enlarged matrix, in paper-style 1-based coordinates. -/
noncomputable def rowCoord (A B : MinorIndex m n t) (q : ℕ) : ℕ :=
  if _hprefix : q < sClose A B then
    rowExt A (q + 1)
  else if _hBmid : q < uClose A B then
    rowExt B (q + 1)
  else if _hAmid : q < uClose A B + width A B then
    rowExt A (sClose A B + 1 + (q - uClose A B))
  else
    rowExt A (q + 1 - width A B)

/-- Column coordinate of the enlarged matrix, in paper-style 1-based coordinates. -/
noncomputable def colCoord (A B : MinorIndex m n t) (q : ℕ) : ℕ :=
  if _hprefix : q < sClose A B then
    colExt A (q + 1)
  else if _hBmid : q < uClose A B then
    colExt B (q + 1)
  else if _hAmid : q < uClose A B + width A B then
    colExt A (sClose A B + 1 + (q - uClose A B))
  else
    colExt A (q + 1 - width A B)

lemma rowCoord_of_prefix
    (A B : MinorIndex m n t)
    {q : ℕ}
    (hq : q < sClose A B) :
    rowCoord A B q = rowExt A (q + 1) := by
  simp [rowCoord, hq]

lemma colCoord_of_prefix
    (A B : MinorIndex m n t)
    {q : ℕ}
    (hq : q < sClose A B) :
    colCoord A B q = colExt A (q + 1) := by
  simp [colCoord, hq]

lemma rowCoord_of_bMiddle
    (A B : MinorIndex m n t)
    {q : ℕ}
    (hq : bMiddle A B q) :
    rowCoord A B q = rowExt B (q + 1) := by
  have hnotPrefix : ¬ q < sClose A B := not_lt_of_ge hq.1
  simp [rowCoord, hnotPrefix, hq.2]

lemma colCoord_of_bMiddle
    (A B : MinorIndex m n t)
    {q : ℕ}
    (hq : bMiddle A B q) :
    colCoord A B q = colExt B (q + 1) := by
  have hnotPrefix : ¬ q < sClose A B := not_lt_of_ge hq.1
  simp [colCoord, hnotPrefix, hq.2]

lemma rowCoord_of_aRepeatedMiddle
    (A B : MinorIndex m n t)
    (hC : Close A B)
    {q : ℕ}
    (hq : aRepeatedMiddle A B q) :
    rowCoord A B q =
      rowExt A (sClose A B + 1 + (q - uClose A B)) := by
  have hnotPrefix : ¬ q < sClose A B := by
    have hsu : sClose A B ≤ uClose A B :=
      Nat.le_of_lt (sClose_lt_uClose A B hC.ne)
    exact not_lt_of_ge (le_trans hsu hq.1)
  have hnotBmid : ¬ q < uClose A B := not_lt_of_ge hq.1
  simp [rowCoord, hnotPrefix, hnotBmid, hq.2]

lemma colCoord_of_aRepeatedMiddle
    (A B : MinorIndex m n t)
    (hC : Close A B)
    {q : ℕ}
    (hq : aRepeatedMiddle A B q) :
    colCoord A B q =
      colExt A (sClose A B + 1 + (q - uClose A B)) := by
  have hnotPrefix : ¬ q < sClose A B := by
    have hsu : sClose A B ≤ uClose A B :=
      Nat.le_of_lt (sClose_lt_uClose A B hC.ne)
    exact not_lt_of_ge (le_trans hsu hq.1)
  have hnotBmid : ¬ q < uClose A B := not_lt_of_ge hq.1
  simp [colCoord, hnotPrefix, hnotBmid, hq.2]

lemma rowCoord_of_tail
    (A B : MinorIndex m n t)
    (hC : Close A B)
    {q : ℕ}
    (hqTail : tailBlock A B q) :
    rowCoord A B q = rowExt A (q + 1 - width A B) := by
  have hsu : sClose A B < uClose A B := sClose_lt_uClose A B hC.ne
  have hnotPrefix : ¬ q < sClose A B := by
    unfold tailBlock width at hqTail
    omega
  have hnotBmid : ¬ q < uClose A B := by
    unfold tailBlock width at hqTail
    omega
  have hnotAmid : ¬ q < uClose A B + width A B := not_lt_of_ge hqTail
  simp [rowCoord, hnotPrefix, hnotBmid, hnotAmid]

lemma colCoord_of_tail
    (A B : MinorIndex m n t)
    (hC : Close A B)
    {q : ℕ}
    (hqTail : tailBlock A B q) :
    colCoord A B q = colExt A (q + 1 - width A B) := by
  have hsu : sClose A B < uClose A B := sClose_lt_uClose A B hC.ne
  have hnotPrefix : ¬ q < sClose A B := by
    unfold tailBlock width at hqTail
    omega
  have hnotBmid : ¬ q < uClose A B := by
    unfold tailBlock width at hqTail
    omega
  have hnotAmid : ¬ q < uClose A B + width A B := not_lt_of_ge hqTail
  simp [colCoord, hnotPrefix, hnotBmid, hnotAmid]

lemma rowCoord_pos_le_of_prefix
    (A B : MinorIndex m n t)
    (hC : Close A B)
    {q : ℕ}
    (hq : prefixBlock A B q) :
    0 < rowCoord A B q ∧ rowCoord A B q ≤ m := by
  have hb := prefix_index_bounds A B hC hq
  rw [rowCoord_of_prefix A B hq]
  exact ⟨rowExt_pos_of_pos_le A hb.1 hb.2,
    rowExt_le_m_of_pos_le A hb.1 hb.2⟩

lemma colCoord_pos_le_of_prefix
    (A B : MinorIndex m n t)
    (hC : Close A B)
    {q : ℕ}
    (hq : prefixBlock A B q) :
    0 < colCoord A B q ∧ colCoord A B q ≤ n := by
  have hb := prefix_index_bounds A B hC hq
  rw [colCoord_of_prefix A B hq]
  exact ⟨colExt_pos_of_pos_le A hb.1 hb.2,
    colExt_le_n_of_pos_le A hb.1 hb.2⟩

lemma rowCoord_pos_le_of_bMiddle
    (A B : MinorIndex m n t)
    (hC : Close A B)
    {q : ℕ}
    (hq : bMiddle A B q) :
    0 < rowCoord A B q ∧ rowCoord A B q ≤ m := by
  have hb := bMiddle_index_bounds A B hC hq
  rw [rowCoord_of_bMiddle A B hq]
  exact ⟨rowExt_pos_of_pos_le B hb.1 hb.2,
    rowExt_le_m_of_pos_le B hb.1 hb.2⟩

lemma colCoord_pos_le_of_bMiddle
    (A B : MinorIndex m n t)
    (hC : Close A B)
    {q : ℕ}
    (hq : bMiddle A B q) :
    0 < colCoord A B q ∧ colCoord A B q ≤ n := by
  have hb := bMiddle_index_bounds A B hC hq
  rw [colCoord_of_bMiddle A B hq]
  exact ⟨colExt_pos_of_pos_le B hb.1 hb.2,
    colExt_le_n_of_pos_le B hb.1 hb.2⟩

lemma rowCoord_pos_le_of_aRepeatedMiddle
    (A B : MinorIndex m n t)
    (hC : Close A B)
    {q : ℕ}
    (hq : aRepeatedMiddle A B q) :
    0 < rowCoord A B q ∧ rowCoord A B q ≤ m := by
  have hb := aRepeatedMiddle_index_bounds A B hC hq
  rw [rowCoord_of_aRepeatedMiddle A B hC hq]
  exact ⟨rowExt_pos_of_pos_le A hb.1 hb.2,
    rowExt_le_m_of_pos_le A hb.1 hb.2⟩

lemma colCoord_pos_le_of_aRepeatedMiddle
    (A B : MinorIndex m n t)
    (hC : Close A B)
    {q : ℕ}
    (hq : aRepeatedMiddle A B q) :
    0 < colCoord A B q ∧ colCoord A B q ≤ n := by
  have hb := aRepeatedMiddle_index_bounds A B hC hq
  rw [colCoord_of_aRepeatedMiddle A B hC hq]
  exact ⟨colExt_pos_of_pos_le A hb.1 hb.2,
    colExt_le_n_of_pos_le A hb.1 hb.2⟩

lemma rowCoord_pos_le_of_tail
    (A B : MinorIndex m n t)
    (hC : Close A B)
    {q : ℕ}
    (hqTail : tailBlock A B q)
    (hqSize : q < size A B) :
    0 < rowCoord A B q ∧ rowCoord A B q ≤ m := by
  have hb := tail_index_bounds A B hC hqTail hqSize
  rw [rowCoord_of_tail A B hC hqTail]
  exact ⟨rowExt_pos_of_pos_le A hb.1 hb.2,
    rowExt_le_m_of_pos_le A hb.1 hb.2⟩

lemma colCoord_pos_le_of_tail
    (A B : MinorIndex m n t)
    (hC : Close A B)
    {q : ℕ}
    (hqTail : tailBlock A B q)
    (hqSize : q < size A B) :
    0 < colCoord A B q ∧ colCoord A B q ≤ n := by
  have hb := tail_index_bounds A B hC hqTail hqSize
  rw [colCoord_of_tail A B hC hqTail]
  exact ⟨colExt_pos_of_pos_le A hb.1 hb.2,
    colExt_le_n_of_pos_le A hb.1 hb.2⟩

lemma block_cases_of_lt_size
    (A B : MinorIndex m n t)
    {q : ℕ}
    (_hqSize : q < size A B) :
    prefixBlock A B q ∨ bMiddle A B q ∨
      aRepeatedMiddle A B q ∨ tailBlock A B q := by
  classical
  by_cases hPrefix : q < sClose A B
  · exact Or.inl hPrefix
  · by_cases hB : q < uClose A B
    · exact Or.inr <| Or.inl ⟨Nat.le_of_not_gt hPrefix, hB⟩
    · by_cases hA : q < uClose A B + width A B
      · exact Or.inr <| Or.inr <|
          Or.inl ⟨Nat.le_of_not_gt hB, hA⟩
      · exact Or.inr <| Or.inr <| Or.inr (Nat.le_of_not_gt hA)

lemma rowCoord_pos_le_of_lt_size
    (A B : MinorIndex m n t)
    (hC : Close A B)
    {q : ℕ}
    (hqSize : q < size A B) :
    0 < rowCoord A B q ∧ rowCoord A B q ≤ m := by
  rcases block_cases_of_lt_size A B hqSize with hq | hq | hq | hq
  · exact rowCoord_pos_le_of_prefix A B hC hq
  · exact rowCoord_pos_le_of_bMiddle A B hC hq
  · exact rowCoord_pos_le_of_aRepeatedMiddle A B hC hq
  · exact rowCoord_pos_le_of_tail A B hC hq hqSize

lemma colCoord_pos_le_of_lt_size
    (A B : MinorIndex m n t)
    (hC : Close A B)
    {q : ℕ}
    (hqSize : q < size A B) :
    0 < colCoord A B q ∧ colCoord A B q ≤ n := by
  rcases block_cases_of_lt_size A B hqSize with hq | hq | hq | hq
  · exact colCoord_pos_le_of_prefix A B hC hq
  · exact colCoord_pos_le_of_bMiddle A B hC hq
  · exact colCoord_pos_le_of_aRepeatedMiddle A B hC hq
  · exact colCoord_pos_le_of_tail A B hC hq hqSize

/-- The zero block used in the strict case: repeated `A`-middle rows against
`B`-middle columns. -/
noncomputable def zeroBlock (A B : MinorIndex m n t) (i j : ℕ) : Prop :=
  aRepeatedMiddle A B i ∧ bMiddle A B j

/-- The enlarged matrix used in the strict case of the paper proof. -/
noncomputable def matrix
    (A B : MinorIndex m n t) :
    Matrix (Fin (size A B)) (Fin (size A B))
      (MvPolynomial (Fin m × Fin n) k) := by
  classical
  exact fun i j =>
    if zeroBlock A B i.1 j.1 then
      0
    else
      entryOfPaperCoords
        (m := m) (n := n) (k := k)
        (rowCoord A B i.1) (colCoord A B j.1)

omit [Nontrivial k] in
@[simp] lemma matrix_zero_of_zeroBlock
    (A B : MinorIndex m n t)
    {i j : Fin (size A B)}
    (hij : zeroBlock A B i.1 j.1) :
    matrix (m := m) (n := n) (t := t) (k := k) A B i j = 0 := by
  simp [matrix, hij]

omit [Nontrivial k] in
lemma matrix_entry_of_not_zeroBlock
    (A B : MinorIndex m n t)
    {i j : Fin (size A B)}
    (hij : ¬ zeroBlock A B i.1 j.1) :
    matrix (m := m) (n := n) (t := t) (k := k) A B i j =
      entryOfPaperCoords
        (m := m) (n := n) (k := k)
        (rowCoord A B i.1) (colCoord A B j.1) := by
  simp [matrix, hij]

omit [Nontrivial k] in
lemma matrix_entry_of_not_zeroBlock_as_X
    (A B : MinorIndex m n t)
    (hC : Close A B)
    {i j : Fin (size A B)}
    (hij : ¬ zeroBlock A B i.1 j.1) :
    matrix (m := m) (n := n) (t := t) (k := k) A B i j =
      MvPolynomial.X
        ((⟨rowCoord A B i.1 - 1,
            by
              have h := rowCoord_pos_le_of_lt_size A B hC i.2
              omega⟩ : Fin m),
          (⟨colCoord A B j.1 - 1,
            by
              have h := colCoord_pos_le_of_lt_size A B hC j.2
              omega⟩ : Fin n)) := by
  rw [matrix_entry_of_not_zeroBlock A B hij]
  exact entryOfPaperCoords_of_pos_le
    (m := m) (n := n) (k := k)
    (rowCoord_pos_le_of_lt_size A B hC i.2).1
    (rowCoord_pos_le_of_lt_size A B hC i.2).2
    (colCoord_pos_le_of_lt_size A B hC j.2).1
    (colCoord_pos_le_of_lt_size A B hC j.2).2

/-- The row variable of a strict-block matrix row. -/
noncomputable def rowFin
    (A B : MinorIndex m n t)
    (hC : Close A B)
    (i : Fin (size A B)) : Fin m :=
  ⟨rowCoord A B i.1 - 1, by
    have h := rowCoord_pos_le_of_lt_size A B hC i.2
    omega⟩

/-- The column variable of a strict-block matrix column. -/
noncomputable def colFin
    (A B : MinorIndex m n t)
    (hC : Close A B)
    (j : Fin (size A B)) : Fin n :=
  ⟨colCoord A B j.1 - 1, by
    have h := colCoord_pos_le_of_lt_size A B hC j.2
    omega⟩

omit [Nontrivial k] in
lemma matrix_entry_of_not_zeroBlock_as_X'
    (A B : MinorIndex m n t)
    (hC : Close A B)
    {i j : Fin (size A B)}
    (hij : ¬ zeroBlock A B i.1 j.1) :
    matrix (m := m) (n := n) (t := t) (k := k) A B i j =
      MvPolynomial.X (rowFin A B hC i, colFin A B hC j) := by
  rw [matrix_entry_of_not_zeroBlock A B hij]
  exact entryOfPaperCoords_of_pos_le
    (m := m) (n := n) (k := k)
    (rowCoord_pos_le_of_lt_size A B hC i.2).1
    (rowCoord_pos_le_of_lt_size A B hC i.2).2
    (colCoord_pos_le_of_lt_size A B hC j.2).1
    (colCoord_pos_le_of_lt_size A B hC j.2).2

/-- The exponent contributed by one nonzero Leibniz term in `det M`. -/
noncomputable def matrixPermExp
    (A B : MinorIndex m n t)
    (hC : Close A B)
    (σ : Equiv.Perm (Fin (size A B))) :
    (Fin m × Fin n) →₀ ℕ :=
  ∑ j : Fin (size A B),
    Finsupp.single (rowFin A B hC (σ j), colFin A B hC j) 1

/-- One Leibniz term in the determinant expansion of the strict-block matrix,
written as a monomial when it does not meet the zero block. -/
noncomputable def matrixPermTerm
    (A B : MinorIndex m n t)
    (hC : Close A B)
    (σ : Equiv.Perm (Fin (size A B))) :
    MvPolynomial (Fin m × Fin n) k := by
  classical
  exact
    if ∃ j : Fin (size A B), zeroBlock A B (σ j).1 j.1 then
      0
    else
      MvPolynomial.monomial
        (matrixPermExp A B hC σ)
        (permCoeff (k := k) σ)

/-- Coefficient of the corresponding `ClosePairThm21Term`; it is zero exactly
for Leibniz terms hitting the zero block. -/
noncomputable def matrixPermCoeff
    (A B : MinorIndex m n t)
    (σ : Equiv.Perm (Fin (size A B))) : k := by
  classical
  exact
    if ∃ j : Fin (size A B), zeroBlock A B (σ j).1 j.1 then
      0
    else
      permCoeff (k := k) σ

/-- Turn one nonzero Leibniz term of the strict-block determinant into a
monomial multiple of a fixed `t × t` minor.  Zero-block terms become zero
coefficient terms, which are harmless in finite sums. -/
noncomputable def matrixPermClosePairTerm
    (A B : MinorIndex m n t)
    (hC : Close A B)
    (K : MinorIndex m n t)
    (σ : Equiv.Perm (Fin (size A B))) :
    ClosePairThm21Term m n t k :=
  { K := K
    d := matrixPermExp A B hC σ
    c := matrixPermCoeff (m := m) (n := n) (t := t) (k := k) A B σ }

/-- Version of `matrixPermClosePairTerm` with an additional scalar coefficient,
used for the signs in the Laplace expansions. -/
noncomputable def scaledMatrixPermClosePairTerm
    (A B : MinorIndex m n t)
    (hC : Close A B)
    (K : MinorIndex m n t)
    (a : k)
    (σ : Equiv.Perm (Fin (size A B))) :
    ClosePairThm21Term m n t k :=
  { K := K
    d := matrixPermExp A B hC σ
    c := a *
      matrixPermCoeff (m := m) (n := n) (t := t) (k := k) A B σ }

omit [Nontrivial k] in
lemma matrixPermClosePairTerm_poly
    (A B : MinorIndex m n t)
    (hC : Close A B)
    (K : MinorIndex m n t)
    (σ : Equiv.Perm (Fin (size A B))) :
    (matrixPermClosePairTerm
        (m := m) (n := n) (t := t) (k := k) A B hC K σ).poly =
      matrixPermTerm (m := m) (n := n) (t := t) (k := k) A B hC σ *
        genericMinor (k := k) K := by
  classical
  by_cases hzero : ∃ j : Fin (size A B), zeroBlock A B (σ j).1 j.1
  · simp [matrixPermClosePairTerm, ClosePairThm21Term.poly,
      ClosePairThm21Term.coeffPoly, matrixPermCoeff, matrixPermTerm, hzero]
  · simp [matrixPermClosePairTerm, ClosePairThm21Term.poly,
      ClosePairThm21Term.coeffPoly, matrixPermCoeff, matrixPermTerm, hzero]

omit [Nontrivial k] in
lemma scaledMatrixPermClosePairTerm_poly
    (A B : MinorIndex m n t)
    (hC : Close A B)
    (K : MinorIndex m n t)
    (a : k)
    (σ : Equiv.Perm (Fin (size A B))) :
    (scaledMatrixPermClosePairTerm
        (m := m) (n := n) (t := t) (k := k) A B hC K a σ).poly =
      MvPolynomial.C a *
        matrixPermTerm (m := m) (n := n) (t := t) (k := k) A B hC σ *
          genericMinor (k := k) K := by
  classical
  by_cases hzero : ∃ j : Fin (size A B), zeroBlock A B (σ j).1 j.1
  · simp [scaledMatrixPermClosePairTerm, ClosePairThm21Term.poly,
      ClosePairThm21Term.coeffPoly, matrixPermCoeff, matrixPermTerm, hzero]
  · simp [scaledMatrixPermClosePairTerm, ClosePairThm21Term.poly,
      ClosePairThm21Term.coeffPoly, matrixPermCoeff, matrixPermTerm, hzero,
      MvPolynomial.C_mul_monomial]

omit [Nontrivial k] in
lemma det_term_eq_matrixPermTerm
    (A B : MinorIndex m n t)
    (hC : Close A B)
    (σ : Equiv.Perm (Fin (size A B))) :
    ((((Equiv.Perm.sign σ : ℤˣ) : ℤ) :
        MvPolynomial (Fin m × Fin n) k)) *
        ∏ j : Fin (size A B),
          matrix (m := m) (n := n) (t := t) (k := k) A B (σ j) j =
      matrixPermTerm (m := m) (n := n) (t := t) (k := k) A B hC σ := by
  classical
  by_cases hzero : ∃ j : Fin (size A B), zeroBlock A B (σ j).1 j.1
  · rcases hzero with ⟨j, hj⟩
    have hzeroEx : ∃ j : Fin (size A B), zeroBlock A B (σ j).1 j.1 := ⟨j, hj⟩
    have hprod :
        (∏ j : Fin (size A B),
          matrix (m := m) (n := n) (t := t) (k := k) A B (σ j) j) = 0 := by
      refine Finset.prod_eq_zero (Finset.mem_univ j) ?_
      simp [matrix_zero_of_zeroBlock A B hj]
    simp [matrixPermTerm, hzeroEx, hprod]
  · have hentry :
        ∀ j : Fin (size A B),
          matrix (m := m) (n := n) (t := t) (k := k) A B (σ j) j =
            MvPolynomial.X (rowFin A B hC (σ j), colFin A B hC j) := by
      intro j
      exact matrix_entry_of_not_zeroBlock_as_X' A B hC
        (by
          intro hz
          exact hzero ⟨j, hz⟩)
    simp_rw [hentry]
    rw [matrixPermTerm, if_neg hzero]
    change MvPolynomial.C (permCoeff (k := k) σ) *
        ∏ j : Fin (size A B),
          (MvPolynomial.monomial
            (Finsupp.single (rowFin A B hC (σ j), colFin A B hC j) 1) 1 :
              MvPolynomial (Fin m × Fin n) k) =
      MvPolynomial.monomial (matrixPermExp A B hC σ) (permCoeff (k := k) σ)
    symm
    simpa [matrixPermExp, permCoeff, MvPolynomial.X] using
      (MvPolynomial.monomial_sum_index
        (s := Finset.univ)
        (f := fun j : Fin (size A B) =>
          Finsupp.single (rowFin A B hC (σ j), colFin A B hC j) 1)
        (a := permCoeff (k := k) σ))

omit [Nontrivial k] in
lemma det_eq_sum_matrixPermTerm
    (A B : MinorIndex m n t)
    (hC : Close A B) :
    Matrix.det (matrix (m := m) (n := n) (t := t) (k := k) A B) =
      ∑ σ : Equiv.Perm (Fin (size A B)),
        matrixPermTerm (m := m) (n := n) (t := t) (k := k) A B hC σ := by
  classical
  rw [Matrix.det_apply']
  refine Finset.sum_congr rfl ?_
  intro σ hσ
  exact det_term_eq_matrixPermTerm (m := m) (n := n) (t := t) (k := k) A B hC σ

omit [Nontrivial k] in
lemma det_mul_minor_eq_sum_matrixPermClosePairTerm
    (A B : MinorIndex m n t)
    (hC : Close A B)
    (K : MinorIndex m n t) :
    Matrix.det (matrix (m := m) (n := n) (t := t) (k := k) A B) *
        genericMinor (k := k) K =
      ∑ σ : Equiv.Perm (Fin (size A B)),
        (matrixPermClosePairTerm
          (m := m) (n := n) (t := t) (k := k) A B hC K σ).poly := by
  classical
  rw [det_eq_sum_matrixPermTerm A B hC]
  rw [Finset.sum_mul]
  refine Finset.sum_congr rfl ?_
  intro σ hσ
  exact (matrixPermClosePairTerm_poly
    (m := m) (n := n) (t := t) (k := k) A B hC K σ).symm

omit [Nontrivial k] in
lemma scaled_det_mul_minor_eq_sum_matrixPermClosePairTerm
    (A B : MinorIndex m n t)
    (hC : Close A B)
    (K : MinorIndex m n t)
    (a : k) :
    MvPolynomial.C a *
        (Matrix.det (matrix (m := m) (n := n) (t := t) (k := k) A B) *
          genericMinor (k := k) K) =
      ∑ σ : Equiv.Perm (Fin (size A B)),
        (scaledMatrixPermClosePairTerm
          (m := m) (n := n) (t := t) (k := k) A B hC K a σ).poly := by
  classical
  rw [det_eq_sum_matrixPermTerm A B hC]
  rw [Finset.sum_mul, Finset.mul_sum]
  refine Finset.sum_congr rfl ?_
  intro σ hσ
  rw [scaledMatrixPermClosePairTerm_poly
    (m := m) (n := n) (t := t) (k := k) A B hC K a σ]
  ring

/-- Positions of the `B`-middle columns `β'_{s+1}, ..., β'_u` in the strict
block matrix.  These are the columns used in the row-choice Laplace expansion
`(2.1.3)`. -/
noncomputable def bMiddlePos
    (A B : MinorIndex m n t)
    (hC : Close A B)
    (i : Fin (width A B)) :
    Fin (size A B) :=
  ⟨sClose A B + i.1, by
    have hs_lt_t : sClose A B < t :=
      lt_of_lt_of_le (sClose_lt_pClose A B hC.ne) (pClose_le A B)
    have hi : i.1 < uClose A B - sClose A B := by
      simp only [width] at i
      exact i.2
    unfold size width
    omega⟩

lemma bMiddlePos_mem
    (A B : MinorIndex m n t)
    (hC : Close A B)
    (i : Fin (width A B)) :
    bMiddle A B (bMiddlePos A B hC i).1 := by
  have hi : i.1 < uClose A B - sClose A B := by
    simp only [width] at i
    exact i.2
  change bMiddle A B (sClose A B + i.1)
  unfold bMiddle
  omega

lemma bMiddlePos_paper_mem_closeMiddle
    (A B : MinorIndex m n t)
    (_hC : Close A B)
    (i : Fin (width A B)) :
    sClose A B + i.1 + 1 ∈ closeMiddle A B := by
  rw [mem_closeMiddle_iff]
  have hi : i.1 < uClose A B - sClose A B := by
    simp only [width] at i
    exact i.2
  constructor
  · omega
  · omega

/-- Positions of the repeated `A`-middle rows `α_{s+1}, ..., α_u` in the strict
block matrix.  These are the rows used in the column-choice Laplace expansion
`(2.1.4)`. -/
noncomputable def aRepeatedMiddlePos
    (A B : MinorIndex m n t)
    (hC : Close A B)
    (i : Fin (width A B)) :
    Fin (size A B) :=
  ⟨uClose A B + i.1, by
    have hu_le_t : uClose A B ≤ t :=
      le_trans (uClose_le_pClose A B hC.ne) (pClose_le A B)
    have hi : i.1 < uClose A B - sClose A B := by
      simp only [width] at i
      exact i.2
    unfold size width
    omega⟩

lemma aRepeatedMiddlePos_mem
    (A B : MinorIndex m n t)
    (hC : Close A B)
    (i : Fin (width A B)) :
    aRepeatedMiddle A B (aRepeatedMiddlePos A B hC i).1 := by
  have hi : i.1 < uClose A B - sClose A B := by
    simp only [width] at i
    exact i.2
  change aRepeatedMiddle A B (uClose A B + i.1)
  unfold aRepeatedMiddle width
  omega

lemma rowFin_bMiddlePos
    (A B : MinorIndex m n t)
    (hC : Close A B)
    (i : Fin (width A B)) :
    rowFin A B hC (bMiddlePos A B hC i) =
      B.row ⟨sClose A B + i.1, by
        have hi : i.1 < uClose A B - sClose A B := by
          simp only [width] at i
          exact i.2
        have hu : uClose A B ≤ t :=
          le_trans (uClose_le_pClose A B hC.ne) (pClose_le A B)
        omega⟩ := by
  apply Fin.ext
  have hq := bMiddlePos_mem A B hC i
  have hcoord := rowCoord_of_bMiddle A B hq
  have hi : i.1 < uClose A B - sClose A B := by
    simp only [width] at i
    exact i.2
  have hbounds :
      1 ≤ sClose A B + i.1 + 1 ∧ sClose A B + i.1 + 1 ≤ t := by
    have hu : uClose A B ≤ t :=
      le_trans (uClose_le_pClose A B hC.ne) (pClose_le A B)
    omega
  change rowCoord A B (bMiddlePos A B hC i).1 - 1 =
    (B.row ⟨sClose A B + i.1, by
      have hu : uClose A B ≤ t :=
        le_trans (uClose_le_pClose A B hC.ne) (pClose_le A B)
      omega⟩ : Fin m).1
  rw [hcoord]
  simp only [bMiddlePos]
  rw [EndpointSelection.rowExt_endpoint (I := B) hbounds.1 hbounds.2]
  have hidx :
      (⟨sClose A B + i.1 + 1 - 1, by omega⟩ : Fin t) =
        ⟨sClose A B + i.1, by
          have hu : uClose A B ≤ t :=
            le_trans (uClose_le_pClose A B hC.ne) (pClose_le A B)
          omega⟩ := by
    apply Fin.ext
    simp
  rw [hidx]
  omega

