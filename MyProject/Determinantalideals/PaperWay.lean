      (closePairThm21_case3_cTailTerm
        (m := m) (n := n) (t := t) (k := k) A B hC σ).d <
    ord.toSyn
      (diagExp (ClosePairStrictBlock.aRepeatedMiddleMinorIndex A B hC)) := by
  classical
  have hσsymm : σ.symm ≠ 1 :=
    perm_symm_ne_one_of_ne_one σ hσ
  simpa [closePairThm21_case3_cTailTerm,
    ClosePairStrictBlock.cBlockTerm,
    MonomialCoefficientMatrix.closePairTerm,
    ClosePairStrictBlock.cBlock_permExp_eq_middle_permExp_symm
      (m := m) (n := n) (t := t) A B hC σ] using
    (hdiag (ClosePairStrictBlock.aRepeatedMiddleMinorIndex A B hC)
      σ.symm hσsymm)

