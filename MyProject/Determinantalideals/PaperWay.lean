/-- The total raw row Laplace sum equals the normalized `RowLaplaceChoice` sum.

Bad raw choices contribute zero; sortable raw choices normalize to row choices. -/
lemma raw_row_laplace_sum_eq_row_choice_sum
    (A B : MinorIndex m n t)
    (hC : Close A B) :
    (∑ R : RawRowLaplaceChoice A B hC,
      rawRowLaplaceSummand
        (m := m) (n := n) (t := t) (k := k) A B hC R) =
      ∑ L : ClosePairStrictBlock.RowLaplaceChoice A B hC,
        strictRowLaplaceSummand
          (m := m) (n := n) (t := t) (k := k) A B hC L := by
  classical
  let f : RawRowLaplaceChoice A B hC →
      MvPolynomial (Fin m × Fin n) k :=
    fun R =>
      rawRowLaplaceSummand
        (m := m) (n := n) (t := t) (k := k) A B hC R
  have hbad :
      (∑ R : {R : RawRowLaplaceChoice A B hC // ¬ R.Sortable},
        f R.1) = 0 := by
    refine Finset.sum_eq_zero ?_
    intro R _hR
    exact rawRowLaplaceSummand_eq_zero_of_not_sortable
      (m := m) (n := n) (t := t) (k := k) A B hC R.1 R.2
  calc
    (∑ R : RawRowLaplaceChoice A B hC,
      rawRowLaplaceSummand
        (m := m) (n := n) (t := t) (k := k) A B hC R)
        =
      (∑ R : {R : RawRowLaplaceChoice A B hC // R.Sortable}, f R.1) +
        ∑ R : {R : RawRowLaplaceChoice A B hC // ¬ R.Sortable}, f R.1 := by
        change
          (∑ R : RawRowLaplaceChoice A B hC, f R) =
            (∑ R : {R : RawRowLaplaceChoice A B hC // R.Sortable}, f R.1) +
              ∑ R : {R : RawRowLaplaceChoice A B hC // ¬ R.Sortable}, f R.1
        exact
          (Fintype.sum_subtype_add_sum_subtype
            (p := fun R : RawRowLaplaceChoice A B hC => R.Sortable) f).symm
    _ =
      ∑ R : {R : RawRowLaplaceChoice A B hC // R.Sortable}, f R.1 := by
        simp [hbad]
    _ =
      ∑ L : ClosePairStrictBlock.RowLaplaceChoice A B hC,
        strictRowLaplaceSummand
          (m := m) (n := n) (t := t) (k := k) A B hC L := by
        change
          (∑ R : {R : RawRowLaplaceChoice A B hC // R.Sortable},
            rawRowLaplaceSummand
              (m := m) (n := n) (t := t) (k := k) A B hC R.1) =
            ∑ L : ClosePairStrictBlock.RowLaplaceChoice A B hC,
              strictRowLaplaceSummand
                (m := m) (n := n) (t := t) (k := k) A B hC L
        exact sortable_raw_row_laplace_sum_eq_row_choice_sum
          (m := m) (n := n) (t := t) (k := k) A B hC



