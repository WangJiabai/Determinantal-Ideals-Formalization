/-- The row-side cofactor exponent cannot contribute a tail `A` diagonal
variable.

This is the tail analogue of
`closePairThm21_case1_cofactorExp_apply_A_prefix_diag_eq_zero`. -/
lemma closePairThm21_case1_cofactorExp_apply_A_tail_diag_eq_zero
    (A B : MinorIndex m n t)
    (hC : Close A B)
    (_hrowLt :
      rowExt B (uClose A B) < rowExt A (uClose A B))
    (L : ClosePairStrictBlock.RowLaplaceChoice A B hC)
    (σ : Equiv.Perm (Fin (ClosePairStrictBlock.width A B)))
    (i : Fin t)
    (hi : uClose A B ≤ i.1) :
    MonomialCoefficientMatrix.permExp
        L.cofactorRow L.cofactorCol σ (A.row i, A.col i) = 0 := by
  classical
  unfold MonomialCoefficientMatrix.permExp
  simp only [Finsupp.coe_finset_sum, Finset.sum_apply]
  refine Finset.sum_eq_zero ?_
  intro j _hj
  rw [Finsupp.single_apply]
  apply if_neg
  intro hp
  have hcol :
      ClosePairStrictBlock.colFin A B hC
          (ClosePairStrictBlock.bMiddlePos A B hC j) =
        A.col i := by
    simpa [ClosePairStrictBlock.RowLaplaceChoice.cofactorCol] using
      congrArg Prod.snd hp
  rw [ClosePairStrictBlock.colFin_bMiddlePos A B hC j] at hcol
  let jm : Fin t :=
    ⟨sClose A B + j.1, by
      have hj : j.1 < uClose A B - sClose A B := by
        simp [ClosePairStrictBlock.width]
      have hu : uClose A B ≤ t :=
        le_trans (uClose_le_pClose A B hC.ne) (pClose_le A B)
      omega⟩
