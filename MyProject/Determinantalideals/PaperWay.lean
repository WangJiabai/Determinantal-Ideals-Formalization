/-- A single failed instance of paper Case 1 statement (b).

This packages the dependent indices appearing in `StatementB`.  The point of
making this a structure is that the paper-specific proof can show directly
that such a failure forces the displayed row-side monomial to be strictly
smaller than the endpoint lcm.  The generic contradiction against `hnot` is
then independent of those details. -/
structure StatementBFailure
    (A B : MinorIndex m n t)
    (hC : Close A B)
    (L : ClosePairStrictBlock.RowLaplaceChoice A B hC)
    (U : Case1UVChain A B hC) where
  i : Fin U.q
  j : ℕ
  hjlo : U.u i.succ ≤ j
  hjhi : j < U.u i.castSucc
  hne :
    L.minorRows
        (middlePaperIndexToFinOfClose A B hC j
          (by
            have hs : sClose A B + 1 ≤ j :=
              le_trans (U.u_bounds i.succ).1 hjlo
            have hu : j ≤ uClose A B := by
              have htop := (U.u_bounds i.castSucc).2
              omega
            exact ⟨hs, hu⟩)) ≠
      aColumnPosOfPaperMiddle A B hC j
        (by
          have hs : sClose A B + 1 ≤ j :=
            le_trans (U.u_bounds i.succ).1 hjlo
          have hu : j ≤ uClose A B := by
            have htop := (U.u_bounds i.castSucc).2
            omega
          exact ⟨hs, hu⟩)

namespace StatementBFailure

/-- The zero-based middle index attached to a failed paper statement (b)
instance. -/
noncomputable def idx
    {A B : MinorIndex m n t}
    {hC : Close A B}
    {L : ClosePairStrictBlock.RowLaplaceChoice A B hC}
    {U : Case1UVChain A B hC}
    (F : StatementBFailure A B hC L U) :
    Fin t :=
  middlePaperIndexToFinOfClose A B hC F.j
    (by
      have hs : sClose A B + 1 ≤ F.j :=
        le_trans (U.u_bounds F.i.succ).1 F.hjlo
      have hu : F.j ≤ uClose A B := by
        have htop := (U.u_bounds F.i.castSucc).2
        have hjhi := F.hjhi
        omega
      exact ⟨hs, hu⟩)

lemma idx_s
    {A B : MinorIndex m n t}
    {hC : Close A B}
    {L : ClosePairStrictBlock.RowLaplaceChoice A B hC}
    {U : Case1UVChain A B hC}
    (F : StatementBFailure A B hC L U) :
    sClose A B ≤ F.idx.1 := by
  have hs : sClose A B + 1 ≤ F.j :=
    le_trans (U.u_bounds F.i.succ).1 F.hjlo
  simp [idx, middlePaperIndexToFinOfClose]
  omega

lemma idx_u
    {A B : MinorIndex m n t}
    {hC : Close A B}
    {L : ClosePairStrictBlock.RowLaplaceChoice A B hC}
    {U : Case1UVChain A B hC}
    (F : StatementBFailure A B hC L U) :
    F.idx.1 < uClose A B := by
  have hs : sClose A B + 1 ≤ F.j :=
    le_trans (U.u_bounds F.i.succ).1 F.hjlo
  have hu : F.j ≤ uClose A B := by
    have htop := (U.u_bounds F.i.castSucc).2
    have hjhi := F.hjhi
    omega
  simp [idx, middlePaperIndexToFinOfClose]
  omega

lemma hne_idx
    {A B : MinorIndex m n t}
    {hC : Close A B}
    {L : ClosePairStrictBlock.RowLaplaceChoice A B hC}
    {U : Case1UVChain A B hC}
    (F : StatementBFailure A B hC L U) :
    L.minorRows F.idx ≠
      ClosePairStrictBlock.aColumnPos A B hC F.idx := by
  simpa [idx, aColumnPosOfPaperMiddle] using F.hne

