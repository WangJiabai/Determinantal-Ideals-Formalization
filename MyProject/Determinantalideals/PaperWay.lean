  let s : Finset (Fin (ClosePairStrictBlock.size A B)) := Finset.univ.image
    (fun j : Fin (ClosePairStrictBlock.width A B) =>
      ClosePairStrictBlock.bMiddlePos A B hC j)
  have hbInj :
      Function.Injective
        (fun j : Fin (ClosePairStrictBlock.width A B) =>
          ClosePairStrictBlock.bMiddlePos A B hC j) := by
    intro i j hij
    apply Fin.ext
    have hval := congrArg Fin.val hij
    simpa [ClosePairStrictBlock.bMiddlePos] using hval
  have hcard : s.card = ClosePairStrictBlock.width A B := by
    unfold s
    rw [Finset.card_image_of_injective]
    · simp
    · exact hbInj
  have hbStrict :
      StrictMono
        (fun j : Fin (ClosePairStrictBlock.width A B) =>
          ClosePairStrictBlock.bMiddlePos A B hC j) := by
    intro i j hij
