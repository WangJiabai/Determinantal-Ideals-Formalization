/-- The finite set of actual `ClosePairThm21Term`s produced by the four raw
strict-case Laplace families.  Passing through this image removes duplicate
raw origins; the indexed family used downstream is the subtype of this finset,
so injectivity is automatic. -/
noncomputable def terms
    (A B : MinorIndex m n t)
    (hC : Close A B) :
    Finset (ClosePairThm21Term m n t k) := by
  classical
  exact
    Finset.univ.image
      (term (m := m) (n := n) (t := t) (k := k) (A := A) (B := B) (hC := hC))

end StrictLaplaceRawIndex

/-- The determinant whose two Laplace expansions produce the strict-case
straightening terms. -/
noncomputable def det
    (A B : MinorIndex m n t) :
    MvPolynomial (Fin m × Fin n) k :=
  Matrix.det (matrix (m := m) (n := n) (t := t) (k := k) A B)

end ClosePairStrictBlock

omit [Nontrivial k] in
/-- Algebraic comparison step behind paper formula `(2.1.5)`.

Once `(2.1.3)` and `(2.1.4)` express the same determinant as
`bDet * D(A) + rowRest` and `cDet * D(B) + colRest`, and once the endpoint
cofactors split into their diagonal monomials plus tails, the displayed
strict-case `S`-polynomial identity follows by cancellation. -/
lemma strict_laplace_linear_identity_of_matrix_expansions
    {P : Type*} [CommRing P]
    (sPoly detM bDet cDet bDiag cDiag rowRest colRest bTail cTail : P)
    (hsp : sPoly = bDiag - cDiag)
    (hrow : detM = bDet + rowRest)
    (hcol : detM = cDet + colRest)
    (hb : bDet = bDiag + bTail)
    (hc : cDet = cDiag + cTail) :
    sPoly = colRest - rowRest + cTail - bTail := by
  have hdet : cDet + colRest = bDet + rowRest := by
    rw [← hcol, ← hrow]
  subst sPoly
  subst bDet
  subst cDet
  linear_combination -hdet

/-! ### Strict-case algebraic identity for formula (2.1.5)

The next lemmas isolate the algebraic part of the strict case:

  `S(D_A,D_B) = rawPolySum A B hC`.

They do not contain any monomial-order smallness proof.  The four-case proof
after `(*)` belongs to the separate `hraw` branch.
-/

/-- The diagonal `B`-cofactor term multiplying `D(A)`.

This is the formal version of `Δ_B D_(α,β)` in the paper. -/
noncomputable def strictBDiagPart
    (A B : MinorIndex m n t)
    (hC : Close A B) :
    MvPolynomial (Fin m × Fin n) k :=
  (ClosePairStrictBlock.bBlockTerm
    (m := m) (n := n) (t := t) (k := k)
    A B hC 1 (1 : Equiv.Perm (Fin (ClosePairStrictBlock.width A B)))).poly

/-- The diagonal `C`-cofactor term multiplying `D(B)`.

This is the formal version of `Δ_C D_(α',β')` in the paper. -/
noncomputable def strictCDiagPart
    (A B : MinorIndex m n t)
    (hC : Close A B) :
    MvPolynomial (Fin m × Fin n) k :=
  (ClosePairStrictBlock.cBlockTerm
    (m := m) (n := n) (t := t) (k := k)
    A B hC 1 (1 : Equiv.Perm (Fin (ClosePairStrictBlock.width A B)))).poly

omit [Nontrivial k] in
lemma strictBDiagPart_eq_lcmQuotient_mul_A
    (A B : MinorIndex m n t)
    (hC : Close A B)
    (_hrowLt :
      rowExt B (uClose A B) < rowExt A (uClose A B)) :
    strictBDiagPart (m := m) (n := n) (t := t) (k := k) A B hC =
      MvPolynomial.monomial
        ((diagExp A ⊔ diagExp B) - diagExp A) (1 : k) *
          genericMinor (k := k) A := by
  classical
  rw [strictBDiagPart, ClosePairStrictBlock.bBlockTerm]
  rw [MonomialCoefficientMatrix.closePairTerm_poly
    (m := m) (n := n) (t := t) (q := ClosePairStrictBlock.width A B) (k := k)
    (row := fun i : Fin (ClosePairStrictBlock.width A B) =>
      ClosePairStrictBlock.rowFin A B hC
        (ClosePairStrictBlock.bMiddlePos A B hC i))
    (col := fun i : Fin (ClosePairStrictBlock.width A B) =>
      ClosePairStrictBlock.colFin A B hC
        (ClosePairStrictBlock.bMiddlePos A B hC i))
    (zero := fun _ _ => False)
    (K := A)
    (a := 1)
    (σ := (1 : Equiv.Perm (Fin (ClosePairStrictBlock.width A B))))]
  rw [MonomialCoefficientMatrix.permTerm]
  rw [ClosePairStrictBlock.bBlock_identity_permExp_eq_lcmQuotient_A
    (m := m) (n := n) (t := t) A B hC]
  simp [MonomialCoefficientMatrix.permCoeffWithZero, permCoeff]

lemma exists_aRepeatedMiddlePos_of_A_diag_not_B
    (A B : MinorIndex m n t)
    (hC : Close A B)
    {a : Fin m} {b : Fin n}
    (hA : ∃ j : Fin t, A.row j = a ∧ A.col j = b)
    (hB : ¬ ∃ j : Fin t, B.row j = a ∧ B.col j = b) :
    ∃ i : Fin (ClosePairStrictBlock.width A B),
      ClosePairStrictBlock.rowFin A B hC
          (ClosePairStrictBlock.aRepeatedMiddlePos A B hC i) = a ∧
        ClosePairStrictBlock.colFin A B hC
          (ClosePairStrictBlock.aRepeatedMiddlePos A B hC i) = b := by
  rcases hA with ⟨j, hjrow, hjcol⟩
  by_cases hprefix : j.1 < sClose A B
  · have hpEq :
        pairExt A (j.1 + 1) = pairExt B (j.1 + 1) := by
      exact pairExt_eq_of_mu_eq_right_le_s
        A B hC.ne hC.mu_eq_right (by omega) (by omega)
    have hj₂ : j.1 + 1 ≤ t := by omega
    rw [EndpointSelection.pairExt_endpoint (I := A) (by omega) hj₂,
      EndpointSelection.pairExt_endpoint (I := B) (by omega) hj₂] at hpEq
    have hidx : (⟨j.1 + 1 - 1, by omega⟩ : Fin t) = j := by
      apply Fin.ext
      simp
    rw [hidx] at hpEq
    have hrow : B.row j = a := by
      apply Fin.ext
      have hval := congrArg Prod.fst hpEq
      simp only [hjrow, Nat.add_right_cancel_iff] at hval
      apply Nat.add_right_cancel (congrFun (congrArg HAdd.hAdd (id (Eq.symm hval))) m)
    have hcol : B.col j = b := by
      apply Fin.ext
      have hval := congrArg Prod.snd hpEq
      simp only [hjcol, Nat.add_right_cancel_iff] at hval
      exact Nat.add_right_cancel (congrFun (congrArg HAdd.hAdd (id (Eq.symm hval))) m)
    exact (hB ⟨j, hrow, hcol⟩).elim
  · by_cases hmid : j.1 < uClose A B
    · let i : Fin (ClosePairStrictBlock.width A B) := ⟨j.1 - sClose A B, by
        simp only [ClosePairStrictBlock.width]
        omega⟩
      refine ⟨i, ?_, ?_⟩
      · rw [ClosePairStrictBlock.rowFin_aRepeatedMiddlePos A B hC i]
        have hidx :
            (⟨sClose A B + i.1, by
              have hi : i.1 < uClose A B - sClose A B := by
                simpa [i, ClosePairStrictBlock.width] using i.2
              have hu : uClose A B ≤ t :=
                le_trans (uClose_le_pClose A B hC.ne) (pClose_le A B)
              omega⟩ : Fin t) = j := by
          have hi_val : i.1 = j.1 - sClose A B := rfl
          apply Fin.ext
          change sClose A B + i.1 = j.1
          rw [hi_val]
          omega
        rw [hidx]
        exact hjrow
      · rw [ClosePairStrictBlock.colFin_aRepeatedMiddlePos A B hC i]
        have hidx :
            (⟨sClose A B + i.1, by
              have hi : i.1 < uClose A B - sClose A B := by
                simpa [i, ClosePairStrictBlock.width] using i.2
              have hu : uClose A B ≤ t :=
                le_trans (uClose_le_pClose A B hC.ne) (pClose_le A B)
              omega⟩ : Fin t) = j := by
          have hi_val : i.1 = j.1 - sClose A B := rfl
          apply Fin.ext
          change sClose A B + i.1 = j.1
          rw [hi_val]
          omega
        rw [hidx]
        exact hjcol
    · have hpEq :
          pairExt A (j.1 + 1) = pairExt B (j.1 + 1) := by
        exact pairExt_eq_of_mu_eq_right_gt_u
          A B hC.ne hC.mu_eq_right (by omega) (by omega)
      have hj₂ : j.1 + 1 ≤ t := by omega
      rw [EndpointSelection.pairExt_endpoint (I := A) (by omega) hj₂,
        EndpointSelection.pairExt_endpoint (I := B) (by omega) hj₂] at hpEq
      have hidx : (⟨j.1 + 1 - 1, by omega⟩ : Fin t) = j := by
        apply Fin.ext
        simp
      rw [hidx] at hpEq
      have hrow : B.row j = a := by
        apply Fin.ext
        have hval := congrArg Prod.fst hpEq
        simp only [hjrow, Nat.add_right_cancel_iff] at hval
        apply Nat.add_right_cancel (congrFun (congrArg HAdd.hAdd (id (Eq.symm hval))) m)
      have hcol : B.col j = b := by
        apply Fin.ext
        have hval := congrArg Prod.snd hpEq
        simp only [hjcol, Nat.add_right_cancel_iff] at hval
        apply Nat.add_right_cancel (congrFun (congrArg HAdd.hAdd (id (Eq.symm hval))) m)
      exact (hB ⟨j, hrow, hcol⟩).elim

lemma cBlock_identity_permExp_eq_lcmQuotient_B
    (A B : MinorIndex m n t)
    (hC : Close A B) :
    MonomialCoefficientMatrix.permExp
        (fun i : Fin (ClosePairStrictBlock.width A B) =>
          ClosePairStrictBlock.rowFin A B hC
            (ClosePairStrictBlock.aRepeatedMiddlePos A B hC i))
        (fun i : Fin (ClosePairStrictBlock.width A B) =>
          ClosePairStrictBlock.colFin A B hC
            (ClosePairStrictBlock.aRepeatedMiddlePos A B hC i))
        (1 : Equiv.Perm (Fin (ClosePairStrictBlock.width A B))) =
      (diagExp A ⊔ diagExp B) - diagExp B := by
  classical
  ext x
  rcases x with ⟨a, b⟩
  rw [ClosePairStrictBlock.cBlock_identity_permExp_apply A B hC a b]
  change
    (if ∃ i : Fin (ClosePairStrictBlock.width A B),
        ClosePairStrictBlock.rowFin A B hC
            (ClosePairStrictBlock.aRepeatedMiddlePos A B hC i) = a ∧
          ClosePairStrictBlock.colFin A B hC
            (ClosePairStrictBlock.aRepeatedMiddlePos A B hC i) = b then 1 else 0) =
      ((diagExp A (a, b) ⊔ diagExp B (a, b)) - diagExp B (a, b))
  rw [diagExp_apply A a b, diagExp_apply B a b]
  by_cases hmid :
      ∃ i : Fin (ClosePairStrictBlock.width A B),
        ClosePairStrictBlock.rowFin A B hC
            (ClosePairStrictBlock.aRepeatedMiddlePos A B hC i) = a ∧
          ClosePairStrictBlock.colFin A B hC
            (ClosePairStrictBlock.aRepeatedMiddlePos A B hC i) = b
  · rcases hmid with ⟨i, hirow, hicol⟩
    have hmidWitness :
        ∃ i : Fin (ClosePairStrictBlock.width A B),
          ClosePairStrictBlock.rowFin A B hC
              (ClosePairStrictBlock.aRepeatedMiddlePos A B hC i) = a ∧
            ClosePairStrictBlock.colFin A B hC
              (ClosePairStrictBlock.aRepeatedMiddlePos A B hC i) = b :=
      ⟨i, hirow, hicol⟩
    have hAdiag :
        ∃ j : Fin t, A.row j = a ∧ A.col j = b := by
      refine ⟨⟨sClose A B + i.1, by
        have hi : i.1 < uClose A B - sClose A B := by
          simp only [ClosePairStrictBlock.width] at i
          exact i.2
        have hu : uClose A B ≤ t :=
          le_trans (uClose_le_pClose A B hC.ne) (pClose_le A B)
        omega⟩, ?_, ?_⟩
      · simpa [ClosePairStrictBlock.rowFin_aRepeatedMiddlePos A B hC i] using hirow
      · simpa [ClosePairStrictBlock.colFin_aRepeatedMiddlePos A B hC i] using hicol
    have hBzero :
        diagExp B (a, b) = 0 := by
      have hz := ClosePairStrictBlock.diagExp_B_apply_A_middle_eq_zero A B hC i
      have hrowA := hirow
      have hcolA := hicol
      rw [ClosePairStrictBlock.rowFin_aRepeatedMiddlePos A B hC i] at hrowA
      rw [ClosePairStrictBlock.colFin_aRepeatedMiddlePos A B hC i] at hcolA
      simpa [hrowA, hcolA] using hz
    have hBdiag :
        ¬ ∃ j : Fin t, B.row j = a ∧ B.col j = b := by
      intro hB
      have hBone : diagExp B (a, b) = 1 := by
        rw [diagExp_apply]
        exact if_pos hB
      omega
    simp [hmidWitness, hAdiag, hBdiag]
  · by_cases hBdiag : ∃ j : Fin t, B.row j = a ∧ B.col j = b
    · by_cases hAdiag : ∃ j : Fin t, A.row j = a ∧ A.col j = b
      · simp [hmid, hAdiag, hBdiag]
      · simp [hmid, hAdiag, hBdiag]
    · by_cases hAdiag : ∃ j : Fin t, A.row j = a ∧ A.col j = b
      · have hmid' :=
          exists_aRepeatedMiddlePos_of_A_diag_not_B A B hC hAdiag hBdiag
        exact (hmid hmid').elim
      · simp [hmid, hAdiag, hBdiag]

