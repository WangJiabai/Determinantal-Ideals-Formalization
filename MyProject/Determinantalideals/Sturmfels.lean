      simpa [D₂, start₂] using
        exists_reverseRowInsertionTrace_afterDelete_with_respects
          R₁.tableau C₂.cell C₂.removable hsecond_nonTop
    let tr₂ := Classical.choose htr₂
    tr₂.movingAt start₁ ≤ D₁.value →
    (∀ {i j : ℕ}, i ≤ start₁ → (i, j) ∈ D₂.shape → (i, j) ∈ D₁.shape) →
    (∀ {i j : ℕ}, i ≤ start₁ → (i, j) ∈ D₁.shape → (i, j) ∈ D₂.shape) →
