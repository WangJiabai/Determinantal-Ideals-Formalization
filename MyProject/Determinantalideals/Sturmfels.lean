    · simpa [pivot] using hpivot_coeff
    · intro S hne hnot
      exact False.elim (hnot hne)
    · simpa [term] using hsum
  rcases h with ⟨coeffRest, hrest⟩
  refine ⟨coeffRest, ?_⟩
  simpa [pivot, term, hpivot_laplace] using hrest

