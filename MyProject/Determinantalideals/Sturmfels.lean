lemma hodgeRowSplit_bad_rowSlots_subset_leftAfter_of_rowBad
    {m n p q : ℕ}
    {I : MinorIndex m n p} {J : MinorIndex m n q}
    (T : SwanRawLaplaceProductTerm I J)
    (hsize : T.G.t ≤ T.F.t)
