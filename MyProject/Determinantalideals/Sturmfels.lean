    simpa [C, step, C₂, start₁, start₂] using
      reverseKrsStep_next_same_upper_start_row_le T h hprev hsame
  exact
    ReverseRowInsertionTrace.topCol_lt_of_movingAt_le_of_rows_equiv_of_strictlyLeftUpTo
