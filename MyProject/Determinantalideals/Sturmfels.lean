lemma neg_one_pow_mul_self {R : Type*} [CommRing R] (r : ℕ) :
    ((-1 : R) ^ r) * ((-1 : R) ^ r) = 1 := by
  induction r with
  | zero =>
      simp
  | succ r ih =>
      simp only [pow_succ]
      calc
        ((-1 : R) ^ r * -1) * ((-1 : R) ^ r * -1)
            =
          ((-1 : R) ^ r * ((-1 : R) ^ r)) * ((-1 : R) * (-1 : R)) := by
            ring
    _ = 1 := by
            rw [ih]
            ring

