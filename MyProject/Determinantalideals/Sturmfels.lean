      · rcases Finset.mem_map.mp hxright with ⟨μ, hμ, hμx⟩
        have hμν : μ ≤ ν := (Finset.mem_filter.mp hμ).2
        have hslot :
            T.toRawPair.slotCol (finSumFinEquiv.symm x) =
