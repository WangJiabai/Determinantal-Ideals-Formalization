      MvPolynomial (Fin m × Fin n) k :=
    fun S => RawMinorPair.laplacePolynomial (k := k) S.toBiReshuffle.toPair
  have h :
      ∃ coeffSupport :
          { S : RawMinorPair.BiReshuffle.HodgeRowSplit P ν hνp //
