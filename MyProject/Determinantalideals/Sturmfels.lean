          ∑ S :
            { S : RawMinorPair.BiReshuffle.HodgeRowSplit P ν hνp //
              S ≠ pivot },
            MvPolynomial.C (coeffSupport S) * term S.1 = 0 := by
    refine signed_subtype_sum_eq_zero_of_total_sum_eq_zero
      (α := RawMinorPair.BiReshuffle.HodgeRowSplit P ν hνp)
      (σ := Fin m × Fin n) (k := k)
